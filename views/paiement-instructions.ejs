<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Paiement - CashLink</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">

<div class="container py-5">
    <div class="card mx-auto shadow border-0 p-4" style="max-width: 500px; border-radius: 20px;">
        <h3 class="fw-bold text-center mb-4">Activation du Pack</h3>
        
        <div class="alert alert-info border-0 shadow-sm">
            Vous avez choisi le <strong><%= packName %></strong><br>
            Montant à envoyer : <strong><%= prix %> CDF</strong>
        </div>

        <div class="my-4 p-3 bg-white border rounded-3">
            <p class="mb-2 text-muted">Envoyez l'argent au numéro suivant :</p>
            <h4 class="fw-bold text-center text-success">082 00 00 000</h4>
            <p class="small text-center text-muted">(M-Pesa / Airtel Money / Orange Money)</p>
        </div>

        <form action="/confirmer-envoi" method="POST">
            <input type="hidden" name="packName" value="<%= packName %>">
            <input type="hidden" name="prix" value="<%= prix %>">
            
            <div class="mb-3">
                <label class="form-label fw-bold">ID DE TRANSACTION (Référence SMS)</label>
                <input type="text" name="reference" class="form-control form-control-lg" placeholder="Ex: 894561237" required>
                <small class="text-muted">Copiez ici l'ID reçu dans le SMS de confirmation après votre envoi.</small>
            </div>

            <button type="submit" class="btn btn-dark w-100 py-3 fw-bold">J'AI ENVOYÉ LE PAIEMENT</button>
        </form>
    </div>
</div>

</body>
</html>