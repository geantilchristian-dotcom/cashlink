<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Retrait | CASHLINK ELITE</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #0b0f1a;
            --card: #161c2d;
            --emerald: #00ff88;
            --danger: #ff4d4d;
            --accent: #00d9ff;
            --text-main: #ffffff;
            --text-dim: #a0aec0;
        }

        body { 
            background-color: var(--bg); 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            color: var(--text-main);
            padding: 15px;
            background: radial-gradient(circle at top right, rgba(0, 217, 255, 0.05), transparent);
        }

        /* --- HEADER & RETOUR --- */
        .back-link {
            color: var(--accent);
            text-decoration: none;
            font-weight: 800;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            margin-bottom: 25px;
            transition: 0.3s;
        }
        .back-link:hover { transform: translateX(-5px); color: var(--text-main); }

        /* --- CARTE DE RETRAIT --- */
        .withdraw-glass-card {
            background: var(--card);
            border-radius: 30px;
            padding: 40px;
            border: 1px solid rgba(255, 77, 77, 0.3);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            max-width: 550px;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
        }

        .withdraw-glass-card::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255, 77, 77, 0.05), transparent);
            pointer-events: none;
        }

        .balance-badge {
            background: rgba(0, 255, 136, 0.1);
            color: var(--emerald);
            padding: 10px 20px;
            border-radius: 15px;
            font-weight: 800;
            display: inline-block;
            margin-top: 10px;
            border: 1px solid rgba(0, 255, 136, 0.2);
        }

        /* --- FORMULAIRE --- */
        .form-label {
            font-weight: 800;
            font-size: 0.75rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .neon-input {
            background: #0b0f1a !important;
            border: 1px solid #2d3748 !important;
            color: white !important;
            border-radius: 15px !important;
            padding: 15px !important;
            font-weight: 600;
        }

        .neon-input:focus {
            border-color: var(--danger) !important;
            box-shadow: 0 0 15px rgba(255, 77, 77, 0.2) !important;
        }

        .btn-withdraw-neon {
            background: var(--danger);
            color: white;
            border: none;
            width: 100%;
            padding: 18px;
            border-radius: 18px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 30px;
            box-shadow: 0 8px 20px rgba(255, 77, 77, 0.3);
            transition: 0.3s;
        }

        .btn-withdraw-neon:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(255, 77, 77, 0.5);
        }

        /* --- TABLEAU HISTORIQUE --- */
        .history-box {
            background: var(--card);
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            margin-top: 40px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
            overflow: hidden;
        }

        .table { margin-bottom: 0; }
        .table thead th {
            background: rgba(0,0,0,0.2);
            border: none;
            color: var(--text-dim);
            font-size: 0.7rem;
            padding: 20px;
            text-transform: uppercase;
        }
        .table td {
            padding: 20px;
            border-color: rgba(255,255,255,0.05);
            vertical-align: middle;
            font-weight: 600;
        }

        .status-pill {
            padding: 6px 15px;
            border-radius: 10px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
        }
        .pending { background: rgba(255, 204, 0, 0.1); color: #ffcc00; }
        .confirmed { background: rgba(0, 255, 136, 0.1); color: var(--emerald); }

    </style>
</head>
<body>

    <div class="container py-4">
        <a href="/dashboard" class="back-link">
            <i class="bi bi-chevron-left me-2"></i> RETOUR AU TABLEAU DE BORD
        </a>

        <div class="withdraw-glass-card">
            <div class="text-center mb-5">
                <div style="width: 70px; height: 70px; background: rgba(255, 77, 77, 0.1); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                    <i class="bi bi-box-arrow-up-right text-danger" style="font-size: 2rem;"></i>
                </div>
                <h2 style="font-weight: 900; letter-spacing: -1px;">Retrait de Fonds</h2>
                <div class="balance-badge">
                    DISPONIBLE : <%= (user.bonus || 0).toLocaleString() %> FC
                </div>
            </div>

            <div class="alert" style="background:#1e293b;border:2px solid #3b82f6;color:#fff;border-radius:12px;padding:16px;margin-bottom:20px;">
    <i class="bi bi-clock-fill me-2 text-info"></i>
    <strong>Fréquence retrait :</strong> 
    <% if(user.certified) { %>
        <span class="text-success fw-bold">Toutes les 24h (Compte Certifié ✅)</span>
    <% } else { %>
        <span class="text-warning fw-bold">Toutes les 72h (Compte Standard)</span>
        <br><small class="text-muted">Certifiez votre compte pour retirer chaque 24h</small>
    <% } %>
</div>
<form action="/retrait" method="POST">
                <div class="mb-4">
                    <label class="form-label">Montant à retirer</label>
                    <div class="input-group">
                        <input type="number" name="montant" class="form-control neon-input" placeholder="Min. 1 000" required min="1000">
                        <span class="input-group-text neon-input" style="background: #1f2937; border-left: none;">FC</span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Coordonnées de paiement (M-Pesa / Airtel)</label>
                    <input type="text" name="numero" class="form-control neon-input" placeholder="081 234 5678" required>
                    <small class="text-dim mt-2 d-block" style="font-size: 0.7rem;">
                        <i class="bi bi-shield-check me-1"></i> Vérifiez bien votre numéro avant de confirmer.
                    </small>
                </div>

                <button type="submit" class="btn-withdraw-neon">
                    DEMANDER LE RETRAIT
                </button>
            </form>
        </div>

        <div class="history-box">
            <div class="p-4 d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.1);">
                <h5 class="m-0 fw-bold"><i class="bi bi-clock-history me-2 text-accent"></i>Historique</h5>
                <span class="badge bg-dark"><%= transactions ? transactions.length : 0 %> Opérations</span>
            </div>
            <div class="table-responsive">
                <table class="table table-dark">
                    <thead>
                        <tr>
                            <th>DATE</th>
                            <th>MONTANT</th>
                            <th>STATUT</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (transactions && transactions.length > 0) { %>
                            <% transactions.forEach(tx => { %>
                                <tr>
                                    <td class="text-dim small"><%= tx.date %></td>
                                    <td style="color: var(--danger);"><%= tx.montant.toLocaleString() %> FC</td>
                                    <td>
                                        <span class="status-pill <%= tx.statut === 'En attente' ? 'pending' : 'confirmed' %>">
                                            <%= tx.statut %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox h2 d-block opacity-20"></i>
                                    Aucune demande de retrait pour le moment.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>