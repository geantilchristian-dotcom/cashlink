<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ACCÈS MAÎTRE | <%= (typeof content !== 'undefined' && content.brand_name) ? content.brand_name : 'CASHLINK' %></title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --admin-dark: #0f172a;
            --admin-blue: #1e40af;
            --admin-accent: #3b82f6;
        }

        body {
            background: var(--admin-dark);
            background-image: 
                linear-gradient(rgba(30, 64, 175, 0.1) 1px, transparent 1px),
                linear-gradient(90deg, rgba(30, 64, 175, 0.1) 1px, transparent 1px);
            background-size: 30px 30px;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0;
            color: #f8fafc;
        }

        .admin-card {
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(10px);
            padding: 40px;
            border-radius: 24px;
            width: 100%;
            max-width: 400px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .terminal-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .icon-shield {
            width: 64px;
            height: 64px;
            background: rgba(59, 130, 246, 0.2);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            color: var(--admin-accent);
            font-size: 2rem;
            border: 1px solid rgba(59, 130, 246, 0.3);
        }

        .form-label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            margin-bottom: 8px;
        }

        .form-control {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 12px 16px;
            color: white;
            transition: all 0.2s;
        }

        .form-control:focus {
            background: rgba(15, 23, 42, 0.8);
            border-color: var(--admin-accent);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            color: white;
        }

        .btn-admin {
            background: var(--admin-accent);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            width: 100%;
            margin-top: 10px;
            transition: 0.3s;
        }

        .btn-admin:hover {
            background: #2563eb;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.4);
        }

        .alert-admin {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            border-radius: 12px;
            font-size: 0.85rem;
            text-align: center;
            padding: 10px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <div class="admin-card animate__animated animate__fadeIn">
        <div class="terminal-header">
            <div class="icon-shield">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h4 class="fw-bold mb-1">TERMINAL MAÎTRE</h4>
            <p class="text-muted small">Système d'administration sécurisé</p>
        </div>

        <% if(typeof msg !== 'undefined' && msg) { %>
            <div class="alert-admin animate__animated animate__shakeX">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= msg %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST">
            <div class="mb-3">
                <label class="form-label">Identifiant Maître</label>
                <input type="text" name="admin_user" class="form-control" placeholder="Entrez votre ID" required autofocus>
            </div>

            <div class="mb-4">
                <label class="form-label">Mot de passe</label>
                <input type="password" name="admin_pass" class="form-control" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn-admin">
                DÉVERROUILLER L'ACCÈS
            </button>
        </form>

        <div class="text-center mt-4">
            <a href="/" class="text-decoration-none small text-muted">
                <i class="bi bi-arrow-left me-1"></i> Retour au site public
            </a>
        </div>
    </div>

</body>
</html>