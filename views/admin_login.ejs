<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>TERMINAL ADMIN | ACCÈS RESTREINT</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --admin-neon: #00d9ff;
            --admin-red: #ff003c;
            --bg-dark: #000510;
        }

        body {
            background-color: var(--bg-dark);
            background-image: 
                linear-gradient(rgba(0, 217, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 217, 255, 0.05) 1px, transparent 1px);
            background-size: 30px 30px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            height: 100vh; display: flex; align-items: center; justify-content: center;
            margin: 0; color: white; overflow: hidden;
        }

        .admin-login-card {
            width: 100%; max-width: 400px;
            background: rgba(0, 12, 36, 0.95);
            border: 2px solid var(--admin-neon);
            border-radius: 30px; padding: 45px;
            box-shadow: 0 0 50px rgba(0, 217, 255, 0.2);
            position: relative; z-index: 10;
        }

        .admin-login-card::before {
            content: "SECURED ACCESS";
            position: absolute; top: -15px; left: 50%; transform: translateX(-50%);
            background: var(--admin-neon); color: black;
            padding: 2px 15px; font-size: 0.65rem; font-weight: 900;
            border-radius: 5px; letter-spacing: 2px;
        }

        .admin-brand-icon {
            width: 70px; height: 70px; background: var(--admin-neon);
            color: black; border-radius: 20px; display: flex;
            align-items: center; justify-content: center; margin: 0 auto 30px;
            box-shadow: 0 0 30px var(--admin-neon);
        }

        .admin-label {
            font-size: 0.7rem; font-weight: 800; color: var(--admin-neon);
            text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; display: block;
        }

        .admin-input-box {
            background: rgba(0,0,0,0.5); border: 1px solid rgba(0, 217, 255, 0.3);
            border-radius: 15px; padding: 15px; display: flex; align-items: center;
            margin-bottom: 25px; transition: 0.3s;
        }
        .admin-input-box:focus-within { border-color: var(--admin-neon); box-shadow: 0 0 15px rgba(0, 217, 255, 0.3); }

        .admin-input-box input {
            background: transparent; border: none; color: white; width: 100%;
            font-weight: 700; padding-left: 10px; font-size: 1rem;
        }

        .btn-admin-login {
            background: var(--admin-neon); color: black; border: none;
            width: 100%; padding: 18px; border-radius: 15px;
            font-weight: 900; text-transform: uppercase; letter-spacing: 1px;
            transition: 0.3s; margin-top: 10px;
        }
        .btn-admin-login:hover { background: white; transform: scale(1.02); }

        .scan-line {
            position: absolute; width: 100%; height: 2px;
            background: var(--admin-neon); opacity: 0.3;
            top: 0; left: 0; animation: scan 4s linear infinite;
        }
        @keyframes scan { 0% { top: 0; } 100% { top: 100%; } }

        .error-msg { color: var(--admin-red); font-size: 0.75rem; font-weight: 800; text-align: center; margin-bottom: 20px; }
    </style>
</head>
<body>

    <div class="scan-line"></div>

    <div class="admin-login-card animate__animated animate__fadeInDown">
        <div class="admin-brand-icon animate__animated animate__pulse animate__infinite">
            <i class="bi bi-cpu-fill fs-1"></i>
        </div>

        <div class="text-center mb-5">
            <h4 class="fw-900 mb-1">COMMAND CENTER</h4>
            <small class="opacity-50 fw-bold">CASH LINK v5.5</small>
        </div>

        <% if(locals.error) { %>
            <div class="error-msg animate__animated animate__shakeX">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
            </div>
        <% } %>

        <form action="/admin-login" method="POST">
            </div>
            <label class="admin-label">Clé de Cryptage (Password)</label>
            <div class="admin-input-box">
                <i class="bi bi-key-fill text-info"></i>
                <input type="password" name="password" id="admin-pass" required placeholder="****">
                <i class="bi bi-eye-fill opacity-50" style="cursor:pointer" onclick="togglePass()"></i>
            </div>

            <button type="submit" class="btn-admin-login">DÉVERROUILLER LE SYSTÈME</button>
        </form>

        <div class="text-center mt-5">
            <a href="/" class="text-info small fw-bold text-decoration-none opacity-50"><i class="bi bi-arrow-left"></i> Retour au site public</a>
        </div>
    </div>

    <script>
        function togglePass() {
            const p = document.getElementById('admin-pass');
            p.type = p.type === 'password' ? 'text' : 'password';
        }

        // Bloquer l'inspection pour faire plus "pro"
        document.onkeydown = function(e) {
            if(e.keyCode == 123) return false;
            if(e.ctrlKey && e.shiftKey && e.keyCode == 'I'.charCodeAt(0)) return false;
        };
    </script>
</body>
</html>
