<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Interface Elite v28.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@700;900&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
            MOTEUR DE DESIGN "TITAN OLYMPUS" - 600 LIGNES DE STYLE
           ============================================================ */
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --emerald: #10b981;
            --rose: #f43f5e;
            --gold: #fbbf24;
            --dark-deep: #000c26;
            --glass-white: rgba(255, 255, 255, 0.15);
            --glass-dark: rgba(0, 0, 0, 0.55);
            --transition-titan: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }

        /* CONFIGURATION GLOBALE DÉTAILLÉE */
        ::-webkit-scrollbar { width: 14px; }
        ::-webkit-scrollbar-track { background: var(--dark-deep); }
        ::-webkit-scrollbar-thumb { 
            background: var(--gold); 
            border-radius: 20px; 
            border: 4px solid var(--dark-deep); 
            box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        }

        * { 
            box-sizing: border-box; 
            -webkit-tap-highlight-color: transparent; 
            outline: none !important; 
            margin: 0; 
            padding: 0;
        }

        body {
            background-color: var(--bleu-bic);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 55%),
                radial-gradient(at 100% 100%, var(--dark-deep) 0px, transparent 55%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            line-height: 1.6;
        }

        /* --- BARRE DE NAVIGATION TITAN (NAVBAR) --- */
        .premium-nav-titan {
            background: var(--gold);
            padding: 18px 20px;
            position: sticky;
            top: 0;
            z-index: 9999;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.7);
            border-bottom: 6px solid rgba(0,0,0,0.25);
        }
        @media (min-width: 992px) { .premium-nav-titan { padding: 25px 100px; } }

        .logo-titan-industrial { 
            font-family: 'Space Grotesk', sans-serif; 
            font-weight: 900; 
            color: var(--bleu-bic); 
            font-size: 2rem; 
            text-decoration: none !important; 
            letter-spacing: -4px; 
            transition: var(--transition-titan);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-titan-industrial:hover { transform: scale(1.1); filter: brightness(1.2); }
        
        .nav-info-box-titan {
            background: #ffffff;
            padding: 12px 28px;
            border-radius: 100px;
            display: flex;
            align-items: center;
            gap: 20px;
            color: #0f172a;
            box-shadow: inset 0 3px 18px rgba(0,0,0,0.3);
            border: 2px solid rgba(255,255,255,0.5);
        }
        .solde-badge-industrial { border-right: 3.5px solid #e2e8f0; padding-right: 22px; }
        .label-titan-bold { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: #64748b; display: block; line-height: 1; margin-bottom: 5px; }
        .val-titan-heavy { font-weight: 900; font-size: 1.3rem; color: var(--bleu-bic); line-height: 1; font-family: 'Space Grotesk'; }

        .btn-logout-industrial {
            background: var(--dark-deep);
            color: white;
            border: none;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            transition: var(--transition-titan);
        }
        .btn-logout-industrial:hover { background: var(--rose); transform: rotate(180deg); }

        /* --- SECTION MARKETING (HERO BANNER BLANC) --- */
        .hero-industrial-banner {
            width: 100%;
            background: #ffffff;
            border-radius: 0 0 70px 70px;
            box-shadow: 0 35px 80px rgba(0,0,0,0.5);
            margin-bottom: 50px;
            padding: 100px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .hero-industrial-banner::after { content: ""; position: absolute; bottom: 0; left: 0; width: 100%; height: 15px; background: var(--gold); }
        
        .hero-title-titan-heavy { 
            font-family: 'Space Grotesk'; 
            font-weight: 900; 
            color: var(--bleu-bic); 
            font-size: clamp(3rem, 15vw, 6rem); 
            line-height: 0.75; 
            margin-bottom: 30px; 
            letter-spacing: -6px; 
        }
        .hero-para-titan-heavy { 
            color: #334155; 
            font-weight: 700; 
            font-size: 1.4rem; 
            max-width: 900px; 
            margin: 0 auto 45px; 
            line-height: 1.7; 
        }
        .user-id-badge-industrial { 
            background: var(--bleu-bic); 
            color: #fff; 
            padding: 15px 45px; 
            border-radius: 100px; 
            font-weight: 900; 
            font-size: 1.1rem; 
            display: inline-block; 
            margin-bottom: 25px; 
            box-shadow: 0 18px 40px rgba(0, 51, 153, 0.35); 
        }

        /* --- STATISTIQUES GÉANTES --- */
        .stats-industrial-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            padding: 10px 25px;
        }
        @media (min-width: 992px) { .stats-industrial-grid { grid-template-columns: repeat(4, 1fr); padding: 20px 100px; gap: 45px; } }

        .stat-industrial-card {
            background: var(--glass-white);
            backdrop-filter: blur(25px);
            padding: 45px 30px;
            border-radius: 50px;
            border: 3px solid rgba(255,255,255,0.3);
            text-align: center;
            transition: var(--transition-titan);
        }
        .stat-industrial-card:hover { transform: translateY(-15px); border-color: var(--gold); background: rgba(255,255,255,0.2); }
        .stat-industrial-icon { font-size: 3rem; color: var(--neon-blue); margin-bottom: 20px; display: block; text-shadow: 0 0 20px rgba(0, 217, 255, 0.4); }
        
        .btn-certif-industrial { 
            background: var(--gold); 
            color: #000; 
            border: none; 
            width: 100%; 
            padding: 18px; 
            border-radius: 25px; 
            font-weight: 900; 
            font-size: 0.9rem; 
            text-transform: uppercase; 
            margin-top: 30px; 
            letter-spacing: 2px; 
            box-shadow: 0 15px 40px rgba(251, 191, 36, 0.6); 
        }

        /* --- SYSTÈME DE PARRAINAGE 10% --- */
        .referral-industrial-container {
            background: var(--glass-dark);
            margin: 40px 30px;
            padding: 60px;
            border-radius: 70px;
            border: 6px dashed var(--gold);
            text-align: center;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
        }
        @media (min-width: 992px) { .referral-industrial-container { margin: 60px 100px; } }
        .ref-title-industrial { font-family: 'Space Grotesk'; font-weight: 900; color: var(--gold); margin-bottom: 25px; text-transform: uppercase; letter-spacing: 4px; font-size: 2.8rem; }
        
        .industrial-copy-group {
            background: #ffffff;
            padding: 12px;
            border-radius: 45px;
            display: flex;
            align-items: center;
            gap: 25px;
            margin-top: 40px;
            box-shadow: 0 30px 70px rgba(0,0,0,0.5);
        }
        .industrial-copy-group input { background: transparent; border: none; color: #000; font-weight: 900; font-size: 1.2rem; width: 100%; padding-left: 35px; font-family: 'JetBrains Mono'; }
        .btn-copy-industrial-action { background: var(--bleu-bic); color: #fff; border: none; padding: 22px 50px; border-radius: 35px; font-weight: 900; text-transform: uppercase; font-size: 1rem; letter-spacing: 1px; }

        /* --- TERMINAL DE MINAGE (LOGIQUE VERTE) --- */
        .mining-industrial-terminal {
            background: var(--glass-dark);
            margin: 40px 30px;
            padding: 60px;
            border-radius: 70px;
            border: 3px solid rgba(255,255,255,0.25);
            position: relative;
        }
        .progress-industrial-track {
            height: 55px;
            background: rgba(0,0,0,0.8);
            border-radius: 100px;
            overflow: hidden;
            margin: 45px 0;
            border: 4px solid rgba(255,255,255,0.25);
            padding: 10px;
            box-shadow: inset 0 10px 30px rgba(0,0,0,0.5);
        }
        .bar-industrial-emerald-fill {
            background: linear-gradient(90deg, #10b981, #059669, #34d399);
            box-shadow: 0 0 60px rgba(16, 185, 129, 0.9);
            border-radius: 100px;
            height: 100%;
            width: <%= p || 0 %>%;
            transition: width 3s ease-in-out;
        }
        .btn-withdraw-industrial-heavy {
            background: var(--rose);
            color: white;
            border: none;
            width: 100%;
            padding: 35px;
            border-radius: 50px;
            font-weight: 900;
            font-size: 2rem;
            text-transform: uppercase;
            box-shadow: 0 30px 80px rgba(244, 63, 94, 0.7);
            margin-top: 35px;
            letter-spacing: 3px;
            transition: var(--transition-titan);
        }

        /* ============================================================
            AJUSTEMENT MOBILE : STYLE ALIBABA COMPACT (GRILLE DE 2)
           ============================================================ */
        .shop-industrial-header { padding: 0 40px; margin: 100px 0 50px; display: flex; align-items: center; gap: 35px; }
        .shop-industrial-header h2 { font-family: 'Space Grotesk'; font-weight: 900; font-size: 3.5rem; text-transform: uppercase; letter-spacing: -2px; }

        .industrial-shop-grid-full {
            display: grid;
            grid-template-columns: repeat(2, 1fr); /* GRILLE DE 2 SUR MOBILE */
            gap: 12px;
            padding: 0 15px 100px;
        }

        @media (min-width: 992px) { 
            .industrial-shop-grid-full { grid-template-columns: repeat(2, 1fr); gap: 50px; padding: 0 100px 200px; } 
        }
        @media (min-width: 1600px) { 
            .industrial-shop-grid-full { grid-template-columns: repeat(4, 1fr); } 
        }

        .pack-industrial-heavy-card {
            background: #ffffff;
            border-radius: 20px; 
            overflow: hidden;
            color: #0f172a;
            min-height: auto; 
            display: flex;
            flex-direction: column;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            transition: var(--transition-titan);
            position: relative;
            border: none;
        }

        @media (max-width: 768px) {
            /* SUPPRESSION DE L'ESPACE VIDE BLANC SOULIGNÉ */
            .p-head-industrial-heavy { padding: 12px 5px !important; font-size: 0.65rem !important; letter-spacing: 0px !important; }
            .p-body-industrial-heavy { padding: 10px 8px !important; } /* Réduction du padding pour enlever le vide */
            
            /* TAILLE DE TEXTE COMPACTE (STYLE ALIBABA) */
            .p-price-industrial-heavy { font-size: 1.1rem !important; letter-spacing: -1px !important; margin: 8px 0 !important; }
            .p-bonus-industrial-heavy { font-size: 0.55rem !important; padding: 5px !important; border-radius: 8px !important; border-width: 1px !important; margin-bottom: 8px !important; }
            .p-daily-industrial-heavy { font-size: 0.8rem !important; margin-bottom: 12px !important; }
            
            .industrial-details-list { margin: 5px 0 !important; padding: 5px 0 !important; border-top: 1px solid #f1f5f9 !important; }
            .industrial-details-list li { font-size: 0.5rem !important; margin-bottom: 4px !important; gap: 4px !important; }
            .industrial-details-list li i { font-size: 0.7rem !important; }
            
            .btn-industrial-heavy-action { padding: 12px 5px !important; border-radius: 12px !important; font-size: 0.7rem !important; }
            .lock-industrial-badge { padding: 10px 20px !important; font-size: 0.8rem !important; border-radius: 50px !important; }
        }

        /* Styles Desktop d'origine conservés */
        .pack-industrial-heavy-card:hover { transform: translateY(-30px); filter: brightness(1.05); }
        .pack-industrial-active-border { border: 8px solid var(--emerald) !important; transform: scale(1.02); z-index: 50; }
        .pack-industrial-locked-mode { filter: grayscale(1) opacity(0.6); }
        .lock-industrial-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 60; display: flex; align-items: center; justify-content: center; pointer-events: none; }
        .lock-industrial-badge { background: var(--gold); color: #000; padding: 20px 50px; border-radius: 100px; font-weight: 900; font-size: 1.8rem; box-shadow: 0 30px 60px rgba(0,0,0,0.8); letter-spacing: 2px; }
        .p-head-industrial-heavy { padding: 45px; text-align: center; color: #fff; font-weight: 900; text-transform: uppercase; font-size: 1.5rem; letter-spacing: 5px; }
        .p-body-industrial-heavy { padding: 55px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .p-price-industrial-heavy { font-size: 3.5rem; font-weight: 900; color: var(--bleu-bic); margin: 25px 0 15px; font-family: 'Space Grotesk'; letter-spacing: -4px; line-height: 0.9; }
        .p-bonus-industrial-heavy { font-size: 1.2rem; font-weight: 900; color: var(--rose); background: #fff0f0; border: 4px dashed var(--rose); padding: 18px; border-radius: 30px; margin-bottom: 15px; }
        .p-daily-industrial-heavy { font-weight: 900; color: var(--emerald); font-size: 2.2rem; letter-spacing: -2px; margin-bottom: 35px; }
        .industrial-details-list { text-align: left; margin: 30px 0; padding: 30px 0; list-style: none; border-top: 3px solid #f1f5f9; }
        .industrial-details-list li { font-weight: 800; color: #475569; margin-bottom: 18px; display: flex; align-items: center; gap: 15px; font-size: 1.1rem; }
        .industrial-details-list li i { color: var(--emerald); font-size: 1.5rem; }
        .btn-buy-industrial-heavy { background: var(--bleu-bic); color: #fff; }
        .btn-activate-industrial-heavy { background: var(--emerald); color: #fff; box-shadow: 0 25px 50px rgba(16, 185, 129, 0.6); }
        .btn-industrial-heavy-action { width: 100%; padding: 30px; border-radius: 45px; border: none; font-weight: 900; text-transform: uppercase; font-size: 1.4rem; transition: 0.4s; box-shadow: 0 25px 60px rgba(0,0,0,0.3); }

        /* --- TOASTS & SCROLL --- */
        #titan-toast-industrial-heavy { position: fixed; bottom: 50px; left: 50px; z-index: 9999; background: #ffffff; color: #000; padding: 40px 55px; border-radius: 45px; box-shadow: 0 40px 100px rgba(0,0,0,0.9); display: none; align-items: center; gap: 40px; border-left: 20px solid var(--emerald); }
        #scrollTopIndustrialHeavy { position: fixed; bottom: 50px; right: 50px; width: 100px; height: 100px; background: var(--gold); color: var(--bleu-bic); border-radius: 50%; border: none; display: none; align-items: center; justify-content: center; font-size: 4rem; z-index: 9500; box-shadow: 0 40px 80px rgba(0,0,0,0.8); }

        /* --- FAQ --- */
        .industrial-faq-titan { margin: 80px 30px 200px; }
        .accordion-titan-industrial-item { background: var(--glass-dark) !important; border: 3px solid rgba(255,255,255,0.25) !important; color: #fff !important; margin-bottom: 40px; border-radius: 60px !important; overflow: hidden; }
        .accordion-titan-industrial-button { background: transparent !important; color: #fff !important; font-weight: 900; padding: 50px; font-size: 1.8rem; }
        .accordion-titan-industrial-body { padding: 60px; opacity: 1; font-size: 1.4rem; line-height: 2.5; }

        .modal-titan-industrial-heavy { border-radius: 80px !important; border: none; overflow: hidden; }
        .payment-titan-industrial-heavy-card { background: #f8fafc; padding: 45px; border-radius: 50px; border: 6px solid #e2e8f0; margin-bottom: 35px; transition: 0.5s; }
        .payment-titan-industrial-heavy-card:hover { border-color: var(--bleu-bic); transform: translateX(30px); }

          /* ============================================================
             OPTIMISATION MOBILE MAXIMALE - TOUS ÉCRANS < 768px
             ============================================================ */
          @media (max-width: 767px) {

              /* NAVBAR */
              .premium-nav-titan { padding: 10px 12px !important; }
              .logo-titan-industrial { font-size: 1.2rem !important; letter-spacing: -2px !important; }
              .nav-info-box-titan { padding: 7px 12px !important; gap: 8px !important; border-radius: 50px !important; }
              .val-titan-heavy { font-size: 0.85rem !important; }
              .label-titan-bold { font-size: 0.5rem !important; margin-bottom: 2px !important; }
              .solde-badge-industrial { padding-right: 10px !important; border-right-width: 2px !important; }
              .btn-logout-industrial { width: 34px !important; height: 34px !important; flex-shrink: 0; }
              .btn-logout-industrial i { font-size: 0.85rem !important; }

              /* HERO BANNER */
              .hero-industrial-banner { padding: 35px 15px 45px !important; border-radius: 0 0 30px 30px !important; margin-bottom: 20px !important; }
              .hero-title-titan-heavy { font-size: 2.2rem !important; letter-spacing: -2px !important; margin-bottom: 12px !important; line-height: 0.85 !important; }
              .hero-para-titan-heavy { font-size: 0.85rem !important; line-height: 1.5 !important; margin: 0 0 18px !important; }
              .user-id-badge-industrial { font-size: 0.6rem !important; padding: 8px 16px !important; margin-bottom: 12px !important; }
              .hero-industrial-banner .btn { font-size: 0.85rem !important; padding: 12px 22px !important; }

              /* STATS GRID */
              .stats-industrial-grid { gap: 10px !important; padding: 10px !important; }
              .stat-industrial-card { padding: 18px 10px !important; border-radius: 18px !important; border-width: 2px !important; }
              .stat-industrial-icon { font-size: 1.6rem !important; margin-bottom: 8px !important; }
              .stat-industrial-card .val-titan-heavy { font-size: 0.85rem !important; }
              .btn-certif-industrial { padding: 10px !important; font-size: 0.6rem !important; margin-top: 10px !important; letter-spacing: 0 !important; border-radius: 10px !important; }

              /* PARRAINAGE */
              .referral-industrial-container { margin: 15px 10px !important; padding: 22px 14px !important; border-radius: 25px !important; border-width: 3px !important; }
              .ref-title-industrial { font-size: 1.2rem !important; letter-spacing: 1px !important; margin-bottom: 10px !important; }
              .referral-industrial-container p.fs-4 { font-size: 0.8rem !important; }
              .industrial-copy-group { flex-direction: column !important; padding: 10px !important; gap: 8px !important; margin-top: 15px !important; border-radius: 18px !important; }
              .industrial-copy-group input { font-size: 0.75rem !important; padding-left: 10px !important; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
              .btn-copy-industrial-action { padding: 12px !important; border-radius: 12px !important; font-size: 0.75rem !important; width: 100% !important; letter-spacing: 0 !important; }

              /* TERMINAL MINAGE */
              .mining-industrial-terminal { margin: 15px 10px !important; padding: 18px 14px !important; border-radius: 22px !important; }
              .mining-industrial-terminal .d-flex.justify-content-between { flex-wrap: wrap; gap: 5px; }
              .mining-industrial-terminal h3.fw-900 { font-size: 0.7rem !important; }
              .mining-industrial-terminal p.label-titan-bold { font-size: 0.55rem !important; }
              .mining-industrial-terminal .text-success.fw-900.fs-1 { font-size: 1.3rem !important; }
              .progress-industrial-track { height: 30px !important; margin: 15px 0 !important; border-width: 2px !important; padding: 4px !important; }
              .btn-withdraw-industrial-heavy { padding: 16px 10px !important; font-size: 0.85rem !important; border-radius: 18px !important; margin-top: 12px !important; letter-spacing: 0.5px !important; box-shadow: 0 8px 25px rgba(244,63,94,0.5) !important; }
              .mining-industrial-terminal .fw-900.text-warning { font-size: 0.75rem !important; }
              .mining-industrial-terminal .d-flex.flex-wrap { gap: 10px !important; margin-top: 15px !important; }

              /* SHOP HEADER */
              .shop-industrial-header { padding: 0 12px !important; margin: 35px 0 18px !important; gap: 10px !important; }
              .shop-industrial-header > div:first-child { width: 6px !important; height: 35px !important; border-radius: 8px !important; }
              .shop-industrial-header h2 { font-size: 1.3rem !important; letter-spacing: -0.5px !important; }

              /* FAQ */
              .industrial-faq-titan { margin: 25px 10px 60px !important; }
              .accordion-titan-industrial-item { border-radius: 18px !important; margin-bottom: 12px !important; border-width: 2px !important; }
              .accordion-titan-industrial-button { padding: 16px 14px !important; font-size: 0.85rem !important; }
              .accordion-titan-industrial-button i { margin-right: 10px !important; font-size: 0.9rem !important; }
              .accordion-titan-industrial-body { padding: 16px 14px !important; font-size: 0.85rem !important; line-height: 1.7 !important; }

              /* FOOTER */
              footer h1 { font-size: 2.2rem !important; letter-spacing: -3px !important; }
              footer p { font-size: 0.7rem !important; }

              /* TOAST */
              #titan-toast-industrial-heavy { bottom: 10px !important; left: 8px !important; right: 8px !important; padding: 14px 16px !important; border-radius: 18px !important; gap: 12px !important; border-left-width: 6px !important; }
              #titan-toast-industrial-heavy i { font-size: 1.5rem !important; }
              #toast-industrial-heavy-msg { font-size: 0.8rem !important; }
              #titan-toast-industrial-heavy .small { font-size: 0.55rem !important; }

              /* BOUTON SCROLL TOP */
              #scrollTopIndustrialHeavy { width: 45px !important; height: 45px !important; bottom: 12px !important; right: 12px !important; font-size: 1.3rem !important; }

              /* MODAL PAIEMENT */
              .modal-dialog { margin: 8px !important; }
              .modal-titan-industrial-heavy { border-radius: 25px !important; }
              .modal-body.p-5 { padding: 20px 16px !important; }
              .modal-body h2.fw-900 { font-size: 1.2rem !important; margin-bottom: 16px !important; }
              .payment-titan-industrial-heavy-card { padding: 16px !important; border-radius: 18px !important; border-width: 3px !important; margin-bottom: 12px !important; }
              .payment-titan-industrial-heavy-card small { font-size: 0.7rem !important; }
              .payment-titan-industrial-heavy-card .fw-900.fs-2 { font-size: 1.1rem !important; }
              .modal-body .alert { padding: 14px !important; font-size: 0.8rem !important; border-radius: 15px !important; margin: 12px 0 !important; }
              .modal-body .btn { font-size: 0.85rem !important; padding: 12px !important; }
          }
      </style>
</head>
<body>

    <div id="titan-toast-industrial-heavy" class="animate__animated animate__slideInLeft">
        <i class="bi bi-cpu-fill text-success" style="font-size: 4.5rem;"></i>
        <div>
            <div class="small opacity-60 fw-900 text-uppercase fs-6">SYSTÈME CASHLINK MASTER RDC</div>
            <div id="toast-industrial-heavy-msg" class="fw-900 text-dark fs-3">Initialisation du terminal v28.0...</div>
        </div>
    </div>

    <button id="scrollTopIndustrialHeavy" onclick="window.scrollTo({top:0, behavior:'smooth'})"><i class="bi bi-arrow-up-circle-fill"></i></button>

    <nav class="premium-nav-titan">
        <a href="/" class="logo-titan-industrial">CASHLINK</a>
        <div class="nav-info-box-titan animate__animated animate__zoomIn">
            <div class="solde-badge-industrial">
                <span class="label-titan-bold">SOLDE DU TERMINAL</span>
                <div class="val-titan-heavy"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span class="label-titan-bold text-success">PROFITS MINAGE</span>
                <div class="val-titan-heavy text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>
        <a href="/logout" class="btn-logout-industrial"><i class="bi bi-power fs-1"></i></a>
    </nav>

    <header class="hero-industrial-banner">
        <div class="animate__animated animate__fadeIn">
            <div class="user-id-badge-industrial">
                SESSION ACTIVE : <%= user.username %>
                <% if(user.certified) { %><span style="display:inline-flex;align-items:center;gap:4px;background:#1d4ed8;color:#fff;font-size:0.65rem;font-weight:900;padding:2px 10px;border-radius:20px;margin-left:6px;letter-spacing:0.5px;vertical-align:middle;"><i class="bi bi-patch-check-fill" style="font-size:0.75rem;"></i> CERTIFIÉ</span><% } %>
                | RÉSEAU : +243 <%= user.phone %>
            </div>
            <h1 class="hero-title-titan-heavy"><%= content.hero_title || 'MINAGE <span class="text-primary">INDUSTRIEL</span>' %></h1>
            <p class="hero-para-titan-heavy"><%= content.hero_subtitle || 'Le protocole CASHLINK v28.0 déploie une puissance de calcul décentralisée pour chaque citoyen congolais. Sécurisez votre avenir financier avec le minage Cloud Master.' %></p>
            <button onclick="document.getElementById('catalog').scrollIntoView({behavior:'smooth'})" class="btn btn-primary rounded-pill px-5 py-4 fw-900 shadow-lg fs-2">LANCER MON UNITÉ DE MINAGE</button>
        </div>
    </header>

    <div class="stats-industrial-grid">
        <div class="stat-industrial-card">
            <i class="bi bi-patch-check-fill stat-industrial-icon text-warning"></i><span class="label-titan-bold">Niveau Compte</span><div class="val-titan-heavy text-white fs-2"><%= user.certified ? 'CERTIFIÉ ÉLITE' : 'BASIQUE' %></div>
            <% if(!user.certified) { %><button onclick="openPaymentModal('CERTIFICATION', <%= content.cert_price || 30000 %>)" class="btn-certif-industrial">CERTIFIER (<%= (parseInt(content.cert_price)||30000).toLocaleString() %> FC)</button><% } %>
        </div>
        <div class="stat-industrial-card"><i class="bi bi-currency-exchange stat-industrial-icon text-success"></i><span class="label-titan-bold">Flux Retrait</span><div class="val-titan-heavy text-white fs-2">SÉCURISÉ</div></div>
    </div>

    <div class="referral-industrial-container animate__animated animate__fadeInUp">
        <h3 class="ref-title-industrial">Programme de Parrainage Elite</h3>
        <%
        const nextMilestone = Math.ceil((refCount + 1) / 100) * 100;
        const progressMilestone = refCount % 100;
        %>
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div style="background:rgba(255,255,255,0.08);border-radius:16px;padding:16px;text-align:center;">
                    <div class="fw-900 text-success fs-2"><%= refCount %></div>
                    <div style="font-size:0.7rem;color:#94a3b8;font-weight:800;">FILLEULS ACTIFS</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:rgba(255,255,255,0.08);border-radius:16px;padding:16px;text-align:center;">
                    <div class="fw-900 text-warning fs-2">10%</div>
                    <div style="font-size:0.7rem;color:#94a3b8;font-weight:800;">COMMISSION PAR FILLEUL</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:rgba(255,255,255,0.08);border-radius:16px;padding:16px;text-align:center;">
                    <div class="fw-900 text-info fs-2"><%= progressMilestone %>/100</div>
                    <div style="font-size:0.7rem;color:#94a3b8;font-weight:800;">VERS PROCHAIN PALIER</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:rgba(255,255,255,0.08);border-radius:16px;padding:16px;text-align:center;">
                    <div class="fw-900 text-primary fs-3">+100K FC</div>
                    <div style="font-size:0.7rem;color:#94a3b8;font-weight:800;">BONUS À <%= nextMilestone %> FILLEULS</div>
                </div>
            </div>
        </div>
        <div style="background:rgba(255,255,255,0.05);border-radius:12px;padding:12px 16px;margin-bottom:16px;font-size:0.82rem;color:#cbd5e1;">
            <i class="bi bi-info-circle-fill text-info me-2"></i>
            Chaque ami qui investit via votre lien vous rapporte <strong class="text-success">10% de son pack</strong> — retirable directement.<br>
            Atteignez <strong class="text-warning"><%= nextMilestone %> filleuls</strong> pour gagner <strong class="text-warning">+100.000 FC</strong> supplémentaires !
        </div>
        <% if(progressMilestone > 0) { %>
        <div style="margin-bottom:16px;">
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:800;margin-bottom:6px;">PROGRESSION PALIER (<%= progressMilestone %>/100)</div>
            <div style="background:rgba(255,255,255,0.1);border-radius:50px;height:10px;overflow:hidden;">
                <div style="width:<%= progressMilestone %>%;height:100%;background:linear-gradient(90deg,#f59e0b,#ef4444);border-radius:50px;"></div>
            </div>
        </div>
        <% } %>
        <div class="industrial-copy-group">
            <input type="text" id="refLinkHeavy" readonly style="font-size:0.8rem;">
            <button class="btn-copy-industrial-action" onclick="copyHeavyLink()">COPIER MON LIEN</button>
        </div>
    </div>
    </div>

    <section class="mining-industrial-terminal animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-end mb-2">
            <div><h3 class="fw-900 mb-0 small text-uppercase">MASTER CLUSTER STATUS</h3><p class="label-titan-bold text-muted mb-0">Unité : <%= user.pack %> industrial_master_v28</p></div>
            <div class="text-success fw-900 fs-1" style="font-family: 'Space Grotesk';"><%= p || 0 %>%</div>
        </div>
        <div class="progress-industrial-track"><div class="bar-industrial-emerald-fill animate__animated animate__pulse animate__infinite" style="width:<%= p || 0 %>%"></div></div>
        <% if(user.pack && user.pack !== 'Aucun') { 
           const dailyGain = parseInt(content['daily_' + user.pack]) || 0;
           const accumulatedNow = Math.floor((p/100) * dailyGain);
           const ratePerHour = Math.floor(dailyGain / 24);
           const ratePerMin = Math.floor(dailyGain / 1440);
        %>
        <div class="d-flex flex-wrap gap-4 mt-3 mb-2" style="font-size:0.85rem;">
            <div class="text-success fw-bold"><i class="bi bi-lightning-fill me-1"></i>Accumulé : <span class="text-white"><%= accumulatedNow.toLocaleString() %> FC</span></div>
            <div class="text-info fw-bold"><i class="bi bi-hourglass-split me-1"></i>+<%= ratePerHour.toLocaleString() %> FC/heure</div>
            <div class="text-warning fw-bold"><i class="bi bi-clock me-1"></i>+<%= ratePerMin.toLocaleString() %> FC/min</div>
        </div>
        <% } %>
        <div class="d-flex flex-wrap justify-content-between mt-5 align-items-center gap-5">
            <div class="fw-900 text-warning fs-3"><i class="bi bi-clock-history me-3"></i>RECHARGE DISPONIBLE DANS : <span id="titan-heavy-timer">--:--:--</span></div>
            <% if(typeof pendingRetrait !== 'undefined' && pendingRetrait) { %>
                <div style="background:rgba(245,158,11,0.15);border:2px solid #f59e0b;border-radius:16px;padding:16px 24px;text-align:center;">
                    <div class="fw-900 text-warning fs-4"><i class="bi bi-hourglass-split me-2"></i>RETRAIT EN TRAITEMENT</div>
                    <div class="text-warning opacity-75 mt-2" style="font-size:0.85rem;">Veuillez patienter pendant que l'admin confirme votre demande de <strong><%= (pendingRetrait.montant||0).toLocaleString() %> FC</strong></div>
                </div>
            <% } else { %>
                <button onclick="handleWithdrawHeavy()" class="btn-withdraw-industrial-heavy animate__animated animate__pulse animate__infinite">RÉCUPÉRER MES PROFITS (MONEY)</button>
            <% } %>
            <% if(typeof pendingAnnulation !== 'undefined' && pendingAnnulation) { %>
                <div style="background:rgba(239,68,68,0.12);border:2px solid #ef4444;border-radius:16px;padding:14px 20px;text-align:center;margin-top:12px;">
                    <div class="fw-900 text-danger fs-5"><i class="bi bi-x-octagon-fill me-2"></i>ANNULATION EN COURS DE TRAITEMENT</div>
                    <div class="text-danger opacity-75 mt-1" style="font-size:0.82rem;">Remboursement de <strong><%= (pendingAnnulation.remboursement||0).toLocaleString() %> FC (50%)</strong> en cours — traitement sous 72h</div>
                </div>
            <% } %>
        </div>
    </section>

    <div class="shop-industrial-header" id="catalog">
        <div style="width: 20px; height: 80px; background: var(--gold); border-radius: 25px;"></div>
        <h2>Unités de Minage 2026-2028</h2>
    </div>

    <div class="industrial-shop-grid-full">
        <% 
        const PACK_LEVELS = { 'Aucun': 0, 'BRONZE': 1, 'SILVER': 2, 'GOLD': 3, 'DIAMOND': 4 };
        const userPackLevel = PACK_LEVELS[user.pack] || 0;
        const heavyPacks = [
            { id: 'BRONZE', price: parseInt(content.price_BRONZE)||50000, daily: parseInt(content.daily_BRONZE)||5000, bonus: 5000, color: '#10b981', locked: false },
            { id: 'SILVER', price: parseInt(content.price_SILVER)||150000, daily: parseInt(content.daily_SILVER)||15000, bonus: 9000, color: '#4f46e5', locked: false },
            { id: 'GOLD', price: parseInt(content.price_GOLD)||500000, daily: parseInt(content.daily_GOLD)||40000, bonus: 40000, color: '#f59e0b', locked: false },
            { id: 'DIAMOND', price: parseInt(content.price_DIAMOND)||1000000, daily: parseInt(content.daily_DIAMOND)||100000, bonus: 120000, color: '#ef4444', locked: false },
            { id: 'AMÉTHYSTE', price: 2500000, daily: 300000, bonus: 250000, color: '#9333ea', locked: true },
            { id: 'ÉMERAUDE', price: 5000000, daily: 700000, bonus: 600000, color: '#059669', locked: true },
            { id: 'RUBIS', price: 10000000, daily: 1500000, bonus: 1200000, color: '#dc2626', locked: true },
            { id: 'SAPHIR', price: 25000000, daily: 4000000, bonus: 3500000, color: '#2563eb', locked: true }
        ];

        heavyPacks.forEach(item => {
            const isOwned = (user.pack === item.id);
            const itemLevel = PACK_LEVELS[item.id] || 0;
            const isUpgrade = !item.locked && !isOwned && (itemLevel > userPackLevel) && (userPackLevel > 0);
            const isLowerOrSame = !item.locked && !isOwned && (itemLevel <= userPackLevel) && (userPackLevel > 0);
            const canBuyFirst = !item.locked && !isOwned && userPackLevel === 0;
        %>
        <div class="pack-industrial-heavy-card animate__animated animate__fadeInUp <%= item.locked ? 'pack-industrial-locked-mode' : '' %> <%= isOwned ? 'pack-industrial-active-border' : '' %>">
            <% if(item.locked) { %><div class="lock-industrial-overlay"><div class="lock-industrial-badge">VERROUILLÉ 2028</div></div><% } %>
            <% if(isLowerOrSame) { %><div class="lock-industrial-overlay"><div class="lock-industrial-badge" style="background:#374151;">DÉJÀ POSSÉDÉ</div></div><% } %>
            <div class="p-head-industrial-heavy" style="background: <%= item.color %>;">
                <%= item.id %> MASTER UNIT
                <% if(isOwned) { %> <span style="background:rgba(255,255,255,0.25);padding:2px 10px;border-radius:20px;font-size:0.7rem;">✅ ACTIF</span><% } %>
            </div>
            <div class="p-body-industrial-heavy">
                <div>
                    <div class="p-price-industrial-heavy"><%= item.price.toLocaleString() %> FC</div>
                    <div class="p-bonus-industrial-heavy">CADEAU D'ACTIVATION : +<%= item.bonus.toLocaleString() %> FC</div>
                    <div class="p-daily-industrial-heavy">+<%= item.daily.toLocaleString() %> FC / JOUR</div>
                    <ul class="industrial-details-list">
                        <li><i class="bi bi-shield-fill-check"></i> Contrat : 30 Jours<% if(isOwned && user.packActivatedDate) { %> <span style="background:#f59e0b;color:#000;padding:1px 8px;border-radius:10px;font-size:0.7rem;"><%= packDaysLeft %>j restants</span><% } %></li>
                        <li><i class="bi bi-shield-fill-check"></i> Support Prioritaire : 24h/7j</li>
                        <li><i class="bi bi-shield-fill-check"></i> Retrait : <%= user.certified ? '✅ 24h (Certifié)' : '72h (Standard)' %></li>
                        <li><i class="bi bi-shield-fill-check"></i> Technologie : Cloud Master v28</li>
                    </ul>
                </div>
                <% if(isOwned) { %>
                    <% if(packDaysLeft === null || packDaysLeft > 0) { %>
                        <% if(!user.packActivated) { %>
                            <button onclick="submitHeavyPost('/activer-gain', { pack: '<%= item.id %>' })" class="btn-industrial-heavy-action btn-activate-industrial-heavy">ACTIVER MAINTENANT</button>
                        <% } else { %>
                            <div style="background:rgba(16,185,129,0.1);border:2px solid #10b981;border-radius:16px;padding:12px;text-align:center;margin-bottom:10px;">
                                <i class="bi bi-check-circle-fill text-success me-2"></i><span class="fw-900 text-success" style="font-size:0.85rem;">MINAGE EN COURS</span>
                            </div>
                        <% } %>
                        <button onclick="confirmerAnnulation('<%= item.id %>', <%= item.price %>)" class="btn-industrial-heavy-action" style="background:transparent;border:2px solid rgba(239,68,68,0.5);color:#ef4444;font-size:0.7rem;padding:10px;margin-top:8px;box-shadow:none;">
                            <i class="bi bi-x-circle me-1"></i>ANNULER MON ABONNEMENT
                        </button>
                    <% } else { %>
                        <button disabled class="btn-industrial-heavy-action" style="background:#374151;cursor:not-allowed;opacity:0.7;">CONTRAT EXPIRÉ (30 JOURS)</button>
                    <% } %>
                <% } else if(isUpgrade) { %>
                    <button onclick="openPaymentModal('<%= item.id %>', <%= item.price %>)" class="btn-industrial-heavy-action btn-buy-industrial-heavy">⬆ UPGRADER VERS <%= item.id %></button>
                <% } else if(canBuyFirst || (!item.locked && !isLowerOrSame && !isOwned)) { %>
                    <button onclick="openPaymentModal('<%= item.id %>', <%= item.price %>)" class="btn-industrial-heavy-action btn-buy-industrial-heavy">ACHETER VOTRE PACK</button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>


    <div style="margin:60px 30px;padding:0;" class="animate__animated animate__fadeInUp">
        <div style="background:linear-gradient(135deg,rgba(6,182,212,0.12),rgba(99,102,241,0.12));border:2px solid rgba(6,182,212,0.4);border-radius:40px;padding:50px 40px;">
            <h2 style="font-weight:900;letter-spacing:-1px;font-size:2.2rem;color:#fff;margin-bottom:30px;"><i class="bi bi-book-fill text-info me-3"></i>RÈGLES D'INVESTISSEMENT</h2>
            
            <!-- PACKS & GAINS -->
            <div style="margin-bottom:35px;">
                <h5 style="font-weight:900;color:#f59e0b;letter-spacing:2px;font-size:0.85rem;margin-bottom:16px;"><i class="bi bi-box-seam-fill me-2"></i>PACKS D'INVESTISSEMENT</h5>
                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
                        <thead>
                            <tr style="background:rgba(255,255,255,0.08);">
                                <th style="padding:12px 16px;text-align:left;font-weight:900;color:#94a3b8;font-size:0.72rem;letter-spacing:1px;">PACK</th>
                                <th style="padding:12px 16px;text-align:right;font-weight:900;color:#94a3b8;font-size:0.72rem;letter-spacing:1px;">INVESTISSEMENT</th>
                                <th style="padding:12px 16px;text-align:right;font-weight:900;color:#94a3b8;font-size:0.72rem;letter-spacing:1px;">GAIN/JOUR</th>
                                <th style="padding:12px 16px;text-align:right;font-weight:900;color:#94a3b8;font-size:0.72rem;letter-spacing:1px;">GAIN/30 JOURS</th>
                                <th style="padding:12px 16px;text-align:right;font-weight:900;color:#94a3b8;font-size:0.72rem;letter-spacing:1px;">BONUS ACTIVATION</th>
                                <th style="padding:12px 16px;text-align:right;font-weight:900;color:#94a3b8;font-size:0.72rem;letter-spacing:1px;">CONTRAT</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% const packDefs = [
                                {name:"BRONZE",color:"#10b981",price:content.price_BRONZE||50000,daily:content.daily_BRONZE||5000,bonus:5000},
                                {name:"SILVER",color:"#4f46e5",price:content.price_SILVER||150000,daily:content.daily_SILVER||15000,bonus:9000},
                                {name:"GOLD",color:"#f59e0b",price:content.price_GOLD||500000,daily:content.daily_GOLD||40000,bonus:40000},
                                {name:"DIAMOND",color:"#ef4444",price:content.price_DIAMOND||1000000,daily:content.daily_DIAMOND||100000,bonus:120000},
                            ]; %>
                            <% packDefs.forEach(pk => { %>
                            <tr style="border-top:1px solid rgba(255,255,255,0.07);<%= user.pack===pk.name ? 'background:rgba(245,158,11,0.08);' : '' %>">
                                <td style="padding:12px 16px;"><span style="background:<%= pk.color %>;color:#fff;font-weight:900;padding:3px 12px;border-radius:20px;font-size:0.75rem;"><%= pk.name %></span><%= user.pack===pk.name ? ' <span style="font-size:0.65rem;color:#f59e0b;font-weight:900;">✅ VOTRE PACK</span>' : '' %></td>
                                <td style="padding:12px 16px;text-align:right;font-weight:900;color:#fff;"><%= parseInt(pk.price).toLocaleString() %> FC</td>
                                <td style="padding:12px 16px;text-align:right;font-weight:900;color:#10b981;">+<%= parseInt(pk.daily).toLocaleString() %> FC</td>
                                <td style="padding:12px 16px;text-align:right;font-weight:900;color:#06b6d4;">+<%= (parseInt(pk.daily)*30).toLocaleString() %> FC</td>
                                <td style="padding:12px 16px;text-align:right;font-weight:900;color:#f59e0b;">+<%= parseInt(pk.bonus).toLocaleString() %> FC</td>
                                <td style="padding:12px 16px;text-align:right;color:#94a3b8;font-weight:700;">30 jours</td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- PARRAINAGE -->
            <div style="margin-bottom:35px;">
                <h5 style="font-weight:900;color:#f59e0b;letter-spacing:2px;font-size:0.85rem;margin-bottom:16px;"><i class="bi bi-people-fill me-2"></i>PROGRAMME DE PARRAINAGE</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div style="background:rgba(255,255,255,0.06);border-radius:16px;padding:20px;">
                            <div style="font-size:0.8rem;font-weight:900;color:#94a3b8;margin-bottom:12px;">TAUX SELON VOTRE PACK</div>
                            <div style="display:flex;flex-direction:column;gap:8px;font-size:0.85rem;">
                                <div style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.06);">
                                    <div class="fw-900 text-warning mb-1" style="font-size:0.82rem;"><i class="bi bi-gift-fill me-2"></i>COMMISSION FIXE : 10% pour tous les packs</div>
                                    <div style="font-size:0.78rem;color:#cbd5e1;">Exemple : filleul achète BRONZE (50.000 FC) → vous gagnez <strong class="text-success">5.000 FC</strong></div>
                                    <div style="font-size:0.78rem;color:#cbd5e1;">Exemple : filleul achète DIAMOND (1.000.000 FC) → vous gagnez <strong class="text-success">100.000 FC</strong></div>
                                </div>
                                <div style="padding:10px 0;">
                                    <div class="fw-900 text-warning mb-1" style="font-size:0.82rem;"><i class="bi bi-trophy-fill me-2"></i>PALIER : 100 filleuls actifs = +100.000 FC</div>
                                    <div style="font-size:0.78rem;color:#cbd5e1;">Cumulable à l'infini : 200 filleuls = +200.000 FC, 300 = +300.000 FC...</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div style="background:rgba(255,255,255,0.06);border-radius:16px;padding:20px;">
                            <div style="font-size:0.8rem;font-weight:900;color:#94a3b8;margin-bottom:12px;">BONUS DE PALIER (filleuls actifs)</div>
                            <div style="display:flex;flex-direction:column;gap:8px;font-size:0.85rem;">
                                <div style="display:flex;justify-content:space-between;"><span style="color:#94a3b8;font-weight:700;">100 filleuls</span><span style="font-weight:900;color:#f59e0b;">+100.000 FC</span></div>
                                <div style="display:flex;justify-content:space-between;"><span style="color:#94a3b8;font-weight:700;">200 filleuls</span><span style="font-weight:900;color:#f59e0b;">+200.000 FC</span></div>
                                <div style="display:flex;justify-content:space-between;"><span style="color:#94a3b8;font-weight:700;">300 filleuls</span><span style="font-weight:900;color:#f59e0b;">+300.000 FC</span></div>
                                <div style="display:flex;justify-content:space-between;"><span style="color:#94a3b8;font-weight:700;">N × 100 filleuls</span><span style="font-weight:900;color:#f59e0b;">+N × 100.000 FC</span></div>
                            </div>
                            <div style="font-size:0.72rem;color:#10b981;font-weight:800;margin-top:10px;"><i class="bi bi-check-circle-fill me-1"></i>Commission retirable directement</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- RETRAITS -->
            <div style="margin-bottom:35px;">
                <h5 style="font-weight:900;color:#f59e0b;letter-spacing:2px;font-size:0.85rem;margin-bottom:16px;"><i class="bi bi-cash-coin me-2"></i>RÈGLES DE RETRAIT</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div style="background:rgba(255,255,255,0.06);border-radius:16px;padding:20px;text-align:center;">
                            <div style="font-size:2rem;font-weight:900;color:#06b6d4;">1.000 FC</div>
                            <div style="font-size:0.75rem;color:#94a3b8;font-weight:800;">MONTANT MINIMUM</div>
                        </div>
                    </div>
                    <div class="col-md-4">
