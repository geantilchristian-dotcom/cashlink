        <h2 style="font-family:'Space Grotesk'; font-weight:900; font-size:1.8rem; color:#fff; letter-spacing:-0.5px; margin:0 0 6px; line-height:1.2;">Les Différents Forfaits<br><span style="color:var(--gold);">Disponibles 2026-2028</span></h2>
        <p style="font-size:0.78rem; color:#94a3b8; font-weight:700; margin:0;">Choisissez votre forfait et commencez à générer des revenus dès aujourd'hui</p>
    </div>
        <h2>Les Différents Forfaits Disponibles 2026-2028</h2>
    </div>

    <div class="industrial-shop-grid-full">
        <% 
        const PACK_LEVELS = { 'Aucun': 0, 'BRONZE': 1, 'SILVER': 2, 'GOLD': 3, 'DIAMOND': 4 };
        const userPackLevel = PACK_LEVELS[user.pack] || 0;
        const heavyPacks = [
            { id: 'BRONZE', price: parseInt(content.price_BRONZE)||50000, daily: parseInt(content.daily_BRONZE)||5000, bonus: 5000, color: '#10b981', locked: false },
            { id: 'SILVER', price: parseInt(content.price_SILVER)||150000, daily: parseInt(content.daily_SILVER)||15000, bonus: 9000, color: '#4f46e5', locked: false },
            { id: 'GOLD', price: parseInt(content.price_GOLD)||500000, daily: parseInt(content.daily_GOLD)||40000, bonus: 40000, color: '#f59e0b', locked: false },
            { id: 'DIAMOND', price: parseInt(content.price_DIAMOND)||1000000, daily: parseInt(content.daily_DIAMOND)||100000, bonus: 120000, color: '#ef4444', locked: false },
            { id: 'AMÉTHYSTE', price: 2500000, daily: 300000, bonus: 250000, color: '#9333ea', locked: true },
            { id: 'ÉMERAUDE', price: 5000000, daily: 700000, bonus: 600000, color: '#059669', locked: true },
            { id: 'RUBIS', price: 10000000, daily: 1500000, bonus: 1200000, color: '#dc2626', locked: true },
            { id: 'SAPHIR', price: 25000000, daily: 4000000, bonus: 3500000, color: '#2563eb', locked: true }
        ];

        heavyPacks.forEach(item => {
            const isOwned = (user.pack === item.id);
            const itemLevel = PACK_LEVELS[item.id] || 0;
            const isUpgrade = !item.locked && !isOwned && (itemLevel > userPackLevel) && (userPackLevel > 0);
            const isLowerOrSame = !item.locked && !isOwned && (itemLevel <= userPackLevel) && (userPackLevel > 0);
            const canBuyFirst = !item.locked && !isOwned && userPackLevel === 0;
        %>
        <div class="pack-industrial-heavy-card animate__animated animate__fadeInUp <%= item.locked ? 'pack-industrial-locked-mode' : '' %> <%= isOwned ? 'pack-industrial-active-border' : '' %>">
            <% if(item.locked) { %><div class="lock-industrial-overlay"><div class="lock-industrial-badge">VERROUILLÉ 2028</div></div><% } %>
            <% if(isLowerOrSame) { %><div class="lock-industrial-overlay"><div class="lock-industrial-badge" style="background:#374151;">DÉJÀ POSSÉDÉ</div></div><% } %>
            <div class="p-head-industrial-heavy" style="background: <%= item.color %>;">
                <%= item.id %> MASTER UNIT
                <% if(isOwned) { %> <span style="background:rgba(255,255,255,0.25);padding:2px 10px;border-radius:20px;font-size:0.7rem;">✅ ACTIF</span><% } %>
            </div>
            <div class="p-body-industrial-heavy">
                <div>
                    <div class="p-price-industrial-heavy"><%= item.price.toLocaleString() %> FC</div>
                    <div class="p-price-label">Investissement</div>
                    <div class="p-stats-row">
                        <div class="p-stat-box" style="background:rgba(16,185,129,0.12);"><div class="p-stat-val" style="color:#10b981;">+<%= item.daily.toLocaleString() %></div><div class="p-stat-lbl">FC/JOUR</div></div>
                        <div class="p-stat-box" style="background:rgba(245,158,11,0.12);"><div class="p-stat-val" style="color:#f59e0b;">+<%= (item.daily*30).toLocaleString() %></div><div class="p-stat-lbl">FC/MOIS</div></div>
                    </div>
                    <div class="p-bonus-industrial-heavy">🎁 BONUS : +<%= item.bonus.toLocaleString() %> FC</div>
                    <ul class="industrial-details-list">
                        <li><i class="bi bi-shield-fill-check"></i> Contrat : 30 Jours<% if(isOwned && user.packActivatedDate) { %> <span style="background:#f59e0b;color:#000;padding:1px 8px;border-radius:10px;font-size:0.7rem;"><%= packDaysLeft %>j restants</span><% } %></li>
                        <li><i class="bi bi-shield-fill-check"></i> Support Prioritaire : 24h/7j</li>
                        <li><i class="bi bi-shield-fill-check"></i> Retrait : <%= user.certified ? '✅ 24h (Certifié)' : '72h (Standard)' %></li>
                        <li><i class="bi bi-shield-fill-check"></i> Technologie : Cloud Master v28</li>
                    </ul>
                </div>
                <% if(isOwned) { %>
                    <% if(packDaysLeft === null || packDaysLeft > 0) { %>
                        <% if(!user.packActivated) { %>
                            <button onclick="submitHeavyPost('/activer-gain', { pack: '<%= item.id %>' })" class="btn-industrial-heavy-action btn-activate-industrial-heavy">ACTIVER MAINTENANT</button>
                        <% } else { %>
                            <div style="background:rgba(16,185,129,0.1);border:2px solid #10b981;border-radius:16px;padding:12px;text-align:center;margin-bottom:10px;">
                                <i class="bi bi-check-circle-fill text-success me-2"></i><span class="fw-900 text-success" style="font-size:0.85rem;">MINAGE EN COURS</span>
                            </div>
                        <% } %>
                        <button onclick="confirmerAnnulation('<%= item.id %>', <%= item.price %>)" class="btn-industrial-heavy-action" style="background:transparent;border:2px solid rgba(239,68,68,0.5);color:#ef4444;font-size:0.7rem;padding:10px;margin-top:8px;box-shadow:none;">
                            <i class="bi bi-x-circle me-1"></i>ANNULER MON ABONNEMENT
                        </button>
                    <% } else { %>
                        <button disabled class="btn-industrial-heavy-action" style="background:#374151;cursor:not-allowed;opacity:0.7;">CONTRAT EXPIRÉ (30 JOURS)</button>
