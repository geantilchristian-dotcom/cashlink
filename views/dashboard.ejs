                        </div>

                        <div class="pay-op-card" onclick="selectOperator(this,'+243 <%= content.admin_orange %>','ORANGE')" style="background:#1e293b;border:2px solid rgba(251,146,60,0.3);border-radius:18px;padding:16px 20px;margin-bottom:10px;cursor:pointer;display:flex;align-items:center;gap:14px;transition:0.2s;">
                            <div style="width:44px;height:44px;background:linear-gradient(135deg,#c2410c,#fb923c);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="bi bi-phone-fill" style="color:#fff;font-size:1.1rem;"></i></div>
                            <div style="flex:1;"><div style="font-weight:900;font-size:0.7rem;color:#fb923c;letter-spacing:1px;text-transform:uppercase;">ORANGE MONEY</div><div style="font-weight:900;font-size:1.3rem;color:#fff;letter-spacing:-0.5px;">+243 <%= content.admin_orange %></div></div>
                            <div style="background:rgba(251,146,60,0.1);border:1px solid rgba(251,146,60,0.3);color:#fb923c;border-radius:10px;padding:5px 10px;font-size:0.65rem;font-weight:900;letter-spacing:1px;flex-shrink:0;">COPIER</div>
                        </div>

                        <div id="copiedBadge" style="display:none;background:rgba(16,185,129,0.1);border:1px solid #10b981;border-radius:12px;padding:10px 14px;text-align:center;margin-top:8px;">
                            <i class="bi bi-check-circle-fill text-success me-2"></i><span id="copiedNumText" style="color:#10b981;font-weight:900;font-size:0.85rem;"></span>
                        </div>
                        <button onclick="goToTIDStep()" style="background:linear-gradient(135deg,#0033cc,#00d9ff);color:#fff;border:none;width:100%;padding:16px;border-radius:16px;font-weight:900;font-size:1rem;text-transform:uppercase;letter-spacing:1px;margin-top:16px;cursor:pointer;">
                            J'AI ENVOYE &rarr; SAISIR LE TID
                        </button>
                    </div>

                    <!-- ETAPE 2 : Saisir le TID -->
                    <div id="payStep2" style="display:none;">
                        <div style="font-size:0.7rem;font-weight:900;color:#64748b;letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">
                            <span style="display:inline-flex;align-items:center;gap:6px;background:#1e293b;padding:4px 12px;border-radius:20px;">
                                <span style="background:#10b981;color:#fff;width:18px;height:18px;border-radius:50%;font-size:0.6rem;display:inline-flex;align-items:center;justify-content:center;font-weight:900;">2</span>
                                SAISISSEZ VOTRE REFERENCE TID
                            </span>
                        </div>
                        <div style="background:linear-gradient(135deg,rgba(245,158,11,0.1),rgba(251,146,60,0.05));border:2px solid rgba(245,158,11,0.4);border-radius:16px;padding:14px 18px;margin-bottom:18px;">
                            <div style="display:flex;align-items:flex-start;gap:12px;">
                                <i class="bi bi-exclamation-triangle-fill" style="color:#f59e0b;font-size:1.3rem;margin-top:2px;flex-shrink:0;"></i>
                                <div>
                                    <div style="color:#f59e0b;font-weight:900;font-size:0.85rem;margin-bottom:6px;">RAPPEL IMPORTANT</div>
                                    <div style="color:#cbd5e1;font-size:0.8rem;font-weight:700;line-height:1.6;">
                                        Le numero de reference TID doit commencer par <span style="background:#f59e0b;color:#000;padding:1px 8px;border-radius:6px;font-weight:900;">TID:</span> suivi des chiffres.
                                        <br>Exemple : <code style="background:#1e293b;color:#00d9ff;padding:2px 8px;border-radius:6px;font-size:0.8rem;">TID:MP260327.1157.FP8352</code>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <label style="font-size:0.7rem;font-weight:900;color:#94a3b8;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px;display:block;">REFERENCE TID (du SMS de confirmation)</label>
                        <input type="text" id="tidInputHeavy" placeholder="TID:MP260327.1157.FP8352" autocomplete="off"
                            style="background:#1e293b;border:2px solid rgba(0,217,255,0.3);border-radius:14px;padding:16px 18px;color:#fff;font-weight:900;font-size:1.1rem;width:100%;font-family:monospace;letter-spacing:1px;margin-bottom:8px;"
                            oninput="validateTIDInput(this)"
                            onfocus="this.style.borderColor='#00d9ff';this.style.boxShadow='0 0 0 3px rgba(0,217,255,0.15)';"
                            onblur="this.style.boxShadow='';">
                        <div id="tidStatus" style="font-size:0.72rem;font-weight:800;margin-bottom:14px;padding:0 4px;min-height:18px;"></div>
                        <div style="display:flex;gap:10px;">
                            <button onclick="goBackStep1()" style="background:#1e293b;color:#94a3b8;border:1px solid #334155;flex:0 0 auto;padding:14px 20px;border-radius:14px;font-weight:900;font-size:0.85rem;cursor:pointer;">&#8592; RETOUR</button>
                            <button onclick="commitHeavyTID()" id="btnSubmitTID" style="background:linear-gradient(135deg,#059669,#10b981);color:#fff;border:none;flex:1;padding:14px;border-radius:14px;font-weight:900;font-size:1rem;text-transform:uppercase;letter-spacing:1px;cursor:pointer;opacity:0.45;pointer-events:none;">
                                <i class="bi bi-check2-circle me-2"></i>VALIDER MON PAIEMENT
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="annulModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content" style="background:#1e293b;border:2px solid #ef4444;border-radius:30px;color:#fff;">
                <div class="modal-body p-5 text-center">
                    <div style="font-size:3rem;">⚠️</div>
                    <h3 class="fw-900 my-3">ANNULER MON ABONNEMENT</h3>
                    <div style="background:rgba(239,68,68,0.1);border-radius:16px;padding:16px;margin:16px 0;font-size:0.9rem;">
                        <div class="fw-900 text-danger mb-2">CONDITIONS D'ANNULATION</div>
                        <div>Vous serez remboursé à <strong class="text-warning">50% de votre investissement initial</strong></div>
                        <div class="mt-2 text-warning fw-900">Remboursement estimé : <span id="annulRemboursement">0</span> FC</div>
                        <div class="mt-2 text-muted" style="font-size:0.8rem;">Traitement sous <strong>72 heures</strong> par l'admin</div>
                    </div>
                    <div class="mt-4 text-start">
                        <label class="fw-900 text-warning mb-2" style="font-size:0.78rem;"><i class="bi bi-lock-fill me-2"></i>CONFIRMEZ AVEC VOTRE MOT DE PASSE</label>
                        <input type="password" id="annulPassword" class="form-control bg-dark text-white border-danger rounded-pill px-4 py-3" placeholder="Votre mot de passe..." style="font-weight:700;">
                    </div>
                    <div class="d-flex gap-3 mt-3">
                        <button onclick="document.getElementById('annulModal').querySelector('.btn-close-modal').click()" class="btn btn-secondary w-50 py-3 rounded-pill fw-900">NON, GARDER</button>
                        <button onclick="confirmerAnnulationFinal()" class="btn btn-danger w-50 py-3 rounded-pill fw-900">OUI, ANNULER</button>
                    </div>
                    <button class="btn-close-modal d-none" data-bs-dismiss="modal"></button>
                </div>
            </div>
        </div>
    </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let heavyPack = ""; let heavyPrice = 0;
        const heavyModal = new bootstrap.Modal(document.getElementById('payHeavyModal'));
        
        window.onscroll = function() {
            const btn = document.getElementById('scrollTopIndustrialHeavy');
            btn.style.display = (document.body.scrollTop > 600 || document.documentElement.scrollTop > 600) ? "flex" : "none";
        };

        // Set referral link dynamically from actual domain
        document.addEventListener('DOMContentLoaded', function() {
            const inp = document.getElementById('refLinkHeavy');
            if(inp) inp.value = window.location.origin + '/?ref=<%= user.id %>';
        });

        function copyHeavyLink() {
            const i = document.getElementById('refLinkHeavy'); i.select();
            document.execCommand('copy'); triggerHeavyToast("Lien de parrainage copié avec succès !");
        }

        function openPaymentModal(id, price) {
            heavyPack = id; heavyPrice = price;
            document.getElementById('modalPackTitle').textContent = 'Pack ' + id;
            document.getElementById('modalPriceDisplay').textContent = price.toLocaleString('fr-FR') + ' FC';
            document.getElementById('payStep1').style.display = 'block';
            document.getElementById('payStep2').style.display = 'none';
            document.getElementById('tidInputHeavy').value = '';
            document.getElementById('tidStatus').textContent = '';
            document.getElementById('btnSubmitTID').style.opacity = '0.45';
            document.getElementById('btnSubmitTID').style.pointerEvents = 'none';
            document.getElementById('copiedBadge').style.display = 'none';
            document.querySelectorAll('.pay-op-card').forEach(c => { c.style.transform=''; c.style.opacity='1'; });
            heavyModal.show();
        }

        function selectOperator(el, number, name) {
            try { navigator.clipboard.writeText(number); } catch(e) {}
            document.querySelectorAll('.pay-op-card').forEach(c => { c.style.transform=''; c.style.opacity='0.5'; });
            el.style.transform = 'scale(1.02)'; el.style.opacity = '1';
            document.getElementById('copiedNumText').textContent = number + ' copié ! (' + name + ')';
            document.getElementById('copiedBadge').style.display = 'block';
        }

        function goToTIDStep() {
            document.getElementById('payStep1').style.display = 'none';
            document.getElementById('payStep2').style.display = 'block';
            setTimeout(() => document.getElementById('tidInputHeavy').focus(), 100);
        }

        function goBackStep1() {
            document.getElementById('payStep2').style.display = 'none';
            document.getElementById('payStep1').style.display = 'block';
        }

        function validateTIDInput(el) {
            const val = el.value.trim();
            const status = document.getElementById('tidStatus');
            const btn = document.getElementById('btnSubmitTID');
            if (!val) { status.textContent = ''; btn.style.opacity='0.45'; btn.style.pointerEvents='none'; return; }
            const ok = /^TID\s*:/i.test(val) && val.length >= 6;
            if (ok) {
                status.textContent = '\u2713 Format TID valide'; status.style.color = '#10b981';
                el.style.borderColor = '#10b981';
                btn.style.opacity = '1'; btn.style.pointerEvents = 'auto';
            } else {
                status.textContent = '\u26a0 Le TID doit commencer par "TID:" (ex: TID: 12345678)'; status.style.color = '#f59e0b';
                el.style.borderColor = '#f59e0b';
                btn.style.opacity = '0.45'; btn.style.pointerEvents = 'none';
            }
        }

        function commitHeavyTID() {
            const tid = document.getElementById('tidInputHeavy').value.trim();
            if(!tid || !/^TID\s*:/i.test(tid) || tid.length < 6) {
                document.getElementById('tidStatus').textContent = '\u26a0 Saisissez un TID valide commençant par "TID:"';
                document.getElementById('tidStatus').style.color = '#ef4444';
                return;
            }
            heavyModal.hide();
            submitHeavyPost('/souscrire-pack', { packName: heavyPack, prix: heavyPrice, reference: tid });       }

        function handleWithdrawHeavy() {
            const m = prompt("Montant du retrait (Min 1.000 FC) :");
            if(m >= 1000) submitHeavyPost('/retrait', { montant: m });
            else alert("Montant insuffisant.");
        }

        function submitHeavyPost(path, data) {
            const form = document.createElement('form'); form.method = 'POST'; form.action = path;
            for (const key in data) { const i = document.createElement('input'); i.type = 'hidden'; i.name = key; i.value = data[key]; form.appendChild(i); }
            document.body.appendChild(form); form.submit();
        }

        setInterval(() => {
            const now = new Date(); const next = new Date(); next.setHours(24, 0, 0, 0); const diff = next - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            const timer = document.getElementById('titan-heavy-timer');
            if(timer) timer.innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        function triggerHeavyToast(msg) {
            const t = document.getElementById('titan-toast-industrial-heavy');
            document.getElementById('toast-industrial-heavy-msg').innerText = msg;
            t.style.display = "flex"; setTimeout(() => t.style.display = "none", 7000);
        }


        // === VRAIES NOTIFICATIONS TEMPS RÉEL ===
        (function() {
            const evtSrc = new EventSource('/stream');
            
            // Écouter les mises à jour de données (bonus, solde)
            evtSrc.onmessage = function(e) {
                try {
                    const d = JSON.parse(e.data);
                    if(d.bonus !== undefined) { const b = document.getElementById('bonus-display'); if(b) b.innerText = Number(d.bonus).toLocaleString('fr-FR') + ' FC'; }
                    if(d.solde !== undefined) { const s = document.getElementById('solde-display'); if(s) s.innerText = Number(d.solde).toLocaleString('fr-FR') + ' FC'; }
                } catch(err) {}
            };
            
            // Écouter les activités globales (pack achat, retrait, bonus)
            evtSrc.addEventListener('activity', function(e) {
                try {
                    const act = JSON.parse(e.data);
                    let msg = '';
                    if(act.type === 'pack') msg = `🎉 ${act.username} vient d'activer le pack ${act.pack}`;
                    else if(act.type === 'retrait') msg = `💸 ${act.username} a soumis un retrait de ${Number(act.montant).toLocaleString('fr-FR')} FC`;
                    else if(act.type === 'paye') msg = `✅ ${act.username} a reçu son paiement de ${Number(act.montant).toLocaleString('fr-FR')} FC`;
                    else if(act.type === 'certif') msg = `🔵 ${act.username} vient d'être certifié`;
                    if(msg) triggerHeavyToast(msg);
                } catch(err) {}
            });
            
            evtSrc.onerror = function() { setTimeout(() => {}, 5000); };
        })();


        // === ANNULATION D'ABONNEMENT ===
        let annulPack = ''; let annulPrix = 0;
        const annulModalEl = new bootstrap.Modal(document.getElementById('annulModal'));
        function confirmerAnnulation(pack, prix) {
            annulPack = pack; annulPrix = prix;
            const remb = Math.floor(prix * 0.5);
            document.getElementById('annulRemboursement').innerText = remb.toLocaleString('fr-FR');
            annulModalEl.show();
        }
        function confirmerAnnulationFinal() {
            const pwd = document.getElementById('annulPassword').value;
            if(!pwd) { alert('Veuillez entrer votre mot de passe pour confirmer.'); return; }
            annulModalEl.hide();
            submitHeavyPost('/annuler-abonnement', { pack: annulPack, password: pwd });
        }

    

        // Chevron rotation for FAQ
        document.querySelectorAll('.faq-body-titan').forEach(body => {
            const btn = body.previousElementSibling;
            const chevron = btn ? btn.querySelector('.bi-chevron-down') : null;
            if (btn) {
                const orig = btn.onclick;
                btn.onclick = function() {
                    body.classList.toggle('open-faq');
                    if (chevron) chevron.style.transform = body.classList.contains('open-faq') ? 'rotate(180deg)' : '';
                };
            }
        });
        // === ONGLETS ===
        function showTab(name) {
            document.querySelectorAll('.tab-pane-titan').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn-titan').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            document.getElementById('tab-btn-' + name).classList.add('active');
            window.scrollTo({top: 0, behavior: 'smooth'});
        }

        // === DROPDOWN PROFIL ===
        function toggleProfileDropdown() {
            const dd = document.getElementById('profileDropdown');
            dd.classList.toggle('open');
        }
        document.addEventListener('click', function(e) {
            const wrap = document.querySelector('.profile-wrap');
            if (wrap && !wrap.contains(e.target)) {
                const dd = document.getElementById('profileDropdown');
                if(dd) dd.classList.remove('open');
            }
        });

</script>
</body>
</html>
