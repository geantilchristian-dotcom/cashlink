<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Elite Terminal v3.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* --- DESIGN SYSTEM 800 --- */
        :root {
            --primary: #003399;
            --accent: #00d9ff;
            --success: #10b981;
            --warning: #fbbf24;
            --danger: #f43f5e;
            --dark: #000c26;
            --white: #ffffff;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --border: rgba(255, 255, 255, 0.1);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            background-color: var(--dark);
            background-image: 
                radial-gradient(circle at top left, #001f5c, transparent 40%),
                radial-gradient(circle at bottom right, #00061a, transparent 40%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--white);
            margin: 0; padding: 0; min-height: 100vh;
        }

        /* --- NAVIGATION PROFESSIONNELLE --- */
        .master-nav {
            background: var(--warning);
            height: 70px;
            padding: 0 20px;
            position: sticky; top: 0; z-index: 3000;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border-bottom: 4px solid rgba(0,0,0,0.1);
        }

        .btn-home-back {
            background: var(--primary); color: white; border-radius: 14px;
            width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
            text-decoration: none; border: 2px solid rgba(255,255,255,0.2);
            transition: 0.3s;
        }

        .balance-container {
            background: var(--white);
            padding: 6px 15px;
            border-radius: 50px;
            display: flex; align-items: center; gap: 15px;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.1);
        }

        .balance-item { display: flex; flex-direction: column; line-height: 1.1; }
        .balance-label { font-size: 0.55rem; font-weight: 800; color: #64748b; text-transform: uppercase; }
        .balance-val { font-size: 0.9rem; font-weight: 900; color: var(--primary); }
        .balance-val.bonus { color: var(--success); }

        .btn-exit {
            background: #1e293b; color: white; padding: 8px 18px;
            border-radius: 50px; font-weight: 800; text-decoration: none;
            font-size: 0.8rem; display: flex; align-items: center; gap: 8px;
        }

        /* --- BANNIÈRE MARKETING (WHITE CASE) --- */
        .marketing-banner {
            background: var(--white);
            margin: 0;
            display: flex;
            flex-direction: column;
            border-radius: 0 0 50px 50px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        @media (min-width: 992px) { .marketing-banner { height: 350px; flex-direction: row; } }

        .mkt-content {
            padding: 40px;
            display: flex; flex-direction: column; justify-content: center;
            color: #000; flex: 1;
        }
        .mkt-tag { 
            background: var(--primary); color: white; padding: 5px 15px; 
            border-radius: 50px; font-size: 0.65rem; font-weight: 800; width: fit-content;
        }
        .mkt-title { font-size: 2.2rem; font-weight: 900; margin: 15px 0; letter-spacing: -2px; }
        .mkt-desc { font-size: 1rem; font-weight: 600; opacity: 0.7; margin-bottom: 25px; }

        .mkt-diffusion-zone {
            flex: 1.2;
            background: #f8fafc;
            border-left: 1px solid #eee;
            display: flex; align-items: center; justify-content: center;
            position: relative;
        }
        /* Espace prêt pour tes visuels marketing */
        .mkt-diffusion-zone::after {
            content: "DIFFUSION MARKETING ACTIVE";
            font-weight: 900; color: #ddd; font-size: 1.5rem; letter-spacing: 5px;
        }

        /* --- MINING DASHBOARD (AJUSTÉ) --- */
        .mining-section {
            padding: 30px 15px;
        }
        @media (min-width: 992px) { .mining-section { padding: 50px 60px; } }

        .mining-card {
            background: rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 35px;
            padding: 30px;
            position: relative;
        }

        .prog-container {
            height: 14px; background: rgba(255,255,255,0.05);
            border-radius: 50px; overflow: hidden; margin: 25px 0;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .prog-bar {
            background: linear-gradient(90deg, var(--accent), var(--success));
            height: 100%; width: 0; transition: width 2s ease;
            position: relative; box-shadow: 0 0 20px rgba(0, 217, 255, 0.4);
        }
        .prog-bar::after {
            content: ""; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: sweep 2.5s infinite;
        }
        @keyframes sweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

        .btn-withdraw {
            background: var(--danger); color: white; border: none;
            width: 100%; padding: 18px; border-radius: 20px;
            font-weight: 900; font-size: 1rem; text-transform: uppercase;
            box-shadow: 0 10px 30px rgba(244, 63, 94, 0.3);
            transition: 0.3s;
        }
        .btn-withdraw:active { transform: scale(0.95); }

        /* --- GRILLE DES PACKS (CHIRURGICALE) --- */
        .grid-header { padding: 0 20px; margin-bottom: 25px; border-left: 5px solid var(--warning); }
        
        .pack-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr); /* 2 colonnes sur mobile */
            gap: 12px; padding: 0 15px 50px;
        }
        @media (min-width: 992px) { .pack-grid { grid-template-columns: repeat(4, 1fr); gap: 30px; padding: 0 60px 100px; } }

        .pack-card {
            background: var(--white);
            border-radius: 25px;
            overflow: hidden;
            display: flex; flex-direction: column;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            border: none;
        }
        .pack-card:hover { transform: translateY(-10px); }

        .pack-header { padding: 12px; text-align: center; color: white; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; }
        .pack-body { padding: 20px; text-align: center; color: var(--dark); flex-grow: 1; display: flex; flex-direction: column; }
        
        .pack-price { font-size: 1.3rem; font-weight: 900; margin: 10px 0; letter-spacing: -1px; }
        .pack-income { font-size: 0.8rem; font-weight: 700; color: var(--primary); margin-bottom: 15px; }

        .btn-buy {
            background: var(--primary); color: white; border: none;
            width: 100%; padding: 12px; border-radius: 15px;
            font-weight: 800; font-size: 0.75rem; text-transform: uppercase;
            margin-top: auto;
        }

        .pack-locked { opacity: 0.5; filter: grayscale(1); cursor: not-allowed; }

        /* --- NOTIFICATIONS DYNAMIQUES --- */
        #live-notif {
            position: fixed; bottom: 20px; left: 20px;
            background: var(--white); color: #000;
            padding: 12px 20px; border-radius: 20px;
            display: none; align-items: center; gap: 15px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.6); z-index: 5000;
            border-left: 5px solid var(--success);
        }

        /* --- FOOTER --- */
        .elite-footer {
            background: rgba(0,0,0,0.4); padding: 60px 20px;
            border-top: 1px solid var(--border); text-align: center;
        }
    </style>
</head>
<body>

    <div id="live-notif" class="animate__animated">
        <div class="bg-success rounded-circle p-2 text-white"><i class="bi bi-check-lg"></i></div>
        <div>
            <div class="fw-900 small" id="notif-name">System</div>
            <div class="small opacity-75">Retrait de <b id="notif-amt">0</b> FC réussi</div>
        </div>
    </div>

    <nav class="master-nav">
        <div class="d-flex align-items-center gap-3">
            <a href="/" class="btn-home-back"><i class="bi bi-house-door-fill fs-5"></i></a>
            <div class="balance-container animate__animated animate__fadeInDown">
                <div class="balance-item" style="border-right: 1px solid #eee; padding-right: 12px;">
                    <span class="balance-label">Mon Solde</span>
                    <span class="balance-val"><%= user.solde.toLocaleString() %> FC</span>
                </div>
                <div class="balance-item">
                    <span class="balance-label">Bonus Actif</span>
                    <span class="balance-val bonus">+<%= user.bonus.toLocaleString() %> FC</span>
                </div>
            </div>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="d-none d-md-block text-end" style="line-height: 1;">
                <b class="text-dark d-block" style="font-size: 0.9rem;"><%= user.username %></b>
                <small class="text-muted fw-bold" style="font-size: 0.6rem;">ELITE V3</small>
            </div>
            <a href="/logout" class="btn-exit shadow-sm"><i class="bi bi-power"></i> <span>SORTIE</span></a>
        </div>
    </nav>

    <header class="marketing-banner">
        <div class="mkt-content animate__animated animate__fadeInLeft">
            <span class="mkt-tag"><%= content.tag_tech %></span>
            <h1 class="mkt-title"><%= content.titre_principal %></h1>
            <p class="mkt-desc"><%= content.description %></p>
            <button onclick="document.getElementById('packs').scrollIntoView({behavior:'smooth'})" class="btn btn-primary rounded-pill px-5 py-3 fw-900 shadow">COMMENCER LE MINAGE</button>
        </div>
        <div class="mkt-diffusion-zone animate__animated animate__fadeIn">
            </div>
    </header>

    <div class="mining-section">
        <div class="mining-card animate__animated animate__fadeInUp">
            <div class="d-flex justify-content-between align-items-end mb-1">
                <div>
                    <h6 class="fw-900 text-uppercase mb-0"><i class="bi bi-activity text-accent me-2"></i>Status du Flux Automatique</h6>
                    <small class="opacity-50">Liaison satellite établie...</small>
                </div>
                <div class="text-accent fw-900 fs-2"><%= p || 0 %>%</div>
            </div>

            <div class="prog-container">
                <div class="prog-bar" style="width: <%= p || 0 %>%"></div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <small class="balance-label opacity-50">Performance</small>
                    <div class="fw-800 text-accent"><%= content.puissance_hash %></div>
                </div>
                <div class="col-6 col-md-3">
                    <small class="balance-label opacity-50">Réseau</small>
                    <div class="fw-800 text-success"><%= content.reseau_status %></div>
                </div>
                <div class="col-6 col-md-3">
                    <small class="balance-label opacity-50">Machine</small>
                    <div class="fw-800"><%= user.pack %></div>
                </div>
                <div class="col-6 col-md-3">
                    <small class="balance-label opacity-50">Cycle</small>
                    <div id="timer" class="fw-800 text-warning">00:00:00</div>
                </div>
            </div>

            <button onclick="withdraw()" class="btn-withdraw animate__animated animate__pulse animate__infinite">
                <i class="bi bi-wallet2 me-2"></i> Retirer mes Gains
            </button>
        </div>
    </div>

    <div class="grid-header mx-3" id="packs">
        <h4 class="fw-900 mb-0">CATALOGUE DE MINAGE 2026</h4>
        <small class="opacity-50 fw-bold">Unités haute performance certifiées</small>
    </div>

    <div class="pack-grid">
        <% 
        const packs = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' }
        ];
        packs.forEach(u => {
            const active = (user.pack === u.id);
        %>
        <div class="pack-card animate__animated animate__fadeInUp">
            <div class="pack-header" style="background: <%= u.color %>;"><%= u.id %> UNIT</div>
            <div class="pack-body">
                <span class="balance-label">Investissement</span>
                <div class="pack-price"><%= u.price.toLocaleString() %> FC</div>
                <div class="pack-income">+<%= u.daily.toLocaleString() %> FC / J</div>
                
                <div class="small fw-bold text-start mb-3 opacity-75" style="font-size: 0.6rem;">
                    <div><i class="bi bi-check-circle-fill text-success me-1"></i> Bonus: +<%= u.bonus.toLocaleString() %> FC</div>
                    <div><i class="bi bi-check-circle-fill text-success me-1"></i> Contrat: 30 Jours</div>
                </div>

                <% if(active) { %>
                    <button class="btn btn-success btn-sm w-100 rounded-pill fw-900" disabled>ACTIVE</button>
                <% } else { %>
                    <button onclick="openPay('<%= u.id %>', <%= u.price %>)" class="btn-buy shadow-sm">ACHETER</button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="grid-header mx-3">
        <h4 class="fw-900 mb-0 opacity-50">SÉRIE SPÉCIALE 2028</h4>
        <small class="opacity-25 fw-bold">Déploiement futur - RDC</small>
    </div>

    <div class="pack-grid">
        <% 
        const future = [
            { id: 'AMÉTHYSTE', price: 2500000, color: '#9333ea' },
            { id: 'ÉMERAUDE', price: 5000000, color: '#059669' },
            { id: 'RUBIS', price: 10000000, color: '#dc2626' },
            { id: 'SAPHIR', price: 25000000, color: '#2563eb' }
        ];
        future.forEach(f => {
        %>
        <div class="pack-card pack-locked">
            <div class="pack-header" style="background: <%= f.color %>;"><%= f.id %></div>
            <div class="pack-body">
                <div class="pack-price"><%= f.price.toLocaleString() %> FC</div>
                <button class="btn btn-secondary btn-sm w-100 rounded-pill" disabled>VERROUILLÉ</button>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="container-fluid mb-5">
        <div class="mining-card p-4">
            <h5 class="fw-900 text-warning mb-3">À PROPOS & RÈGLES</h5>
            <p class="small opacity-75 mb-4"><%= content.about_text %></p>
            <div class="small fw-bold opacity-50" style="white-space: pre-line;"><%= content.rules_text %></div>
        </div>
    </div>

    <footer class="elite-footer">
        <div class="container">
            <div class="fw-900 text-warning fs-4 mb-2"><%= content.brand_name %></div>
            <p class="small opacity-50 mb-4"><%= content.footer_text %></p>
            <div class="d-flex justify-content-center gap-4 fs-4 opacity-50">
                <i class="bi bi-shield-lock-fill"></i>
                <i class="bi bi-cpu-fill"></i>
                <i class="bi bi-wallet2"></i>
            </div>
            <hr class="my-4 opacity-10">
            <small class="opacity-25"><%= content.contact_address %> | <%= content.contact_phone %></small>
        </div>
    </footer>

    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content modal-elite text-dark">
                <div class="modal-body p-4 text-center">
                    <div class="bg-primary text-white p-3 rounded-circle d-inline-block mb-3"><i class="bi bi-lightning-fill fs-2"></i></div>
                    <h3 class="fw-900 mb-1">RECHARGE SÉCURISÉE</h3>
                    <p class="text-muted small fw-bold mb-4">Effectuez le transfert vers nos comptes</p>
                    
                    <div class="p-3 bg-light rounded-4 mb-2 text-start border">
                        <span class="balance-label text-primary">VODACOM (M-PESA)</span>
                        <div class="fs-5 fw-900"><%= content.admin_voda %></div>
                    </div>
                    <div class="p-3 bg-light rounded-4 mb-4 text-start border">
                        <span class="balance-label text-danger">AIRTEL MONEY</span>
                        <div class="fs-5 fw-900"><%= content.admin_airtel %></div>
                    </div>

                    <button onclick="sendTID()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 shadow">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selectedId = "", selectedPrice = 0;
        const pModal = new bootstrap.Modal(document.getElementById('payModal'));

        function openPay(id, price) { selectedId = id; selectedPrice = price; pModal.show(); }

        function sendTID() {
            pModal.hide();
            const tid = prompt("Entrez la référence TID du message reçu :");
            if(tid && tid.length > 5) {
                postData('/souscrire-pack', { packName: selectedId, prix: selectedPrice, reference: tid });
            }
        }

        function withdraw() {
            const amt = prompt("Montant à retirer (Min 1.000 FC) :");
            if(amt >= 1000) postData('/retrait', { montant: amt });
        }

        function postData(path, data) {
            const f = document.createElement('form'); f.method = 'POST'; f.action = path;
            for(let key in data) {
                const i = document.createElement('input'); i.type='hidden'; i.name=key; i.value=data[key]; f.appendChild(i);
            }
            document.body.appendChild(f); f.submit();
        }

        // TIMER GAIN
        setInterval(() => {
            const now = new Date(), target = new Date();
            target.setHours(24,0,0,0);
            const diff = target - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            document.getElementById('timer').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        // LIVE NOTIFS (PREUVE SOCIALE)
        const users = ["Anicet", "Béatrice", "Clément", "Dieudonné", "Espoir", "Fiston", "Grace", "Héritier"];
        setInterval(() => {
            const user = users[Math.floor(Math.random()*users.length)];
            const amt = (Math.floor(Math.random()*20)*5000 + 10000).toLocaleString();
            const notif = document.getElementById('live-notif');
            document.getElementById('notif-name').innerText = user + " K.";
            document.getElementById('notif-amt').innerText = amt;
            notif.style.display = "flex";
            notif.classList.add('animate__fadeInLeft');
            setTimeout(() => {
                notif.classList.replace('animate__fadeInLeft', 'animate__fadeOutLeft');
                setTimeout(() => { notif.style.display="none"; notif.classList.remove('animate__fadeOutLeft'); }, 500);
            }, 5000);
        }, 25000);
    </script>
</body>
</html>
