<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Interface Elite v25.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           MOTEUR DE STYLE "TITAN OLYMPUS" (500 LIGNES DE STYLE)
           ============================================================ */
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --emerald: #10b981; /* VERT ÉMERAUDE POUR PROGRESSION */
            --rose: #f43f5e;
            --gold: #fbbf24;
            --dark-deep: #000c26;
            --glass-white: rgba(255, 255, 255, 0.1);
            --glass-dark: rgba(0, 0, 0, 0.4);
            --transition-titan: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* CONFIGURATION SCROLLBAR PROFESSIONNELLE */
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--dark-deep); }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 10px; border: 2px solid var(--dark-deep); }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }

        body {
            background-color: var(--bleu-bic);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 55%),
                radial-gradient(at 100% 100%, var(--dark-deep) 0px, transparent 55%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff; margin: 0; padding: 0; min-height: 100vh;
            overflow-x: hidden; -webkit-font-smoothing: antialiased;
        }

        /* --- BARRE DE NAVIGATION (NAVBAR GOLD) --- */
        .premium-nav {
            background: var(--gold); padding: 12px 15px; position: sticky;
            top: 0; z-index: 4000; display: flex; justify-content: space-between;
            align-items: center; box-shadow: 0 15px 45px rgba(0,0,0,0.5);
            border-bottom: 5px solid rgba(0,0,0,0.15);
        }
        @media (min-width: 992px) { .premium-nav { padding: 15px 80px; } }

        .logo-brand { 
            font-family: 'Space Grotesk', sans-serif; font-weight: 900; 
            color: var(--bleu-bic); font-size: 1.8rem; text-decoration: none !important; 
            letter-spacing: -2px; transition: var(--transition-titan);
        }

        .nav-info-box {
            background: #ffffff; padding: 8px 18px; border-radius: 60px;
            display: flex; align-items: center; gap: 12px; color: #0f172a;
            box-shadow: inset 0 2px 12px rgba(0,0,0,0.2);
        }
        .solde-badge { border-right: 2.5px solid #f1f5f9; padding-right: 15px; }
        .label-xs { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: #94a3b8; display: block; line-height: 1; margin-bottom: 4px; }
        .val-md { font-weight: 900; font-size: 1rem; color: var(--bleu-bic); line-height: 1.1; font-family: 'Space Grotesk'; }

        .btn-logout-titan {
            background: var(--dark-deep); color: white; border: none;
            width: 45px; height: 45px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3); transition: var(--transition-titan);
        }
        .btn-logout-titan:hover { background: var(--rose); transform: rotate(90deg); }

        /* --- SECTION MARKETING (BANNIÈRE BLANCHE) --- */
        .marketing-hero-titan {
            width: 100%; background: #ffffff; border-radius: 0 0 55px 55px;
            box-shadow: 0 25px 65px rgba(0,0,0,0.4); overflow: hidden;
            margin-bottom: 35px; padding: 70px 25px; text-align: center;
            position: relative;
        }
        .marketing-hero-titan::after { content: ""; position: absolute; bottom: 0; left: 0; width: 100%; height: 10px; background: var(--gold); }
        .m-title-titan { font-family: 'Space Grotesk'; font-weight: 900; color: var(--bleu-bic); font-size: clamp(2.5rem, 12vw, 4.8rem); line-height: 0.82; margin-bottom: 25px; letter-spacing: -3px; }
        .m-para-titan { color: #475569; font-weight: 700; font-size: 1.2rem; max-width: 800px; margin: 0 auto 35px; line-height: 1.5; }
        .user-id-badge-titan { background: var(--bleu-bic); color: #fff; padding: 12px 30px; border-radius: 60px; font-weight: 900; font-size: 0.9rem; display: inline-block; margin-bottom: 20px; box-shadow: 0 12px 25px rgba(0, 51, 153, 0.25); }

        /* --- ÉLÉMENTS DE STATISTIQUES --- */
        .stats-titan-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 20px; padding: 10px 20px;
        }
        @media (min-width: 992px) { .stats-titan-grid { grid-template-columns: repeat(4, 1fr); padding: 20px 85px; gap: 35px; } }

        .stat-titan-glass {
            background: var(--glass-white); backdrop-filter: blur(18px);
            padding: 30px; border-radius: 35px; border: 1.5px solid rgba(255,255,255,0.2);
            text-align: center; transition: var(--transition-titan);
        }
        .stat-titan-glass:hover { transform: translateY(-10px); border-color: var(--gold); background: rgba(255,255,255,0.15); }
        .stat-titan-icon-box { font-size: 2.2rem; color: var(--neon-blue); margin-bottom: 15px; display: block; }
        
        .btn-titan-certif {
            background: var(--gold); color: #000; border: none; width: 100%;
            padding: 14px; border-radius: 18px; font-weight: 900; font-size: 0.75rem;
            text-transform: uppercase; margin-top: 20px; letter-spacing: 1.2px;
            box-shadow: 0 10px 25px rgba(251, 191, 36, 0.45); transition: 0.4s;
        }

        /* --- SYSTÈME DE PARRAINAGE --- */
        .referral-titan-container {
            background: var(--glass-dark); margin: 25px; padding: 45px;
            border-radius: 50px; border: 4px dashed var(--gold); text-align: center;
        }
        @media (min-width: 992px) { .referral-titan-container { margin: 45px 85px; } }
        .ref-title-titan { font-family: 'Space Grotesk'; font-weight: 900; color: var(--gold); margin-bottom: 18px; text-transform: uppercase; letter-spacing: 2px; }
        
        .copy-box-titan {
            background: #ffffff; padding: 10px; border-radius: 30px;
            display: flex; align-items: center; gap: 15px; margin-top: 25px;
            box-shadow: 0 20px 45px rgba(0,0,0,0.35);
        }
        .copy-box-titan input { background: transparent; border: none; color: #000; font-weight: 800; font-size: 0.95rem; width: 100%; padding-left: 25px; }
        .btn-copy-titan-action { background: var(--bleu-bic); color: #fff; border: none; padding: 16px 35px; border-radius: 25px; font-weight: 900; text-transform: uppercase; font-size: 0.85rem; }

        /* --- TERMINAL DE MINAGE (LIGNE VERTE ÉMERAUDE) --- */
        .mining-titan-terminal {
            background: var(--glass-dark); margin: 25px; padding: 40px;
            border-radius: 50px; border: 1.5px solid rgba(255,255,255,0.15);
        }
        @media (min-width: 992px) { .mining-titan-terminal { margin: 45px 85px; padding: 60px; } }

        .progress-titan-track {
            height: 40px; background: rgba(0,0,0,0.6); border-radius: 70px;
            overflow: hidden; margin: 30px 0; border: 2.5px solid rgba(255,255,255,0.15); padding: 6px;
        }
        .bar-titan-emerald-fill {
            background: linear-gradient(90deg, #10b981, #059669, #34d399);
            box-shadow: 0 0 35px rgba(16, 185, 129, 0.7); border-radius: 70px;
            height: 100%; position: relative; width: <%= p || 0 %>%;
            transition: width 2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .withdraw-titan-btn {
            background: var(--rose); color: white; border: none; width: 100%;
            padding: 25px; border-radius: 35px; font-weight: 900; font-size: 1.5rem;
            text-transform: uppercase; box-shadow: 0 20px 50px rgba(244, 63, 94, 0.5);
            transition: var(--transition-titan); margin-top: 20px;
        }

        /* --- SHOP GRID (8 PACKS ALIGNÉS 480PX) --- */
        .shop-titan-title-box { padding: 0 35px; margin: 70px 0 35px; display: flex; align-items: center; gap: 25px; }
        @media (min-width: 992px) { .shop-titan-title-box { padding: 0 85px; } }
        .shop-titan-title-box h2 { font-family: 'Space Grotesk'; font-weight: 900; font-size: 2.6rem; text-transform: uppercase; }

        .industrial-titan-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 20px; padding: 0 20px 130px;
        }
        @media (min-width: 1200px) { .industrial-titan-grid { grid-template-columns: repeat(4, 1fr); padding: 0 85px 200px; gap: 45px; } }

        .pack-titan-card-box {
            background: #ffffff; border-radius: 55px; overflow: hidden;
            color: #0f172a; height: 480px; /* ALIGNEMENT FIXE CHIRURGICAL */
            display: flex; flex-direction: column; box-shadow: 0 35px 70px rgba(0,0,0,0.55);
            transition: var(--transition-titan); position: relative; border: none;
        }
        .pack-titan-card-box:hover { transform: translateY(-25px); }
        .active-pack-glow { border: 10px solid var(--emerald) !important; transform: scale(1.06); }

        /* VERROUILLAGE VISUEL 2028 */
        .titan-locked-mode { filter: grayscale(1) brightness(0.7); }
        .titan-lock-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.45); z-index: 50; display: flex; align-items: center; justify-content: center; pointer-events: none; }
        .titan-lock-tag { background: var(--gold); color: #000; padding: 12px 30px; border-radius: 60px; font-weight: 900; font-size: 1rem; box-shadow: 0 15px 30px rgba(0,0,0,0.6); }

        .p-head-titan { padding: 30px; text-align: center; color: #fff; font-weight: 900; text-transform: uppercase; font-size: 1.1rem; letter-spacing: 2.5px; }
        .p-body-titan { padding: 40px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-price-titan { font-size: 2rem; font-weight: 900; color: var(--bleu-bic); margin: 15px 0 10px; font-family: 'Space Grotesk'; word-break: break-all; letter-spacing: -2px; }
        @media (min-width: 768px) { .p-price-titan { font-size: 2.8rem; } }
        
        .p-bonus-titan { font-size: 0.8rem; font-weight: 900; color: var(--rose); background: #fff0f0; border: 2.5px dashed var(--rose); padding: 12px; border-radius: 20px; margin-bottom: 8px; }
        .p-daily-titan { font-weight: 900; color: var(--emerald); font-size: 1.2rem; }

        /* LOGIQUE BOUTONS DYNAMIQUES */
        .btn-buy-titan-mode { background: var(--bleu-bic); color: #fff; }
        .btn-activate-titan-mode { background: var(--emerald); color: #fff; box-shadow: 0 15px 30px rgba(16, 185, 129, 0.45); }

        .btn-titan-action-final {
            width: 100%; padding: 22px; border-radius: 32px; border: none;
            font-weight: 900; text-transform: uppercase; font-size: 1rem;
            transition: 0.4s; box-shadow: 0 15px 35px rgba(0,0,0,0.25);
        }

        /* --- SYSTÈME DE TOASTS & ACCORDÉONS --- */
        #titan-toast-box { position: fixed; bottom: 35px; left: 35px; z-index: 9999; background: #ffffff; color: #000; padding: 25px 35px; border-radius: 30px; box-shadow: 0 25px 60px rgba(0,0,0,0.75); display: none; align-items: center; gap: 25px; border-left: 12px solid var(--emerald); }
        #scrollTopTitan { position: fixed; bottom: 35px; right: 35px; width: 75px; height: 75px; background: var(--gold); color: var(--bleu-bic); border-radius: 50%; border: none; display: none; align-items: center; justify-content: center; font-size: 2.5rem; z-index: 8500; box-shadow: 0 25px 50px rgba(0,0,0,0.65); }

        .titan-faq-section { margin: 30px 25px 120px; }
        @media (min-width: 992px) { .titan-faq-section { margin: 70px 85px 180px; } }
        .accordion-item-titan { background: var(--glass-dark) !important; border: 1.5px solid rgba(255,255,255,0.15) !important; color: #fff !important; margin-bottom: 20px; border-radius: 35px !important; overflow: hidden; }
        .accordion-button-titan { background: transparent !important; color: #fff !important; font-weight: 900; padding: 35px; font-size: 1.2rem; box-shadow: none !important; }
        .accordion-button-titan:not(.collapsed) { color: var(--gold) !important; border-bottom: 1.5px solid rgba(255,255,255,0.15); }
        .accordion-body-titan { padding: 40px; opacity: 0.85; font-size: 1.1rem; line-height: 2; }
    </style>
</head>
<body>

    <div id="titan-toast-box" class="animate__animated animate__slideInLeft">
        <i class="bi bi-shield-fill-check text-success fs-1"></i>
        <div>
            <div class="small opacity-50 fw-900 text-uppercase">Réseau CashLink Live</div>
            <div id="toast-msg-final" class="fw-800 text-dark">Initialisation du terminal...</div>
        </div>
    </div>

    <button id="scrollTopTitan" onclick="window.scrollTo({top:0, behavior:'smooth'})"><i class="bi bi-arrow-up-circle-fill"></i></button>

    <nav class="premium-nav">
        <a href="/" class="logo-brand animate__animated animate__fadeInLeft">CASHLINK</a>
        <div class="nav-info-box animate__animated animate__zoomIn">
            <div class="solde-badge">
                <span class="label-xs">SOLDE PRINCIPAL</span>
                <div class="val-md"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span class="label-xs text-success">SOLDE BONUS</span>
                <div class="val-md text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>
        <a href="/logout" class="btn-logout-titan shadow-lg"><i class="bi bi-power fs-3"></i></a>
    </nav>

    <header class="marketing-hero-titan">
        <div class="animate__animated animate__fadeIn">
            <div class="user-id-badge-titan animate__animated animate__fadeInDown">
                TERMINAL ID : <%= user.username %> | ACCÈS : +243 <%= user.phone %>
            </div>
            <h1 class="m-title-titan">MINAGE <span class="text-primary">INDUSTRIEL</span></h1>
            <p class="m-para-titan">Exploitez la puissance du Cloud Mining décentralisé pour générer vos revenus passifs 24h/7j. Technologie CASHLINK v25.0 optimisée pour la République Démocratique du Congo.</p>
            <button onclick="document.getElementById('catalog').scrollIntoView({behavior:'smooth'})" class="btn btn-primary rounded-pill px-5 py-4 fw-900 shadow-lg fs-5">LANCER MON UNITÉ MAINTENANT</button>
        </div>
    </header>

    <div class="stats-titan-grid">
        <div class="stat-titan-glass">
            <i class="bi bi-cpu-fill stat-titan-icon-box"></i>
            <span class="label-xs">Puissance Hash</span>
            <div class="val-md text-white"><%= (user.pack && user.pack !== 'Aucun') ? '104.2 TH/s' : '0.00 TH/s' %></div>
        </div>
        <div class="stat-titan-glass">
            <i class="bi bi-patch-check-fill stat-titan-icon-box text-warning"></i>
            <span class="label-xs">Statut Certification</span>
            <div class="val-md text-white"><%= user.certified ? 'CERTIFIÉ ÉLITE' : 'COMPTE BASIQUE' %></div>
            <% if(!user.certified) { %>
                <button onclick="openPaymentModal('CERTIFICATION', 25000)" class="btn-titan-certif">S'ACTIVER (25.000 FC)</button>
            <% } %>
        </div>
        <div class="stat-titan-glass">
            <i class="bi bi-currency-exchange stat-titan-icon-box text-success"></i>
            <span class="label-xs">Canal Retrait</span>
            <div class="val-md text-white">OPÉRATIONNEL</div>
        </div>
        <div class="stat-titan-glass">
            <i class="bi bi-people-fill stat-titan-icon-box text-info"></i>
            <span class="label-xs">Membres Réseau</span>
            <div class="val-md text-white">ACTIF (v25)</div>
        </div>
    </div>

    <div class="referral-titan-container animate__animated animate__fadeInUp">
        <h3 class="ref-title-titan">Programme Parrainage Elite</h3>
        <p class="small opacity-80 fw-bold">Partagez votre lien et gagnez instantanément 10% cash sur chaque investissement de vos amis directement sur votre solde bonus.</p>
        <div class="copy-box-titan">
            <input type="text" id="refLinkFinal" value="https://cashlink-rdc.cd/register?ref=<%= user.id %>" readonly>
            <button class="btn-copy-titan-action" onclick="copyFinalLink()">COPIER LE LIEN</button>
        </div>
    </div>

    <section class="mining-titan-terminal animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-end mb-2">
            <div>
                <h4 class="fw-900 mb-0 small text-uppercase">Statut Temps Réel du Moteur</h4>
                <p class="label-xs text-muted mb-0">Unité Active : <%= user.pack %> Engine</p>
            </div>
            <div class="text-success fw-900 fs-1"><%= p || 0 %>%</div>
        </div>
        <div class="progress-titan-track">
            <div class="bar-titan-emerald-fill animate__animated animate__pulse animate__infinite"></div>
        </div>
        <div class="d-flex flex-wrap justify-content-between mt-4 align-items-center gap-3">
            <div class="small fw-bold text-warning" style="font-size: 0.8rem;"><i class="bi bi-clock-history me-2"></i>RECHARGEMENT DES PROFITS DANS : <span id="titan-timer-final">--:--:--</span></div>
            <button onclick="handleWithdrawTitan()" class="withdraw-titan-btn animate__animated animate__pulse animate__infinite">RÉCUPÉRER MES PROFITS (MONEY)</button>
        </div>
    </section>

    <div class="shop-titan-title-box" id="catalog">
        <div style="width: 12px; height: 50px; background: var(--gold); border-radius: 15px;"></div>
        <h2>Unités de Minage 2026-2028</h2>
    </div>

    <div class="industrial-titan-grid">
        <% 
        const packsCatalog = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981', locked: false },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5', locked: false },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b', locked: false },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444', locked: false },
            { id: 'AMÉTHYSTE', price: 2500000, daily: 300000, bonus: 250000, color: '#9333ea', locked: true },
            { id: 'ÉMERAUDE', price: 5000000, daily: 700000, bonus: 600000, color: '#059669', locked: true },
            { id: 'RUBIS', price: 10000000, daily: 1500000, bonus: 1200000, color: '#dc2626', locked: true },
            { id: 'SAPHIR', price: 25000000, daily: 4000000, bonus: 3500000, color: '#2563eb', locked: true }
        ];

        packsCatalog.forEach(item => {
            const isOwned = (user.pack === item.id);
        %>
        <div class="pack-titan-card-box animate__animated animate__fadeInUp <%= item.locked ? 'titan-locked-mode' : '' %> <%= isOwned ? 'active-pack-glow' : '' %>">
            <% if(item.locked) { %><div class="titan-lock-overlay"><div class="titan-lock-tag">PRÉVU 2028</div></div><% } %>
            <div class="p-head-titan" style="background: <%= item.color %>;"><%= item.id %> ENGINE</div>
            <div class="p-body-titan">
                <div>
                    <div class="p-price-titan"><%= item.price.toLocaleString() %> FC</div>
                    <div class="p-bonus-titan">CADEAU D'ACTIVATION : +<%= item.bonus.toLocaleString() %> FC</div>
                    <div class="p-daily-titan">+<%= item.daily.toLocaleString() %> FC / JOUR</div>
                </div>
                
                <% if(isOwned) { %>
                    <button onclick="submitTitanData('/activer-gain', { pack: '<%= item.id %>' })" class="btn-titan-action-final btn-activate-titan-mode">
                        ACTIVER MAINTENANT
                    </button>
                <% } else { %>
                    <button onclick="openPaymentModal('<%= item.id %>', <%= item.price %>)" class="btn-titan-action-final btn-buy-titan-mode">
                        ACHETER VOTRE PACK
                    </button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="titan-faq-section" id="accTitan">
        <div class="accordion-item-titan shadow-sm">
            <h2 class="accordion-header"><button class="accordion-button-titan collapsed" data-bs-toggle="collapse" data-bs-target="#qa1"><i class="bi bi-info-circle-fill me-3 text-info"></i> QUI SOMMES-NOUS ?</button></h2>
            <div id="qa1" class="accordion-collapse collapse" data-bs-parent="#accTitan"><div class="accordion-body-titan"><%= content.about_text %></div></div>
        </div>
        <div class="accordion-item-titan shadow-sm">
            <h2 class="accordion-header"><button class="accordion-button-titan collapsed" data-bs-toggle="collapse" data-bs-target="#qa2"><i class="bi bi-shield-lock-fill me-3 text-success"></i> RÈGLES DE SÉCURITÉ ET RETRAITS</button></h2>
            <div id="qa2" class="accordion-collapse collapse" data-bs-parent="#accTitan"><div class="accordion-body-titan" style="white-space: pre-line;"><%= content.rules_text %></div></div>
        </div>
        <div class="accordion-item-titan shadow-sm">
            <h2 class="accordion-header"><button class="accordion-button-titan collapsed" data-bs-toggle="collapse" data-bs-target="#qa3"><i class="bi bi-geo-alt-fill me-3 text-danger"></i> SIÈGE SOCIAL ET SUPPORT WHATSAPP</button></h2>
            <div id="qa3" class="accordion-collapse collapse" data-bs-parent="#accTitan">
                <div class="accordion-body-titan">
                    <strong>ADRESSE :</strong> <%= content.contact_address %><br>
                    <strong>SUPPORT WHATSAPP :</strong> +243 <%= content.contact_phone %><br>
                    <strong>SUPPORT EMAIL :</strong> <%= content.contact_email %>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center py-5 opacity-20">
        <h1 class="fw-900" style="font-family: 'Space Grotesk'; letter-spacing: -4px; font-size: 4rem;">CASHLINK</h1>
        <p class="small fw-bold text-uppercase">Terminal de Minage Décentralisé v25.0 | RDC 2026</p>
    </footer>

    <div class="modal fade" id="payTitanModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content modal-industrial text-dark shadow-lg">
                <div class="modal-body p-5 text-center">
                    <h3 class="fw-900 mb-4">RECHARGE DU TERMINAL</h3>
                    <div class="payment-titan-card text-start">
                        <small class="text-primary fw-bold">VODACOM (M-PESA)</small>
                        <div class="fw-900 fs-4"><%= content.admin_voda %></div>
                    </div>
                    <div class="payment-titan-card text-start">
                        <small class="text-danger fw-bold">AIRTEL MONEY</small>
                        <div class="fw-900 fs-4 text-danger"><%= content.admin_airtel %></div>
                    </div>
                    <div class="payment-titan-card text-start">
                        <small class="text-warning fw-bold">ORANGE MONEY</small>
                        <div class="fw-900 fs-4 text-warning"><%= content.admin_orange %></div>
                    </div>
                    <div class="alert alert-danger rounded-4 fw-bold small my-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Veuillez saisir la référence (TID SMS) après avoir envoyé les fonds.
                    </div>
                    <button onclick="commitFinalTID()" class="btn btn-primary w-100 py-4 rounded-pill fw-900 shadow-lg fs-5">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selectedPack = ""; let selectedPrice = 0;
        const titanPayModal = new bootstrap.Modal(document.getElementById('payTitanModal'));
        
        // SCROLL TOP
        window.onscroll = function() {
            const btn = document.getElementById('scrollTopTitan');
            btn.style.display = (document.body.scrollTop > 400 || document.documentElement.scrollTop > 400) ? "flex" : "none";
        };

        // COPY LINK
        function copyFinalLink() {
            const i = document.getElementById('refLinkFinal'); i.select();
            document.execCommand('copy'); triggerToastTitan("Lien de parrainage copié avec succès !");
        }

        // ACTIONS BOUTIQUE
        function openPaymentModal(id, price) { selectedPack = id; selectedPrice = price; titanPayModal.show(); }

        function commitFinalTID() {
            titanPayModal.hide();
            const tid = prompt("Veuillez saisir le TID de la transaction SMS :");
            if(tid && tid.length > 5) {
                submitTitanData('/souscrire-pack', { packName: selectedPack, prix: selectedPrice, reference: tid });
            } else {
                alert("Référence invalide.");
            }
        }

        function handleWithdrawTitan() {
            const m = prompt("Montant du retrait (Minimum 1.000 FC) :");
            if(m >= 1000) submitTitanData('/retrait', { montant: m });
            else alert("Le montant minimum est de 1.000 FC.");
        }

        function submitTitanData(path, data) {
            const f = document.createElement('form'); f.method = 'POST'; f.action = path;
            for (const k in data) { const i = document.createElement('input'); i.type = 'hidden'; i.name = k; i.value = data[k]; f.appendChild(i); }
            document.body.appendChild(f); f.submit();
        }

        // TIMER 24H
        setInterval(() => {
            const now = new Date(); const next = new Date(); next.setHours(24, 0, 0, 0); const diff = next - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            document.getElementById('titan-timer-final').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        // TOASTS & SIMULATION
        function triggerToastTitan(m) {
            const t = document.getElementById('titan-toast-box');
            document.getElementById('toast-msg-final').innerText = m;
            t.style.display = "flex"; setTimeout(() => t.style.display = "none", 5000);
        }

        const names = ["Patrick", "Mado", "Sarah", "Guelord", "Elvis", "Bijou", "Junior"];
        const acts = ["vient de retirer 25.000 FC", "a activé le pack GOLD", "vient de parrainer un ami", "a reçu son bonus de minage"];
        setInterval(() => {
            if(Math.random() > 0.5) triggerToastTitan(`${names[Math.floor(Math.random()*names.length)]} ${acts[Math.floor(Math.random()*acts.length)]}`);
        }, 20000);
    </script>
</body>
</html>
