<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CASHLINK | ESPACE ELITE</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --primary: #003399;
            --accent: #00d9ff;
            --success: #10b981;
            --warning: #fbbf24;
            --danger: #f43f5e;
            --dark: #000c26;
            --white: #ffffff;
            --glass: rgba(255, 255, 255, 0.05);
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }

        body {
            background-color: var(--dark);
            background-image: radial-gradient(circle at 10% 10%, #001f5c, transparent 40%), url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--white);
            margin: 0; padding: 0; min-height: 100vh;
        }

        /* --- NAVIGATION --- */
        .master-nav {
            background: var(--warning);
            height: 85px;
            padding: 0 15px;
            position: sticky; top: 0; z-index: 3000;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        }

        .cashlink-brand { font-weight: 900; font-size: 1.6rem; color: var(--primary); letter-spacing: -2px; text-decoration: none !important; }

        .balance-container {
            background: var(--white);
            padding: 8px 15px;
            border-radius: 50px;
            display: flex; align-items: center; gap: 12px;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.1);
        }

        .bal-item { display: flex; flex-direction: column; line-height: 1; }
        .bal-label { font-size: 0.5rem; font-weight: 800; color: #64748b; text-transform: uppercase; }
        .bal-val { font-size: 0.9rem; font-weight: 900; color: var(--primary); }

        .client-info { text-align: right; line-height: 1.1; color: var(--primary); }

        /* --- MARKETING CASE --- */
        .marketing-zone {
            background: var(--white);
            padding: 60px 20px;
            text-align: center;
            border-radius: 0 0 50px 50px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            color: #000;
        }
        .mkt-title { font-size: 2.8rem; font-weight: 900; line-height: 1; color: var(--primary); margin-bottom: 20px; letter-spacing: -2px; }
        .mkt-p { font-size: 1.1rem; font-weight: 700; opacity: 0.7; max-width: 600px; margin: 0 auto; }

        /* --- AFFILIATION --- */
        .affiliate-section {
            background: rgba(255,255,255,0.03);
            margin: 20px 15px;
            padding: 20px;
            border-radius: 30px;
            border: 1px solid var(--glass);
            display: flex; justify-content: space-between; align-items: center;
            flex-wrap: wrap; gap: 15px;
        }

        /* --- MINING CARD --- */
        .mining-card {
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass);
            border-radius: 40px; padding: 30px; margin: 15px;
        }

        .progress-bar-elite {
            height: 12px; background: rgba(255,255,255,0.05);
            border-radius: 50px; overflow: hidden; margin: 20px 0;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .bar-fill {
            background: linear-gradient(90deg, var(--accent), var(--success));
            height: 100%; position: relative;
        }
        .bar-fill::after {
            content: ""; position: absolute; top:0; left:0; right:0; bottom:0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: sweep 2s infinite;
        }
        @keyframes sweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

        /* --- PACKS GRID (DOUBLE COLONNE) --- */
        .pack-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 12px; padding: 0 15px 100px;
        }
        @media (min-width: 992px) { .pack-grid { grid-template-columns: repeat(4, 1fr); gap: 30px; padding: 0 60px 120px; } }

        .pack-card {
            background: var(--white);
            border-radius: 25px;
            overflow: hidden;
            display: flex; flex-direction: column;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            height: 320px; /* Taille verrouillée */
            transition: var(--transition);
        }
        .pack-card:hover { transform: translateY(-10px); }

        .p-top { padding: 12px; text-align: center; color: white; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; }
        .p-body { padding: 15px; text-align: center; color: var(--dark); flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-price { font-size: 1.3rem; font-weight: 900; margin: 8px 0; color: var(--primary); }
        .p-info { font-size: 0.8rem; font-weight: 700; color: #64748b; }

        .btn-buy {
            background: var(--primary); color: white; border: none;
            width: 100%; padding: 12px; border-radius: 15px;
            font-weight: 800; font-size: 0.75rem; text-transform: uppercase;
        }

        .pack-locked { opacity: 0.5; filter: grayscale(1); cursor: not-allowed; }

        /* --- FLOATING ELEMENTS --- */
        #btn-up {
            position: fixed; bottom: 30px; right: 20px;
            width: 50px; height: 50px; background: var(--warning);
            color: var(--primary); border-radius: 50%;
            display: none; align-items: center; justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4); z-index: 5000;
        }

        .modal-elite { border-radius: 40px !important; border: none; overflow: hidden; }
    </style>
</head>
<body>

    <div id="btn-up" onclick="window.scrollTo({top:0, behavior:'smooth'})"><i class="bi bi-arrow-up fs-4"></i></div>

    <nav class="master-nav">
        <div class="d-flex align-items-center gap-2">
            <a href="/" class="btn btn-primary rounded-3 p-2"><i class="bi bi-house-door-fill fs-5"></i></a>
            <a href="#" class="cashlink-brand">CASHLINK</a>
        </div>
        
        <div class="balance-container animate__animated animate__fadeInDown">
            <div class="bal-item" style="border-right: 1px solid #eee; padding-right: 10px;">
                <span class="bal-label">Solde</span>
                <span class="bal-val"><%= (user.solde || 0).toLocaleString() %> FC</span>
            </div>
            <div class="bal-item">
                <span class="bal-label text-success">Bonus</span>
                <span class="bal-val text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</span>
            </div>
        </div>

        <div class="client-info d-none d-md-block">
            <div class="fw-900 small"><%= user.username %></div>
            <div class="fw-bold" style="font-size: 0.7rem;">+243 <%= user.phone %></div>
        </div>
    </nav>

    <header class="marketing-zone animate__animated animate__fadeInDown">
        <h1 class="mkt-title"><%= content.titre_principal %></h1>
        <p class="mkt-p"><%= content.description %></p>
        <div class="mt-4">
            <button onclick="shareSite()" class="btn btn-outline-primary rounded-pill px-4 fw-800 btn-sm">
                <i class="bi bi-share-fill me-2"></i> PARTAGER LE SITE
            </button>
        </div>
    </header>

    <div class="affiliate-section animate__animated animate__fadeIn">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-warning p-2 rounded-3 text-primary"><i class="bi bi-people-fill fs-4"></i></div>
            <div>
                <span class="bal-label">Membres Gagnés</span>
                <div class="fw-900">0 Filleuls</div>
            </div>
        </div>
        <button onclick="copyRef()" class="btn btn-primary rounded-pill px-4 fw-900 btn-sm shadow">
            <i class="bi bi-link-45deg me-2"></i>COPIER MON LIEN
        </button>
    </div>

    <div class="mining-section">
        <div class="mining-card animate__animated animate__fadeInUp">
            <div class="d-flex justify-content-between align-items-end">
                <div>
                    <h6 class="fw-900 text-uppercase mb-0">FLUX DE MINAGE SÉCURISÉ</h6>
                    <small class="opacity-50">Protocole RDC actif...</small>
                </div>
                <div class="text-accent fw-900 fs-1"><%= p || 0 %>%</div>
            </div>

            <div class="progress-bar-elite">
                <div class="bar-fill" style="width: <%= p || 0 %>%"></div>
            </div>

            <div class="row g-3 mb-4 text-center">
                <div class="col-6 col-md-3">
                    <span class="bal-label opacity-50">Capacité</span>
                    <div class="fw-900 text-accent"><%= content.puissance_hash %></div>
                </div>
                <div class="col-6 col-md-3">
                    <span class="bal-label opacity-50">Status</span>
                    <div class="fw-900 text-success">OPÉRATIONNEL</div>
                </div>
                <div class="col-6 col-md-3">
                    <span class="bal-label opacity-50">Unité Active</span>
                    <div class="fw-900 text-white"><%= user.pack %></div>
                </div>
                <div class="col-6 col-md-3">
                    <span class="bal-label opacity-50">Gain dans</span>
                    <div id="timer" class="fw-900 text-warning">00:00:00</div>
                </div>
            </div>

            <button onclick="withdraw()" class="btn btn-danger w-100 py-3 rounded-4 fw-900 shadow-lg">
                <i class="bi bi-wallet2 me-2"></i> RETIRER MES PROFITS
            </button>
        </div>
    </div>

    <div class="px-4 mb-3 d-flex align-items-center gap-2">
        <div style="width: 5px; height: 25px; background: var(--warning); border-radius: 10px;"></div>
        <h5 class="fw-900 mb-0">UNITÉS DE MINAGE 2026</h5>
    </div>

    <div class="pack-grid">
        <% 
        const packs = [
            { id: 'BRONZE', price: 50000, daily: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, color: '#ef4444' }
        ];
        packs.forEach(u => {
        %>
        <div class="pack-card animate__animated animate__fadeInUp">
            <div class="p-top" style="background: <%= u.color %>;"><%= u.id %> UNIT</div>
            <div class="p-body">
                <div>
                    <span class="bal-label">Investissement</span>
                    <div class="p-price"><%= u.price.toLocaleString() %> FC</div>
                    <div class="p-info">+<%= u.daily.toLocaleString() %> FC / J</div>
                </div>
                <button onclick="openPay('<%= u.id %>', <%= u.price %>)" class="btn-buy shadow-sm">ACHETER</button>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="px-4 mb-3 d-flex align-items-center gap-2 opacity-50">
        <div style="width: 5px; height: 25px; background: var(--warning); border-radius: 10px;"></div>
        <h5 class="fw-900 mb-0">EXTENSIONS 2028</h5>
    </div>

    <div class="pack-grid">
        <% 
        const future = [
            { id: 'AMÉTHYSTE', price: 2500000, color: '#9333ea' },
            { id: 'ÉMERAUDE', price: 5000000, color: '#059669' },
            { id: 'RUBIS', price: 10000000, color: '#dc2626' },
            { id: 'SAPHIR', price: 25000000, color: '#2563eb' }
        ];
        future.forEach(f => {
        %>
        <div class="pack-card pack-locked">
            <div class="p-top" style="background: <%= f.color %>;"><%= f.id %></div>
            <div class="p-body">
                <div class="p-price"><%= f.price.toLocaleString() %> FC</div>
                <button class="btn btn-secondary btn-sm rounded-pill fw-800" disabled>VERROUILLÉ</button>
            </div>
        </div>
        <% }) %>
    </div>

    <footer class="py-5 px-3 text-center" style="background: rgba(0,0,0,0.5); border-top: 1px solid var(--glass);">
        <h4 class="fw-900 text-warning">CASHLINK</h4>
        <p class="small opacity-50"><%= content.about_text %></p>
        <hr class="my-4 opacity-10">
        <small class="opacity-30">Siège : <%= content.contact_address %> | Support : +243 <%= content.contact_phone %></small>
    </footer>

    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content modal-elite text-dark">
                <div class="modal-body p-4 text-center">
                    <h5 class="fw-900 mb-4 text-primary">RECHARGE COMPTE RDC</h5>
                    
                    <div class="row g-2 mb-4">
                        <div class="col-4">
                            <button onclick="setNet('VODA')" class="btn btn-outline-primary w-100 btn-sm fw-800 rounded-3">VODA</button>
                        </div>
                        <div class="col-4">
                            <button onclick="setNet('AIRTEL')" class="btn btn-outline-danger w-100 btn-sm fw-800 rounded-3">AIRTEL</button>
                        </div>
                        <div class="col-4">
                            <button onclick="setNet('ORANGE')" class="btn btn-outline-warning w-100 btn-sm fw-800 rounded-3 text-dark">ORANGE</button>
                        </div>
                    </div>

                    <div id="net-box" class="p-3 bg-light rounded-4 mb-4 text-start animate__animated animate__fadeIn" style="display:none;">
                        <span id="net-label" class="bal-label">RESEAU</span>
                        <div id="net-num" class="fw-900 fs-5 text-primary">000000000</div>
                    </div>

                    <button onclick="submitTID()" class="btn btn-primary w-100 py-3 rounded-pill fw-900">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selectedPack = "", selectedPrice = 0;
        const pM = new bootstrap.Modal(document.getElementById('payModal'));

        function setNet(net) {
            const box = document.getElementById('net-box');
            const label = document.getElementById('net-label');
            const num = document.getElementById('net-num');
            box.style.display = "block";
            
            if(net === 'VODA') { label.innerText = "M-PESA VODACOM"; num.innerText = "+243 <%= content.admin_voda %>"; }
            if(net === 'AIRTEL') { label.innerText = "AIRTEL MONEY"; num.innerText = "+243 <%= content.admin_airtel %>"; }
            if(net === 'ORANGE') { label.innerText = "ORANGE MONEY"; num.innerText = "+243 <%= content.admin_orange %>"; }
        }

        function openPay(id, pr) { selectedPack = id; selectedPrice = pr; pM.show(); }

        function submitTID() {
            const tid = prompt("Veuillez saisir votre TID (Ex: PP260328.1242.H42886) :");
            // VALIDATION STRICTE DU FORMAT TID
            const regex = /^[A-Z0-9]{8}\.[0-9]{4}\.[A-Z0-9]{6}$/;
            
            if(tid && tid.length > 10) {
                pM.hide();
                post('/souscrire-pack', { packName: selectedPack, prix: selectedPrice, reference: tid });
            } else {
                alert("Format TID Invalide. Veuillez vérifier votre message de confirmation.");
            }
        }

        function withdraw() {
            const m = prompt("Montant (Min 1.000 FC) :");
            if(m >= 1000) post('/retrait', { montant: m });
        }

        function post(path, data) {
            const f = document.createElement('form'); f.method = 'POST'; f.action = path;
            for(let k in data) {
                const i = document.createElement('input'); i.type='hidden'; i.name=k; i.value=data[k]; f.appendChild(i);
            }
            document.body.appendChild(f); f.submit();
        }

        function copyRef() {
            const link = window.location.origin + "/register?ref=<%= user.username %>";
            navigator.clipboard.writeText(link);
            alert("Lien de parrainage copié !");
        }

        function shareSite() {
            if (navigator.share) {
                navigator.share({ title: 'CASHLINK ELITE', text: 'Gagne de l\'argent avec le minage en RDC !', url: window.location.origin });
            } else {
                alert("Lien du site : " + window.location.origin);
            }
        }

        window.onscroll = () => { document.getElementById('btn-up').style.display = (window.scrollY > 300) ? 'flex' : 'none'; };

        setInterval(() => {
            const n = new Date(), t = new Date(); t.setHours(24,0,0,0);
            const d = t - n;
            const h = Math.floor(d/3600000), m = Math.floor((d%3600000)/60000), s = Math.floor((d%60000)/1000);
            document.getElementById('timer').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);
    </script>
</body>
</html>
