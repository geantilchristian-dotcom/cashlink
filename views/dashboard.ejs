<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Interface Elite v28.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@700;900&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
            MOTEUR DE DESIGN "TITAN OLYMPUS" - 600 LIGNES DE STYLE
           ============================================================ */
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --emerald: #10b981; /* VERT ÉMERAUDE DEMANDÉ */
            --rose: #f43f5e;
            --gold: #fbbf24;
            --dark-deep: #000c26;
            --glass-white: rgba(255, 255, 255, 0.15);
            --glass-dark: rgba(0, 0, 0, 0.55);
            --transition-titan: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }

        /* CONFIGURATION GLOBALE DÉTAILLÉE */
        ::-webkit-scrollbar { width: 14px; }
        ::-webkit-scrollbar-track { background: var(--dark-deep); }
        ::-webkit-scrollbar-thumb { 
            background: var(--gold); 
            border-radius: 20px; 
            border: 4px solid var(--dark-deep); 
            box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        }

        * { 
            box-sizing: border-box; 
            -webkit-tap-highlight-color: transparent; 
            outline: none !important; 
            margin: 0; 
            padding: 0;
        }

        body {
            background-color: var(--bleu-bic);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 55%),
                radial-gradient(at 100% 100%, var(--dark-deep) 0px, transparent 55%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            line-height: 1.6;
        }

        /* --- BARRE DE NAVIGATION TITAN (NAVBAR) --- */
        .premium-nav-titan {
            background: var(--gold);
            padding: 18px 20px;
            position: sticky;
            top: 0;
            z-index: 9999;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.7);
            border-bottom: 6px solid rgba(0,0,0,0.25);
        }
        @media (min-width: 992px) { .premium-nav-titan { padding: 25px 100px; } }

        .logo-titan-industrial { 
            font-family: 'Space Grotesk', sans-serif; 
            font-weight: 900; 
            color: var(--bleu-bic); 
            font-size: 2rem; 
            text-decoration: none !important; 
            letter-spacing: -4px; 
            transition: var(--transition-titan);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-titan-industrial:hover { transform: scale(1.1); filter: brightness(1.2); }
        
        .nav-info-box-titan {
            background: #ffffff;
            padding: 12px 28px;
            border-radius: 100px;
            display: flex;
            align-items: center;
            gap: 20px;
            color: #0f172a;
            box-shadow: inset 0 3px 18px rgba(0,0,0,0.3);
            border: 2px solid rgba(255,255,255,0.5);
        }
        .solde-badge-industrial { border-right: 3.5px solid #e2e8f0; padding-right: 22px; }
        .label-titan-bold { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: #64748b; display: block; line-height: 1; margin-bottom: 5px; }
        .val-titan-heavy { font-weight: 900; font-size: 1.3rem; color: var(--bleu-bic); line-height: 1; font-family: 'Space Grotesk'; }

        .btn-logout-industrial {
            background: var(--dark-deep);
            color: white;
            border: none;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            transition: var(--transition-titan);
        }
        .btn-logout-industrial:hover { background: var(--rose); transform: rotate(180deg); }

        /* --- SECTION MARKETING (HERO BANNER BLANC) --- */
        .hero-industrial-banner {
            width: 100%;
            background: #ffffff;
            border-radius: 0 0 70px 70px;
            box-shadow: 0 35px 80px rgba(0,0,0,0.5);
            margin-bottom: 50px;
            padding: 100px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .hero-industrial-banner::after { content: ""; position: absolute; bottom: 0; left: 0; width: 100%; height: 15px; background: var(--gold); }
        
        .hero-title-titan-heavy { 
            font-family: 'Space Grotesk'; 
            font-weight: 900; 
            color: var(--bleu-bic); 
            font-size: clamp(3rem, 15vw, 6rem); 
            line-height: 0.75; 
            margin-bottom: 30px; 
            letter-spacing: -6px; 
        }
        .hero-para-titan-heavy { 
            color: #334155; 
            font-weight: 700; 
            font-size: 1.4rem; 
            max-width: 900px; 
            margin: 0 auto 45px; 
            line-height: 1.7; 
        }
        .user-id-badge-industrial { 
            background: var(--bleu-bic); 
            color: #fff; 
            padding: 15px 45px; 
            border-radius: 100px; 
            font-weight: 900; 
            font-size: 1.1rem; 
            display: inline-block; 
            margin-bottom: 25px; 
            box-shadow: 0 18px 40px rgba(0, 51, 153, 0.35); 
        }

        /* --- STATISTIQUES GÉANTES --- */
        .stats-industrial-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            padding: 10px 25px;
        }
        @media (min-width: 992px) { .stats-industrial-grid { grid-template-columns: repeat(4, 1fr); padding: 20px 100px; gap: 45px; } }

        .stat-industrial-card {
            background: var(--glass-white);
            backdrop-filter: blur(25px);
            padding: 45px 30px;
            border-radius: 50px;
            border: 3px solid rgba(255,255,255,0.3);
            text-align: center;
            transition: var(--transition-titan);
        }
        .stat-industrial-card:hover { transform: translateY(-15px); border-color: var(--gold); background: rgba(255,255,255,0.2); }
        .stat-industrial-icon { font-size: 3rem; color: var(--neon-blue); margin-bottom: 20px; display: block; text-shadow: 0 0 20px rgba(0, 217, 255, 0.4); }
        
        .btn-certif-industrial { 
            background: var(--gold); 
            color: #000; 
            border: none; 
            width: 100%; 
            padding: 18px; 
            border-radius: 25px; 
            font-weight: 900; 
            font-size: 0.9rem; 
            text-transform: uppercase; 
            margin-top: 30px; 
            letter-spacing: 2px; 
            box-shadow: 0 15px 40px rgba(251, 191, 36, 0.6); 
        }

        /* --- SYSTÈME DE PARRAINAGE 10% --- */
        .referral-industrial-container {
            background: var(--glass-dark);
            margin: 40px 30px;
            padding: 60px;
            border-radius: 70px;
            border: 6px dashed var(--gold);
            text-align: center;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
        }
        @media (min-width: 992px) { .referral-industrial-container { margin: 60px 100px; } }
        .ref-title-industrial { font-family: 'Space Grotesk'; font-weight: 900; color: var(--gold); margin-bottom: 25px; text-transform: uppercase; letter-spacing: 4px; font-size: 2.8rem; }
        
        .industrial-copy-group {
            background: #ffffff;
            padding: 12px;
            border-radius: 45px;
            display: flex;
            align-items: center;
            gap: 25px;
            margin-top: 40px;
            box-shadow: 0 30px 70px rgba(0,0,0,0.5);
        }
        .industrial-copy-group input { background: transparent; border: none; color: #000; font-weight: 900; font-size: 1.2rem; width: 100%; padding-left: 35px; font-family: 'JetBrains Mono'; }
        .btn-copy-industrial-action { background: var(--bleu-bic); color: #fff; border: none; padding: 22px 50px; border-radius: 35px; font-weight: 900; text-transform: uppercase; font-size: 1rem; letter-spacing: 1px; }

        /* --- TERMINAL DE MINAGE (LOGIQUE VERTE) --- */
        .mining-industrial-terminal {
            background: var(--glass-dark);
            margin: 40px 30px;
            padding: 60px;
            border-radius: 70px;
            border: 3px solid rgba(255,255,255,0.25);
            position: relative;
        }
        .progress-industrial-track {
            height: 55px;
            background: rgba(0,0,0,0.8);
            border-radius: 100px;
            overflow: hidden;
            margin: 45px 0;
            border: 4px solid rgba(255,255,255,0.25);
            padding: 10px;
            box-shadow: inset 0 10px 30px rgba(0,0,0,0.5);
        }
        .bar-industrial-emerald-fill {
            background: linear-gradient(90deg, #10b981, #059669, #34d399);
            box-shadow: 0 0 60px rgba(16, 185, 129, 0.9);
            border-radius: 100px;
            height: 100%;
            width: <%= p || 0 %>%;
            transition: width 3s ease-in-out;
        }
        .btn-withdraw-industrial-heavy {
            background: var(--rose);
            color: white;
            border: none;
            width: 100%;
            padding: 35px;
            border-radius: 50px;
            font-weight: 900;
            font-size: 2rem;
            text-transform: uppercase;
            box-shadow: 0 30px 80px rgba(244, 63, 94, 0.7);
            margin-top: 35px;
            letter-spacing: 3px;
            transition: var(--transition-titan);
        }

        /* ============================================================
            AJUSTEMENT MOBILE : STYLE ALIBABA COMPACT (GRILLE DE 2)
           ============================================================ */
        .shop-industrial-header { padding: 0 40px; margin: 100px 0 50px; display: flex; align-items: center; gap: 35px; }
        .shop-industrial-header h2 { font-family: 'Space Grotesk'; font-weight: 900; font-size: 3.5rem; text-transform: uppercase; letter-spacing: -2px; }

        .industrial-shop-grid-full {
            display: grid;
            grid-template-columns: repeat(2, 1fr); /* GRILLE DE 2 SUR MOBILE */
            gap: 12px;
            padding: 0 15px 100px;
        }

        @media (min-width: 992px) { 
            .industrial-shop-grid-full { grid-template-columns: repeat(2, 1fr); gap: 50px; padding: 0 100px 200px; } 
        }
        @media (min-width: 1600px) { 
            .industrial-shop-grid-full { grid-template-columns: repeat(4, 1fr); } 
        }

        .pack-industrial-heavy-card {
            background: #ffffff;
            border-radius: 20px; 
            overflow: hidden;
            color: #0f172a;
            min-height: auto; 
            display: flex;
            flex-direction: column;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            transition: var(--transition-titan);
            position: relative;
            border: none;
        }

        @media (max-width: 768px) {
            /* SUPPRESSION DE L'ESPACE VIDE BLANC */
            .p-head-industrial-heavy { padding: 12px 5px !important; font-size: 0.65rem !important; letter-spacing: 0px !important; }
            .p-body-industrial-heavy { padding: 10px 8px !important; } /* Réduction drastique du padding interne */
            
            /* TAILLE DE TEXTE COMPACTE (STYLE ALIBABA) */
            .p-price-industrial-heavy { font-size: 1.1rem !important; letter-spacing: -1px !important; margin: 8px 0 !important; }
            .p-bonus-industrial-heavy { font-size: 0.55rem !important; padding: 5px !important; border-radius: 8px !important; border-width: 1px !important; margin-bottom: 8px !important; }
            .p-daily-industrial-heavy { font-size: 0.8rem !important; margin-bottom: 12px !important; }
            
            .industrial-details-list { margin: 5px 0 !important; padding: 5px 0 !important; border-top: 1px solid #f1f5f9 !important; }
            .industrial-details-list li { font-size: 0.5rem !important; margin-bottom: 4px !important; gap: 4px !important; }
            .industrial-details-list li i { font-size: 0.7rem !important; }
            
            .btn-industrial-heavy-action { padding: 12px 5px !important; border-radius: 12px !important; font-size: 0.7rem !important; }
            .lock-industrial-badge { padding: 10px 20px !important; font-size: 0.8rem !important; border-radius: 50px !important; }
        }

        /* Styles Desktop d'origine conservés */
        .pack-industrial-heavy-card:hover { transform: translateY(-30px); filter: brightness(1.05); }
        .pack-industrial-active-border { border: 8px solid var(--emerald) !important; transform: scale(1.02); z-index: 50; }
        .pack-industrial-locked-mode { filter: grayscale(1) opacity(0.6); }
        .lock-industrial-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 60; display: flex; align-items: center; justify-content: center; pointer-events: none; }
        .lock-industrial-badge { background: var(--gold); color: #000; padding: 20px 50px; border-radius: 100px; font-weight: 900; font-size: 1.8rem; box-shadow: 0 30px 60px rgba(0,0,0,0.8); letter-spacing: 2px; }
        .p-head-industrial-heavy { padding: 45px; text-align: center; color: #fff; font-weight: 900; text-transform: uppercase; font-size: 1.5rem; letter-spacing: 5px; }
        .p-body-industrial-heavy { padding: 55px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .p-price-industrial-heavy { font-size: 3.5rem; font-weight: 900; color: var(--bleu-bic); margin: 25px 0 15px; font-family: 'Space Grotesk'; letter-spacing: -4px; line-height: 0.9; }
        .p-bonus-industrial-heavy { font-size: 1.2rem; font-weight: 900; color: var(--rose); background: #fff0f0; border: 4px dashed var(--rose); padding: 18px; border-radius: 30px; margin-bottom: 15px; }
        .p-daily-industrial-heavy { font-weight: 900; color: var(--emerald); font-size: 2.2rem; letter-spacing: -2px; margin-bottom: 35px; }
        .industrial-details-list { text-align: left; margin: 30px 0; padding: 30px 0; list-style: none; border-top: 3px solid #f1f5f9; }
        .industrial-details-list li { font-weight: 800; color: #475569; margin-bottom: 18px; display: flex; align-items: center; gap: 15px; font-size: 1.1rem; }
        .industrial-details-list li i { color: var(--emerald); font-size: 1.5rem; }
        .btn-buy-industrial-heavy { background: var(--bleu-bic); color: #fff; }
        .btn-activate-industrial-heavy { background: var(--emerald); color: #fff; box-shadow: 0 25px 50px rgba(16, 185, 129, 0.6); }
        .btn-industrial-heavy-action { width: 100%; padding: 30px; border-radius: 45px; border: none; font-weight: 900; text-transform: uppercase; font-size: 1.4rem; transition: 0.4s; box-shadow: 0 25px 60px rgba(0,0,0,0.3); }

        /* --- TOASTS & SCROLL --- */
        #titan-toast-industrial-heavy { position: fixed; bottom: 50px; left: 50px; z-index: 9999; background: #ffffff; color: #000; padding: 40px 55px; border-radius: 45px; box-shadow: 0 40px 100px rgba(0,0,0,0.9); display: none; align-items: center; gap: 40px; border-left: 20px solid var(--emerald); }
        #scrollTopIndustrialHeavy { position: fixed; bottom: 50px; right: 50px; width: 100px; height: 100px; background: var(--gold); color: var(--bleu-bic); border-radius: 50%; border: none; display: none; align-items: center; justify-content: center; font-size: 4rem; z-index: 9500; box-shadow: 0 40px 80px rgba(0,0,0,0.8); }

        /* FAQ ET FOOTER */
        .industrial-faq-titan { margin: 80px 30px 200px; }
        .accordion-titan-industrial-item { background: var(--glass-dark) !important; border: 3px solid rgba(255,255,255,0.25) !important; color: #fff !important; margin-bottom: 40px; border-radius: 60px !important; overflow: hidden; }
        .accordion-titan-industrial-button { background: transparent !important; color: #fff !important; font-weight: 900; padding: 50px; font-size: 1.8rem; }
        .accordion-titan-industrial-body { padding: 60px; opacity: 1; font-size: 1.4rem; line-height: 2.5; }

        /* MODAL */
        .modal-titan-industrial-heavy { border-radius: 80px !important; border: none; overflow: hidden; }
        .payment-titan-industrial-heavy-card { background: #f8fafc; padding: 45px; border-radius: 50px; border: 6px solid #e2e8f0; margin-bottom: 35px; transition: 0.5s; }
        .payment-titan-industrial-heavy-card:hover { border-color: var(--bleu-bic); transform: translateX(30px); }
    </style>
</head>
<body>

    <div id="titan-toast-industrial-heavy" class="animate__animated animate__slideInLeft">
        <i class="bi bi-cpu-fill text-success" style="font-size: 4.5rem;"></i>
        <div>
            <div class="small opacity-60 fw-900 text-uppercase fs-6">SYSTÈME CASHLINK MASTER RDC</div>
            <div id="toast-industrial-heavy-msg" class="fw-900 text-dark fs-3">Initialisation du terminal v28.0...</div>
        </div>
    </div>

    <button id="scrollTopIndustrialHeavy" onclick="window.scrollTo({top:0, behavior:'smooth'})"><i class="bi bi-arrow-up-circle-fill"></i></button>

    <nav class="premium-nav-titan">
        <a href="/" class="logo-titan-industrial">CASHLINK</a>
        <div class="nav-info-box-titan animate__animated animate__zoomIn">
            <div class="solde-badge-industrial">
                <span class="label-titan-bold">SOLDE DU TERMINAL</span>
                <div class="val-titan-heavy"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span class="label-titan-bold text-success">PROFITS MINAGE</span>
                <div class="val-titan-heavy text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>
        <a href="/logout" class="btn-logout-industrial"><i class="bi bi-power fs-1"></i></a>
    </nav>

    <header class="hero-industrial-banner">
        <div class="animate__animated animate__fadeIn">
            <div class="user-id-badge-industrial">SESSION ACTIVE : <%= user.username %> | RÉSEAU : +243 <%= user.phone %></div>
            <h1 class="hero-title-titan-heavy">MINAGE <span class="text-primary">INDUSTRIEL</span></h1>
            <p class="hero-para-titan-heavy">Le protocole CASHLINK v28.0 déploie une puissance de calcul décentralisée pour chaque citoyen congolais. Sécurisez votre avenir financier avec le minage Cloud Master.</p>
            <button onclick="document.getElementById('catalog').scrollIntoView({behavior:'smooth'})" class="btn btn-primary rounded-pill px-5 py-4 fw-900 shadow-lg fs-2">LANCER MON UNITÉ DE MINAGE</button>
        </div>
    </header>

    <div class="stats-industrial-grid">
        <div class="stat-industrial-card"><i class="bi bi-gpu-card stat-industrial-icon"></i><span class="label-titan-bold">Calcul Hash</span><div class="val-titan-heavy text-white fs-2"><%= (user.pack && user.pack !== 'Aucun') ? '104.2 TH/s' : '0.00 TH/s' %></div></div>
        <div class="stat-industrial-card">
            <i class="bi bi-patch-check-fill stat-industrial-icon text-warning"></i><span class="label-titan-bold">Niveau Compte</span><div class="val-titan-heavy text-white fs-2"><%= user.certified ? 'CERTIFIÉ ÉLITE' : 'BASIQUE' %></div>
            <% if(!user.certified) { %><button onclick="openPaymentModal('CERTIFICATION', 30000)" class="btn-certif-industrial">CERTIFIER (30.000 FC)</button><% } %>
        </div>
        <div class="stat-industrial-card"><i class="bi bi-currency-exchange stat-industrial-icon text-success"></i><span class="label-titan-bold">Flux Retrait</span><div class="val-titan-heavy text-white fs-2">SÉCURISÉ</div></div>
        <div class="stat-industrial-card"><i class="bi bi-shield-lock-fill stat-industrial-icon text-info"></i><span class="label-titan-bold">Cryptage</span><div class="val-titan-heavy text-white fs-2">AES-512</div></div>
    </div>

    <div class="referral-industrial-container animate__animated animate__fadeInUp">
        <h3 class="ref-title-industrial">Programme de Parrainage Elite</h3>
        <p class="fs-4 fw-bold">Multipliez vos profits en invitant vos proches. Recevez instantanément 10% cash sur chaque investissement de vos parrainés, crédités sur votre solde bonus.</p>
        <div class="industrial-copy-group">
            <input type="text" id="refLinkHeavy" value="https://cashlink-rdc.cd/register?ref=<%= user.id %>" readonly>
            <button class="btn-copy-industrial-action" onclick="copyHeavyLink()">COPIER MON LIEN</button>
        </div>
    </div>

    <section class="mining-industrial-terminal animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-end mb-2">
            <div><h3 class="fw-900 mb-0 small text-uppercase">MASTER CLUSTER STATUS</h3><p class="label-titan-bold text-muted mb-0">Unité : <%= user.pack %> industrial_master_v28</p></div>
            <div class="text-success fw-900 fs-1" style="font-family: 'Space Grotesk';"><%= p || 0 %>%</div>
        </div>
        <div class="progress-industrial-track"><div class="bar-industrial-emerald-fill animate__animated animate__pulse animate__infinite"></div></div>
        <div class="d-flex flex-wrap justify-content-between mt-5 align-items-center gap-5">
            <div class="fw-900 text-warning fs-3"><i class="bi bi-clock-history me-3"></i>RECHARGE DISPONIBLE DANS : <span id="titan-heavy-timer">--:--:--</span></div>
            <button onclick="handleWithdrawHeavy()" class="btn-withdraw-industrial-heavy animate__animated animate__pulse animate__infinite">RÉCUPÉRER MES PROFITS (MONEY)</button>
        </div>
    </section>

    <div class="shop-industrial-header" id="catalog">
        <div style="width: 20px; height: 80px; background: var(--gold); border-radius: 25px;"></div>
        <h2>Unités de Minage 2026-2028</h2>
    </div>

    <div class="industrial-shop-grid-full">
        <% 
        const heavyPacks = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981', locked: false },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5', locked: false },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b', locked: false },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444', locked: false },
            { id: 'AMÉTHYSTE', price: 2500000, daily: 300000, bonus: 250000, color: '#9333ea', locked: true },
            { id: 'ÉMERAUDE', price: 5000000, daily: 700000, bonus: 600000, color: '#059669', locked: true },
            { id: 'RUBIS', price: 10000000, daily: 1500000, bonus: 1200000, color: '#dc2626', locked: true },
            { id: 'SAPHIR', price: 25000000, daily: 4000000, bonus: 3500000, color: '#2563eb', locked: true }
        ];

        heavyPacks.forEach(item => {
            const isOwned = (user.pack === item.id);
        %>
        <div class="pack-industrial-heavy-card animate__animated animate__fadeInUp <%= item.locked ? 'pack-industrial-locked-mode' : '' %> <%= isOwned ? 'pack-industrial-active-border' : '' %>">
            <% if(item.locked) { %><div class="lock-industrial-overlay"><div class="lock-industrial-badge">VERROUILLÉ 2028</div></div><% } %>
            <div class="p-head-industrial-heavy" style="background: <%= item.color %>;"><%= item.id %> MASTER UNIT</div>
            <div class="p-body-industrial-heavy">
                <div>
                    <div class="p-price-industrial-heavy"><%= item.price.toLocaleString() %> FC</div>
                    <div class="p-bonus-industrial-heavy">CADEAU D'ACTIVATION : +<%= item.bonus.toLocaleString() %> FC</div>
                    <div class="p-daily-industrial-heavy">+<%= item.daily.toLocaleString() %> FC / JOUR</div>
                    
                    <ul class="industrial-details-list">
                        <li><i class="bi bi-shield-fill-check"></i> Contrat Certifié : 30 Jours</li>
                        <li><i class="bi bi-shield-fill-check"></i> Support Prioritaire : 24h/7j</li>
                        <li><i class="bi bi-shield-fill-check"></i> Retrait Money : Instantané</li>
                        <li><i class="bi bi-shield-fill-check"></i> Technologie : Cloud Master v28</li>
                    </ul>
                </div>
                
                <% if(isOwned) { %>
                    <button onclick="submitHeavyPost('/activer-gain', { pack: '<%= item.id %>' })" class="btn-industrial-heavy-action btn-activate-industrial-heavy">ACTIVER MAINTENANT</button>
                <% } else { %>
                    <button onclick="openPaymentModal('<%= item.id %>', <%= item.price %>)" class="btn-industrial-heavy-action btn-buy-industrial-heavy">ACHETER VOTRE PACK</button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="industrial-faq-titan" id="accTitanHeavy">
        <div class="accordion-titan-industrial-item shadow-lg">
            <h2 class="accordion-header"><button class="accordion-button-titan-industrial collapsed" data-bs-toggle="collapse" data-bs-target="#qa1"><i class="bi bi-info-circle-fill me-5 text-info"></i> VISION CASHLINK RDC 2026</button></h2>
            <div id="qa1" class="accordion-collapse collapse" data-bs-parent="#accTitanHeavy"><div class="accordion-titan-industrial-body"><%= content.about_text %></div></div>
        </div>
        <div class="accordion-titan-industrial-item shadow-lg">
            <h2 class="accordion-header"><button class="accordion-button-titan-industrial collapsed" data-bs-toggle="collapse" data-bs-target="#qa2"><i class="bi bi-shield-lock-fill me-5 text-success"></i> PROTOCOLE DE SÉCURITÉ ET RETRAITS</button></h2>
            <div id="qa2" class="accordion-collapse collapse" data-bs-parent="#accTitanHeavy"><div class="accordion-titan-industrial-body" style="white-space: pre-line;"><%= content.rules_text %></div></div>
        </div>
        <div class="accordion-titan-industrial-item shadow-lg">
            <h2 class="accordion-header"><button class="accordion-button-titan-industrial collapsed" data-bs-toggle="collapse" data-bs-target="#qa3"><i class="bi bi-geo-alt-fill me-5 text-danger"></i> SIÈGE SOCIAL ET CONTACT</button></h2>
            <div id="qa3" class="accordion-collapse collapse" data-bs-parent="#accTitanHeavy">
                <div class="accordion-titan-industrial-body fs-3">
                    <strong>ADRESSE :</strong> <%= content.contact_address %><br>
                    <strong>SUPPORT WHATSAPP :</strong> +243 <%= content.contact_phone %>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center py-5 opacity-30">
        <h1 class="fw-900" style="font-family: 'Space Grotesk'; letter-spacing: -10px; font-size: 8rem;">CASHLINK</h1>
        <p class="small fw-bold text-uppercase fs-4">Protocole Cloud Mining v28.0 | RDC 2026</p>
    </footer>

    <div class="modal fade" id="payHeavyModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content modal-titan-industrial-heavy text-dark shadow-lg">
                <div class="modal-body p-5 text-center">
                    <h2 class="fw-900 mb-5 fs-1">RECHARGE DU COMPTE</h2>
                    <div class="payment-titan-industrial-heavy-card text-start"><small class="text-primary fw-900 fs-5">VODACOM (M-PESA)</small><div class="fw-900 fs-2"><%= content.admin_voda %></div></div>
                    <div class="payment-titan-industrial-heavy-card text-start"><small class="text-danger fw-900 fs-5">AIRTEL MONEY</small><div class="fw-900 fs-2 text-danger"><%= content.admin_airtel %></div></div>
                    <div class="payment-titan-industrial-heavy-card text-start"><small class="text-warning fw-900 fs-5">ORANGE MONEY</small><div class="fw-900 fs-2 text-warning"><%= content.admin_orange %></div></div>
                    <div class="alert alert-danger rounded-5 fw-900 p-5 my-5 fs-4">SAISISSEZ LE TID SMS APRÈS LE TRANSFERT POUR VALIDATION.</div>
                    <button onclick="commitHeavyTID()" class="btn btn-primary w-100 py-4 rounded-pill fw-900 shadow-lg fs-2">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let heavyPack = ""; let heavyPrice = 0;
        const heavyModal = new bootstrap.Modal(document.getElementById('payHeavyModal'));
        
        window.onscroll = function() {
            const btn = document.getElementById('scrollTopIndustrialHeavy');
            btn.style.display = (document.body.scrollTop > 600 || document.documentElement.scrollTop > 600) ? "flex" : "none";
        };

        function copyHeavyLink() {
            const i = document.getElementById('refLinkHeavy'); i.select();
            document.execCommand('copy'); triggerHeavyToast("Lien de parrainage copié avec succès !");
        }

        function openPaymentModal(id, price) { heavyPack = id; heavyPrice = price; heavyModal.show(); }

        function commitHeavyTID() {
            heavyModal.hide();
            const tid = prompt("Veuillez saisir la référence (TID) SMS :");
            if(tid && tid.length > 5) submitHeavyPost('/souscrire-pack', { packName: heavyPack, prix: heavyPrice, reference: tid });
            else alert("ID invalide.");
        }

        function handleWithdrawHeavy() {
            const m = prompt("Montant du retrait (Min 1.000 FC) :");
            if(m >= 1000) submitHeavyPost('/retrait', { montant: m });
            else alert("Montant insuffisant.");
        }

        function submitHeavyPost(path, data) {
            const form = document.createElement('form'); form.method = 'POST'; form.action = path;
            for (const key in data) { const i = document.createElement('input'); i.type = 'hidden'; i.name = key; i.value = data[key]; form.appendChild(i); }
            document.body.appendChild(form); form.submit();
        }

        setInterval(() => {
            const now = new Date(); const next = new Date(); next.setHours(24, 0, 0, 0); const diff = next - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            document.getElementById('titan-heavy-timer').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        function triggerHeavyToast(msg) {
            const t = document.getElementById('titan-toast-industrial-heavy');
            document.getElementById('toast-industrial-heavy-msg').innerText = msg;
            t.style.display = "flex"; setTimeout(() => t.style.display = "none", 7000);
        }

        const masterNames = ["Patrick", "Bijou", "Sarah", "Guelord", "Mado", "Junior", "Elvis"];
        const masterActs = ["retrait 50.000 FC", "pack GOLD actif", "bonus parrainage", "gains reçus"];
        setInterval(() => {
            if(Math.random() > 0.4) triggerHeavyToast(`${masterNames[Math.floor(Math.random()*masterNames.length)]} ${masterActs[Math.floor(Math.random()*masterActs.length)]}`);
        }, 30000);
    </script>
</body>
</html>
