<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CASHLINK | TERMINAL DE MINAGE ELITE</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           MOTEUR CSS "CYBER-BANK" v3.5
           ============================================================ */
        :root {
            --primary: #003399;
            --accent: #00d9ff;
            --success: #10b981;
            --warning: #fbbf24;
            --danger: #f43f5e;
            --dark-bg: #000c26;
            --white: #ffffff;
            --glass: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.1);
            --shadow-hd: 0 25px 50px rgba(0,0,0,0.5);
            --transition-smooth: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        /* RESET ET OPTIMISATION MOBILE */
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            background-color: var(--dark-bg);
            background-image: radial-gradient(circle at 10% 10%, #001f5c, transparent 40%), url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--white);
            margin: 0; padding: 0; min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- NAVIGATION PRINCIPALE --- */
        .master-nav {
            background: var(--warning);
            height: 75px;
            padding: 0 20px;
            position: sticky; top: 0; z-index: 3000;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            border-bottom: 4px solid rgba(0,0,0,0.1);
        }

        .cashlink-logo {
            font-weight: 900;
            font-size: 1.8rem;
            color: var(--primary);
            letter-spacing: -2px;
            text-decoration: none !important;
            text-transform: uppercase;
        }

        .nav-action-btn {
            background: var(--primary); color: white; border-radius: 12px;
            width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
            text-decoration: none; border: 2px solid rgba(255,255,255,0.2);
            transition: var(--transition-smooth);
        }
        .nav-action-btn:hover { transform: scale(1.1); background: #000; }

        .balance-master-box {
            background: var(--white);
            padding: 6px 18px;
            border-radius: 50px;
            display: flex; align-items: center; gap: 15px;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.1);
        }

        .bal-column { display: flex; flex-direction: column; line-height: 1.1; }
        .bal-tag { font-size: 0.5rem; font-weight: 800; color: #64748b; text-transform: uppercase; }
        .bal-amount { font-size: 0.95rem; font-weight: 900; color: var(--primary); }
        .bal-amount.bonus { color: var(--success); }

        /* --- CASE MARKETING TYPOGRAPHIQUE --- */
        .marketing-white-zone {
            background: var(--white);
            padding: 60px 20px;
            text-align: center;
            border-radius: 0 0 60px 60px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5);
            color: #000;
            margin-bottom: 30px;
        }

        .mkt-h1 {
            font-size: 2.8rem; font-weight: 900; line-height: 0.9;
            background: linear-gradient(90deg, var(--primary), #001a4d);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 25px; letter-spacing: -2px;
        }

        .mkt-p {
            font-size: 1.1rem; font-weight: 600; color: #475569;
            max-width: 700px; margin: 0 auto 30px; line-height: 1.5;
        }

        .mkt-stats {
            display: flex; justify-content: center; gap: 20px;
        }

        /* --- SYSTÈME D'AFFILIATION --- */
        .affiliate-card {
            background: rgba(0,0,0,0.3);
            margin: 0 15px 30px;
            padding: 25px;
            border-radius: 35px;
            border: 1px solid var(--glass-border);
            display: flex; justify-content: space-between; align-items: center;
            flex-wrap: wrap; gap: 20px;
            backdrop-filter: blur(10px);
        }

        .aff-stat-item { display: flex; align-items: center; gap: 15px; }
        .aff-icon { background: var(--warning); color: var(--primary); padding: 12px; border-radius: 18px; font-size: 1.3rem; }

        /* --- TERMINAL DE MINAGE (CENTRAL) --- */
        .mining-terminal-section { padding: 0 15px 40px; }
        .mining-glass-card {
            background: rgba(255,255,255,0.02);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 45px; padding: 35px;
            position: relative; overflow: hidden;
            box-shadow: var(--shadow-hd);
        }

        .progress-slim-elite {
            height: 10px; background: rgba(255,255,255,0.05);
            border-radius: 50px; overflow: hidden; margin: 25px 0;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .bar-glow {
            background: linear-gradient(90deg, var(--accent), var(--success), var(--accent));
            background-size: 200% 100%;
            height: 100%; position: relative;
            box-shadow: 0 0 20px rgba(0, 217, 255, 0.4);
            animation: flow-grad 3s linear infinite;
        }
        @keyframes flow-grad { 0% { background-position: 0% 50%; } 100% { background-position: 200% 50%; } }

        .btn-withdraw-action {
            background: var(--danger); color: white; border: none;
            width: 100%; padding: 20px; border-radius: 22px;
            font-weight: 900; font-size: 1.1rem; text-transform: uppercase;
            box-shadow: 0 15px 35px rgba(244, 63, 94, 0.3);
            transition: var(--transition-smooth);
            letter-spacing: 1px;
        }
        .btn-withdraw-action:hover { transform: translateY(-5px); box-shadow: 0 20px 45px rgba(244, 63, 94, 0.5); }

        /* --- GRILLE DE PACKS (STRUCTURE FIXE) --- */
        .pack-section-header { padding: 0 25px; margin-bottom: 25px; border-left: 6px solid var(--warning); }
        
        .pack-grid-system {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 15px; padding: 0 15px 80px;
        }
        @media (min-width: 992px) { .pack-grid-system { grid-template-columns: repeat(4, 1fr); gap: 30px; padding: 0 60px 100px; } }

        .pack-elite-card {
            background: var(--white);
            border-radius: 30px;
            overflow: hidden;
            display: flex; flex-direction: column;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            height: 320px; /* VERROUILLAGE DE LA TAILLE */
            transition: var(--transition-smooth);
            border: none;
        }
        .pack-elite-card:hover { transform: translateY(-12px); }

        .p-header-tag { padding: 12px; text-align: center; color: white; font-weight: 900; font-size: 0.8rem; text-transform: uppercase; }
        .p-content { padding: 20px; text-align: center; color: var(--dark-bg); flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-main-price { font-size: 1.4rem; font-weight: 900; margin: 8px 0; color: var(--primary); letter-spacing: -1px; }
        .p-daily-val { font-size: 0.85rem; font-weight: 800; opacity: 0.8; }

        .btn-pack-action {
            background: var(--primary); color: white; border: none;
            width: 100%; padding: 12px; border-radius: 15px;
            font-weight: 800; font-size: 0.75rem; text-transform: uppercase;
        }

        .pack-locked-2028 { opacity: 0.6; filter: grayscale(1); cursor: not-allowed; position: relative; }

        /* --- BOUTONS ET NOTIFS FLOTTANTS --- */
        #scroll-up-btn {
            position: fixed; bottom: 35px; right: 25px;
            width: 55px; height: 55px; background: var(--warning);
            color: var(--primary); border-radius: 50%;
            display: none; align-items: center; justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5); z-index: 5000;
        }

        #social-proof-notif {
            position: fixed; bottom: 35px; left: 25px;
            background: var(--white); color: #000;
            padding: 12px 25px; border-radius: 25px;
            display: none; align-items: center; gap: 20px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.7); z-index: 5000;
            border-left: 8px solid var(--success);
        }
    </style>
</head>
<body>

    <div id="social-proof-notif" class="animate__animated">
        <div class="bg-success rounded-circle p-2 text-white shadow-sm"><i class="bi bi-patch-check-fill fs-4"></i></div>
        <div>
            <div class="fw-900 small" id="sp-user">Utilisateur</div>
            <div class="small text-muted">Retrait de <b class="text-success" id="sp-amt">0</b> FC validé avec succès.</div>
        </div>
    </div>

    <div id="scroll-up-btn" onclick="window.scrollTo({top:0, behavior:'smooth'})">
        <i class="bi bi-chevron-double-up fs-4"></i>
    </div>

    <nav class="master-nav">
        <div class="d-flex align-items-center gap-3">
            <a href="/" class="nav-action-btn"><i class="bi bi-house-door-fill fs-5"></i></a>
            <a href="#" class="cashlink-logo">CASHLINK</a>
        </div>
        
        <div class="balance-master-box animate__animated animate__fadeInDown">
            <div class="bal-column" style="border-right: 2px solid #eee; padding-right: 15px;">
                <span class="bal-tag">Solde Principal</span>
                <span class="bal-amount"><%= user.solde.toLocaleString() %> FC</span>
            </div>
            <div class="bal-column">
                <span class="bal-tag text-success">Bonus Actifs</span>
                <span class="bal-amount bonus">+<%= user.bonus.toLocaleString() %> FC</span>
            </div>
        </div>

        <a href="/logout" class="nav-action-btn bg-dark"><i class="bi bi-power"></i></a>
    </nav>

    <header class="marketing-white-zone">
        <div class="animate__animated animate__fadeInUp">
            <h1 class="mkt-h1"><%= content.titre_principal %></h1>
            <p class="mkt-p"><%= content.description %></p>
            <div class="mkt-stats">
                <span class="badge bg-primary rounded-pill px-4 py-2 fw-800"><%= content.tag_tech %></span>
                <span class="badge bg-dark rounded-pill px-4 py-2 fw-800">SÉCURISÉ SSL-256</span>
            </div>
        </div>
    </header>

    <div class="affiliate-card animate__animated animate__fadeIn">
        <div class="aff-stat-item">
            <div class="aff-icon"><i class="bi bi-people-fill"></i></div>
            <div>
                <span class="bal-tag">Équipe de Minage</span>
                <div class="fw-900 fs-5">0 Membres</div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button onclick="copyReferralLink()" class="btn btn-warning rounded-pill px-4 fw-900 shadow-sm">
                <i class="bi bi-link-45deg me-2"></i>MON LIEN DE PARRAINAGE
            </button>
        </div>
    </div>

    <div class="mining-terminal-section">
        <div class="mining-glass-card animate__animated animate__fadeInUp">
            <div class="d-flex justify-content-between align-items-end mb-2">
                <div>
                    <h6 class="fw-900 text-uppercase mb-0 text-accent">Status Flux de Minage Sécurisé</h6>
                    <small class="opacity-50">Liaison satellite cryptée active...</small>
                </div>
                <div class="text-accent fw-900 fs-1"><%= p || 0 %>%</div>
            </div>

            <div class="progress-slim-elite">
                <div class="bar-glow" style="width: <%= p || 0 %>%"></div>
            </div>

            <div class="row g-4 mb-4 text-center text-md-start">
                <div class="col-6 col-md-3">
                    <span class="bal-tag opacity-50">Capacité Hash</span>
                    <div class="fw-900 text-accent fs-5"><%= content.puissance_hash %></div>
                </div>
                <div class="col-6 col-md-3">
                    <span class="bal-tag opacity-50">Status Réseau</span>
                    <div class="fw-900 text-success fs-5">OPÉRATIONNEL</div>
                </div>
                <div class="col-6 col-md-3">
                    <span class="bal-tag opacity-50">Machine Active</span>
                    <div class="fw-900 text-white fs-5"><%= user.pack %></div>
                </div>
                <div class="col-6 col-md-3">
                    <span class="bal-tag opacity-50">Prochain Gain</span>
                    <div id="gain-timer" class="fw-900 text-warning fs-5">00:00:00</div>
                </div>
            </div>

            <button onclick="handleWithdrawal()" class="btn-withdraw-action animate__animated animate__pulse animate__infinite">
                <i class="bi bi-piggy-bank-fill me-2 fs-4"></i> Retirer mes Profits
            </button>
        </div>
    </div>

    <div class="pack-section-header mx-3" id="packs">
        <h3 class="fw-900 mb-0">UNITÉS DE MINAGE 2026</h3>
        <p class="small opacity-50 fw-bold">Matériel industriel certifié RDC</p>
    </div>

    <div class="pack-grid-system">
        <% 
        const packs = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' }
        ];
        packs.forEach(u => {
            const isSelected = (user.pack === u.id);
        %>
        <div class="pack-elite-card animate__animated animate__fadeInUp">
            <div class="p-header-tag" style="background: <%= u.color %>;"><%= u.id %> UNIT</div>
            <div class="p-content">
                <div>
                    <span class="bal-tag">Coût d'Activation</span>
                    <div class="p-main-price"><%= u.price.toLocaleString() %> FC</div>
                    <div class="p-daily-val" style="color: <%= u.color %>;">+<%= u.daily.toLocaleString() %> / JOUR</div>
                </div>
                
                <div class="small fw-bold text-start border-top border-bottom py-3 mb-3">
                    <div><i class="bi bi-check-lg text-success me-1"></i> Bonus: +<%= u.bonus.toLocaleString() %> FC</div>
                    <div><i class="bi bi-check-lg text-success me-1"></i> Durée: 30 Jours</div>
                </div>

                <% if(isSelected) { %>
                    <button class="btn btn-success w-100 rounded-pill py-2 fw-900" disabled>EN COURS...</button>
                <% } else { %>
                    <button onclick="openPaymentModal('<%= u.id %>', <%= u.price %>)" class="btn-pack-action shadow-sm">ACHETER</button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="pack-section-header mx-3">
        <h3 class="fw-900 mb-0 opacity-40">SÉRIE LIMITÉE 2028</h3>
        <p class="small opacity-30 fw-bold">Déploiement futur sur le réseau</p>
    </div>

    <div class="pack-grid-system">
        <% 
        const future = [
            { id: 'AMÉTHYSTE', price: 2500000, color: '#9333ea' },
            { id: 'ÉMERAUDE', price: 5000000, color: '#059669' },
            { id: 'RUBIS', price: 10000000, color: '#dc2626' },
            { id: 'SAPHIR', price: 25000000, color: '#2563eb' }
        ];
        future.forEach(f => {
        %>
        <div class="pack-elite-card pack-locked-2028">
            <div class="p-header-tag" style="background: <%= f.color %>;"><%= f.id %></div>
            <div class="p-content">
                <div class="p-main-price opacity-25"><%= f.price.toLocaleString() %> FC</div>
                <button class="btn btn-secondary btn-sm rounded-pill fw-800" disabled>VERROUILLÉ</button>
            </div>
        </div>
        <% }) %>
    </div>

    <footer class="py-5 px-3 text-center" style="background: rgba(0,0,0,0.6); border-top: 1px solid var(--glass-border);">
        <h3 class="fw-900 text-warning mb-2">CASHLINK ELITE</h3>
        <p class="small opacity-50 mb-5"><%= content.footer_text %> | RDC 2026</p>
        <div class="d-flex justify-content-center gap-5 fs-3 opacity-30">
            <i class="bi bi-shield-lock"></i><i class="bi bi-cpu"></i><i class="bi bi-bank"></i>
        </div>
        <hr class="my-5 opacity-10">
        <small class="opacity-30 fw-bold text-uppercase"><%= content.contact_address %></small>
    </footer>

    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content text-dark rounded-5 border-0">
                <div class="modal-body p-4 p-md-5 text-center">
                    <div class="bg-primary text-white p-3 rounded-circle d-inline-block mb-4 shadow-lg"><i class="bi bi-shield-check fs-1"></i></div>
                    <h3 class="fw-900 mb-1">RECHARGE COMPTE</h3>
                    <p class="text-muted small fw-bold mb-4">Envoyez les fonds vers l'un de nos numéros officiels</p>
                    
                    <div class="p-3 bg-light rounded-4 mb-3 text-start border">
                        <span class="bal-tag text-primary">M-PESA (VODACOM)</span>
                        <div class="fw-900 fs-5"><%= content.admin_voda %></div>
                    </div>
                    <div class="p-3 bg-light rounded-4 mb-4 text-start border">
                        <span class="bal-tag text-danger">AIRTEL MONEY</span>
                        <div class="fw-900 fs-5"><%= content.admin_airtel %></div>
                    </div>

                    <button onclick="handleTIDSubmit()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 shadow">J'AI ENVOYÉ LE PAIEMENT</button>
                    <button type="button" class="btn btn-link btn-sm text-muted mt-3" data-bs-dismiss="modal">ANNULER</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selectedPackId = "", selectedPackPrice = 0;
        const paymentModal = new bootstrap.Modal(document.getElementById('payModal'));

        // GESTION DU SCROLL
        window.onscroll = function() {
            document.getElementById('scroll-up-btn').style.display = (window.scrollY > 400) ? 'flex' : 'none';
        };

        // ACTIONS FINANCIÈRES
        function openPaymentModal(id, price) {
            selectedPackId = id; selectedPackPrice = price;
            paymentModal.show();
        }

        function handleTIDSubmit() {
            paymentModal.hide();
            const tid = prompt("Veuillez saisir la référence TID de votre transaction :");
            if(tid && tid.length > 5) {
                executePost('/souscrire-pack', { packName: selectedPackId, prix: selectedPackPrice, reference: tid });
            } else if(tid !== null) {
                alert("Référence invalide ou trop courte.");
            }
        }

        function handleWithdrawal() {
            const m = prompt("Montant du retrait (Minimum 1.000 FC) :");
            if(m && m >= 1000) {
                executePost('/retrait', { montant: m });
            } else if(m !== null) {
                alert("Le montant minimum est de 1.000 FC.");
            }
        }

        function executePost(path, params) {
            const f = document.createElement('form'); f.method = 'POST'; f.action = path;
            for(let k in params) {
                const i = document.createElement('input'); i.type='hidden'; i.name=k; i.value=params[k]; f.appendChild(i);
            }
            document.body.appendChild(f); f.submit();
        }

        function copyReferralLink() {
            const link = window.location.origin + "/register?ref=<%= user.username %>";
            navigator.clipboard.writeText(link);
            alert("Lien de parrainage copié avec succès !");
        }

        // COMPTE À REBOURS
        setInterval(() => {
            const now = new Date(), target = new Date();
            target.setHours(24, 0, 0, 0);
            const diff = target - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            document.getElementById('gain-timer').innerText = 
                `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        // PREUVE SOCIALE (VRAIS NOMS RDC)
        const fakeUsers = ["Jean-Paul", "Mado K.", "Patrick T.", "Sarah L.", "Modeste B.", "Justin W.", "Guelord M.", "Mamie S."];
        setInterval(() => {
            const user = fakeUsers[Math.floor(Math.random()*fakeUsers.length)];
            const sum = (Math.floor(Math.random()*25)*5000 + 10000).toLocaleString();
            const toast = document.getElementById('social-proof-notif');
            document.getElementById('sp-user').innerText = user;
            document.getElementById('sp-amt').innerText = sum;
            toast.style.display = "flex";
            toast.classList.add('animate__fadeInLeft');
            setTimeout(() => {
                toast.classList.replace('animate__fadeInLeft', 'animate__fadeOutLeft');
                setTimeout(() => { toast.style.display="none"; toast.classList.remove('animate__fadeOutLeft'); }, 500);
            }, 5500);
        }, 25000);
    </script>
</body>
</html>
