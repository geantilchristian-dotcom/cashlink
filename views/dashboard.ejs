<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CASHLINK | DASHBOARD ELITE v12.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           MOTEUR DE STYLE "TITAN GIGA" (450 LIGNES DE CSS)
           ============================================================ */
        :root {
            --primary: #003399; /* BLEU BIC RDC */
            --warning: #ffcc00; /* JAUNE TRÈS VISIBLE */
            --accent: #00d9ff; /* CYAN NÉON */
            --success: #10b981;
            --danger: #f43f5e;
            --dark-core: #00081a;
            --white: #ffffff;
            --glass: rgba(255, 255, 255, 0.05);
            --transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* CONFIGURATION SCROLLBAR */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--dark-core); }
        ::-webkit-scrollbar-thumb { background: var(--warning); border-radius: 10px; }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }

        body {
            background-color: var(--primary);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 55%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--white); margin: 0; padding: 0; min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- BARRE DE NOTIFICATION DYNAMIQUE (JAUNE) --- */
        .header-notif-titan {
            background: var(--warning); color: #000; padding: 15px;
            font-weight: 900; text-align: center; text-transform: uppercase;
            border-bottom: 5px solid #000; position: relative; z-index: 5000;
            display: flex; justify-content: center; align-items: center; gap: 15px;
            font-size: 0.85rem; letter-spacing: 1px;
        }
        .header-notif-titan i { font-size: 1.3rem; animation: pulse 1s infinite; }

        /* --- NAVIGATION ELITE --- */
        .navbar-titan {
            background: var(--warning); padding: 12px 25px;
            position: sticky; top: 0; z-index: 4000;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 15px 40px rgba(0,0,0,0.5);
            border-bottom: 2px solid rgba(0,0,0,0.1);
        }

        .brand-titan { font-family: 'Space Grotesk', sans-serif; font-weight: 900; color: var(--primary); font-size: 1.8rem; text-decoration: none !important; letter-spacing: -2px; }

        .user-pill-container {
            background: #ffffff; padding: 10px 25px; border-radius: 60px;
            display: flex; align-items: center; gap: 20px; color: #000;
            border: 3px solid var(--primary); box-shadow: inset 0 2px 8px rgba(0,0,0,0.2);
        }
        .user-meta-data { line-height: 1.1; border-right: 2px solid #e2e8f0; padding-right: 20px; }
        .user-bal-val { font-size: 1.1rem; font-weight: 900; color: var(--primary); font-family: 'Space Grotesk'; }

        .btn-power-off {
            background: var(--danger); color: white; border: none;
            width: 50px; height: 50px; border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 8px 20px rgba(244, 63, 94, 0.4);
            transition: var(--transition);
        }
        .btn-power-off:hover { transform: rotate(90deg) scale(1.1); }

        /* --- TERMINAL DE MINAGE NÉON --- */
        .terminal-titan {
            background: rgba(0,0,0,0.35); backdrop-filter: blur(25px);
            margin: 20px; padding: 45px; border-radius: 50px;
            border: 2px solid rgba(255,255,255,0.08);
            box-shadow: 0 40px 80px rgba(0,0,0,0.6);
        }

        .neon-bar-track {
            height: 30px; background: rgba(255,255,255,0.05);
            border-radius: 50px; overflow: hidden; margin: 30px 0;
            border: 2px solid var(--accent); padding: 4px;
        }
        .neon-bar-fill {
            background: linear-gradient(90deg, var(--accent), var(--success));
            box-shadow: 0 0 25px var(--accent); height: 100%;
            border-radius: 50px; position: relative;
        }

        .stats-titan-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        @media (min-width: 992px) { .stats-titan-grid { grid-template-columns: repeat(4, 1fr); } }

        .stat-titan-item { background: rgba(255,255,255,0.08); padding: 25px; border-radius: 30px; border: 1px solid var(--glass); text-align: center; }
        .stat-titan-label { font-size: 0.65rem; font-weight: 800; color: var(--accent); text-transform: uppercase; margin-bottom: 10px; display: block; }
        .stat-titan-val { font-size: 1.2rem; font-weight: 900; font-family: 'Space Grotesk'; }

        /* --- BOUTON RETRAIT GÉANT --- */
        .btn-withdraw-titan {
            background: var(--danger); color: white; border: none; width: 100%;
            padding: 25px; border-radius: 35px; font-weight: 900; font-size: 1.6rem;
            text-transform: uppercase; box-shadow: 0 20px 50px rgba(244, 63, 94, 0.4);
            transition: var(--transition); margin-top: 40px;
        }

        /* --- SYSTÈME DE PARRAINAGE 10% --- */
        .referral-titan-box {
            background: rgba(255,255,255,0.03); margin: 20px; padding: 35px;
            border-radius: 40px; border: 3px dashed var(--warning); text-align: center;
        }
        .copy-wrapper {
            background: rgba(255,255,255,0.1); padding: 15px; border-radius: 20px;
            display: flex; align-items: center; gap: 15px;
        }
        .copy-wrapper input { background: transparent; border: none; color: white; width: 100%; font-weight: 700; font-size: 0.85rem; }

        /* --- PACKS 2028 (HAUTEUR FIXE 480PX) --- */
        .industrial-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;
            padding: 20px 20px 100px;
        }
        @media (min-width: 1200px) { .industrial-grid { grid-template-columns: repeat(4, 1fr); gap: 40px; padding: 20px 80px 150px; } }

        .titan-pack-card {
            background: #ffffff; border-radius: 50px; overflow: hidden;
            color: #000; height: 480px; /* ALIGNEMENT PARFAIT */
            display: flex; flex-direction: column;
            box-shadow: 0 35px 70px rgba(0,0,0,0.7); transition: var(--transition);
        }
        .titan-pack-card:hover { transform: translateY(-20px) scale(1.03); }

        .p-titan-head { padding: 25px; text-align: center; color: white; font-weight: 900; font-size: 1.1rem; text-transform: uppercase; }
        .p-titan-body { padding: 35px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-titan-price { font-size: 2.4rem; font-weight: 900; color: var(--primary); letter-spacing: -2px; font-family: 'Space Grotesk'; }
        .p-titan-bonus { 
            font-size: 0.85rem; font-weight: 900; color: var(--danger); 
            background: #fff0f0; border: 2.5px dashed var(--danger); 
            padding: 12px; border-radius: 20px; margin: 20px 0; 
        }

        .btn-buy-titan {
            background: var(--primary); color: white; border: none;
            width: 100%; padding: 20px; border-radius: 25px;
            font-weight: 900; text-transform: uppercase; font-size: 1rem;
        }

        /* --- ACCORDÉONS --- */
        .accordion-titan { margin: 20px; border-radius: 35px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
        .accordion-item { background: rgba(0,0,0,0.2) !important; border: none !important; color: white !important; }
        .accordion-button { background: transparent !important; color: white !important; font-weight: 800; padding: 25px; font-size: 1rem; }
        .accordion-button:not(.collapsed) { color: var(--warning) !important; }

        /* --- BOUTON SCROLL TOP --- */
        #backToTop {
            position: fixed; bottom: 30px; right: 30px;
            width: 65px; height: 65px; background: var(--warning);
            color: #000; border-radius: 50%; border: none;
            display: none; align-items: center; justify-content: center;
            font-size: 2rem; z-index: 6000; box-shadow: 0 15px 30px rgba(0,0,0,0.5);
        }

        .footer-titan { background: rgba(0,0,0,0.5); padding: 120px 20px; text-align: center; border-top: 10px solid var(--warning); }

        /* --- TOASTS --- */
        .toast-box {
            position: fixed; bottom: 20px; left: 20px; z-index: 9999;
            background: white; color: black; padding: 15px 25px;
            border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            display: none; align-items: center; gap: 15px;
            border-left: 8px solid var(--success);
        }
    </style>
</head>
<body>

    <button id="backToTop" onclick="window.scrollTo({top:0, behavior:'smooth'})"><i class="bi bi-arrow-up"></i></button>

    <div id="toast" class="toast-box animate__animated animate__slideInLeft">
        <i class="bi bi-check-circle-fill text-success fs-3"></i>
        <div class="fw-bold" id="toast-msg">Opération réussie !</div>
    </div>

    <div class="header-notif-titan animate__animated animate__fadeInDown">
        <i class="bi bi-megaphone-fill"></i>
        <span>ALERTE PARRAINAGE : Gagnez 10% Cash sur l'investissement de vos amis !</span>
    </div>

    <nav class="navbar-titan">
        <div class="d-flex align-items-center gap-3">
            <a href="#" onclick="window.location.reload()" class="btn btn-primary rounded-3 p-2"><i class="bi bi-arrow-clockwise fs-4"></i></a>
            <a href="#" class="brand-titan">CASHLINK</a>
        </div>
        
        <div class="user-pill-container animate__animated animate__zoomIn">
            <div class="user-meta-data d-none d-lg-block">
                <span style="font-size: 0.6rem; font-weight: 800; opacity: 0.5;">ID: <%= user.username %></span>
                <div style="font-weight: 900; font-size: 0.85rem;">+243 <%= user.phone %></div>
            </div>
            <div class="pe-4 border-end">
                <span style="font-size: 0.6rem; font-weight: 800; opacity: 0.5;">SOLDE</span>
                <div class="user-bal-val"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span style="font-size: 0.6rem; font-weight: 800; color: var(--success);">GAINS</span>
                <div class="user-bal-val text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>

        <a href="/logout" class="btn-power-off"><i class="bi bi-power fs-3"></i></a>
    </nav>

    <div class="terminal-titan animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-end mb-1">
            <h4 class="fw-900 mb-0 text-uppercase"><i class="bi bi-cpu-fill me-3"></i>TERMINAL DE MINAGE</h4>
            <div class="fw-900" style="color: var(--accent); font-size: 4rem; line-height: 1;"><%= p || 0 %>%</div>
        </div>
        <div class="neon-bar-track">
            <div class="neon-bar-fill" style="width: <%= p || 0 %>%"></div>
        </div>
        <div class="stats-titan-grid">
            <div class="stat-titan-item">
                <span class="stat-titan-label">STATUT RÉSEAU</span>
                <div class="stat-titan-val text-success">EN LIGNE</div>
            </div>
            <div class="stat-titan-item">
                <span class="stat-titan-label">UNITÉ ACTIVE</span>
                <div class="stat-titan-val"><%= user.pack %></div>
            </div>
            <div class="stat-titan-item">
                <span class="stat-titan-label">PROCHAIN GAIN</span>
                <div id="titan-timer" class="stat-titan-val text-warning">--:--:--</div>
            </div>
            <div class="stat-titan-item">
                <span class="stat-titan-label">VITESSE HASH</span>
                <div class="stat-titan-val text-accent"><%= content.puissance_hash %></div>
            </div>
        </div>
        <button onclick="handleWithdraw()" class="btn-withdraw-titan animate__animated animate__pulse animate__infinite">RÉCUPÉRER MES PROFITS (MONEY)</button>
    </div>

    <div class="referral-titan-box animate__animated animate__fadeInUp">
        <h5 class="fw-900 text-warning mb-3">PROGRAMME DE PARRAINAGE (10%)</h5>
        <p class="small opacity-75 mb-4">Invitez un ami. S'il active un pack de 1.000.000 FC, vous recevez 100.000 FC cash !</p>
        <div class="copy-wrapper">
            <input type="text" id="refLink" value="https://cashlink.rdc/register?ref=<%= user.id %>" readonly>
            <button onclick="copyRef()" class="btn btn-warning fw-900 px-4 rounded-3"><i class="bi bi-clipboard-check"></i></button>
        </div>
    </div>

    <div class="accordion accordion-titan" id="titanAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#col1"><i class="bi bi-info-circle-fill me-3"></i> À PROPOS DE NOUS</button></h2>
            <div id="col1" class="accordion-collapse collapse" data-bs-parent="#titanAccordion"><div class="accordion-body opacity-75"><%= content.about_text %></div></div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#col2"><i class="bi bi-shield-lock-fill me-3"></i> RÈGLES DU SYSTÈME</button></h2>
            <div id="col2" class="accordion-collapse collapse" data-bs-parent="#titanAccordion"><div class="accordion-body opacity-75" style="white-space: pre-line;"><%= content.rules_text %></div></div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#col3"><i class="bi bi-geo-alt-fill me-3"></i> SIÈGE SOCIAL ET CONTACT</button></h2>
            <div id="col3" class="accordion-collapse collapse" data-bs-parent="#titanAccordion">
                <div class="accordion-body opacity-75">
                    SIÈGE : <%= content.contact_address %><br>
                    SUPPORT : +243 <%= content.contact_phone %><br>
                    EMAIL : <%= content.contact_email %>
                </div>
            </div>
        </div>
    </div>

    <div class="px-4 mb-4 d-flex align-items-center gap-3">
        <div style="width: 12px; height: 50px; background: var(--warning); border-radius: 10px;"></div>
        <h2 class="fw-900 mb-0">UNITÉS DE MINAGE 2028</h2>
    </div>

    <div class="industrial-grid">
        <% 
        const items = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' }
        ];
        items.forEach(p => {
        %>
        <div class="titan-pack-card animate__animated animate__fadeInUp">
            <div class="p-titan-head" style="background: <%= p.color %>;"><%= p.id %> ENGINE</div>
            <div class="p-titan-body">
                <div>
                    <div class="p-titan-bonus">🎁 BONUS ACTIVATION : <%= p.bonus.toLocaleString() %> FC</div>
                    <div class="p-titan-price"><%= p.price.toLocaleString() %> FC</div>
                    <div class="fw-900 text-success mt-2">+<%= p.daily.toLocaleString() %> FC / JOUR</div>
                </div>
                <button onclick="handlePay('<%= p.id %>', <%= p.price %>)" class="btn-buy-titan mt-4">ACTIVER MAINTENANT</button>
            </div>
        </div>
        <% }) %>
    </div>

    <footer class="footer-titan">
        <h1 class="fw-900 text-warning mb-2" style="font-family: 'Space Grotesk'; font-size: 4rem; letter-spacing: -5px;">CASHLINK RDC</h1>
        <p class="small opacity-50 mb-5 fw-bold">TECHNOLOGIE DE MINAGE INDUSTRIEL v12.0</p>
        <div class="d-flex justify-content-center gap-5 fs-1 opacity-20 mb-5">
            <i class="bi bi-shield-check"></i><i class="bi bi-cpu"></i><i class="bi bi-globe"></i>
        </div>
        <hr class="opacity-10 my-5 mx-5">
        <small class="opacity-30 fw-bold">© 2026-2028 | CASHLINK GLOBAL TERMINAL | PAR ANASH MASTER</small>
    </footer>

    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content overflow-hidden border-0" style="border-radius: 40px; color: #000;">
                <div class="modal-body p-5 text-center">
                    <h3 class="fw-900 mb-4">RECHARGE COMPTE</h3>
                    <div class="p-4 bg-light rounded-4 mb-3 text-start border-start border-primary border-5">
                        <span class="small fw-bold text-primary">VODACOM (M-PESA)</span>
                        <div class="fs-4 fw-900"><%= content.admin_voda %></div>
                    </div>
                    <div class="p-4 bg-light rounded-4 mb-3 text-start border-start border-danger border-5">
                        <span class="small fw-bold text-danger">AIRTEL MONEY</span>
                        <div class="fs-4 fw-900 text-danger"><%= content.admin_airtel %></div>
                    </div>
                    <div class="p-4 bg-light rounded-4 mb-4 text-start border-start border-warning border-5">
                        <span class="small fw-bold text-warning">ORANGE MONEY</span>
                        <div class="fs-4 fw-900 text-warning"><%= content.admin_orange %></div>
                    </div>
                    <button onclick="submitTID()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 shadow-lg fs-5">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let packSel = "", priceSel = 0;
        const pMod = new bootstrap.Modal(document.getElementById('payModal'));

        // --- GESTION SCROLL ---
        window.onscroll = function() {
            const b = document.getElementById('backToTop');
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) b.style.display = "flex";
            else b.style.display = "none";
        };

        // --- TOASTS ---
        function showT(m) {
            const t = document.getElementById('toast');
            document.getElementById('toast-msg').innerText = m;
            t.style.display = "flex";
            setTimeout(() => t.style.display = "none", 4000);
        }

        // --- ACTIONS ---
        function copyRef() {
            const c = document.getElementById('refLink');
            c.select(); document.execCommand('copy');
            showT("Lien de parrainage copié !");
        }

        function handlePay(id, pr) { packSel = id; priceSel = pr; pMod.show(); }

        function submitTID() {
            pMod.hide();
            const tid = prompt("Saisissez le TID (ID Transaction SMS) :");
            if(tid && tid.length > 5) submitData('/souscrire-pack', { packName: packSel, prix: priceSel, reference: tid });
        }

        function handleWithdraw() {
            const m = prompt("Montant (FC) à retirer (Min 1.000) :");
            if(m >= 1000) submitData('/retrait', { montant: m });
        }

        function submitData(path, data) {
            const f = document.createElement('form'); f.method='POST'; f.action=path;
            for(let k in data) { const i = document.createElement('input'); i.name=k; i.value=data[k]; f.appendChild(i); }
            document.body.appendChild(f); f.submit();
        }

        // --- TIMER GAIN INDIVIDUEL ---
        let ms = <%= locals.msRemaining || 0 %>;
        setInterval(() => {
            if (ms <= 0) { document.getElementById('titan-timer').innerText = "CYCLE PRÊT"; return; }
            ms -= 1000;
            const h = Math.floor(ms/3600000), m = Math.floor((ms%3600000)/60000), s = Math.floor((ms%60000)/1000);
            document.getElementById('titan-timer').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        // Simulation notifications
        setInterval(() => {
            const n = ["Patrick", "Mado", "Guelord", "Sarah", "Elvis"][Math.floor(Math.random()*5)];
            const a = [50000, 150000, 1000000][Math.floor(Math.random()*3)];
            showT(`${n} vient d'activer un pack de ${a.toLocaleString()} FC !`);
        }, 30000);
    </script>
</body>
</html>
