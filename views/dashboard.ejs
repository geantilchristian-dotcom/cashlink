<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CASH LINK | GLOBAL TERMINAL v8.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --primary: #003399;
            --accent: #00d9ff; /* CYAN NÉON POUR LA BARRE */
            --success: #10b981;
            --warning: #ffcc00;
            --danger: #f43f5e;
            --dark: #00081a;
            --white: #ffffff;
            --voda: #e60000;
            --airtel: #ff0000;
            --orange: #ff6600;
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        /* RESET ET SCROLL */
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }
        body {
            background-color: var(--dark);
            background-image: radial-gradient(circle at 10% 10%, #001f5c, transparent 45%);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--white); margin: 0; padding: 0; min-height: 100vh;
        }

        /* --- BARRE DE NOTIFICATION --- */
        .notif-flash {
            background: linear-gradient(90deg, #ffcc00, #ffaa00); color: #000;
            padding: 15px; font-weight: 900; text-align: center;
            border-bottom: 4px solid #000; z-index: 5000;
            display: flex; justify-content: center; align-items: center; gap: 15px;
            font-size: 0.85rem; text-transform: uppercase;
        }

        /* --- NAVIGATION --- */
        .master-nav {
            background: var(--white); height: 95px; padding: 0 25px;
            position: sticky; top: 0; z-index: 4000;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 15px 50px rgba(0,0,0,0.8); border-bottom: 6px solid var(--primary);
        }

        .brand-logo { font-weight: 900; font-size: 2.2rem; color: var(--primary); text-decoration: none !important; letter-spacing: -3px; }

        .balance-container {
            background: #f1f5f9; padding: 12px 30px; border-radius: 60px;
            display: flex; align-items: center; gap: 25px; border: 3px solid var(--primary);
        }
        .bal-val { font-size: 1.3rem; font-weight: 900; color: var(--primary); }

        /* --- BOUTONS DE NAVIGATION --- */
        .btn-nav-square {
            width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;
            border-radius: 15px; background: var(--primary); color: white;
            text-decoration: none; transition: 0.3s; border: 2px solid rgba(255,255,255,0.2);
        }
        .btn-nav-square.logout { background: var(--danger); }
        .btn-nav-square:hover { transform: scale(1.1); filter: brightness(1.2); }

        /* --- HERO MARKETING --- */
        .hero-premium {
            background: var(--white); padding: 100px 25px; text-align: center;
            border-radius: 0 0 80px 80px; color: #000;
            box-shadow: 0 40px 80px rgba(0,0,0,0.5); margin-bottom: 60px;
        }
        .hero-h1 { font-size: 4rem; font-weight: 900; color: var(--primary); margin-bottom: 25px; letter-spacing: -4px; line-height: 0.85; }

        /* --- TERMINAL DE MINAGE (BARRE NÉON) --- */
        .terminal-panel { padding: 0 20px 80px; }
        .mining-card {
            background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(30px);
            border: 2px solid rgba(255,255,255,0.1); border-radius: 60px; padding: 60px;
            box-shadow: 0 50px 100px rgba(0,0,0,0.8);
        }

        .neon-progress-track {
            height: 25px; background: rgba(0,0,0,0.5);
            border-radius: 50px; overflow: hidden; margin: 40px 0;
            border: 2px solid var(--accent); padding: 3px;
        }
        .neon-progress-fill {
            background: linear-gradient(90deg, #00d9ff, #0055ff);
            height: 100%; width: <%= p || 0 %>%; border-radius: 50px;
            box-shadow: 0 0 25px var(--accent); position: relative;
            animation: pulse-neon 2s infinite;
        }
        @keyframes pulse-neon { 0% { opacity: 0.8; } 50% { opacity: 1; } 100% { opacity: 0.8; } }

        .stat-titan-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 30px; margin-bottom: 50px; }
        @media (min-width: 992px) { .stat-titan-grid { grid-template-columns: repeat(4, 1fr); } }

        .stat-card-titan { background: rgba(0,0,0,0.4); padding: 30px; border-radius: 35px; border: 1px solid var(--glass); text-align: center; }
        .stat-label-titan { font-size: 0.75rem; font-weight: 800; color: var(--accent); text-transform: uppercase; margin-bottom: 12px; display: block; }
        .stat-val-titan { font-size: 1.5rem; font-weight: 900; color: #fff; }

        /* --- PACKS 2026 ET 2028 --- */
        .grid-master {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 25px;
            padding: 0 20px 100px;
        }
        @media (min-width: 1200px) { .grid-master { grid-template-columns: repeat(4, 1fr); gap: 40px; padding: 0 80px 150px; } }

        .industrial-pack {
            background: var(--white); border-radius: 50px; overflow: hidden;
            display: flex; flex-direction: column; height: 450px;
            box-shadow: 0 35px 70px rgba(0,0,0,0.7); transition: var(--transition);
        }
        .industrial-pack:hover { transform: translateY(-20px) scale(1.02); }

        .p-header { padding: 25px; text-align: center; color: white; font-weight: 900; font-size: 1.1rem; text-transform: uppercase; }
        .p-body { padding: 35px; text-align: center; color: var(--dark); flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-price-big { font-size: 2.4rem; font-weight: 900; color: var(--primary); letter-spacing: -3px; }
        .p-bonus-badge { 
            font-size: 0.9rem; font-weight: 900; color: var(--danger); 
            background: #fff0f0; border: 2.5px dashed var(--danger); 
            padding: 12px; border-radius: 20px; margin: 20px 0; 
        }

        .btn-activate { background: var(--primary); color: white; border: none; width: 100%; padding: 20px; border-radius: 25px; font-weight: 900; font-size: 1rem; text-transform: uppercase; }

        /* --- RESEAUX DESIGN --- */
        .net-badge {
            padding: 15px; border-radius: 20px; color: white; font-weight: 900;
            display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;
            cursor: pointer; transition: 0.3s; border: none; width: 100%;
        }
        .net-voda { background: var(--voda); }
        .net-airtel { background: var(--airtel); }
        .net-orange { background: var(--orange); }
        .net-badge:hover { transform: scale(1.03); filter: brightness(1.2); }

        /* --- SECTIONS INFO --- */
        .info-block { background: rgba(255, 255, 255, 0.04); margin: 0 20px 60px; padding: 80px 60px; border-radius: 60px; border: 1px solid rgba(255,255,255,0.1); }
        .info-block h4 { font-weight: 900; color: var(--warning); margin-bottom: 35px; text-transform: uppercase; font-size: 2rem; }
        .info-block p { color: #e2e8f0; font-size: 1.2rem; line-height: 2; opacity: 0.9; }

        .footer-titan { background: #000; padding: 120px 20px; text-align: center; border-top: 8px solid var(--warning); }
    </style>
</head>
<body>

    <div class="notif-flash animate__animated animate__slideInDown">
        <i class="bi bi-broadcast-pin"></i>
        <span>ACCÈS ILLIMITÉ : Synchronisation avec le satellite de minage CASH LINK v8.0 confirmée.</span>
        <button class="btn btn-sm btn-dark ms-auto fw-bold" onclick="this.parentElement.remove()">FERMER</button>
    </div>

    <nav class="master-nav">
        <div class="d-flex align-items-center gap-3">
            <a href="/dashboard" class="btn-nav-square"><i class="bi bi-arrow-left fs-4"></i></a>
            <a href="#" class="brand-logo">CASH LINK</a>
        </div>
        
        <div class="balance-container animate__animated animate__fadeInDown">
            <div style="border-right: 3px solid #cbd5e1; padding-right: 30px;">
                <span class="bal-label">SOLDE PRINCIPAL</span>
                <div class="bal-val"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span class="bal-label text-success">BONUS MINAGE</span>
                <div class="bal-val text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="d-none d-lg-block text-end me-2" style="color: var(--primary);">
                <div class="fw-900 fs-5">ID: <%= user.username %></div>
                <div class="fw-bold small">+243 <%= user.phone %></div>
            </div>
            <a href="/logout" class="btn-nav-square logout shadow-sm"><i class="bi bi-power fs-4"></i></a>
        </div>
    </nav>

    <header class="hero-premium animate__animated animate__fadeIn">
        <h1 class="hero-h1">MINAGE AUTO 2026</h1>
        <p class="hero-p">Le terminal CASH LINK transforme la puissance de calcul en argent réel. Activez vos serveurs aujourd'hui et regardez votre capital fructifier en temps réel.</p>
        <button onclick="requestElite()" class="btn-elite mt-4">
            <i class="bi bi-patch-check-fill me-2"></i> ACTIVER MA CERTIFICATION ELITE (RETRAIT 24H)
        </button>
    </header>

    <div class="terminal-panel">
        <div class="mining-card animate__animated animate__fadeInUp">
            <div class="d-flex justify-content-between align-items-end mb-3">
                <div>
                    <h2 class="fw-900 text-accent mb-0">PROGRESSION DES GAINS</h2>
                    <p class="small opacity-75 fw-bold mb-0">ID TERMINAL: <%= user.id %></p>
                </div>
                <div class="text-accent fw-900" style="font-size: 3.5rem;"><%= p || 0 %>%</div>
            </div>

            <div class="neon-progress-track">
                <div class="neon-progress-fill"></div>
            </div>

            <div class="stat-titan-grid">
                <div class="stat-card-titan">
                    <span class="stat-label-titan">UNITÉ CONNECTÉE</span>
                    <div class="stat-val-titan text-accent"><%= content.puissance_hash %></div>
                </div>
                <div class="stat-card-titan">
                    <span class="stat-label-titan">Réseau Status</span>
                    <div class="stat-val-titan text-success">OPÉRATIONNEL</div>
                </div>
                <div class="stat-card-titan">
                    <span class="stat-label-titan">Machine Active</span>
                    <div class="stat-val-titan"><%= user.pack %></div>
                </div>
                <div class="stat-card-titan">
                    <span class="stat-label-titan">Temps avant Crédit</span>
                    <div id="countdown" class="stat-val-titan text-warning">--:--:--</div>
                </div>
            </div>

            <button onclick="openWithdraw()" class="btn-withdraw animate__animated animate__pulse animate__infinite">
                <i class="bi bi-wallet2 me-3"></i> RETIRER MES PROFITS (MONEY)
            </button>
        </div>
    </div>

    <div class="px-4 mb-5 d-flex align-items-center gap-3">
        <div style="width: 12px; height: 50px; background: var(--warning); border-radius: 10px;"></div>
        <h2 class="fw-900 mb-0">GÉNÉRATION INDUSTRIELLE 2026</h2>
    </div>

    <div class="grid-master">
        <% 
        const packs26 = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' }
        ];
        packs26.forEach(p => {
        %>
        <div class="industrial-pack animate__animated animate__fadeInUp">
            <div class="p-header" style="background: <%= p.color %>;"><%= p.id %> UNIT</div>
            <div class="p-body">
                <div>
                    <span class="bal-label">INVESTISSEMENT</span>
                    <div class="p-price-big"><%= p.price.toLocaleString() %> FC</div>
                    <div class="fw-900 text-success fs-5">+<%= p.daily.toLocaleString() %> FC / JOUR</div>
                    <div class="p-bonus-badge">🎁 BONUS ACTIVATION : <%= p.bonus.toLocaleString() %> FC</div>
                </div>
                <button onclick="payGateway('<%= p.id %>', <%= p.price %>)" class="btn-activate">ACTIVER</button>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="px-4 mb-5 mt-5 d-flex align-items-center gap-3">
        <div style="width: 12px; height: 50px; background: var(--accent); border-radius: 10px;"></div>
        <h2 class="fw-900 mb-0 opacity-50">EXTENSIONS RÉSEAU 2028</h2>
    </div>

    <div class="grid-master">
        <% 
        const packs28 = [
            { id: 'AMÉTHYSTE', price: 2500000, daily: 300000, color: '#9333ea' },
            { id: 'ÉMERAUDE', price: 5000000, daily: 700000, color: '#059669' },
            { id: 'RUBIS', price: 10000000, daily: 1500000, color: '#dc2626' },
            { id: 'SAPHIR', price: 25000000, daily: 4000000, color: '#2563eb' }
        ];
        packs28.forEach(f => {
        %>
        <div class="industrial-pack" style="opacity: 0.4; filter: grayscale(1);">
            <div class="p-header" style="background: <%= f.color %>;"><%= f.id %></div>
            <div class="p-body">
                <div class="p-price-big"><%= f.price.toLocaleString() %> FC</div>
                <button class="btn btn-secondary w-100 rounded-pill py-3 fw-900" disabled>BIENTÔT DISPONIBLE</button>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="info-block">
        <div class="row g-5">
            <div class="col-lg-6">
                <h4><i class="bi bi-info-circle-fill me-3"></i>À PROPOS DE CASH LINK</h4>
                <p><%= content.about_text %></p>
            </div>
            <div class="col-lg-6">
                <h4><i class="bi bi-shield-lock-fill me-3"></i>RÈGLES DU SYSTÈME</h4>
                <p style="white-space: pre-line;"><%= content.rules_text %></p>
            </div>
        </div>

        <div class="row mt-5 pt-5 border-top border-secondary border-opacity-25">
            <div class="col-md-4 mb-4">
                <h6 class="stat-label-titan text-warning">ADRESSE DU SIÈGE</h6>
                <div class="fw-bold"><i class="bi bi-geo-alt-fill me-2 text-danger"></i><%= content.contact_address %></div>
            </div>
            <div class="col-md-4 mb-4">
                <h6 class="stat-label-titan text-warning">SUPPORT TECHNIQUE</h6>
                <div class="fw-bold"><i class="bi bi-envelope-at-fill me-2 text-primary"></i><%= content.contact_email %></div>
            </div>
            <div class="col-md-4">
                <h6 class="stat-label-titan text-warning">HOTLINE RDC</h6>
                <div class="fw-bold"><i class="bi bi-headset me-2 text-success"></i>+243 <%= content.contact_phone %></div>
            </div>
        </div>
    </div>

    <footer class="footer-titan">
        <h1 class="fw-900 text-warning mb-2">CASH LINK</h1>
        <p class="small opacity-50 mb-5">TERMINAL DE MINAGE GLOBAL v8.0 | TOUS DROITS RÉSERVÉS</p>
        <div class="d-flex justify-content-center gap-5 fs-1 opacity-20 mb-5">
            <i class="bi bi-shield-check"></i><i class="bi bi-cpu"></i><i class="bi bi-globe"></i>
        </div>
        <hr class="opacity-10 my-5 mx-5">
        <small class="opacity-20 fw-bold">DESIGNED FOR ANASH MASTER | RDC 2026</small>
    </footer>

    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content overflow-hidden" style="border-radius: 40px; border: none;">
                <div class="modal-body p-4 p-md-5 text-center text-dark">
                    <h3 class="fw-900 mb-3">RÉSEAU DE PAIEMENT</h3>
                    <p class="text-muted small fw-bold mb-4">Cliquez sur votre réseau pour voir le numéro</p>
                    
                    <button onclick="setN('VODA')" class="net-badge net-voda">
                        <span>VODACOM (M-PESA)</span> <i class="bi bi-chevron-right"></i>
                    </button>
                    <button onclick="setN('AIRTEL')" class="net-badge net-airtel">
                        <span>AIRTEL MONEY</span> <i class="bi bi-chevron-right"></i>
                    </button>
                    <button onclick="setN('ORANGE')" class="net-badge net-orange">
                        <span>ORANGE MONEY</span> <i class="bi bi-chevron-right"></i>
                    </button>

                    <div id="term-box" class="p-4 bg-light rounded-4 my-4 text-start animate__animated animate__fadeIn" style="display:none; border: 2px solid var(--primary);">
                        <span class="bal-label">NUMÉRO DU TERMINAL</span>
                        <div class="fs-4 fw-900 text-primary d-flex justify-content-between align-items-center mt-2">
                            <span id="term-num">+243 000 000 000</span>
                            <i class="bi bi-clipboard-check-fill fs-2" style="cursor:pointer;" onclick="copyData()"></i>
                        </div>
                    </div>

                    <div class="alert alert-danger small rounded-4 py-3 border-0 shadow-sm mb-4 fw-bold">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i> SAISISSEZ LE TID : L'identifiant se trouve dans le SMS de confirmation de transfert.
                    </div>

                    <button onclick="commitTID()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 shadow-lg fs-5">J'AI ENVOYÉ LES FONDS</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let sId = "", sAmt = 0, cNum = "";
        const mP = new bootstrap.Modal(document.getElementById('payModal'));

        // COMPTEUR INDIVIDUEL RÉEL
        let msRemaining = <%= locals.msRemaining || 0 %>;

        function updateTimer() {
            const timerEl = document.getElementById('countdown');
            if (msRemaining <= 0) {
                timerEl.innerText = "CYCLE PRÊT";
                return;
            }
            const interval = setInterval(() => {
                if (msRemaining <= 0) {
                    clearInterval(interval);
                    timerEl.innerText = "CRÉDIT EN COURS...";
                    return;
                }
                msRemaining -= 1000;
                const h = Math.floor(msRemaining / 3600000);
                const m = Math.floor((msRemaining % 3600000) / 60000);
                const s = Math.floor((msRemaining % 60000) / 1000);
                timerEl.innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
            }, 1000);
        }

        function setN(n) {
            const box = document.getElementById('term-box');
            box.style.display = "block";
            if(n==='VODA'){ document.getElementById('term-num').innerText="+243 <%= content.admin_voda %>"; cNum="+243 <%= content.admin_voda %>"; }
            if(n==='AIRTEL'){ document.getElementById('term-num').innerText="+243 <%= content.admin_airtel %>"; cNum="+243 <%= content.admin_airtel %>"; }
            if(n==='ORANGE'){ document.getElementById('term-num').innerText="+243 <%= content.admin_orange %>"; cNum="+243 <%= content.admin_orange %>"; }
        }

        function payGateway(id, pr) { sId = id; sAmt = pr; mP.show(); }

        function requestElite() {
            if(confirm("La certification Elite (10.000 FC) débloque le retrait toutes les 24h. Continuer ?")) {
                sId = "CERTIFICATION"; sAmt = 10000; mP.show();
            }
        }

        function commitTID() {
            mP.hide();
            const tid = prompt("Entrez le TID (ID Transaction) reçu par SMS :");
            if(tid && tid.length > 5) post('/souscrire-pack', { packName: sId, prix: sAmt, reference: tid });
        }

        function openWithdraw() {
            const m = prompt("Montant (FC) à retirer (Min 1.000) :");
            if(m >= 1000) post('/retrait', { montant: m });
        }

        function post(p, d) {
            const f = document.createElement('form'); f.method = 'POST'; f.action = p;
            for(let k in d) {
                const i = document.createElement('input'); i.type='hidden'; i.name=k; i.value=d[k]; f.appendChild(i);
            }
            document.body.appendChild(f); f.submit();
        }

        function copyData() { navigator.clipboard.writeText(cNum); alert("Numéro copié avec succès !"); }

        updateTimer();
    </script>
</body>
</html>
