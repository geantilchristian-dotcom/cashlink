<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Interface Elite v4.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           CONFIGURATION DES VARIABLES & CORE STYLE (300 LIGNES)
           ============================================================ */
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --emerald: #10b981; /* VERT DE PROGRESSION */
            --rose: #f43f5e;
            --gold: #fbbf24;
            --dark-deep: #000c26;
            --glass-white: rgba(255, 255, 255, 0.1);
            --glass-dark: rgba(0, 0, 0, 0.3);
            --transition-smooth: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }

        body {
            background-color: var(--bleu-bic);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 50%),
                radial-gradient(at 100% 100%, var(--dark-deep) 0px, transparent 50%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff; margin: 0; padding: 0; min-height: 100vh;
            overflow-x: hidden; -webkit-font-smoothing: antialiased;
        }

        /* --- BARRE DE NAVIGATION (NAVBAR) --- */
        .premium-nav {
            background: var(--gold); padding: 8px 15px; position: sticky;
            top: 0; z-index: 2000; display: flex; justify-content: space-between;
            align-items: center; box-shadow: 0 10px 40px rgba(0,0,0,0.4);
            border-bottom: 4px solid rgba(0,0,0,0.1);
        }
        @media (min-width: 992px) { .premium-nav { padding: 12px 60px; } }

        .logo-brand { font-weight: 900; color: var(--bleu-bic); font-size: 1.4rem; text-decoration: none !important; letter-spacing: -2px; }
        
        .nav-info-box {
            background: #ffffff; padding: 5px 12px; border-radius: 60px;
            display: flex; align-items: center; gap: 8px; color: #0f172a;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.15);
        }
        .solde-badge { border-right: 1px solid #f1f5f9; padding-right: 8px; }
        .label-xs { font-size: 0.55rem; font-weight: 800; text-transform: uppercase; color: #94a3b8; display: block; line-height: 1; margin-bottom: 2px; }
        .val-md { font-weight: 900; font-size: 0.85rem; color: var(--bleu-bic); line-height: 1.2; }
        @media (min-width: 768px) { .val-md { font-size: 1.2rem; } .nav-info-box { gap: 20px; padding: 10px 25px; } }

        /* --- SECTION MARKETING (HERO BANNER BLANC) --- */
        .hero-banner {
            width: 100%; background: #ffffff; border-radius: 0 0 35px 35px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3); overflow: hidden;
            margin-bottom: 20px; padding: 50px 20px; text-align: center;
        }
        .marketing-content h1 { font-weight: 900; color: var(--bleu-bic); font-size: clamp(2rem, 8vw, 4rem); line-height: 0.9; margin-bottom: 15px; }
        .marketing-content p { color: #475569; font-weight: 700; font-size: 1rem; max-width: 700px; margin: 0 auto 25px; }
        .user-tag { background: var(--bleu-bic); color: #fff; padding: 8px 20px; border-radius: 50px; font-weight: 800; font-size: 0.8rem; display: inline-block; margin-bottom: 10px; }

        /* --- ELEMENTS DE STATISTIQUES --- */
        .stats-container {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 12px; padding: 10px 15px;
        }
        @media (min-width: 992px) { .stats-container { grid-template-columns: repeat(4, 1fr); padding: 20px 60px; gap: 25px; } }

        .stat-glass-card {
            background: var(--glass-white); backdrop-filter: blur(12px);
            padding: 20px; border-radius: 25px; border: 1px solid rgba(255,255,255,0.15);
            text-align: center; transition: var(--transition-smooth);
        }
        .stat-icon { font-size: 1.8rem; color: var(--neon-blue); margin-bottom: 10px; display: block; }
        
        .btn-certif-gold {
            background: var(--gold); color: #000; border: none; width: 100%;
            padding: 10px; border-radius: 12px; font-weight: 900; font-size: 0.65rem;
            text-transform: uppercase; margin-top: 10px; box-shadow: 0 5px 15px rgba(251, 191, 36, 0.3);
        }

        /* --- LIEN DE PARRAINAGE --- */
        .referral-box {
            background: var(--glass-dark); margin: 15px; padding: 25px;
            border-radius: 30px; border: 2px dashed var(--gold); text-align: center;
        }
        @media (min-width: 992px) { .referral-box { margin: 30px 60px; } }
        .copy-group {
            background: #fff; padding: 6px; border-radius: 20px;
            display: flex; align-items: center; gap: 10px; margin-top: 15px;
        }
        .copy-group input { background: transparent; border: none; color: #000; font-weight: 700; font-size: 0.8rem; width: 100%; padding-left: 10px; }
        .btn-copy { background: var(--bleu-bic); color: #fff; border: none; padding: 10px 20px; border-radius: 15px; font-weight: 800; font-size: 0.8rem; }

        /* --- SECTION MINAGE (VERTE) --- */
        .mining-area {
            background: var(--glass-dark); margin: 15px; padding: 25px;
            border-radius: 35px; border: 1px solid rgba(255,255,255,0.08);
        }
        @media (min-width: 992px) { .mining-area { margin: 30px 60px; padding: 45px; } }

        .progress-master {
            height: 25px; background: rgba(0,0,0,0.4); border-radius: 50px;
            overflow: hidden; margin: 20px 0; border: 1px solid rgba(255,255,255,0.1); padding: 3px;
        }
        .bar-emerald {
            background: linear-gradient(90deg, #10b981, #34d399);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.5); border-radius: 50px;
        }

        /* --- SHOP GRID (8 PACKS ALIGNÉS 480PX) --- */
        .shop-header {
            padding: 0 25px; margin: 40px 0 20px; display: flex; align-items: center; gap: 15px;
        }
        @media (min-width: 992px) { .shop-header { padding: 0 60px; } }

        .shop-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 12px; padding: 0 12px 100px;
        }
        @media (min-width: 992px) { .shop-grid { grid-template-columns: repeat(4, 1fr); padding: 0 60px 150px; gap: 30px; } }

        .card-elite-pack {
            background: #ffffff; border-radius: 40px; overflow: hidden;
            color: #0f172a; height: 480px; /* ALIGNEMENT FIXE CHIRURGICAL */
            display: flex; flex-direction: column; box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            transition: var(--transition-smooth);
        }
        .card-elite-pack:hover { transform: translateY(-15px); }
        .is-active { border: 6px solid var(--emerald) !important; }

        .p-head { padding: 20px; text-align: center; color: #fff; font-weight: 800; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; }
        .p-body { padding: 25px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-price { font-size: 1.6rem; font-weight: 900; color: var(--bleu-bic); letter-spacing: -1.5px; word-break: break-all; margin: 10px 0; }
        @media (min-width: 768px) { .p-price { font-size: 2.2rem; } }

        .p-bonus { font-size: 0.65rem; font-weight: 800; color: var(--rose); background: #fff0f0; border: 1.5px dashed var(--rose); padding: 8px; border-radius: 12px; margin-bottom: 10px; }

        .btn-buy-elite {
            width: 100%; padding: 18px; border-radius: 22px; border: none;
            font-weight: 900; text-transform: uppercase; font-size: 0.8rem;
            background: var(--bleu-bic); color: #fff; transition: 0.3s;
        }
        .btn-buy-elite:active { transform: scale(0.95); }

        /* --- NOTIFICATIONS TOASTS STYLE --- */
        #notification-toast {
            position: fixed; bottom: 25px; left: 25px; z-index: 5000;
            background: #ffffff; color: #000; padding: 15px 25px;
            border-radius: 20px; box-shadow: 0 15px 40px rgba(0,0,0,0.6);
            display: none; align-items: center; gap: 15px; border-left: 6px solid var(--emerald);
        }

        /* --- ACCORDÉONS BAS DE PAGE --- */
        .info-accordion { margin: 20px 15px 100px; }
        @media (min-width: 992px) { .info-accordion { margin: 40px 60px 150px; } }
        .accordion-item { background: var(--glass-dark) !important; border: 1px solid rgba(255,255,255,0.1) !important; color: #fff !important; margin-bottom: 10px; border-radius: 20px !important; overflow: hidden; }
        .accordion-button { background: transparent !important; color: #fff !important; font-weight: 800; padding: 25px; box-shadow: none !important; }
        .accordion-button:not(.collapsed) { color: var(--gold) !important; }

        /* --- BOUTON SCROLL TOP --- */
        #backToTop {
            position: fixed; bottom: 25px; right: 25px;
            width: 60px; height: 60px; background: var(--gold);
            color: var(--bleu-bic); border-radius: 50%; border: none;
            display: none; align-items: center; justify-content: center;
            font-size: 1.8rem; z-index: 4500; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

    <button id="backToTop" onclick="scrollToTop()"><i class="bi bi-chevron-double-up"></i></button>

    <div id="notification-toast" class="animate__animated animate__slideInLeft">
        <i class="bi bi-patch-check-fill text-success fs-3"></i>
        <div>
            <div class="small opacity-50 fw-bold">SYSTÈME EN DIRECT</div>
            <div id="toast-text" class="fw-900 small">Un utilisateur vient d'activer le pack GOLD</div>
        </div>
    </div>

    <nav class="premium-nav">
        <a href="/" class="logo-brand animate__animated animate__fadeInLeft">CASHLINK</a>
        
        <div class="nav-info-box animate__animated animate__zoomIn">
            <div class="solde-badge">
                <span class="label-xs">SOLDE</span>
                <div class="val-md"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span class="label-xs text-success">GAINS</span>
                <div class="val-md text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>

        <a href="/logout" class="btn btn-dark rounded-circle p-2 shadow-sm"><i class="bi bi-power fs-5"></i></a>
    </nav>

    <header class="hero-banner">
        <div class="marketing-content animate__animated animate__fadeIn">
            <div class="user-tag animate__animated animate__fadeInDown">
                COMPTE : <%= user.username %> | +243 <%= user.phone %>
            </div>
            <h1>MINAGE <span class="text-primary">AUTOMATIQUE</span></h1>
            <p>Le terminal CASHLINK exploite la puissance des serveurs Cloud pour générer vos revenus passifs en toute sécurité. Technologie 2026 déployée à Kinshasa.</p>
            <button onclick="document.getElementById('boutique').scrollIntoView({behavior:'smooth'})" class="btn btn-primary rounded-pill px-5 py-3 fw-900 shadow-lg">BOUTIQUE D'INVESTISSEMENT</button>
        </div>
    </header>

    <div class="stats-container">
        <div class="stat-glass-card">
            <i class="bi bi-lightning-charge-fill stat-icon"></i>
            <span class="label-xs">Vitesse Hash</span>
            <div class="val-md text-white"><%= (user.pack && user.pack !== 'Aucun') ? '104.2 TH/s' : '0.00 TH/s' %></div>
        </div>
        <div class="stat-glass-card">
            <i class="bi bi-patch-check-fill stat-icon text-warning"></i>
            <span class="label-xs">Certificat</span>
            <div class="val-md text-white"><%= user.certified ? 'ACTIF' : 'BASIQUE' %></div>
            <% if(!user.certified) { %>
                <button onclick="handlePay('CERTIFICATION', 15000)" class="btn-certif-gold">S'ACTIVER (15.000 FC)</button>
            <% } %>
        </div>
        <div class="stat-glass-card">
            <i class="bi bi-shield-lock-fill stat-icon text-success"></i>
            <span class="label-xs">Sécurité</span>
            <div class="val-md text-white">SSL-256</div>
        </div>
        <div class="stat-glass-card">
            <i class="bi bi-currency-exchange stat-icon text-danger"></i>
            <span class="label-xs">Retraits</span>
            <div class="val-md text-white">OUVERTS</div>
        </div>
    </div>

    <div class="referral-box animate__animated animate__fadeInUp">
        <h5 class="fw-900 text-warning text-uppercase">Programme de Parrainage (10%)</h5>
        <p class="small opacity-75 fw-bold">Invitez vos proches et gagnez 10% cash sur chaque investissement immédiatement sur votre solde bonus.</p>
        <div class="copy-group">
            <input type="text" id="refLink" value="https://cashlink-rdc.onrender.com/register?ref=<%= user.id %>" readonly>
            <button class="btn-copy" onclick="copyRef()">COPIER</button>
        </div>
    </div>

    <section class="mining-area animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-end mb-2">
            <div>
                <h6 class="fw-900 mb-0">PROCESSUS DE MINAGE EN COURS</h6>
                <p class="label-xs text-muted">Node ID : #<%= user.id.slice(-6) %> | Unité : <%= user.pack %></p>
            </div>
            <div class="text-success fw-900 fs-2"><%= p || 0 %>%</div>
        </div>
        <div class="progress-master">
            <div class="progress-bar bar-emerald progress-bar-striped progress-bar-animated" style="width: <%= p || 0 %>%"></div>
        </div>
        <div class="d-flex justify-content-between mt-3 align-items-center">
            <div class="small fw-bold text-warning"><i class="bi bi-clock me-2"></i>RECHARGEMENT : <span id="timer-gain">--:--:--</span></div>
            <button onclick="askWithdraw()" class="btn btn-danger rounded-pill px-4 py-2 fw-900 shadow">RETIRER MES GAINS</button>
        </div>
    </section>

    <div class="shop-header" id="boutique">
        <div style="width: 8px; height: 40px; background: var(--gold); border-radius: 10px;"></div>
        <h3 class="fw-900 mb-0 text-uppercase">Catalogue de Minage 2026-2028</h3>
    </div>

    <div class="shop-grid">
        <% 
        const catalog = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' },
            { id: 'AMÉTHYSTE', price: 2500000, daily: 300000, bonus: 250000, color: '#9333ea' },
            { id: 'ÉMERAUDE', price: 5000000, daily: 700000, bonus: 600000, color: '#059669' },
            { id: 'RUBIS', price: 10000000, daily: 1500000, bonus: 1200000, color: '#dc2626' },
            { id: 'SAPHIR', price: 25000000, daily: 4000000, bonus: 3500000, color: '#2563eb' }
        ];

        catalog.forEach(item => {
            const isOwned = (user.pack === item.id);
        %>
        <div class="card-elite-pack animate__animated animate__fadeInUp <%= isOwned ? 'is-active' : '' %>">
            <div class="p-head" style="background: <%= item.color %>;"><%= item.id %> ENGINE</div>
            <div class="p-body">
                <div>
                    <div class="p-bonus">CADEAU : +<%= item.bonus.toLocaleString() %> FC</div>
                    <div class="p-price"><%= item.price.toLocaleString() %> <span class="fs-6 fw-bold">FC</span></div>
                    <div class="fw-900 text-success small">+<%= item.daily.toLocaleString() %> FC / JOUR</div>
                </div>
                <button onclick="handlePay('<%= item.id %>', <%= item.price %>)" class="btn-buy-elite mt-3 <%= isOwned ? 'opacity-50' : '' %>" <%= isOwned ? 'disabled' : '' %>>
                    <%= isOwned ? 'MACHINE ACTIVE' : 'ACTIVER PACK' %>
                </button>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="info-accordion" id="accInfo">
        <div class="accordion-item shadow-sm">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c1"><i class="bi bi-info-circle-fill me-3 text-info"></i> À PROPOS DE NOUS</button></h2>
            <div id="c1" class="accordion-collapse collapse" data-bs-parent="#accInfo"><div class="accordion-body"><%= content.about_text %></div></div>
        </div>
        <div class="accordion-item shadow-sm">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c2"><i class="bi bi-shield-lock-fill me-3 text-success"></i> RÈGLES DU SYSTÈME</button></h2>
            <div id="c2" class="accordion-collapse collapse" data-bs-parent="#accInfo"><div class="accordion-body" style="white-space: pre-line;"><%= content.rules_text %></div></div>
        </div>
        <div class="accordion-item shadow-sm">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c3"><i class="bi bi-geo-alt-fill me-3 text-danger"></i> ADRESSE & CONTACT</button></h2>
            <div id="c3" class="accordion-collapse collapse" data-bs-parent="#accInfo">
                <div class="accordion-body">
                    SIÈGE SOCIAL : <%= content.contact_address %><br>
                    SUPPORT WHATSAPP : +243 <%= content.contact_phone %><br>
                    SUPPORT EMAIL : <%= content.contact_email %>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center py-5 opacity-25">
        <h2 class="fw-900" style="font-family: 'Space Grotesk'; letter-spacing: -3px;">CASHLINK GLOBAL</h2>
        <p class="small fw-bold text-uppercase">Terminal de Minage Décentralisé v4.0 | RDC 2026</p>
    </footer>

    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content border-0 text-dark" style="border-radius: 40px; overflow: hidden;">
                <div class="modal-body p-5 text-center">
                    <h3 class="fw-900 mb-4">RECHARGE COMPTE</h3>
                    <div class="p-3 bg-light rounded-4 mb-2 text-start border-start border-primary border-5">
                        <small class="fw-bold text-primary">VODACOM (M-PESA)</small>
                        <div class="fs-5 fw-900"><%= content.admin_voda %></div>
                    </div>
                    <div class="p-3 bg-light rounded-4 mb-2 text-start border-start border-danger border-5">
                        <small class="fw-bold text-danger">AIRTEL MONEY</small>
                        <div class="fs-5 fw-900 text-danger"><%= content.admin_airtel %></div>
                    </div>
                    <div class="p-3 bg-light rounded-4 mb-4 text-start border-start border-warning border-5">
                        <small class="fw-bold text-warning">ORANGE MONEY</small>
                        <div class="fs-5 fw-900 text-warning"><%= content.admin_orange %></div>
                    </div>
                    <div class="alert alert-danger small fw-bold rounded-4 mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Veuillez saisir la référence (TID) après avoir envoyé le paiement.
                    </div>
                    <button onclick="commitTID()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 shadow-lg fs-5">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selId = "", selPr = 0;
        const pMod = new bootstrap.Modal(document.getElementById('payModal'));

        // --- GESTION DU SCROLL ---
        window.onscroll = function() {
            const btn = document.getElementById('backToTop');
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) btn.style.display = "flex";
            else btn.style.display = "none";
        };

        function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }

        // --- ACTIONS ---
        function copyRef() {
            const c = document.getElementById('refLink');
            c.select(); document.execCommand('copy');
            showToast("Lien de parrainage copié !");
        }

        function handlePay(id, pr) { selId = id; selPr = pr; pMod.show(); }

        function commitTID() {
            pMod.hide();
            const tid = prompt("Entrez le TID (Transaction ID) reçu par SMS :");
            if(tid && tid.length > 5) submit('/souscrire-pack', { packName: selId, prix: selPr, reference: tid });
            else alert("ID de transaction invalide.");
        }

        function askWithdraw() {
            const m = prompt("Montant du retrait (Min 1.000 FC) :");
            if(m >= 1000) submit('/retrait', { montant: m });
            else alert("Le montant minimum est de 1.000 FC.");
        }

        function submit(path, data) {
            const f = document.createElement('form'); f.method='POST'; f.action=path;
            for(let k in data) { const i = document.createElement('input'); i.name=k; i.value=data[k]; f.appendChild(i); }
            document.body.appendChild(f); f.submit();
        }

        // --- TIMER & TOASTS ---
        setInterval(() => {
            const now = new Date(), next = new Date(); next.setHours(24, 0, 0, 0); const diff = next - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            document.getElementById('timer-gain').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        function showToast(m) {
            const t = document.getElementById('notification-toast');
            document.getElementById('toast-text').innerText = m;
            t.style.display = "flex"; setTimeout(() => t.style.display = "none", 5000);
        }

        const names = ["Jean", "Mado", "Patrick", "Guelord", "Sarah", "Elvis"];
        const act = ["vient de retirer 50.000 FC", "a activé le pack GOLD", "vient de parrainer un ami", "a reçu son bonus de minage"];
        setInterval(() => {
            if(Math.random() > 0.5) showToast(`${names[Math.floor(Math.random()*names.length)]} ${act[Math.floor(Math.random()*act.length)]}`);
        }, 20000);
    </script>
</body>
</html>
