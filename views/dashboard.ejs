<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Interface Elite v26.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           MOTEUR DE DESIGN "TITAN OLYMPUS" (SECTIONS STYLES DÉTAILLÉES)
           ============================================================ */
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --emerald: #10b981; /* VERT ÉMERAUDE POUR PROGRESSION */
            --rose: #f43f5e;
            --gold: #fbbf24;
            --dark-deep: #000c26;
            --glass-white: rgba(255, 255, 255, 0.12);
            --glass-dark: rgba(0, 0, 0, 0.45);
            --transition-titan: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* PERSONNALISATION DE LA BARRE DE DÉFILEMENT */
        ::-webkit-scrollbar { width: 12px; }
        ::-webkit-scrollbar-track { background: var(--dark-deep); }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 12px; border: 3px solid var(--dark-deep); }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }

        body {
            background-color: var(--bleu-bic);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 55%),
                radial-gradient(at 100% 100%, var(--dark-deep) 0px, transparent 55%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff; margin: 0; padding: 0; min-height: 100vh;
            overflow-x: hidden; -webkit-font-smoothing: antialiased;
        }

        /* --- NAVIGATION SUPÉRIEURE (NAVBAR) --- */
        .premium-nav-titan {
            background: var(--gold); padding: 12px 15px; position: sticky;
            top: 0; z-index: 5000; display: flex; justify-content: space-between;
            align-items: center; box-shadow: 0 15px 50px rgba(0,0,0,0.6);
            border-bottom: 5px solid rgba(0,0,0,0.2);
        }
        @media (min-width: 992px) { .premium-nav-titan { padding: 15px 80px; } }

        .logo-titan { 
            font-family: 'Space Grotesk', sans-serif; font-weight: 900; 
            color: var(--bleu-bic); font-size: 1.8rem; text-decoration: none !important; 
            letter-spacing: -3px; transition: var(--transition-titan);
        }
        .logo-titan:hover { transform: scale(1.08); }
        
        .nav-info-container {
            background: #ffffff; padding: 8px 20px; border-radius: 80px;
            display: flex; align-items: center; gap: 15px; color: #0f172a;
            box-shadow: inset 0 2px 15px rgba(0,0,0,0.25);
        }
        .solde-badge-titan { border-right: 3px solid #f1f5f9; padding-right: 18px; }
        .label-titan-xs { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: #94a3b8; display: block; line-height: 1; margin-bottom: 4px; }
        .val-titan-md { font-weight: 900; font-size: 1.1rem; color: var(--bleu-bic); line-height: 1.1; font-family: 'Space Grotesk'; }

        .btn-logout-titan-circle {
            background: var(--dark-deep); color: white; border: none;
            width: 50px; height: 50px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 12px 25px rgba(0,0,0,0.4); transition: var(--transition-titan);
        }
        .btn-logout-titan-circle:hover { background: var(--rose); transform: rotate(90deg) scale(1.1); }

        /* --- SECTION MARKETING (HERO BANNER BLANC) --- */
        .hero-banner-titan {
            width: 100%; background: #ffffff; border-radius: 0 0 60px 60px;
            box-shadow: 0 30px 70px rgba(0,0,0,0.45); overflow: hidden;
            margin-bottom: 40px; padding: 80px 25px; text-align: center;
            position: relative;
        }
        .hero-banner-titan::after { content: ""; position: absolute; bottom: 0; left: 0; width: 100%; height: 12px; background: var(--gold); }
        
        .hero-title-titan { font-family: 'Space Grotesk'; font-weight: 900; color: var(--bleu-bic); font-size: clamp(2.5rem, 12vw, 5rem); line-height: 0.8; margin-bottom: 25px; letter-spacing: -4px; }
        .hero-para-titan { color: #475569; font-weight: 700; font-size: 1.25rem; max-width: 850px; margin: 0 auto 40px; line-height: 1.6; }
        .user-id-badge-titan { background: var(--bleu-bic); color: #fff; padding: 12px 35px; border-radius: 70px; font-weight: 900; font-size: 1rem; display: inline-block; margin-bottom: 20px; box-shadow: 0 15px 30px rgba(0, 51, 153, 0.3); }

        /* --- STATISTIQUES ÉLITE --- */
        .stats-titan-grid-container {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 20px; padding: 10px 25px;
        }
        @media (min-width: 992px) { .stats-titan-grid-container { grid-template-columns: repeat(4, 1fr); padding: 20px 90px; gap: 40px; } }

        .stat-titan-glass-card {
            background: var(--glass-white); backdrop-filter: blur(20px);
            padding: 35px; border-radius: 40px; border: 2px solid rgba(255,255,255,0.25);
            text-align: center; transition: var(--transition-titan);
        }
        .stat-titan-glass-card:hover { transform: translateY(-12px); border-color: var(--gold); background: rgba(255,255,255,0.2); }
        .stat-titan-icon-style { font-size: 2.5rem; color: var(--neon-blue); margin-bottom: 15px; display: block; }
        
        .btn-certification-titan-action {
            background: var(--gold); color: #000; border: none; width: 100%;
            padding: 15px; border-radius: 20px; font-weight: 900; font-size: 0.8rem;
            text-transform: uppercase; margin-top: 25px; letter-spacing: 1.5px;
            box-shadow: 0 12px 30px rgba(251, 191, 36, 0.5); transition: 0.4s;
        }

        /* --- SYSTÈME DE PARRAINAGE 10% --- */
        .referral-titan-master-box {
            background: var(--glass-dark); margin: 30px; padding: 50px;
            border-radius: 60px; border: 5px dashed var(--gold); text-align: center;
        }
        @media (min-width: 992px) { .referral-titan-master-box { margin: 50px 90px; } }
        .ref-title-titan-master { font-family: 'Space Grotesk'; font-weight: 900; color: var(--gold); margin-bottom: 20px; text-transform: uppercase; letter-spacing: 3px; font-size: 2rem; }
        
        .industrial-copy-titan-group {
            background: #ffffff; padding: 10px; border-radius: 35px;
            display: flex; align-items: center; gap: 20px; margin-top: 30px;
            box-shadow: 0 25px 55px rgba(0,0,0,0.4);
        }
        .industrial-copy-titan-group input { background: transparent; border: none; color: #000; font-weight: 900; font-size: 1rem; width: 100%; padding-left: 30px; }
        .btn-copy-titan-master-action { background: var(--bleu-bic); color: #fff; border: none; padding: 18px 40px; border-radius: 30px; font-weight: 900; text-transform: uppercase; font-size: 0.9rem; transition: 0.3s; }

        /* --- TERMINAL DE MINAGE (BARRE VERTE ÉMERAUDE) --- */
        .mining-titan-terminal-box {
            background: var(--glass-dark); margin: 30px; padding: 45px;
            border-radius: 60px; border: 2px solid rgba(255,255,255,0.2);
        }
        @media (min-width: 992px) { .mining-titan-terminal-box { margin: 50px 90px; padding: 70px; } }

        .progress-titan-industrial-track {
            height: 45px; background: rgba(0,0,0,0.7); border-radius: 80px;
            overflow: hidden; margin: 35px 0; border: 3px solid rgba(255,255,255,0.2); padding: 8px;
        }
        .bar-titan-industrial-fill {
            background: linear-gradient(90deg, #10b981, #059669, #34d399);
            box-shadow: 0 0 45px rgba(16, 185, 129, 0.8); border-radius: 80px;
            height: 100%; position: relative; width: <%= p || 0 %>%;
            transition: width 2.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-withdraw-titan-industrial {
            background: var(--rose); color: white; border: none; width: 100%;
            padding: 28px; border-radius: 40px; font-weight: 900; font-size: 1.6rem;
            text-transform: uppercase; box-shadow: 0 25px 60px rgba(244, 63, 94, 0.6);
            transition: var(--transition-titan); margin-top: 25px; letter-spacing: 2px;
        }

        /* --- SHOP GRID (8 PACKS ALIGNÉS 480PX) --- */
        .shop-titan-industrial-header { padding: 0 40px; margin: 80px 0 40px; display: flex; align-items: center; gap: 30px; }
        @media (min-width: 992px) { .shop-titan-industrial-header { padding: 0 90px; } }
        .shop-titan-industrial-header h2 { font-family: 'Space Grotesk'; font-weight: 900; font-size: 3rem; text-transform: uppercase; }

        .industrial-titan-shop-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 20px; padding: 0 20px 150px;
        }
        @media (min-width: 1200px) { .industrial-titan-shop-grid { grid-template-columns: repeat(4, 1fr); padding: 0 90px 220px; gap: 50px; } }

        .pack-titan-industrial-card {
            background: #ffffff; border-radius: 60px; overflow: hidden;
            color: #0f172a; height: 480px; /* ALIGNEMENT FIXE DEMANDÉ */
            display: flex; flex-direction: column; box-shadow: 0 40px 80px rgba(0,0,0,0.6);
            transition: var(--transition-titan); position: relative; border: none;
        }
        .pack-titan-industrial-card:hover { transform: translateY(-30px); box-shadow: 0 55px 110px rgba(0,0,0,0.7); }
        
        .pack-active-titan-border { border: 12px solid var(--emerald) !important; transform: scale(1.08); z-index: 100; }

        /* VERROUILLAGE VISUEL 2028 */
        .pack-titan-industrial-locked { filter: grayscale(1) brightness(0.65); }
        .lock-titan-industrial-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 60; display: flex; align-items: center; justify-content: center; pointer-events: none; }
        .lock-titan-industrial-badge { background: var(--gold); color: #000; padding: 15px 35px; border-radius: 70px; font-weight: 900; font-size: 1.1rem; box-shadow: 0 20px 40px rgba(0,0,0,0.7); }

        .p-head-titan-industrial { padding: 35px; text-align: center; color: #fff; font-weight: 900; text-transform: uppercase; font-size: 1.2rem; letter-spacing: 3px; }
        .p-body-titan-industrial { padding: 45px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-price-titan-industrial { font-size: 2rem; font-weight: 900; color: var(--bleu-bic); margin: 20px 0 10px; font-family: 'Space Grotesk'; word-break: break-all; letter-spacing: -3px; }
        @media (min-width: 768px) { .p-price-titan-industrial { font-size: 3rem; } }
        
        .p-bonus-titan-industrial { font-size: 0.85rem; font-weight: 900; color: var(--rose); background: #fff0f0; border: 3px dashed var(--rose); padding: 14px; border-radius: 25px; margin-bottom: 10px; }
        .p-daily-titan-industrial { font-weight: 900; color: var(--emerald); font-size: 1.4rem; letter-spacing: -1px; }

        /* LOGIQUE BOUTONS DYNAMIQUES */
        .btn-buy-titan-industrial { background: var(--bleu-bic); color: #fff; }
        .btn-activate-titan-industrial { background: var(--emerald); color: #fff; box-shadow: 0 20px 40px rgba(16, 185, 129, 0.5); }

        .btn-titan-industrial-action {
            width: 100%; padding: 24px; border-radius: 35px; border: none;
            font-weight: 900; text-transform: uppercase; font-size: 1.1rem;
            transition: 0.4s; box-shadow: 0 20px 45px rgba(0,0,0,0.3);
        }

        /* --- SYSTÈME DE TOASTS & ACCORDÉONS --- */
        #titan-toast-industrial-container { position: fixed; bottom: 40px; left: 40px; z-index: 9999; background: #ffffff; color: #000; padding: 30px 40px; border-radius: 35px; box-shadow: 0 30px 70px rgba(0,0,0,0.8); display: none; align-items: center; gap: 30px; border-left: 15px solid var(--emerald); }
        #scrollTopTitanIndustrial { position: fixed; bottom: 40px; right: 40px; width: 85px; height: 85px; background: var(--gold); color: var(--bleu-bic); border-radius: 50%; border: none; display: none; align-items: center; justify-content: center; font-size: 3rem; z-index: 9000; box-shadow: 0 30px 60px rgba(0,0,0,0.7); }

        .industrial-faq-section { margin: 40px 30px 150px; }
        @media (min-width: 992px) { .industrial-faq-section { margin: 80px 100px 200px; } }
        .accordion-titan-item { background: var(--glass-dark) !important; border: 2px solid rgba(255,255,255,0.2) !important; color: #fff !important; margin-bottom: 25px; border-radius: 45px !important; overflow: hidden; }
        .accordion-titan-button { background: transparent !important; color: #fff !important; font-weight: 900; padding: 40px; font-size: 1.4rem; box-shadow: none !important; }
        .accordion-titan-button:not(.collapsed) { color: var(--gold) !important; border-bottom: 2px solid rgba(255,255,255,0.2); }
        .accordion-titan-body { padding: 50px; opacity: 0.9; font-size: 1.2rem; line-height: 2.2; }

        /* MODAL PAIEMENT INDUSTRIEL */
        .modal-industrial-titan { border-radius: 60px !important; border: none; overflow: hidden; }
        .payment-titan-industrial-card { background: #f8fafc; padding: 35px; border-radius: 40px; border: 5px solid #e2e8f0; margin-bottom: 25px; transition: 0.4s; }
        .payment-titan-industrial-card:hover { border-color: var(--bleu-bic); background: #fff; transform: translateX(20px); }
    </style>
</head>
<body>

    <div id="titan-toast-industrial-container" class="animate__animated animate__slideInLeft">
        <i class="bi bi-cpu-fill text-success" style="font-size: 3rem;"></i>
        <div>
            <div class="small opacity-60 fw-900 text-uppercase">Flux de Données Terminal</div>
            <div id="toast-industrial-msg" class="fw-900 text-dark fs-5">Lancement des protocoles...</div>
        </div>
    </div>

    <button id="scrollTopTitanIndustrial" onclick="window.scrollTo({top:0, behavior:'smooth'})"><i class="bi bi-arrow-up-circle-fill"></i></button>

    <nav class="premium-nav-titan">
        <a href="/" class="logo-titan animate__animated animate__fadeInLeft">CASHLINK</a>
        
        <div class="nav-info-container animate__animated animate__zoomIn">
            <div class="solde-badge-titan">
                <span class="label-titan-xs">SOLDE PRINCIPAL</span>
                <div class="val-titan-md"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span class="label-titan-xs text-success">GAINS MINAGE</span>
                <div class="val-titan-md text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>

        <a href="/logout" class="btn-logout-titan-circle shadow-lg"><i class="bi bi-power fs-2"></i></a>
    </nav>

    <header class="hero-banner-titan">
        <div class="animate__animated animate__fadeIn">
            <div class="user-id-badge-titan animate__animated animate__fadeInDown">
                TERMINAL ID : <%= user.username %> | ACCÈS RÉSEAU : +243 <%= user.phone %>
            </div>
            <h1 class="hero-title-titan">MINAGE <span class="text-primary">INDUSTRIEL</span></h1>
            <p class="hero-para-titan">Activez la puissance de calcul brute de nos fermes de serveurs Cloud. Le protocole CASHLINK v26.0 garantit une distribution équitable des profits de minage 24h/24 en République Démocratique du Congo.</p>
            <div class="d-flex justify-content-center gap-4 mt-2">
                <button onclick="document.getElementById('catalog').scrollIntoView({behavior:'smooth'})" class="btn btn-primary rounded-pill px-5 py-4 fw-900 shadow-lg fs-4">LANCER MON UNITÉ MAINTENANT</button>
            </div>
        </div>
    </header>

    <div class="stats-titan-grid-container">
        <div class="stat-titan-glass-card">
            <i class="bi bi-gpu-card stat-titan-icon-style"></i>
            <span class="label-titan-xs">Vitesse de Calcul</span>
            <div class="val-titan-md text-white fs-3"><%= (user.pack && user.pack !== 'Aucun') ? '104.2 TH/s' : '0.00 TH/s' %></div>
        </div>
        <div class="stat-titan-glass-card">
            <i class="bi bi-patch-check-fill stat-titan-icon-style text-warning"></i>
            <span class="label-titan-xs">Certification Compte</span>
            <div class="val-titan-md text-white fs-3"><%= user.certified ? 'ACTIF ÉLITE' : 'BASIQUE V1' %></div>
            <% if(!user.certified) { %>
                <button onclick="openPaymentModal('CERTIFICATION', 30000)" class="btn-certification-titan-action">S'ACTIVER (30.000 FC)</button>
            <% } %>
        </div>
        <div class="stat-titan-glass-card">
            <i class="bi bi-currency-exchange stat-titan-icon-style text-success"></i>
            <span class="label-titan-xs">Statut Retrait</span>
            <div class="val-titan-md text-white fs-3">OPÉRATIONNEL</div>
        </div>
        <div class="stat-titan-glass-card">
            <i class="bi bi-shield-lock-fill stat-titan-icon-style text-info"></i>
            <span class="label-titan-xs">Sécurité Protocole</span>
            <div class="val-titan-md text-white fs-3">AES-512</div>
        </div>
    </div>

    <div class="referral-titan-master-box animate__animated animate__fadeInUp">
        <h3 class="ref-title-titan-master">Système de Parrainage Olympus</h3>
        <p class="fs-5 opacity-90 fw-bold">Multipliez vos revenus en invitant votre réseau. Recevez instantanément 10% cash sur chaque pack activé par vos parrainés directement sur votre solde bonus.</p>
        <div class="industrial-copy-titan-group">
            <input type="text" id="refLinkOlympus" value="https://cashlink-titan.cd/register?ref=<%= user.id %>" readonly>
            <button class="btn-copy-titan-master-action" onclick="copyOlympusLink()">COPIER MON LIEN ÉLITE</button>
        </div>
    </div>

    <section class="mining-titan-terminal-box animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-end mb-2">
            <div>
                <h3 class="fw-900 mb-0 small text-uppercase">Statut en Direct du Cluster</h3>
                <p class="label-titan-xs text-muted mb-0">Moteur ID : <%= user.pack %> industrial_v3</p>
            </div>
            <div class="text-success fw-900 fs-1" style="font-family: 'Space Grotesk';"><%= p || 0 %>%</div>
        </div>
        <div class="progress-titan-industrial-track">
            <div class="bar-titan-industrial-fill animate__animated animate__pulse animate__infinite"></div>
        </div>
        <div class="d-flex flex-wrap justify-content-between mt-5 align-items-center gap-4">
            <div class="fw-900 text-warning fs-5"><i class="bi bi-hourglass-split me-3"></i>SYNCHRONISATION DANS : <span id="titan-industrial-timer">--:--:--</span></div>
            <button onclick="handleWithdrawIndustrial()" class="btn-withdraw-titan-industrial animate__animated animate__pulse animate__infinite">TRANSFÉRER VERS MON MOBILE MONEY</button>
        </div>
    </section>

    <div class="shop-titan-industrial-header" id="catalog">
        <div style="width: 15px; height: 60px; background: var(--gold); border-radius: 20px;"></div>
        <h2>Catalogue de Minage 2026-2028</h2>
    </div>

    <div class="industrial-titan-shop-grid">
        <% 
        const catalogPacks = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981', locked: false },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5', locked: false },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b', locked: false },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444', locked: false },
            { id: 'AMÉTHYSTE', price: 2500000, daily: 300000, bonus: 250000, color: '#9333ea', locked: true },
            { id: 'ÉMERAUDE', price: 5000000, daily: 700000, bonus: 600000, color: '#059669', locked: true },
            { id: 'RUBIS', price: 10000000, daily: 1500000, bonus: 1200000, color: '#dc2626', locked: true },
            { id: 'SAPHIR', price: 25000000, daily: 4000000, bonus: 3500000, color: '#2563eb', locked: true }
        ];

        catalogPacks.forEach(item => {
            const isOwned = (user.pack === item.id);
        %>
        <div class="pack-titan-industrial-card animate__animated animate__fadeInUp <%= item.locked ? 'pack-titan-industrial-locked' : '' %> <%= isOwned ? 'pack-active-titan-border' : '' %>">
            <% if(item.locked) { %><div class="lock-titan-industrial-overlay"><div class="lock-titan-industrial-badge">PRÉVU 2028</div></div><% } %>
            <div class="p-head-titan-industrial" style="background: <%= item.color %>;"><%= item.id %> INDUSTRIAL</div>
            <div class="p-body-titan-industrial">
                <div>
                    <div class="p-price-titan-industrial"><%= item.price.toLocaleString() %> FC</div>
                    <div class="p-bonus-titan-industrial">CADEAU D'ACTIVATION : +<%= item.bonus.toLocaleString() %> FC</div>
                    <div class="p-daily-titan-industrial">+<%= item.daily.toLocaleString() %> FC / JOUR</div>
                </div>
                
                <% if(isOwned) { %>
                    <button onclick="submitIndustrialPost('/activer-gain', { pack: '<%= item.id %>' })" class="btn-titan-industrial-action btn-activate-titan-industrial shadow-lg">
                        ACTIVER MAINTENANT
                    </button>
                <% } else { %>
                    <button onclick="openPaymentModal('<%= item.id %>', <%= item.price %>)" class="btn-titan-industrial-action btn-buy-titan-industrial shadow-lg">
                        ACHETER VOTRE PACK
                    </button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="industrial-faq-section" id="accIndustrial">
        <div class="accordion-titan-item shadow-lg">
            <h2 class="accordion-header"><button class="accordion-button-titan collapsed" data-bs-toggle="collapse" data-bs-target="#qa1"><i class="bi bi-info-circle-fill me-4 text-info"></i> VISION ET TECHNOLOGIE CASHLINK</button></h2>
            <div id="qa1" class="accordion-collapse collapse" data-bs-parent="#accIndustrial"><div class="accordion-titan-body"><%= content.about_text %></div></div>
        </div>
        <div class="accordion-titan-item shadow-lg">
            <h2 class="accordion-header"><button class="accordion-button-titan collapsed" data-bs-toggle="collapse" data-bs-target="#qa2"><i class="bi bi-shield-lock-fill me-4 text-success"></i> PROTOCOLE DE SÉCURITÉ ET PAIEMENTS</button></h2>
            <div id="qa2" class="accordion-collapse collapse" data-bs-parent="#accIndustrial"><div class="accordion-titan-body" style="white-space: pre-line;"><%= content.rules_text %></div></div>
        </div>
        <div class="accordion-titan-item shadow-lg">
            <h2 class="accordion-header"><button class="accordion-button-titan collapsed" data-bs-toggle="collapse" data-bs-target="#qa3"><i class="bi bi-geo-alt-fill me-4 text-danger"></i> SIÈGE ET SUPPORT TECHNIQUE</button></h2>
            <div id="qa3" class="accordion-collapse collapse" data-bs-parent="#accIndustrial">
                <div class="accordion-titan-body fs-4">
                    <strong>LOCALISATION :</strong> <%= content.contact_address %><br>
                    <strong>WHATSAPP DIRECT :</strong> +243 <%= content.contact_phone %><br>
                    <strong>EMAIL MASTER :</strong> <%= content.contact_email %>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center py-5 opacity-30">
        <h1 class="fw-900" style="font-family: 'Space Grotesk'; letter-spacing: -6px; font-size: 6rem;">CASHLINK</h1>
        <p class="small fw-bold text-uppercase fs-5">Protocole Cloud Mining v26.0 | RDC 2026</p>
        <p class="small">Déployé et Sécurisé par le Terminal ANASH MASTER</p>
    </footer>

    <div class="modal fade" id="payIndustrialModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content modal-industrial-titan text-dark shadow-lg">
                <div class="modal-body p-5 text-center">
                    <h2 class="fw-900 mb-5">RECHARGE DU TERMINAL</h2>
                    <p class="text-muted fw-bold mb-5">Transférez les fonds vers l'un des canaux administrateurs suivants :</p>
                    
                    <div class="payment-titan-industrial-card text-start">
                        <small class="text-primary fw-900 fs-6">VODACOM (M-PESA)</small>
                        <div class="fw-900 fs-3"><%= content.admin_voda %></div>
                    </div>
                    <div class="payment-titan-industrial-card text-start">
                        <small class="text-danger fw-900 fs-6">AIRTEL MONEY</small>
                        <div class="fw-900 fs-3 text-danger"><%= content.admin_airtel %></div>
                    </div>
                    <div class="payment-titan-industrial-card text-start">
                        <small class="text-warning fw-900 fs-6">ORANGE MONEY</small>
                        <div class="fw-900 fs-3 text-warning"><%= content.admin_orange %></div>
                    </div>
                    
                    <div class="alert alert-danger rounded-5 fw-900 fs-6 p-4 my-5">
                        <i class="bi bi-exclamation-octagon-fill me-3"></i> SAISISSEZ LE TID SMS APRÈS LE TRANSFERT POUR VALIDATION.
                    </div>
                    
                    <button onclick="commitIndustrialTID()" class="btn btn-primary w-100 py-4 rounded-pill fw-900 shadow-lg fs-4">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let industrialPack = ""; let industrialPrice = 0;
        const industrialModal = new bootstrap.Modal(document.getElementById('payIndustrialModal'));
        
        // --- SCROLL TOP TITAN ---
        window.onscroll = function() {
            const btn = document.getElementById('scrollTopTitanIndustrial');
            btn.style.display = (document.body.scrollTop > 500 || document.documentElement.scrollTop > 500) ? "flex" : "none";
        };

        // --- COPY OLYMPUS LINK ---
        function copyOlympusLink() {
            const i = document.getElementById('refLinkOlympus'); i.select();
            document.execCommand('copy'); triggerIndustrialToast("Lien de parrainage copié avec succès !");
        }

        // --- GESTION DES PACKS ---
        function openPaymentModal(id, price) { industrialPack = id; industrialPrice = price; industrialModal.show(); }

        function commitIndustrialTID() {
            industrialModal.hide();
            const tid = prompt("Veuillez saisir la référence (TID) SMS :");
            if(tid && tid.length > 5) {
                submitIndustrialPost('/souscrire-pack', { packName: industrialPack, prix: industrialPrice, reference: tid });
            } else {
                alert("ID de transaction non reconnu.");
            }
        }

        function handleWithdrawIndustrial() {
            const m = prompt("Montant du retrait Mobile Money (Min 1.000 FC) :");
            if(m >= 1000) submitIndustrialPost('/retrait', { montant: m });
            else alert("Montant insuffisant.");
        }

        function submitIndustrialPost(path, data) {
            const form = document.createElement('form'); form.method = 'POST'; form.action = path;
            for (const key in data) { const i = document.createElement('input'); i.type = 'hidden'; i.name = key; i.value = data[key]; form.appendChild(i); }
            document.body.appendChild(form); form.submit();
        }

        // --- TIMER OLYMPUS 24H ---
        setInterval(() => {
            const now = new Date(); const next = new Date(); next.setHours(24, 0, 0, 0); const diff = next - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            document.getElementById('titan-industrial-timer').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        // --- TOASTS INDUSTRIELS ---
        function triggerIndustrialToast(msg) {
            const t = document.getElementById('titan-toast-industrial-container');
            document.getElementById('toast-industrial-msg').innerText = msg;
            t.style.display = "flex"; setTimeout(() => t.style.display = "none", 6000);
        }

        const networkNames = ["Patrick", "Bijou", "Sarah", "Guelord", "Mado", "Junior", "Elvis"];
        const networkActs = ["vient de retirer 25.000 FC", "a activé un pack DIAMOND", "a parrainé un nouveau membre", "a reçu son bonus journalier"];
        setInterval(() => {
            if(Math.random() > 0.4) triggerIndustrialToast(`${networkNames[Math.floor(Math.random()*networkNames.length)]} ${networkActs[Math.floor(Math.random()*networkActs.length)]}`);
        }, 25000);
    </script>
</body>
</html>
