<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Interface Elite v3.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* --- CONFIGURATION DES VARIABLES --- */
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --emerald: #10b981;
            --rose: #f43f5e;
            --gold: #fbbf24;
            --dark-deep: #000c26;
            --glass-white: rgba(255, 255, 255, 0.1);
            --glass-dark: rgba(0, 0, 0, 0.2);
            --transition-smooth: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        /* --- RÉGLAGES GÉNÉRAUX DU CORPS --- */
        body {
            background-color: var(--bleu-bic);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 50%),
                radial-gradient(at 100% 100%, var(--dark-deep) 0px, transparent 50%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* --- BARRE DE NAVIGATION (NAVBAR) --- */
        .premium-nav {
            background: var(--gold);
            padding: 8px 15px;
            position: sticky;
            top: 0;
            z-index: 2000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
            border-bottom: 4px solid rgba(0,0,0,0.1);
        }

        @media (min-width: 992px) { .premium-nav { padding: 12px 60px; } }

        .logo-brand { 
            font-weight: 900; 
            color: var(--bleu-bic); 
            font-size: 1.4rem; 
            text-decoration: none !important; 
            letter-spacing: -2px;
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-brand:hover { transform: scale(1.02); opacity: 0.9; }
        @media (min-width: 768px) { .logo-brand { font-size: 2rem; } }
        
        .nav-info-box {
            background: #ffffff;
            padding: 5px 12px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #0f172a;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.15);
        }
        @media (min-width: 768px) { .nav-info-box { padding: 10px 25px; gap: 25px; } }

        .solde-badge { border-right: 2px solid #f1f5f9; padding-right: 12px; }
        .label-xs { font-size: 0.5rem; font-weight: 800; text-transform: uppercase; color: #94a3b8; display: block; line-height: 1; margin-bottom: 2px; }
        .val-md { font-weight: 900; font-size: 0.9rem; color: var(--bleu-bic); line-height: 1; }
        @media (min-width: 768px) { .val-md { font-size: 1.2rem; } .label-xs { font-size: 0.65rem; } }

        /* --- SECTION PUBLICITAIRE --- */
        .hero-banner {
            width: 100%;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            border-radius: 0 0 35px 35px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            overflow: hidden;
            margin-bottom: 20px;
        }
        @media (min-width: 768px) { .hero-banner { height: 280px; flex-direction: row; border-radius: 0 0 50px 50px; } }

        .banner-left {
            width: 100%;
            background: #ffffff;
            color: #000;
            padding: 30px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }
        @media (min-width: 768px) { .banner-left { width: 45%; padding: 50px; align-items: flex-start; text-align: left; } }

        .banner-right { width: 100%; background: #ffffff; display: none; }
        @media (min-width: 768px) { .banner-right { width: 55%; display: block; } }

        .carousel-item img {
            width: 100%;
            height: 280px;
            object-fit: contain;
            padding: 20px;
            background: #fff;
        }

        /* --- ÉLÉMENTS DE STATISTIQUES --- */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            padding: 10px 20px;
        }
        @media (min-width: 992px) { .stats-container { grid-template-columns: repeat(4, 1fr); padding: 20px 60px; gap: 25px; } }

        .stat-glass-card {
            background: var(--glass-white);
            backdrop-filter: blur(12px);
            padding: 20px;
            border-radius: 25px;
            border: 1px solid rgba(255,255,255,0.15);
            transition: var(--transition-smooth);
        }
        .stat-glass-card:hover { background: rgba(255,255,255,0.18); transform: translateY(-5px); }
        .stat-icon { font-size: 1.8rem; color: var(--neon-blue); margin-bottom: 8px; }

        /* --- SECTION MINAGE --- */
        .mining-area {
            background: var(--glass-dark);
            margin: 15px;
            padding: 25px;
            border-radius: 35px;
            border: 1px solid rgba(255,255,255,0.08);
            position: relative;
            overflow: hidden;
        }
        @media (min-width: 992px) { .mining-area { margin: 30px 60px; padding: 45px; border-radius: 45px; } }

        .progress-master {
            height: 30px;
            background: rgba(255,255,255,0.05);
            border-radius: 50px;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.3);
            overflow: hidden;
            margin: 15px 0;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .bar-elite {
            background: linear-gradient(90deg, var(--neon-blue), var(--emerald));
            box-shadow: 0 0 20px rgba(0, 217, 255, 0.5);
        }

        /* --- BOUTIQUE DE PACKS --- */
        .shop-header {
            padding: 0 25px;
            margin: 40px 0 30px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        @media (min-width: 992px) { .shop-header { padding: 0 60px; } }

        .shop-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            padding: 0 15px 80px;
        }
        @media (min-width: 992px) { .shop-grid { grid-template-columns: repeat(4, 1fr); padding: 0 60px 120px; gap: 30px; } }

        .card-elite-pack {
            background: #ffffff;
            border-radius: 40px;
            overflow: hidden;
            transition: var(--transition-smooth);
            color: #0f172a;
            display: flex;
            flex-direction: column;
            border: none;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }
        .card-elite-pack:hover { transform: translateY(-12px); box-shadow: 0 30px 60px rgba(0,0,0,0.4); }
        .is-active { border: 6px solid var(--neon-blue) !important; transform: scale(1.03); }

        .card-top { padding: 20px; text-align: center; color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; font-size: 0.9rem; }
        .card-body-custom { padding: 25px; text-align: center; flex-grow: 1; }
        
        .price-tag { font-size: 1.8rem; font-weight: 900; margin: 15px 0; letter-spacing: -1px; }
        @media (min-width: 768px) { .price-tag { font-size: 2.6rem; } }

        .btn-action-elite {
            width: 100%;
            padding: 18px;
            border-radius: 22px;
            border: none;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
            font-size: 0.8rem;
        }
        .btn-buy { background: var(--bleu-bic); color: #fff; }
        .btn-invest { background: var(--emerald); color: #fff; }
        .btn-active { background: #64748b; color: #fff; cursor: not-allowed; }

        /* --- SECTIONS LÉGALES --- */
        .legal-section {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            margin: 20px 15px;
            padding: 30px;
            border-radius: 35px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        @media (min-width: 992px) { .legal-section { margin: 40px 60px; padding: 50px; } }

        /* --- NOTIFICATION FLOTTANTE --- */
        #floating-notif {
            position: fixed;
            bottom: 100px;
            left: 20px;
            background: white;
            color: black;
            padding: 12px 20px;
            border-radius: 20px;
            display: none;
            align-items: center;
            gap: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            z-index: 5000;
            animation: slideInUp 0.5s forwards;
        }

        /* --- BOUTON RETOUR EN HAUT --- */
        #backToTop {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 55px;
            height: 55px;
            background: var(--gold);
            color: var(--bleu-bic);
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            cursor: pointer;
            z-index: 3000;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            transition: 0.3s;
            border: 2px solid rgba(0,0,0,0.1);
        }
        #backToTop:hover { transform: translateY(-5px); background: #fff; }

        /* --- MODAL PAIEMENT --- */
        .modal-elite { border-radius: 40px !important; border: none; overflow: hidden; }
        .payment-box {
            background: #f8fafc;
            padding: 20px;
            border-radius: 25px;
            margin-bottom: 15px;
            border: 2px solid #e2e8f0;
            transition: 0.3s;
        }
        .payment-box:hover { border-color: var(--bleu-bic); background: #fff; }

        /* --- ANIMATIONS --- */
        .fade-up { animation: fadeInUp 0.8s ease-out forwards; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <div id="floating-notif">
        <div class="bg-success rounded-circle p-2 text-white"><i class="bi bi-check-lg"></i></div>
        <div>
            <div class="fw-900 small" id="notif-user">Jean-Pierre</div>
            <div class="small text-muted">Vient de retirer <span class="fw-bold text-success" id="notif-sum">45.000 FC</span></div>
        </div>
    </div>

    <div id="backToTop" onclick="scrollToTop()">
        <i class="bi bi-arrow-up"></i>
    </div>

    <nav class="premium-nav">
        <div class="nav-left d-flex align-items-center gap-2 gap-lg-4">
            <a href="/" class="logo-brand animate__animated animate__fadeInLeft">
                <i class="bi bi-cpu-fill"></i> CASHLINK
            </a>
            <div class="nav-info-box animate__animated animate__zoomIn">
                <div class="solde-badge">
                    <span class="label-xs">Mon Solde</span>
                    <div class="val-md"><%= (user.solde || 0).toLocaleString() %> FC</div>
                </div>
                <div>
                    <span class="label-xs text-success">Bonus Actif</span>
                    <div class="val-md text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
                </div>
            </div>
        </div>
        
        <div class="d-flex align-items-center gap-2 gap-lg-4">
            <div class="text-end d-none d-md-block text-dark animate__animated animate__fadeIn">
                <div class="fw-900 fs-5 line-height-1"><%= user.username %></div>
                <div class="small fw-bold opacity-75">Niveau : ELITE V3</div>
            </div>
            <a href="/logout" class="btn btn-dark rounded-pill fw-900 px-4 py-2 shadow-sm">
                <i class="bi bi-power me-2"></i> <span class="d-none d-sm-inline">DÉCONNEXION</span>
            </a>
        </div>
    </nav>

    <header class="hero-banner">
        <div class="banner-left">
            <span class="badge bg-primary mb-3 px-3 py-2 rounded-pill"><%= content.tag_tech %></span>
            <h1 class="fw-900 display-5 mb-2"><%= content.titre_principal %></h1>
            <p class="text-muted fw-bold mb-4"><%= content.description %></p>
            <button onclick="document.getElementById('boutique').scrollIntoView({behavior:'smooth'})" class="btn btn-primary rounded-pill px-5 py-3 fw-900 shadow">DÉCOUVRIR LES OFFRES</button>
        </div>
        <div class="banner-right">
            <div id="tradingCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="https://img.freepik.com/free-vector/gradient-stock-market-concept_23-2149166910.jpg" alt="Trading 1">
                    </div>
                    <div class="carousel-item">
                        <img src="https://img.freepik.com/free-vector/digital-money-transfer-technology-background_1017-17454.jpg" alt="Trading 2">
                    </div>
                    <div class="carousel-item">
                        <img src="https://img.freepik.com/free-vector/gradient-cryptocurrency-concept_23-2149151121.jpg" alt="Trading 3">
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="stats-container">
        <div class="stat-glass-card">
            <i class="bi bi-lightning-charge-fill stat-icon"></i>
            <span class="label-xs">Puissance Hash</span>
            <div class="fs-4 fw-900"><%= content.puissance_hash %></div>
        </div>
        <div class="stat-glass-card">
            <i class="bi bi-people-fill stat-icon" style="color: var(--emerald);"></i>
            <span class="label-xs">Réseau Elite</span>
            <div class="fs-4 fw-900"><%= content.reseau_status %></div>
        </div>
        <div class="stat-glass-card">
            <i class="bi bi-shield-shaded stat-icon" style="color: var(--gold);"></i>
            <span class="label-xs">Sécurité</span>
            <div class="fs-4 fw-900"><%= content.securite_type %></div>
        </div>
        <div class="stat-glass-card">
            <i class="bi bi-currency-exchange stat-icon" style="color: var(--rose);"></i>
            <span class="label-xs">Retraits 24h</span>
            <div class="fs-4 fw-900"><%= content.retraits_status %></div>
        </div>
    </div>

    <section class="mining-area fade-up">
        <div class="row align-items-center g-4">
            <div class="col-xl-8">
                <div class="d-flex justify-content-between align-items-end mb-2">
                    <div>
                        <h5 class="fw-900 mb-0"><i class="bi bi-activity me-2"></i>PROCESSUS DE MINAGE</h5>
                        <p class="small text-muted mb-0">Contrat de 30 jours en cours d'exécution</p>
                    </div>
                    <div class="text-info fw-900 fs-3"><%= p || 0 %>%</div>
                </div>
                <div class="progress-master">
                    <div class="progress-bar bar-elite progress-bar-striped progress-bar-animated" style="width: <%= p || 0 %>%"></div>
                </div>
                <div class="d-flex flex-wrap gap-4 mt-3">
                    <div class="small fw-bold"><i class="bi bi-calendar-event me-2 text-info"></i>Activation : <%= user.investDate ? new Date(user.investDate).toLocaleDateString() : 'N/A' %></div>
                    <div class="small fw-bold"><i class="bi bi-hdd-network me-2 text-info"></i>Machine : <%= user.pack %></div>
                    <div class="small fw-bold text-warning"><i class="bi bi-clock me-2"></i>Prochain gain : <span id="timer-gain">--:--:--</span></div>
                </div>
            </div>
            <div class="col-xl-4 text-center text-xl-end">
                <button onclick="handleWithdraw()" class="btn btn-danger w-100 w-xl-auto px-5 py-4 rounded-4 fw-900 shadow-lg animate__animated animate__pulse animate__infinite">
                    <i class="bi bi-wallet2 me-2"></i> RÉCUPÉRER MES PROFITS
                </button>
            </div>
        </div>
    </section>

    <div class="shop-header" id="boutique">
        <div style="width: 8px; height: 40px; background: var(--gold); border-radius: 10px;"></div>
        <h3 class="fw-900 mb-0 text-uppercase">Boutique d'Investissement</h3>
    </div>

    <div class="shop-grid">
        <% 
        const items = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' }
        ];

        items.forEach(item => {
            const isUserPack = (user.pack === item.id);
            const hasAnyPack = (user.pack && user.pack !== 'Aucun');
            const enoughMoney = (user.solde >= item.price);
        %>
        <div class="card-elite-pack <%= isUserPack ? 'is-active' : '' %> animate__animated animate__fadeInUp">
            <div class="card-top" style="background: <%= item.color %>;"><%= item.id %> MINER</div>
            <div class="card-body-custom">
                <div class="bonus-tag">BONUS : +<%= item.bonus.toLocaleString() %> FC</div>
                <div class="price-tag"><%= item.price.toLocaleString() %> <span class="fs-6 fw-bold">FC</span></div>
                <div class="fw-900 fs-5 mb-4" style="color: <%= item.color %>;">+<%= item.daily.toLocaleString() %> FC / JOUR</div>
                
                <div class="text-start mb-4">
                    <div class="small fw-bold mb-2"><i class="bi bi-check2-circle text-success me-2"></i>Contrat : 30 Jours</div>
                    <div class="small fw-bold mb-2"><i class="bi bi-check2-circle text-success me-2"></i>Support : 24h/7j</div>
                    <div class="small fw-bold"><i class="bi bi-check2-circle text-success me-2"></i>Retrait : Quotidien</div>
                </div>

                <% if(isUserPack) { %>
                    <button class="btn-action-elite btn-active">UNITE ACTIVE</button>
                <% } else if (hasAnyPack) { %>
                    <button class="btn-action-elite btn-active" title="Un seul pack à la fois">INDISPONIBLE</button>
                <% } else if (enoughMoney) { %>
                    <button onclick="confirmInvestAction('<%= item.id %>', <%= item.price %>)" class="btn-action-elite btn-invest shadow">ACTIVER MAINTENANT</button>
                <% } else { %>
                    <button onclick="openPaymentModal('<%= item.id %>', <%= item.price %>)" class="btn-action-elite btn-buy shadow">ACHETER L'UNITÉ</button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="legal-section animate__animated animate__fadeIn">
        <h3 class="fw-900 text-gold mb-3 text-uppercase">À Propos de <%= content.brand_name %></h3>
        <p class="opacity-75"><%= content.about_text %></p>
    </div>

    <div class="legal-section animate__animated animate__fadeIn">
        <h3 class="fw-900 text-info mb-3 text-uppercase">Règles du Système</h3>
        <div class="opacity-75" style="white-space: pre-line;"><%= content.rules_text %></div>
    </div>

    <div class="legal-section animate__animated animate__fadeIn mb-5" id="contact-info">
        <h3 class="fw-900 text-rose mb-3 text-uppercase">Contact et Adresse</h3>
        <p class="mb-2 fw-bold"><i class="bi bi-geo-alt-fill me-2"></i> Siège Social : <span class="fw-normal"><%= content.contact_address %></span></p>
        <p class="mb-2 fw-bold"><i class="bi bi-envelope-fill me-2"></i> Support Email : <span class="fw-normal"><%= content.contact_email %></span></p>
        <p class="mb-0 fw-bold"><i class="bi bi-telephone-fill me-2"></i> Hotline : <span class="fw-normal"><%= content.contact_phone %></span></p>
    </div>

    <footer class="text-center py-5" style="background: rgba(0,0,0,0.5);">
        <p class="fw-bold small mb-1"><%= content.footer_text %></p>
        <p class="small opacity-50"><%= content.footer_sub %></p>
    </footer>

    <div class="modal fade" id="paymentModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3 mx-md-auto">
            <div class="modal-content modal-elite text-dark">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-4 p-md-5">
                    <h3 class="fw-900 mb-2">RECHARGE COMPTE</h3>
                    <p class="text-muted small fw-bold mb-4">Effectuez le transfert vers l'un des numéros ci-dessous</p>
                    
                    <div class="payment-box">
                        <span class="label-xs text-primary">M-PESA (VODACOM)</span>
                        <div class="fs-4 fw-900"><%= content.admin_voda %></div>
                    </div>

                    <div class="payment-box">
                        <span class="label-xs text-danger">AIRTEL MONEY</span>
                        <div class="fs-4 fw-900 text-danger"><%= content.admin_airtel %></div>
                    </div>

                    <div class="payment-box">
                        <span class="label-xs text-warning">ORANGE MONEY</span>
                        <div class="fs-4 fw-900 text-warning"><%= content.admin_orange %></div>
                    </div>

                    <div class="alert alert-warning rounded-4 small fw-bold mt-4">
                        <i class="bi bi-info-circle-fill me-2"></i> Après l'envoi, cliquez sur le bouton ci-dessous pour soumettre votre TID.
                    </div>

                    <button onclick="handleTID()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 mt-3 shadow-lg">J'AI ENVOYÉ LE PAIEMENT</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // --- VARIABLES GLOBALES ---
        let packEnAttente = "";
        let prixEnAttente = 0;
        const pModal = new bootstrap.Modal(document.getElementById('paymentModal'));
        const btnTop = document.getElementById('backToTop');

        // --- GESTION DU SCROLL (RETOUR EN HAUT) ---
        window.onscroll = function() {
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                btnTop.style.display = "flex";
            } else {
                btnTop.style.display = "none";
            }
        };

        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // --- ACTIONS BOUTIQUE ---
        function openPaymentModal(id, price) {
            packEnAttente = id;
            prixEnAttente = price;
            pModal.show();
        }

        function handleTID() {
            pModal.hide();
            const tid = prompt("Veuillez saisir la référence (TID) de la transaction :");
            if(tid && tid.length > 5) {
                submitFinalData('/souscrire-pack', {
                    packName: packEnAttente,
                    prix: prixEnAttente,
                    reference: tid
                });
            } else {
                alert("Référence invalide ou trop courte.");
            }
        }

        function confirmInvestAction(id, price) {
            if(confirm(`Souhaitez-vous déduire ${price.toLocaleString()} FC de votre solde pour activer le pack ${id} ?`)) {
                submitFinalData('/activer-investissement', {
                    packName: id,
                    prix: price
                });
            }
        }

        function handleWithdraw() {
            const m = prompt("Montant du retrait (Minimum 1.000 FC) :");
            if(m && m >= 1000) {
                submitFinalData('/retrait', { montant: m });
            } else {
                alert("Le montant minimum de retrait est de 1.000 FC.");
            }
        }

        // --- ENVOI DES DONNÉES (POST) ---
        function submitFinalData(path, data) {
            const f = document.createElement('form');
            f.method = 'POST';
            f.action = path;
            for (const key in data) {
                const i = document.createElement('input');
                i.type = 'hidden';
                i.name = key;
                i.value = data[key];
                f.appendChild(i);
            }
            document.body.appendChild(f);
            f.submit();
        }

        // --- TIMER DE GAIN QUOTIDIEN ---
        function startTimer() {
            setInterval(() => {
                const now = new Date();
                const next = new Date();
                next.setHours(24, 0, 0, 0);
                const diff = next - now;

                const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const s = Math.floor((diff % (1000 * 60)) / 1000);

                document.getElementById('timer-gain').innerText = 
                    (h < 10 ? "0"+h : h) + ":" + 
                    (m < 10 ? "0"+m : m) + ":" + 
                    (s < 10 ? "0"+s : s);
            }, 1000);
        }
        
        startTimer();

        // --- NOTIFICATIONS AUTOMATIQUES RÉELLES ---
        function showNotification() {
            const names = ["Jean-Paul", "Modeste", "Mado", "Patrick", "Guelord", "Sarah", "Elvis", "Clémentine", "Justin"];
            const amounts = ["25.000", "45.000", "150.000", "500.000", "12.500", "200.000"];
            
            const n = document.getElementById('floating-notif');
            document.getElementById('notif-user').innerText = names[Math.floor(Math.random() * names.length)];
            document.getElementById('notif-sum').innerText = amounts[Math.floor(Math.random() * amounts.length)] + " FC";
            
            n.style.display = "flex";
            setTimeout(() => { n.style.display = "none"; }, 5000);
        }
        
        // Lance une notification toutes les 15-20 secondes
        setInterval(showNotification, 18000);
    </script>
</body>
</html>
