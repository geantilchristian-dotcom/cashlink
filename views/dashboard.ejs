<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CASH LINK | GLOBAL MINING TERMINAL</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           MOTEUR DE DESIGN "PREMIUM TITAN" v6.0
           ============================================================ */
        :root {
            --primary: #003399;
            --accent: #00d9ff;
            --success: #10b981;
            --warning: #fbbf24;
            --danger: #f43f5e;
            --dark: #000c26;
            --white: #ffffff;
            --glass: rgba(255, 255, 255, 0.08);
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }

        body {
            background-color: var(--dark);
            background-image: radial-gradient(circle at 10% 10%, #001f5c, transparent 40%), url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--white);
            margin: 0; padding: 0; min-height: 100vh;
        }

        /* --- NAVIGATION --- */
        .master-nav {
            background: var(--warning);
            height: 90px;
            padding: 0 25px;
            position: sticky; top: 0; z-index: 3000;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 15px 40px rgba(0,0,0,0.6);
        }

        .brand-text {
            font-weight: 900; font-size: 2rem; color: var(--primary);
            letter-spacing: -2px; text-decoration: none !important;
            text-transform: uppercase;
        }

        .balance-pill {
            background: var(--white);
            padding: 10px 25px;
            border-radius: 60px;
            display: flex; align-items: center; gap: 20px;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.15);
        }

        .bal-item { display: flex; flex-direction: column; line-height: 1.1; }
        .bal-label { font-size: 0.6rem; font-weight: 800; color: #64748b; text-transform: uppercase; }
        .bal-val { font-size: 1.1rem; font-weight: 900; color: var(--primary); }

        /* --- HERO SECTION --- */
        .hero-section {
            background: var(--white);
            padding: 90px 25px;
            text-align: center;
            border-radius: 0 0 70px 70px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5);
            color: #000;
            margin-bottom: 50px;
        }
        .hero-title { font-size: 3.5rem; font-weight: 900; color: var(--primary); margin-bottom: 25px; letter-spacing: -3px; line-height: 0.9; }
        .hero-p { font-size: 1.3rem; font-weight: 700; color: #475569; max-width: 800px; margin: 0 auto 35px; }

        .btn-action-certif {
            background: var(--primary); color: white; border: none;
            padding: 18px 45px; border-radius: 60px; font-weight: 900;
            text-transform: uppercase; transition: var(--transition);
            box-shadow: 0 15px 35px rgba(0, 51, 153, 0.3);
        }
        .btn-action-certif:hover { transform: scale(1.05); background: #000; }

        /* --- MINING CARD --- */
        .mining-container { padding: 0 20px 60px; }
        .mining-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(30px);
            border: 1px solid var(--glass);
            border-radius: 55px; padding: 55px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.6);
        }

        .mining-progress-track {
            height: 20px; background: rgba(255,255,255,0.08);
            border-radius: 50px; overflow: hidden; margin: 35px 0;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .mining-progress-fill {
            background: linear-gradient(90deg, var(--accent), var(--success));
            height: 100%; transition: width 2s ease;
            position: relative; box-shadow: 0 0 30px rgba(0, 217, 255, 0.5);
        }

        .stat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 30px; margin-bottom: 50px; }
        @media (min-width: 992px) { .stat-grid { grid-template-columns: repeat(4, 1fr); } }

        .stat-box { text-align: center; }
        .stat-label { font-size: 0.7rem; font-weight: 800; color: var(--accent); text-transform: uppercase; margin-bottom: 10px; display: block; }
        .stat-value { font-size: 1.4rem; font-weight: 900; color: #fff; }

        /* --- PACKS GRID --- */
        .section-header { padding: 0 25px; margin-bottom: 35px; border-left: 8px solid var(--warning); }
        .section-header h3 { font-weight: 900; text-transform: uppercase; margin: 0; font-size: 1.8rem; }

        .pack-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 20px; padding: 0 20px 100px;
        }
        @media (min-width: 1200px) { .pack-grid { grid-template-columns: repeat(4, 1fr); gap: 35px; padding: 0 80px 150px; } }

        .pack-card {
            background: var(--white);
            border-radius: 40px; overflow: hidden;
            display: flex; flex-direction: column;
            box-shadow: 0 25px 60px rgba(0,0,0,0.6);
            height: 380px; /* HAUTEUR AJUSTÉE POUR LE BONUS */
            transition: var(--transition);
            border: none;
        }
        .pack-card:hover { transform: translateY(-15px); }

        .p-head { padding: 18px; text-align: center; color: white; font-weight: 900; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }
        .p-body { padding: 30px; text-align: center; color: var(--dark); flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-price { font-size: 1.8rem; font-weight: 900; color: var(--primary); letter-spacing: -1.5px; margin-bottom: 5px; }
        .p-income { font-size: 1rem; font-weight: 800; color: var(--success); margin-bottom: 15px; }
        
        .p-bonus-tag { 
            background: #f1f5f9; padding: 8px; border-radius: 15px; 
            font-size: 0.8rem; font-weight: 800; color: var(--danger);
            border: 1px dashed var(--danger); margin-bottom: 20px;
        }

        .btn-buy-pack {
            background: var(--primary); color: white; border: none;
            width: 100%; padding: 18px; border-radius: 20px;
            font-weight: 900; font-size: 0.9rem; text-transform: uppercase;
            box-shadow: 0 10px 25px rgba(0, 51, 153, 0.2);
        }

        /* --- INFO SECTIONS (À PROPOS / RÈGLES) --- */
        .info-panel {
            background: rgba(255, 255, 255, 0.02);
            margin: 0 20px 50px; padding: 60px 40px;
            border-radius: 50px; border: 1px solid var(--glass);
        }
        .info-panel h4 { font-weight: 900; color: var(--warning); margin-bottom: 30px; text-transform: uppercase; }
        .info-panel p { line-height: 1.8; font-weight: 500; opacity: 0.8; font-size: 1.1rem; }

        .address-box {
            display: grid; grid-template-columns: repeat(1, 1fr); gap: 30px;
            margin-top: 50px; border-top: 1px solid var(--glass); padding-top: 50px;
        }
        @media (min-width: 768px) { .address-box { grid-template-columns: repeat(3, 1fr); } }

        /* --- FOOTER --- */
        .master-footer {
            background: #000; padding: 100px 20px; text-align: center;
        }

        .modal-titan { border-radius: 50px !important; overflow: hidden; border: none; }
    </style>
</head>
<body>

    <nav class="master-nav">
        <div class="d-flex align-items-center gap-4">
            <a href="/" class="btn btn-primary rounded-circle p-3 shadow-lg"><i class="bi bi-house-fill fs-4"></i></a>
            <a href="#" class="brand-text">CASH LINK</a>
        </div>
        
        <div class="balance-pill animate__animated animate__fadeInDown">
            <div class="bal-item" style="border-right: 2px solid #f1f5f9; padding-right: 25px;">
                <span class="bal-label">Capital Actuel</span>
                <span class="bal-val"><%= (user.solde || 0).toLocaleString() %> FC</span>
            </div>
            <div class="bal-item">
                <span class="bal-label text-success">Accumulation Bonus</span>
                <span class="bal-val text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</span>
            </div>
        </div>

        <div class="d-none d-md-block text-end" style="color: var(--primary);">
            <div class="fw-900 fs-5"><%= user.username %></div>
            <div class="fw-bold small">+243 <%= user.phone %></div>
        </div>
    </nav>

    <header class="hero-section animate__animated animate__fadeIn">
        <h1 class="hero-title">MINAGE AUTOMATIQUE</h1>
        <p class="hero-p">Le futur de la liberté financière est arrivé. Activez vos unités de minage globales et générez des revenus passifs chaque seconde, sans interruption.</p>
        <div class="mt-5">
            <button onclick="reqCertif()" class="btn-action-certif">
                <i class="bi bi-shield-check-fill me-2"></i> ACTIVER MA CERTIFICATION ELITE
            </button>
        </div>
    </header>

    <div class="mining-container">
        <div class="mining-card animate__animated animate__fadeInUp">
            <div class="d-flex justify-content-between align-items-end">
                <div>
                    <h4 class="fw-900 text-accent mb-0">PROGRESSION DES GAINS</h4>
                    <p class="small opacity-50 fw-bold mb-0">Synchronisation globale avec les serveurs de minage...</p>
                </div>
                <div class="text-accent fw-900 fs-1"><%= p || 0 %>%</div>
            </div>

            <div class="mining-progress-track">
                <div class="mining-progress-fill" style="width: <%= p || 0 %>%"></div>
            </div>

            <div class="stat-grid">
                <div class="stat-box">
                    <span class="stat-label">UNITÉ CONNECTÉE</span>
                    <div class="stat-value text-accent"><%= content.puissance_hash %></div>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Statut Réseau</span>
                    <div class="stat-value text-success">OPÉRATIONNEL</div>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Machine Active</span>
                    <div class="stat-value"><%= user.pack %></div>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Temps de Gain</span>
                    <div id="timer" class="stat-value text-warning">00:00:00</div>
                </div>
            </div>

            <button onclick="requestWithdrawal()" class="btn btn-danger w-100 py-4 rounded-4 fw-900 shadow-lg fs-4 animate__animated animate__pulse animate__infinite">
                <i class="bi bi-wallet2 me-3"></i> RETIRER MES PROFITS
            </button>
            <div class="text-center mt-4">
                <% if(user.certified) { %>
                    <span class="badge bg-success px-4 py-2 rounded-pill fw-900"><i class="bi bi-patch-check-fill me-2"></i> RETRAIT : TOUTES LES 24H</span>
                <% } else { %>
                    <span class="badge bg-light text-dark px-4 py-2 rounded-pill fw-900 opacity-75"><i class="bi bi-clock-history me-2"></i> RETRAIT : TOUS LES 3 JOURS</span>
                <% } %>
            </div>
        </div>
    </div>

    <div class="section-header mx-4" id="packs">
        <h3>UNITÉS DE MINAGE 2026</h3>
    </div>

    <div class="pack-grid">
        <% 
        const packDefinitions = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' }
        ];
        packDefinitions.forEach(pack => {
            const isOwned = (user.pack === pack.id);
        %>
        <div class="pack-card animate__animated animate__fadeInUp">
            <div class="p-head" style="background: <%= pack.color %>;"><%= pack.id %> UNIT</div>
            <div class="p-body">
                <div>
                    <span class="bal-label">Investissement</span>
                    <div class="p-price"><%= pack.price.toLocaleString() %> FC</div>
                    <div class="p-income">+<%= pack.daily.toLocaleString() %> FC / JOUR</div>
                    
                    <div class="p-bonus-tag">
                        <i class="bi bi-gift-fill me-2"></i>BONUS ACTIVATION : <%= pack.bonus.toLocaleString() %> FC
                    </div>
                </div>

                <% if(isOwned) { %>
                    <button class="btn btn-success w-100 rounded-pill py-3 fw-900 shadow-sm" disabled>UNITÉ OPÉRATIONNELLE</button>
                <% } else { %>
                    <button onclick="buyPack('<%= pack.id %>', <%= pack.price %>)" class="btn-buy-pack">ACHETER L'UNITÉ</button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <div class="info-panel animate__animated animate__fadeIn">
        <div class="row g-5">
            <div class="col-lg-6">
                <h4><i class="bi bi-info-circle-fill me-3"></i>À PROPOS DE CASH LINK</h4>
                <p><%= content.about_text %></p>
            </div>
            <div class="col-lg-6">
                <h4><i class="bi bi-shield-lock-fill me-3"></i>RÈGLES DU SYSTÈME</h4>
                <p style="white-space: pre-line;"><%= content.rules_text %></p>
            </div>
        </div>

        <div class="address-box">
            <div>
                <h6 class="bal-label text-warning mb-3">SIÈGE SOCIAL INTERNATIONAL</h6>
                <div class="fw-bold"><i class="bi bi-geo-alt-fill me-2 text-danger"></i><%= content.contact_address %></div>
            </div>
            <div>
                <h6 class="bal-label text-warning mb-3">SUPPORT TECHNIQUE 24/7</h6>
                <div class="fw-bold"><i class="bi bi-envelope-at-fill me-2 text-primary"></i><%= content.contact_email %></div>
            </div>
            <div>
                <h6 class="bal-label text-warning mb-3">HOTLINE DIRECTE</h6>
                <div class="fw-bold"><i class="bi bi-headset me-2 text-success"></i>+243 <%= content.contact_phone %></div>
            </div>
        </div>
    </div>

    <footer class="master-footer">
        <h2 class="fw-900 text-warning mb-3">CASH LINK</h2>
        <p class="small opacity-50 mb-5">LEADER MONDIAL DU MINAGE CLOUD DÉCENTRALISÉ</p>
        <div class="d-flex justify-content-center gap-5 fs-1 opacity-20 mb-5">
            <i class="bi bi-shield-fill-check"></i><i class="bi bi-cpu-fill"></i><i class="bi bi-globe"></i>
        </div>
        <hr class="opacity-10 my-5">
        <small class="opacity-30 fw-bold">© 2026 CASH LINK GLOBAL TERMINAL | TOUS DROITS RÉSERVÉS</small>
    </footer>

    <div class="modal fade" id="paymentModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content modal-titan text-dark">
                <div class="modal-body p-4 p-md-5 text-center">
                    <h3 class="fw-900 mb-2">RECHARGE COMPTE</h3>
                    <p class="text-muted small fw-bold mb-5">Sélectionnez votre réseau de paiement local</p>
                    
                    <div class="row g-3 mb-5">
                        <div class="col-4"><button onclick="setNet('VODA')" class="btn btn-outline-primary w-100 fw-900 rounded-4 py-3">VODA</button></div>
                        <div class="col-4"><button onclick="setNet('AIRTEL')" class="btn btn-outline-danger w-100 fw-900 rounded-4 py-3">AIRTEL</button></div>
                        <div class="col-4"><button onclick="setNet('ORANGE')" class="btn btn-outline-warning w-100 fw-900 rounded-4 py-3 text-dark">ORANGE</button></div>
                    </div>

                    <div id="payment-info" class="p-4 bg-light rounded-4 mb-4 text-start animate__animated animate__fadeIn" style="display:none;">
                        <span id="p-label" class="bal-label">RÉSEAU SÉLECTIONNÉ</span>
                        <div class="fs-4 fw-900 text-primary d-flex justify-content-between align-items-center mt-2">
                            <span id="p-num">+243 000 000 000</span>
                            <i class="bi bi-clipboard-check-fill fs-2" style="cursor:pointer;" onclick="copyNum()"></i>
                        </div>
                    </div>

                    <div class="alert alert-warning small rounded-4 py-3 border-0 shadow-sm mb-4 fw-bold">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i> IMPORTANT : Veuillez saisir l'ID (TID) qui se trouve dans le message (SMS) de confirmation que votre réseau vous a envoyé.
                    </div>

                    <button onclick="submitTransaction()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 shadow-lg fs-5">J'AI ENVOYÉ LES FONDS</button>
                    <button type="button" class="btn btn-link btn-sm text-muted mt-3 fw-bold" data-bs-dismiss="modal">ANNULER</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selectedP = "", selectedPr = 0, currentTerminal = "";
        const pModal = new bootstrap.Modal(document.getElementById('paymentModal'));

        function setNet(net) {
            const box = document.getElementById('payment-info');
            const label = document.getElementById('p-label');
            const num = document.getElementById('p-num');
            box.style.display = "block";
            
            if(net==='VODA'){ label.innerText="M-PESA (VODACOM RDC)"; currentTerminal="+243 <%= content.admin_voda %>"; }
            if(net==='AIRTEL'){ label.innerText="AIRTEL MONEY (RDC)"; currentTerminal="+243 <%= content.admin_airtel %>"; }
            if(net==='ORANGE'){ label.innerText="ORANGE MONEY (RDC)"; currentTerminal="+243 <%= content.admin_orange %>"; }
            num.innerText = currentTerminal;
        }

        function buyPack(id, pr) { selectedP = id; selectedPr = pr; pModal.show(); }

        function reqCertif() {
            if(confirm("La certification coûte 10.000 FC et permet des retraits toutes les 24h. Continuer ?")) {
                selectedP = "CERTIFICATION"; selectedPr = 10000; pModal.show();
            }
        }

        function submitTransaction() {
            pModal.hide();
            const tid = prompt("Veuillez saisir l'ID (TID) de la transaction (Ex: PP260328.1242.H42886) :");
            if(tid && tid.length > 5) {
                postForm('/souscrire-pack', { packName: selectedP, prix: selectedPr, reference: tid });
            }
        }

        function requestWithdrawal() {
            const amt = prompt("Montant à retirer (Minimum 1.000 FC) :");
            if(amt && amt >= 1000) postForm('/retrait', { montant: amt });
        }

        function postForm(path, params) {
            const f = document.createElement('form'); f.method = 'POST'; f.action = path;
            for(let key in params) {
                const i = document.createElement('input'); i.type='hidden'; i.name=key; i.value=params[key]; f.appendChild(i);
            }
            document.body.appendChild(f); f.submit();
        }

        function copyNum() { navigator.clipboard.writeText(currentTerminal); alert("Numéro de terminal copié !"); }

        // TIMER GAINS
        setInterval(() => {
            const now = new Date(), target = new Date();
            target.setHours(24, 0, 0, 0);
            const diff = target - now;
            const h = Math.floor(diff/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
            document.getElementById('timer').innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);
    </script>
</body>
</html>
