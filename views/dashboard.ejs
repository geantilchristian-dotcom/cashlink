<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= content.brand_name %> | Interface Elite v28.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@700;900&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
            MOTEUR DE DESIGN "TITAN OLYMPUS" - 600 LIGNES DE STYLE
           ============================================================ */
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --emerald: #10b981;
            --rose: #f43f5e;
            --gold: #fbbf24;
            --dark-deep: #000c26;
            --glass-white: rgba(255, 255, 255, 0.15);
            --glass-dark: rgba(0, 0, 0, 0.55);
            --transition-titan: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }

        /* CONFIGURATION GLOBALE DÉTAILLÉE */
        ::-webkit-scrollbar { width: 14px; }
        ::-webkit-scrollbar-track { background: var(--dark-deep); }
        ::-webkit-scrollbar-thumb { 
            background: var(--gold); 
            border-radius: 20px; 
            border: 4px solid var(--dark-deep); 
            box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        }

        * { 
            box-sizing: border-box; 
            -webkit-tap-highlight-color: transparent; 
            outline: none !important; 
            margin: 0; 
            padding: 0;
        }

        body {
            background-color: var(--bleu-bic);
            background-image: 
                radial-gradient(at 0% 0%, #0044cc 0px, transparent 55%),
                radial-gradient(at 100% 100%, var(--dark-deep) 0px, transparent 55%),
                url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            line-height: 1.6;
        }

        /* --- BARRE DE NAVIGATION TITAN (NAVBAR) --- */
        .premium-nav-titan {
            background: var(--gold);
            padding: 18px 20px;
            position: sticky;
            top: 0;
            z-index: 9999;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.7);
            border-bottom: 6px solid rgba(0,0,0,0.25);
        }
        @media (min-width: 992px) { .premium-nav-titan { padding: 25px 100px; } }

        .logo-titan-industrial { 
            font-family: 'Space Grotesk', sans-serif; 
            font-weight: 900; 
            color: var(--bleu-bic); 
            font-size: 2rem; 
            text-decoration: none !important; 
            letter-spacing: -4px; 
            transition: var(--transition-titan);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-titan-industrial:hover { transform: scale(1.1); filter: brightness(1.2); }
        
        .nav-info-box-titan {
            background: #ffffff;
            padding: 12px 28px;
            border-radius: 100px;
            display: flex;
            align-items: center;
            gap: 20px;
            color: #0f172a;
            box-shadow: inset 0 3px 18px rgba(0,0,0,0.3);
            border: 2px solid rgba(255,255,255,0.5);
        }
        .solde-badge-industrial { border-right: 3.5px solid #e2e8f0; padding-right: 22px; }
        .label-titan-bold { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: #64748b; display: block; line-height: 1; margin-bottom: 5px; }
        .val-titan-heavy { font-weight: 900; font-size: 1.3rem; color: var(--bleu-bic); line-height: 1; font-family: 'Space Grotesk'; }

        .btn-logout-industrial {
            background: var(--dark-deep);
            color: white;
            border: none;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            transition: var(--transition-titan);
        }
        .btn-logout-industrial:hover { background: var(--rose); transform: rotate(180deg); }

        /* --- SECTION MARKETING (HERO BANNER BLANC) --- */
        .hero-industrial-banner {
            width: 100%;
            background: #ffffff;
            border-radius: 0 0 70px 70px;
            box-shadow: 0 35px 80px rgba(0,0,0,0.5);
            margin-bottom: 50px;
            padding: 100px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .hero-industrial-banner::after { content: ""; position: absolute; bottom: 0; left: 0; width: 100%; height: 15px; background: var(--gold); }
        
        .hero-title-titan-heavy { 
            font-family: 'Space Grotesk'; 
            font-weight: 900; 
            color: var(--bleu-bic); 
            font-size: clamp(3rem, 15vw, 6rem); 
            line-height: 0.75; 
            margin-bottom: 30px; 
            letter-spacing: -6px; 
        }
        .hero-para-titan-heavy { 
            color: #334155; 
            font-weight: 700; 
            font-size: 1.4rem; 
            max-width: 900px; 
            margin: 0 auto 45px; 
            line-height: 1.7; 
        }
        .user-id-badge-industrial { 
            background: var(--bleu-bic); 
            color: #fff; 
            padding: 15px 45px; 
            border-radius: 100px; 
            font-weight: 900; 
            font-size: 1.1rem; 
            display: inline-block; 
            margin-bottom: 25px; 
            box-shadow: 0 18px 40px rgba(0, 51, 153, 0.35); 
        }

        /* --- STATISTIQUES GÉANTES --- */
        .stats-industrial-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            padding: 10px 25px;
        }
        @media (min-width: 992px) { .stats-industrial-grid { grid-template-columns: repeat(4, 1fr); padding: 20px 100px; gap: 45px; } }

        .stat-industrial-card {
            background: var(--glass-white);
            backdrop-filter: blur(25px);
            padding: 45px 30px;
            border-radius: 50px;
            border: 3px solid rgba(255,255,255,0.3);
            text-align: center;
            transition: var(--transition-titan);
        }
        .stat-industrial-card:hover { transform: translateY(-15px); border-color: var(--gold); background: rgba(255,255,255,0.2); }
        .stat-industrial-icon { font-size: 3rem; color: var(--neon-blue); margin-bottom: 20px; display: block; text-shadow: 0 0 20px rgba(0, 217, 255, 0.4); }
        
        .btn-certif-industrial { 
            background: var(--gold); 
            color: #000; 
            border: none; 
            width: 100%; 
            padding: 18px; 
            border-radius: 25px; 
            font-weight: 900; 
            font-size: 0.9rem; 
            text-transform: uppercase; 
            margin-top: 30px; 
            letter-spacing: 2px; 
            box-shadow: 0 15px 40px rgba(251, 191, 36, 0.6); 
        }

        /* --- SYSTÈME DE PARRAINAGE 10% --- */
        .referral-industrial-container {
            background: var(--glass-dark);
            margin: 40px 30px;
            padding: 60px;
            border-radius: 70px;
            border: 6px dashed var(--gold);
            text-align: center;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
        }
        @media (min-width: 992px) { .referral-industrial-container { margin: 60px 100px; } }
        .ref-title-industrial { font-family: 'Space Grotesk'; font-weight: 900; color: var(--gold); margin-bottom: 25px; text-transform: uppercase; letter-spacing: 4px; font-size: 2.8rem; }
        
        .industrial-copy-group {
            background: #ffffff;
            padding: 12px;
            border-radius: 45px;
            display: flex;
            align-items: center;
            gap: 25px;
            margin-top: 40px;
            box-shadow: 0 30px 70px rgba(0,0,0,0.5);
        }
        .industrial-copy-group input { background: transparent; border: none; color: #000; font-weight: 900; font-size: 1.2rem; width: 100%; padding-left: 35px; font-family: 'JetBrains Mono'; }
        .btn-copy-industrial-action { background: var(--bleu-bic); color: #fff; border: none; padding: 22px 50px; border-radius: 35px; font-weight: 900; text-transform: uppercase; font-size: 1rem; letter-spacing: 1px; }

        /* --- TERMINAL DE MINAGE (LOGIQUE VERTE) --- */
        .mining-industrial-terminal {
            background: var(--glass-dark);
            margin: 40px 30px;
            padding: 60px;
            border-radius: 70px;
            border: 3px solid rgba(255,255,255,0.25);
            position: relative;
        }
        .progress-industrial-track {
            height: 55px;
            background: rgba(0,0,0,0.8);
            border-radius: 100px;
            overflow: hidden;
            margin: 45px 0;
            border: 4px solid rgba(255,255,255,0.25);
            padding: 10px;
            box-shadow: inset 0 10px 30px rgba(0,0,0,0.5);
        }
        .bar-industrial-emerald-fill {
            background: linear-gradient(90deg, #10b981, #059669, #34d399);
            box-shadow: 0 0 60px rgba(16, 185, 129, 0.9);
            border-radius: 100px;
            height: 100%;
            width: <%= p || 0 %>%;
            transition: width 3s ease-in-out;
        }
        .btn-withdraw-industrial-heavy {
            background: var(--rose);
            color: white;
            border: none;
            width: 100%;
            padding: 35px;
            border-radius: 50px;
            font-weight: 900;
            font-size: 2rem;
            text-transform: uppercase;
            box-shadow: 0 30px 80px rgba(244, 63, 94, 0.7);
            margin-top: 35px;
            letter-spacing: 3px;
            transition: var(--transition-titan);
        }

        /* ============================================================
            AJUSTEMENT MOBILE : STYLE ALIBABA COMPACT (GRILLE DE 2)
           ============================================================ */
        .shop-industrial-header { padding: 0 16px; margin: 24px 0 16px; display: flex; align-items: center; gap: 14px; }
        .shop-industrial-header h2 { font-family: 'Space Grotesk'; font-weight: 900; font-size: 1.4rem; text-transform: uppercase; letter-spacing: -0.5px; color:#fff; margin:0; }

        .industrial-shop-grid-full {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            padding: 0 12px 80px;
        }

        @media (min-width: 992px) { 
            .industrial-shop-grid-full { grid-template-columns: repeat(2, 1fr); gap: 50px; padding: 0 100px 200px; } 
        }
        @media (min-width: 1600px) { 
            .industrial-shop-grid-full { grid-template-columns: repeat(4, 1fr); } 
        }

        .pack-industrial-heavy-card {
            background: #ffffff;
            border-radius: 20px; 
            overflow: hidden;
            color: #0f172a;
            min-height: auto; 
            display: flex;
            flex-direction: column;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            transition: var(--transition-titan);
            position: relative;
            border: none;
        }

        @media (max-width: 768px) {
            /* SUPPRESSION DE L'ESPACE VIDE BLANC SOULIGNÉ */
            .p-head-industrial-heavy { padding: 12px 5px !important; font-size: 0.65rem !important; letter-spacing: 0px !important; }
            .p-body-industrial-heavy { padding: 10px 8px !important; } /* Réduction du padding pour enlever le vide */
            
            /* TAILLE DE TEXTE COMPACTE (STYLE ALIBABA) */
            .p-price-industrial-heavy { font-size: 1.1rem !important; letter-spacing: -1px !important; margin: 8px 0 !important; }
            .p-bonus-industrial-heavy { font-size: 0.55rem !important; padding: 5px !important; border-radius: 8px !important; border-width: 1px !important; margin-bottom: 8px !important; }
            .p-daily-industrial-heavy { font-size: 0.8rem !important; margin-bottom: 12px !important; }
            
            .industrial-details-list { margin: 5px 0 !important; padding: 5px 0 !important; border-top: 1px solid #f1f5f9 !important; }
            .industrial-details-list li { font-size: 0.5rem !important; margin-bottom: 4px !important; gap: 4px !important; }
            .industrial-details-list li i { font-size: 0.7rem !important; }
            
            .btn-industrial-heavy-action { padding: 12px 5px !important; border-radius: 12px !important; font-size: 0.7rem !important; }
            .lock-industrial-badge { padding: 10px 20px !important; font-size: 0.8rem !important; border-radius: 50px !important; }
        }

        /* Styles Desktop d'origine conservés */
        .pack-industrial-heavy-card:hover { transform: translateY(-30px); filter: brightness(1.05); }
        .pack-industrial-active-border { border: 8px solid var(--emerald) !important; transform: scale(1.02); z-index: 50; }
        .pack-industrial-locked-mode { filter: grayscale(1) opacity(0.6); }
        .lock-industrial-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 60; display: flex; align-items: center; justify-content: center; pointer-events: none; }
        .lock-industrial-badge { background: var(--gold); color: #000; padding: 8px 20px; border-radius: 30px; font-weight: 900; font-size: 0.75rem; box-shadow: 0 8px 20px rgba(0,0,0,0.5); letter-spacing: 1.5px; }
        .p-head-industrial-heavy { padding: 45px; text-align: center; color: #fff; font-weight: 900; text-transform: uppercase; font-size: 1.5rem; letter-spacing: 5px; }
        .p-body-industrial-heavy { padding: 55px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .p-price-industrial-heavy { font-size: 3.5rem; font-weight: 900; color: var(--bleu-bic); margin: 25px 0 15px; font-family: 'Space Grotesk'; letter-spacing: -4px; line-height: 0.9; }
        .p-bonus-industrial-heavy { font-size: 1.2rem; font-weight: 900; color: var(--rose); background: #fff0f0; border: 4px dashed var(--rose); padding: 18px; border-radius: 30px; margin-bottom: 15px; }
        .p-daily-industrial-heavy { font-weight: 900; color: var(--emerald); font-size: 2.2rem; letter-spacing: -2px; margin-bottom: 35px; }
        .industrial-details-list { text-align: left; margin: 30px 0; padding: 30px 0; list-style: none; border-top: 3px solid #f1f5f9; }
        .industrial-details-list li { font-weight: 800; color: #475569; margin-bottom: 18px; display: flex; align-items: center; gap: 15px; font-size: 1.1rem; }
        .industrial-details-list li i { color: var(--emerald); font-size: 1.5rem; }
        .btn-buy-industrial-heavy { background: var(--bleu-bic); color: #fff; }
        .btn-activate-industrial-heavy { background: var(--emerald); color: #fff; box-shadow: 0 25px 50px rgba(16, 185, 129, 0.6); }
        .btn-industrial-heavy-action { width: 100%; padding: 30px; border-radius: 45px; border: none; font-weight: 900; text-transform: uppercase; font-size: 1.4rem; transition: 0.4s; box-shadow: 0 25px 60px rgba(0,0,0,0.3); }

        /* --- TOASTS & SCROLL --- */
        #titan-toast-industrial-heavy { position: fixed; bottom: 50px; left: 50px; z-index: 9999; background: #ffffff; color: #000; padding: 40px 55px; border-radius: 45px; box-shadow: 0 40px 100px rgba(0,0,0,0.9); display: none; align-items: center; gap: 40px; border-left: 20px solid var(--emerald); }
        #scrollTopIndustrialHeavy { position: fixed; bottom: 50px; right: 50px; width: 100px; height: 100px; background: var(--gold); color: var(--bleu-bic); border-radius: 50%; border: none; display: none; align-items: center; justify-content: center; font-size: 4rem; z-index: 9500; box-shadow: 0 40px 80px rgba(0,0,0,0.8); }

        /* --- FAQ --- */
        .industrial-faq-titan { margin: 80px 30px 200px; }
        .accordion-titan-industrial-item { background: var(--glass-dark) !important; border: 3px solid rgba(255,255,255,0.25) !important; color: #fff !important; margin-bottom: 40px; border-radius: 60px !important; overflow: hidden; }
        .accordion-titan-industrial-button { background: transparent !important; color: #fff !important; font-weight: 900; padding: 50px; font-size: 1.8rem; }
        .accordion-titan-industrial-body { padding: 60px; opacity: 1; font-size: 1.4rem; line-height: 2.5; }

        .modal-titan-industrial-heavy { border-radius: 80px !important; border: none; overflow: hidden; }
        .payment-titan-industrial-heavy-card { background: #f8fafc; padding: 45px; border-radius: 50px; border: 6px solid #e2e8f0; margin-bottom: 35px; transition: 0.5s; }
        .payment-titan-industrial-heavy-card:hover { border-color: var(--bleu-bic); transform: translateX(30px); }

          /* ============================================================
             OPTIMISATION MOBILE MAXIMALE - TOUS ÉCRANS < 768px
             ============================================================ */
          @media (max-width: 767px) {

              /* NAVBAR */
              .premium-nav-titan { padding: 10px 12px !important; }
              .logo-titan-industrial { font-size: 1.2rem !important; letter-spacing: -2px !important; }
              .nav-info-box-titan { padding: 7px 12px !important; gap: 8px !important; border-radius: 50px !important; }
              .val-titan-heavy { font-size: 0.85rem !important; }
              .label-titan-bold { font-size: 0.5rem !important; margin-bottom: 2px !important; }
              .solde-badge-industrial { padding-right: 10px !important; border-right-width: 2px !important; }
              .btn-logout-industrial { width: 34px !important; height: 34px !important; flex-shrink: 0; }
              .btn-logout-industrial i { font-size: 0.85rem !important; }

              /* HERO BANNER */
              .hero-industrial-banner { padding: 35px 15px 45px !important; border-radius: 0 0 30px 30px !important; margin-bottom: 20px !important; }
              .hero-title-titan-heavy { font-size: 2.2rem !important; letter-spacing: -2px !important; margin-bottom: 12px !important; line-height: 0.85 !important; }
              .hero-para-titan-heavy { font-size: 0.85rem !important; line-height: 1.5 !important; margin: 0 0 18px !important; }
              .user-id-badge-industrial { font-size: 0.6rem !important; padding: 8px 16px !important; margin-bottom: 12px !important; }
              .hero-industrial-banner .btn { font-size: 0.85rem !important; padding: 12px 22px !important; }

              /* STATS GRID */
              .stats-industrial-grid { gap: 10px !important; padding: 10px !important; }
              .stat-industrial-card { padding: 18px 10px !important; border-radius: 18px !important; border-width: 2px !important; }
              .stat-industrial-icon { font-size: 1.6rem !important; margin-bottom: 8px !important; }
              .stat-industrial-card .val-titan-heavy { font-size: 0.85rem !important; }
              .btn-certif-industrial { padding: 10px !important; font-size: 0.6rem !important; margin-top: 10px !important; letter-spacing: 0 !important; border-radius: 10px !important; }

              /* PARRAINAGE */
              .referral-industrial-container { margin: 15px 10px !important; padding: 22px 14px !important; border-radius: 25px !important; border-width: 3px !important; }
              .ref-title-industrial { font-size: 1.2rem !important; letter-spacing: 1px !important; margin-bottom: 10px !important; }
              .referral-industrial-container p.fs-4 { font-size: 0.8rem !important; }
              .industrial-copy-group { flex-direction: column !important; padding: 10px !important; gap: 8px !important; margin-top: 15px !important; border-radius: 18px !important; }
              .industrial-copy-group input { font-size: 0.75rem !important; padding-left: 10px !important; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
              .btn-copy-industrial-action { padding: 12px !important; border-radius: 12px !important; font-size: 0.75rem !important; width: 100% !important; letter-spacing: 0 !important; }

              /* TERMINAL MINAGE */
              .mining-industrial-terminal { margin: 15px 10px !important; padding: 18px 14px !important; border-radius: 22px !important; }
              .mining-industrial-terminal .d-flex.justify-content-between { flex-wrap: wrap; gap: 5px; }
              .mining-industrial-terminal h3.fw-900 { font-size: 0.7rem !important; }
              .mining-industrial-terminal p.label-titan-bold { font-size: 0.55rem !important; }
              .mining-industrial-terminal .text-success.fw-900.fs-1 { font-size: 1.3rem !important; }
              .progress-industrial-track { height: 30px !important; margin: 15px 0 !important; border-width: 2px !important; padding: 4px !important; }
              .btn-withdraw-industrial-heavy { padding: 16px 10px !important; font-size: 0.85rem !important; border-radius: 18px !important; margin-top: 12px !important; letter-spacing: 0.5px !important; box-shadow: 0 8px 25px rgba(244,63,94,0.5) !important; }
              .mining-industrial-terminal .fw-900.text-warning { font-size: 0.75rem !important; }
              .mining-industrial-terminal .d-flex.flex-wrap { gap: 10px !important; margin-top: 15px !important; }

              /* SHOP HEADER */
              .shop-industrial-header { padding: 0 12px !important; margin: 35px 0 18px !important; gap: 10px !important; }
              .shop-industrial-header > div:first-child { width: 6px !important; height: 35px !important; border-radius: 8px !important; }
              .shop-industrial-header h2 { font-size: 1.3rem !important; letter-spacing: -0.5px !important; }

              /* FAQ */
              .industrial-faq-titan { margin: 25px 10px 60px !important; }
              .accordion-titan-industrial-item { border-radius: 18px !important; margin-bottom: 12px !important; border-width: 2px !important; }
              .accordion-titan-industrial-button { padding: 16px 14px !important; font-size: 0.85rem !important; }
              .accordion-titan-industrial-button i { margin-right: 10px !important; font-size: 0.9rem !important; }
              .accordion-titan-industrial-body { padding: 16px 14px !important; font-size: 0.85rem !important; line-height: 1.7 !important; }

              /* FOOTER */
              footer h1 { font-size: 2.2rem !important; letter-spacing: -3px !important; }
              footer p { font-size: 0.7rem !important; }

              /* TOAST */
              #titan-toast-industrial-heavy { bottom: 10px !important; left: 8px !important; right: 8px !important; padding: 14px 16px !important; border-radius: 18px !important; gap: 12px !important; border-left-width: 6px !important; }
              #titan-toast-industrial-heavy i { font-size: 1.5rem !important; }
              #toast-industrial-heavy-msg { font-size: 0.8rem !important; }
              #titan-toast-industrial-heavy .small { font-size: 0.55rem !important; }

              /* BOUTON SCROLL TOP */
              #scrollTopIndustrialHeavy { width: 45px !important; height: 45px !important; bottom: 12px !important; right: 12px !important; font-size: 1.3rem !important; }

              /* MODAL PAIEMENT */
              .modal-dialog { margin: 8px !important; }
              .modal-titan-industrial-heavy { border-radius: 25px !important; }
              .modal-body.p-5 { padding: 20px 16px !important; }
              .modal-body h2.fw-900 { font-size: 1.2rem !important; margin-bottom: 16px !important; }
              .payment-titan-industrial-heavy-card { padding: 16px !important; border-radius: 18px !important; border-width: 3px !important; margin-bottom: 12px !important; }
              .payment-titan-industrial-heavy-card small { font-size: 0.7rem !important; }
              .payment-titan-industrial-heavy-card .fw-900.fs-2 { font-size: 1.1rem !important; }
              .modal-body .alert { padding: 14px !important; font-size: 0.8rem !important; border-radius: 15px !important; margin: 12px 0 !important; }
              .modal-body .btn { font-size: 0.85rem !important; padding: 12px !important; }
          }
      
        /* ============================================================
