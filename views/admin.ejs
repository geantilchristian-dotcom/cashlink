<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TERMINAL DE CONTRÔLE | CASHLINK ELITE v3.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --bg-master: #000c24;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
            --neon-blue: #00d9ff;
            --sidebar-width: 290px;
        }

        body {
            background-color: var(--bg-master);
            background-image: radial-gradient(circle at 50% -20%, #001a4d, transparent);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff; margin: 0; overflow-x: hidden;
        }

        .admin-sidebar {
            width: var(--sidebar-width); height: 100vh;
            background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(30px);
            position: fixed; left: 0; top: 0; padding: 40px 20px;
            border-right: 1px solid var(--border-glass); z-index: 1000;
        }

        .nav-item-custom {
            display: flex; align-items: center; gap: 15px; padding: 15px 22px;
            color: rgba(255,255,255,0.4); text-decoration: none; border-radius: 20px;
            margin-bottom: 10px; font-weight: 700; cursor: pointer; transition: 0.3s;
        }

        .nav-item-custom.active { background: var(--neon-blue); color: #000; box-shadow: 0 0 25px rgba(0, 217, 255, 0.3); }

        .admin-main-content { margin-left: var(--sidebar-width); padding: 50px; }

        .glass-card {
            background: var(--card-glass); border: 1px solid var(--border-glass);
            border-radius: 40px; padding: 40px; margin-bottom: 40px;
        }

        .stat-val { font-size: 2.2rem; font-weight: 800; color: var(--neon-blue); }
        .stat-label { font-size: 0.75rem; text-transform: uppercase; font-weight: 800; opacity: 0.5; }

        .premium-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; }
        .premium-table td { background: rgba(255,255,255,0.02); padding: 20px; border: none; font-size: 0.95rem; font-weight: 600; border-radius: 20px; }

        .admin-label { font-size: 0.7rem; font-weight: 800; color: var(--neon-blue); text-transform: uppercase; margin-bottom: 8px; display: block; }
        .admin-input {
            background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border-glass);
            border-radius: 18px; padding: 15px 20px; color: white; width: 100%; margin-bottom: 20px;
        }

        .btn-update { background: var(--neon-blue); color: #000; border: none; padding: 18px; border-radius: 20px; font-weight: 800; width: 100%; text-transform: uppercase; cursor: pointer; transition: 0.3s; }
        .btn-update:hover { transform: scale(1.02); background: #fff; }

        .section-panel { display: none; }
        .section-panel.active { display: block; animation: fadeInUp 0.5s ease-out; }
        
        #admin-alert { position: fixed; top: 20px; right: 20px; z-index: 9999; display: none; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <audio id="notif-sound" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3"></audio>

    <div id="admin-alert" class="animate__animated animate__bounceIn">
        <div class="alert alert-info border-0 shadow-lg rounded-4 p-3 d-flex align-items-center gap-3">
            <div class="bg-info p-2 rounded-3 text-white"><i class="bi bi-bell-fill"></i></div>
            <div>
                <strong class="d-block">Nouvelle activité !</strong>
                <small>Consultez les dépôts ou retraits.</small>
            </div>
        </div>
    </div>

    <div class="admin-sidebar">
        <div class="text-center mb-5">
            <div class="p-3 mb-3 animate__animated animate__pulse animate__infinite" style="background: var(--neon-blue); border-radius: 22px; display: inline-block;">
                <i class="bi bi-cpu-fill text-dark fs-3"></i>
            </div>
            <h5 class="fw-900 text-white">ELITE COMMAND</h5>
            <span class="badge bg-danger rounded-pill">MASTER RDC 2026</span>
        </div>

        <div class="nav-menu">
            <div class="nav-item-custom active" onclick="openTab('stats', this)"><i class="bi bi-graph-up"></i> Performances</div>
            <div class="nav-item-custom" onclick="openTab('validations', this)"><i class="bi bi-check2-circle"></i> Dépôts TID <% if(stats.enAttente > 0){ %><span class="badge bg-danger ms-auto"><%= stats.enAttente %></span><% } %></div>
            <div class="nav-item-custom" onclick="openTab('retraits_tab', this)"><i class="bi bi-cash-stack"></i> Retraits</div>
            <div class="nav-item-custom" onclick="openTab('interface', this)"><i class="bi bi-pencil-square"></i> Modifier Dashboard</div>
            <div class="nav-item-custom" onclick="openTab('legal', this)"><i class="bi bi-file-earmark-text"></i> Contenu Légal</div>
            <div class="nav-item-custom" onclick="openTab('members', this)"><i class="bi bi-people"></i> Investisseurs</div>
        </div>

        <div style="margin-top: 50px;">
            <a href="/" class="nav-item-custom text-info"><i class="bi bi-arrow-left"></i> VOIR LE SITE</a>
        </div>
    </div>

    <div class="admin-main-content">

        <div id="stats" class="section-panel active">
            <h3 class="fw-800 mb-5 text-white">STATISTIQUES SYSTÈME</h3>
            <div class="row g-4 mb-4">
                <div class="col-md-4"><div class="glass-card text-center"><span class="stat-label">Membres</span><div class="stat-val"><%= stats.totalUsers %></div></div></div>
                <div class="col-md-4"><div class="glass-card text-center"><span class="stat-label">En Attente</span><div class="stat-val text-warning"><%= stats.enAttente %></div></div></div>
                <div class="col-md-4"><div class="glass-card text-center"><span class="stat-label">Capital Global</span><div class="stat-val text-info"><%= stats.soldeTotalUsers.toLocaleString() %> FC</div></div></div>
            </div>
        </div>

        <form action="/admin/update-content" method="POST">

            <div id="interface" class="section-panel">
                <div class="glass-card">
                    <h4 class="fw-900 text-info mb-4">Pilotage du Dashboard & Paiements</h4>
                    <div class="row">
                        <div class="col-md-6 border-end border-secondary">
                            <h6 class="text-info mb-3">NUMÉROS OFFICIELS</h6>
                            <label class="admin-label">M-PESA (VODACOM)</label>
                            <input type="text" name="admin_voda" class="admin-input" value="<%= site.admin_voda %>">
                            <label class="admin-label">AIRTEL MONEY</label>
                            <input type="text" name="admin_airtel" class="admin-input" value="<%= site.admin_airtel %>">
                            <label class="admin-label">ORANGE MONEY</label>
                            <input type="text" name="admin_orange" class="admin-input" value="<%= site.admin_orange %>">
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <h6 class="text-warning mb-3">TEXTES D'ACCUEIL</h6>
                            <label class="admin-label">Nom de la Marque</label>
                            <input type="text" name="brand_name" class="admin-input" value="<%= site.brand_name %>">
                            <label class="admin-label">Étiquette Tech</label>
                            <input type="text" name="tag_tech" class="admin-input" value="<%= site.tag_tech %>">
                            <label class="admin-label">Titre Principal</label>
                            <input type="text" name="titre_principal" class="admin-input" value="<%= site.titre_principal %>">
                            <label class="admin-label">Description / Slogan</label>
                            <textarea name="description" class="admin-input" rows="2"><%= site.description %></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div id="legal" class="section-panel">
                <div class="glass-card">
                    <h4 class="fw-900 text-info mb-4">Pages d'Information & Contact</h4>
                    <label class="admin-label">À Propos de nous</label>
                    <textarea name="about_text" class="admin-input" rows="4"><%= site.about_text %></textarea>
                    
                    <label class="admin-label">Règles du Système</label>
                    <textarea name="rules_text" class="admin-input" rows="4"><%= site.rules_text %></textarea>
                    
                    <div class="row">
                        <div class="col-md-4">
                            <label class="admin-label">Siège Social (Adresse)</label>
                            <input type="text" name="contact_address" class="admin-input" value="<%= site.contact_address %>">
                        </div>
                        <div class="col-md-4">
                            <label class="admin-label">Email Support</label>
                            <input type="text" name="contact_email" class="admin-input" value="<%= site.contact_email %>">
                        </div>
                        <div class="col-md-4">
                            <label class="admin-label">Hotline (+243...)</label>
                            <input type="text" name="contact_phone" class="admin-input" value="<%= site.contact_phone %>">
                        </div>
                    </div>
                </div>
            </div>

            <div id="save-area" style="display:none;">
                <button type="submit" class="btn-update shadow-lg">💾 SAUVEGARDER TOUS LES CHANGEMENTS</button>
            </div>
        </form>

        <div id="validations" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-info mb-4">Approbation des Dépôts</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead><tr class="text-muted"><th>Pack</th><th>Référence TID</th><th>Montant</th><th>Action</th></tr></thead>
                        <tbody>
                            <% transactions.filter(t => t.statut === 'En attente').forEach(tx => { %>
                            <tr>
                                <td><span class="badge bg-primary"><%= tx.type %></span></td>
                                <td class="text-white fw-bold"><code><%= tx.reference %></code></td>
                                <td><%= tx.montant.toLocaleString() %> FC</td>
                                <td>
                                    <form action="/valider-depot" method="POST">
                                        <input type="hidden" name="txId" value="<%= tx._id %>">
                                        <button class="btn btn-success btn-sm rounded-pill px-4">VALIDER</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="retraits_tab" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-warning mb-4">Demandes de Retrait Bonus</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead><tr class="text-muted"><th>Utilisateur</th><th>Montant</th><th>Date</th><th>Action</th></tr></thead>
                        <tbody>
                            <% retraits.filter(r => r.statut === 'En attente').forEach(req => { %>
                            <tr>
                                <td class="text-white"><%= req.username %></td>
                                <td class="text-warning fw-bold"><%= req.montant.toLocaleString() %> FC</td>
                                <td class="small opacity-50"><%= req.date %></td>
                                <td>
                                    <form action="/admin/payer-retrait" method="POST">
                                        <input type="hidden" name="requestId" value="<%= req._id %>">
                                        <button class="btn btn-warning btn-sm rounded-pill px-4 fw-bold text-dark">MARQUER PAYÉ</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="members" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-white mb-4">Journal des Investisseurs</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead><tr class="text-muted"><th>Nom d'utilisateur</th><th>Machine Active</th><th>Solde</th><th>Bonus</th></tr></thead>
                        <tbody>
                            <% users.forEach(u => { %>
                            <tr>
                                <td class="text-white"><%= u.username %></td>
                                <td><span class="badge bg-dark"><%= u.pack || 'Aucun' %></span></td>
                                <td class="text-info fw-bold"><%= u.solde.toLocaleString() %> FC</td>
                                <td class="text-success fw-bold">+<%= u.bonus.toLocaleString() %> FC</td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function openTab(tabId, btn) {
            // Cacher tous les panels
            document.querySelectorAll('.section-panel').forEach(s => s.classList.remove('active'));
            // Afficher le panel sélectionné
            document.getElementById(tabId).classList.add('active');
            
            // Gérer le style des boutons du menu
            document.querySelectorAll('.nav-item-custom').forEach(n => n.classList.remove('active'));
            btn.classList.add('active');

            // Afficher le bouton de sauvegarde seulement pour l'interface et le légal
            const saveArea = document.getElementById('save-area');
            if (tabId === 'interface' || tabId === 'legal') {
                saveArea.style.display = 'block';
            } else {
                saveArea.style.display = 'none';
            }
        }

        // Système d'alerte sonore
        let currentEnAttente = <%= stats.enAttente %>;
        if (currentEnAttente > 0) {
            document.getElementById('admin-alert').style.display = 'block';
            document.getElementById('notif-sound').play().catch(() => {});
        }
    </script>
</body>
</html>
