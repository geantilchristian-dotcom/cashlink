<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ELITE SYSTEM COMMAND | CASHLINK MASTER</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --bg-master: #000c24;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
            --neon-blue: #00d9ff;
            --neon-purple: #bc13fe;
            --emerald: #10b981;
            --rose: #f43f5e;
            --gold: #ffb400;
            --sidebar-width: 290px;
        }

        body {
            background-color: var(--bg-master);
            background-image: radial-gradient(circle at 50% -20%, #001a4d, transparent);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff; margin: 0; overflow-x: hidden;
        }
        .admin-layout-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* --- SIDEBAR --- */
        .admin-sidebar {
            width: 260px;
            min-width: 260px;
            flex-shrink: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(30px);
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            padding: 30px 16px;
            border-right: 1px solid var(--border-glass);
            z-index: 100;
            display: flex;
            flex-direction: column;
        }

        .nav-item-custom {
            display: flex; align-items: center; gap: 15px; padding: 15px 22px;
            color: rgba(255,255,255,0.4); text-decoration: none; border-radius: 20px;
            margin-bottom: 10px; font-weight: 700; cursor: pointer; transition: 0.3s;
        }

        .nav-item-custom:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-item-custom.active { background: var(--neon-blue); color: #000; box-shadow: 0 0 25px rgba(0, 217, 255, 0.3); }

        /* --- MAIN CONTENT --- */
        .admin-main-content { flex: 1; min-width: 0; padding: 40px 36px; overflow-x: hidden; }


        .glass-card {
            background: var(--card-glass); border: 1px solid var(--border-glass);
            border-radius: 40px; padding: 40px; margin-bottom: 40px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
        }

        .stat-val { font-size: 2.2rem; font-weight: 800; color: var(--neon-blue); letter-spacing: -1px; }
        .stat-label { font-size: 0.75rem; text-transform: uppercase; font-weight: 800; opacity: 0.5; letter-spacing: 1px; }

        /* --- TABLES --- */
        .premium-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; }
        .premium-table thead th { padding: 0 20px 10px; font-size: 0.7rem; text-transform: uppercase; color: var(--neon-blue); border: none; }
        .premium-table td { background: rgba(255,255,255,0.02); padding: 20px; border: none; font-size: 0.95rem; font-weight: 600; vertical-align: middle; transition: 0.3s; }
        .premium-table tr td:first-child { border-radius: 20px 0 0 20px; border-left: 4px solid transparent; }
        .premium-table tr:hover td { background: rgba(255,255,255,0.05); }
        .premium-table tr:hover td:first-child { border-left-color: var(--neon-blue); }
        .premium-table tr td:last-child { border-radius: 0 20px 20px 0; }

        .admin-label { font-size: 0.7rem; font-weight: 800; color: var(--neon-blue); text-transform: uppercase; margin-bottom: 8px; display: block; }
        .admin-input {
            background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border-glass);
            border-radius: 18px; padding: 15px 20px; color: white; width: 100%; margin-bottom: 20px;
            font-weight: 600; transition: 0.3s;
        }
        .btn-update { background: var(--neon-blue); color: #000; border: none; padding: 18px; border-radius: 20px; font-weight: 800; width: 100%; text-transform: uppercase; cursor: pointer; }

        .section-panel { display: none; animation: fadeInUp 0.5s ease-out; }
        .section-panel.active { display: block; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

        .badge-vip { background: rgba(255, 180, 0, 0.15); color: var(--gold); border: 1px solid var(--gold); padding: 5px 12px; border-radius: 10px; font-size: 0.7rem; }
        .badge-std { background: rgba(255, 255, 255, 0.05); color: #fff; padding: 5px 12px; border-radius: 10px; font-size: 0.7rem; }

        .btn-action { width: 40px; height: 40px; border-radius: 12px; border: none; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
        .btn-del { background: rgba(244, 63, 94, 0.1); color: var(--rose); }
        .cover-preview { width: 100%; height: 180px; border-radius: 20px; object-fit: cover; border: 2px dashed var(--border-glass); margin-bottom: 15px; }


        /* Style des items du menu mobile */
        .mob-nav-item {
            display: flex; align-items: center;
            padding: 12px 14px; border-radius: 14px;
            color: rgba(255,255,255,0.65); font-weight: 700;
            font-size: 0.85rem; cursor: pointer;
            margin-bottom: 4px; transition: 0.2s;
        }
        .mob-nav-item:hover, .mob-nav-item.mob-active {
            background: var(--neon-blue); color: #000;
        }

        /* ============================================================
           ADMIN RESPONSIVE — Mobile & Tablette (< 1100px)
           ============================================================ */

        /* Barre mobile cachée sur desktop */
        .mobile-admin-topbar { display: none; }

        @media (max-width: 767px) {
            /* Cacher la sidebar fixe */
            .admin-sidebar { display: none !important; }

            /* Afficher la barre mobile */
            .mobile-admin-topbar {
                display: block;
                position: sticky; top: 0; z-index: 1100;
                background: rgba(0,12,36,0.97);
                backdrop-filter: blur(20px);
                border-bottom: 1px solid rgba(0,217,255,0.2);
                box-shadow: 0 4px 30px rgba(0,0,0,0.6);
            }

            /* Contenu principal pleine largeur */
            .admin-main-content { padding: 16px 12px !important; }

            /* Cards */
            .glass-card { padding: 16px 12px !important; border-radius: 20px !important; margin-bottom: 16px !important; }
            h2.fw-900, h3.fw-900, h4.fw-900, h5.fw-900 { font-size: 1rem !important; }
            .stat-val { font-size: 1.4rem !important; }

            /* Tables scrollables */
            .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
            .premium-table { min-width: 700px; }
            .premium-table thead th { font-size: 0.6rem !important; padding: 0 10px 8px !important; }
            .premium-table td { padding: 12px 10px !important; font-size: 0.75rem !important; }
            .btn-action { width: 30px !important; height: 30px !important; font-size: 0.65rem !important; border-radius: 8px !important; }

            /* Row stats 2 colonnes */
            .row.g-4 .col-md-3 { flex: 0 0 50%; max-width: 50%; }
        }

        @media (max-width: 420px) {
            .admin-main-content { padding: 12px 8px !important; }
            .glass-card { padding: 12px 10px !important; border-radius: 14px !important; }
            .row.g-4 .col-md-3 { flex: 0 0 100%; max-width: 100%; }
            .admin-input { padding: 10px 14px !important; border-radius: 12px !important; }
        }

    </style>
</head>
<body>

    <!-- ======= BARRE NAVIGATION MOBILE (< 1100px) ======= -->
    <div class="mobile-admin-topbar">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:13px 16px;">
            <div style="display:flex;align-items:center;gap:10px;">
                <div style="background:var(--neon-blue);width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 12px rgba(0,217,255,0.4);">
                    <i class="bi bi-shield-lock-fill text-dark" style="font-size:1rem;"></i>
                </div>
                <div>
                    <div style="font-weight:900;font-size:0.95rem;line-height:1;">ELITE COMMAND</div>
                    <div style="font-size:0.6rem;color:rgba(0,217,255,0.7);font-weight:700;letter-spacing:1px;">CASHLINK MASTER</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
                <a href="/logout" style="background:rgba(244,63,94,0.15);border:1px solid rgba(244,63,94,0.3);color:#f43f5e;width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;text-decoration:none;" title="Déconnexion">
                    <i class="bi bi-power"></i>
                </a>
                <button id="mob-hamburger" style="background:rgba(0,217,255,0.1);border:1px solid rgba(0,217,255,0.3);color:var(--neon-blue);width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                    <i class="bi bi-list fs-5"></i>
                </button>
            </div>
        </div>
        <!-- Menu déroulant -->
        <div id="mob-menu" style="display:none;padding:6px 12px 14px;border-top:1px solid rgba(255,255,255,0.06);max-height:70vh;overflow-y:auto;">
            <div class="mob-nav-item active" data-tab="stats" data-mobile="1"><i class="bi bi-cpu me-2"></i>Performances CA</div>
            <div class="mob-nav-item" data-tab="validations" data-mobile="1"><i class="bi bi-shield-check me-2"></i>Validations TID<% if(stats.enAttente > 0){ %> <span class="badge bg-danger ms-1"><%= stats.enAttente %></span><% } %></div>
            <div class="mob-nav-item" data-tab="clients" data-mobile="1"><i class="bi bi-people me-2"></i>Gestion Membres</div>
            <div class="mob-nav-item" data-tab="interface" data-mobile="1"><i class="bi bi-palette me-2"></i>Design & Pubs</div>
            <div class="mob-nav-item" data-tab="packs" data-mobile="1"><i class="bi bi-box-seam me-2"></i>Config Machines</div>
            <div class="mob-nav-item" data-tab="messages" data-mobile="1"><i class="bi bi-chat-dots me-2"></i>Messages Clients</div>
            <div class="mob-nav-item" data-tab="retraits" data-mobile="1"><i class="bi bi-cash-coin me-2"></i>Retraits<% if(retraits && retraits.length > 0){ %> <span class="badge bg-warning text-dark ms-1"><%= retraits.length %></span><% } %></div>
            <div class="mob-nav-item" data-tab="preuves" data-mobile="1"><i class="bi bi-image me-2"></i>Preuves Paiement<% if(proofs && proofs.length > 0){ %> <span class="badge bg-success ms-1"><%= proofs.length %></span><% } %></div>
            <div class="mob-nav-item" data-tab="logs" data-mobile="1"><i class="bi bi-journal-text me-2"></i>Journal Activité</div>
            <div class="mob-nav-item" data-tab="annulations" data-mobile="1"><i class="bi bi-x-octagon me-2"></i>Annulations</div>
            <div class="mob-nav-item" data-tab="security" data-mobile="1"><i class="bi bi-lock me-2"></i>Accès & Sécurité</div>
        </div>
    </div>

    <div class="admin-layout-wrapper">
    <div class="admin-sidebar">
        <div class="text-center mb-5">
            <div class="p-3 mb-3 animate__animated animate__pulse animate__infinite" style="background: var(--neon-blue); border-radius: 22px; display: inline-block; box-shadow: 0 0 20px rgba(0, 217, 255, 0.5);">
                <i class="bi bi-shield-lock-fill text-dark fs-3"></i>
            </div>
            <h5 class="fw-900">ELITE COMMAND</h5>
            <span class="badge bg-danger rounded-pill" style="font-size: 0.6rem;">MASTER 2026</span>
        </div>

        <div class="nav-menu" id="navMenu">
            <div class="nav-item-custom active" data-tab="stats"><i class="bi bi-cpu"></i> Performances CA</div>
            <div class="nav-item-custom" data-tab="validations"><i class="bi bi-shield-check"></i> Validations TID <% if(stats.enAttente > 0){ %><span class="badge bg-danger ms-auto"><%= stats.enAttente %></span><% } %></div>
            <div class="nav-item-custom" data-tab="clients"><i class="bi bi-people"></i> Gestion Membres</div>
            <div class="nav-item-custom" data-tab="interface"><i class="bi bi-palette"></i> Design & Pubs</div>
            <div class="nav-item-custom" data-tab="packs"><i class="bi bi-box-seam"></i> Config Machines</div>
            <div class="nav-item-custom" data-tab="messages"><i class="bi bi-chat-dots"></i> Messages Clients</div>
            <div class="nav-item-custom" data-tab="retraits"><i class="bi bi-cash-coin"></i> Retraits <% if(retraits && retraits.length > 0){ %><span class="badge bg-warning text-dark ms-auto"><%= retraits.length %></span><% } %></div>
            <div class="nav-item-custom" data-tab="preuves"><i class="bi bi-image"></i> Preuves Paiement <% if(proofs && proofs.length > 0){ %><span class="badge bg-success ms-auto"><%= proofs.length %></span><% } %></div>
            <div class="nav-item-custom" data-tab="logs"><i class="bi bi-journal-text"></i> Journal Activité</div>
            <div class="nav-item-custom" data-tab="annulations"><i class="bi bi-x-octagon"></i> Annulations</div>
            <div class="nav-item-custom" data-tab="security"><i class="bi bi-lock"></i> Accès & Sécurité</div>
        </div>

        <div style="margin-top: auto;">
            <a href="/admin-logout" class="nav-item-custom text-danger"><i class="bi bi-power"></i> SHUTDOWN ADMIN</a>
        </div>
    </div>

    <div class="admin-main-content">

        <div id="stats" class="section-panel active">
            <h3 class="fw-800 mb-5 text-uppercase">Rapport de Croissance</h3>
            <div class="row g-4 mb-5">
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">CA Journalier</span><div class="stat-val text-success"><%= (stats.packsToday || 0).toLocaleString() %></div></div></div>
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">Inscrits (24h)</span><div class="stat-val text-primary"><%= stats.usersToday || 0 %></div></div></div>
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">En Attente</span><div class="stat-val text-warning"><%= stats.enAttente || 0 %></div></div></div>
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">Dette Membres</span><div class="stat-val text-danger" style="font-size: 1.3rem;"><%= (stats.soldeTotalUsers || 0).toLocaleString() %> FC</div></div></div>
            </div>
            
            <div class="glass-card">
                <h5 class="fw-800 mb-4 text-info">Analyse Périodique</h5>
                <div class="row text-center g-4">
                    <div class="col-md-4 border-end border-secondary">
                        <span class="stat-label">Mensuel</span>
                        <div class="h2 fw-900 mt-2 text-white"><%= (stats.packsMonth || 0).toLocaleString() %> FC</div>
                    </div>
                    <div class="col-md-4 border-end border-secondary">
                        <span class="stat-label">Annuel</span>
                        <div class="h2 fw-900 mt-2 text-white"><%= (stats.packsYear || 0).toLocaleString() %> FC</div>
                    </div>
                    <div class="col-md-4">
                        <span class="stat-label">Chiffre d'Affaire Total</span>
                        <div class="h2 fw-900 mt-2" style="color: var(--neon-blue); text-shadow: 0 0 15px rgba(0, 217, 255, 0.4);"><%= (stats.totalGagne || 0).toLocaleString() %> FC</div>
                    </div>
                </div>
            </div>
        </div>

        <div id="validations" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-info mb-4">Transactions en attente</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead>
                            <tr><th>Client</th><th>Opération</th><th>Référence / TID</th><th>Montant</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            <% (typeof transactions !== 'undefined' ? transactions : []).filter(t => t.statut === "EN_ATTENTE").forEach(tx => { %>
                            <tr>
                                <td><b><%= tx.utilisateur %></b><br><small class="opacity-50"><%= tx.phone %></small></td>
                                <td><span class="badge bg-info text-dark"><%= tx.type %></span></td>
                                <td><code class="text-white fs-6"><%= tx.reference || 'N/A' %></code></td>
                                <td class="text-info fw-900"><%= (tx.montant || 0).toLocaleString() %> FC</td>
                                <td>
                                    <form action="/valider-depot" method="POST">
                                        <input type="hidden" name="txId" value="<%= tx._id %>">
                                        <button class="btn btn-success rounded-pill px-4 fw-bold">APPROUVER</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="clients" class="section-panel">
            <div class="glass-card" style="padding:30px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-900 m-0"><i class="bi bi-people-fill me-3 text-info"></i>Gestion des Membres</h4>
                    <span class="badge bg-info text-dark fw-800 px-3 py-2" style="border-radius:20px;font-size:0.8rem;"><%= users.length %> membres inscrits</span>
                </div>
                <div class="table-responsive">
                    <table class="premium-table" style="border-spacing:0 8px;">
                        <thead><tr>
                            <th style="color:#00d9ff;">IDENTITÉ</th>
                            <th style="color:#00d9ff;">TÉLÉPHONE</th>
                            <th style="color:#00d9ff;">PACK</th>
                            <th style="color:#00d9ff;">STATUT</th>
                            <th style="color:#00d9ff;">SOLDE ACTIF</th>
                            <th style="color:#00d9ff;">PROFITS</th>
                            <th style="color:#00d9ff;">PARRAIN</th>
                            <th style="color:#00d9ff;">FILLEULS</th>
                            <th style="color:#00d9ff;">INSCRIPTION</th>
                            <th style="color:#00d9ff;">ACTIONS</th>
                        </tr></thead>
                        <tbody>
                        <% (typeof users !== 'undefined' ? users : []).forEach((u,i) => {
                            const packColor = u.pack==='DIAMOND'?'#a855f7':u.pack==='GOLD'?'#f59e0b':u.pack==='SILVER'?'#94a3b8':u.pack==='BRONZE'?'#b45309':'#374151';
                            const packBg = u.pack==='DIAMOND'?'rgba(168,85,247,0.15)':u.pack==='GOLD'?'rgba(245,158,11,0.15)':u.pack==='SILVER'?'rgba(148,163,184,0.1)':u.pack==='BRONZE'?'rgba(180,83,9,0.15)':'rgba(55,65,81,0.3)';
                        %>
                        <tr id="row-<%= u._id %>" style="<% if(i%2===0){%>background:rgba(255,255,255,0.015);<% } %>">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#00d9ff,#0066ff);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:0.85rem;flex-shrink:0;">
                                        <%= u.username.charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <div class="fw-900" style="font-size:0.9rem;"><%= u.username %></div>
                                        <div style="font-size:0.65rem;color:#64748b;font-weight:600;">ID: <%= u.id ? u.id.slice(-8) : 'N/A' %></div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-700" style="font-size:0.85rem;">+243 <%= u.phone %></div>
                            </td>
                            <td>
                                <span style="background:<%= packBg %>;color:<%= packColor %>;border:1px solid <%= packColor %>;padding:5px 14px;border-radius:20px;font-weight:900;font-size:0.75rem;letter-spacing:0.5px;">
                                    <%= u.pack || 'AUCUN' %>
                                </span>
                            </td>
                            <td>
                                <% if(u.certified){ %>
                                <span style="background:rgba(29,78,216,0.2);color:#60a5fa;border:1px solid #1d4ed8;padding:4px 10px;border-radius:20px;font-size:0.7rem;font-weight:900;"><i class="bi bi-patch-check-fill me-1"></i>CERTIFIÉ</span>
                                <% } else { %>
                                <span style="background:rgba(100,116,139,0.15);color:#64748b;border:1px solid #334155;padding:4px 10px;border-radius:20px;font-size:0.7rem;font-weight:700;">BASIQUE</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="fw-900" style="color:#10b981;font-size:0.9rem;"><%= (u.solde||0).toLocaleString() %> FC</div>
                            </td>
                            <td>
                                <div class="fw-900" style="color:#fbbf24;font-size:0.9rem;"><%= (u.bonus||0).toLocaleString() %> FC</div>
                            </td>
                            <td>
                                <div style="font-size:0.8rem;color:#94a3b8;font-weight:700;"><%= u.referredBy || '—' %></div>
                            </td>
                            <td class="text-center">
                                <span style="background:rgba(0,217,255,0.1);color:#00d9ff;padding:3px 12px;border-radius:20px;font-weight:900;font-size:0.8rem;">
                                    <%= u.referralCount || 0 %>
                                </span>
                            </td>
                            <td>
                                <div style="font-size:0.75rem;color:#64748b;font-weight:600;"><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('fr-FR') : 'N/A' %></div>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <button onclick="voirCahier('<%= u.id %>','<%= u.username %>')" class="btn btn-sm fw-800" style="background:rgba(0,217,255,0.1);color:#00d9ff;border:1px solid #00d9ff;border-radius:10px;font-size:0.7rem;padding:6px 12px;">
                                        <i class="bi bi-journal-bookmark-fill me-1"></i>CAHIER
                                    </button>
                                    <button class="btn-action btn-del" onclick="deleteUser('<%= u._id %>')"><i class="bi bi-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                        </tbody>
                    </table>
</div>                </div>
            </div>
        </div>

        <div id="interface" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-info mb-4">Design & Pubs</h4>
                <form action="/admin/update-content" method="POST">
                    <div class="row">
                        <div class="col-md-7">
                            <label class="admin-label">URL Photo de Couverture</label>
                            <input type="text" name="cover_url" class="admin-input" value="<%= (typeof content !== 'undefined' ? content.cover_url : '') %>" id="cover_input" onchange="previewImg()">
                            <img src="<%= (typeof content !== 'undefined' ? content.cover_url : '') %>" id="preview" class="cover-preview" alt="Preview">
                            <label class="admin-label">Nom de la Marque</label>
