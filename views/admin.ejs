<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MASTER CONTROL | CASH LINK v5.0</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        /* ============================================================
           MOTEUR DE DESIGN "ADMIN TITAN" 
           ============================================================ */
        :root {
            --bg-dark: #00081a;
            --sidebar-bg: rgba(0, 0, 0, 0.9);
            --card-glass: rgba(255, 255, 255, 0.02);
            --border-glass: rgba(255, 255, 255, 0.08);
            --neon-blue: #00d9ff;
            --neon-green: #10b981;
            --neon-red: #f43f5e;
            --sidebar-width: 280px;
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        /* CONFIGURATION GÉNÉRALE */
        * { box-sizing: border-box; outline: none !important; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: var(--neon-blue); border-radius: 10px; }

        body {
            background-color: var(--bg-dark);
            background-image: radial-gradient(circle at 50% -20%, #001a4d, transparent);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff; margin: 0; overflow-x: hidden;
        }

        /* --- SIDEBAR DE CONTRÔLE --- */
        .sidebar-master {
            width: var(--sidebar-width); height: 100vh;
            background: var(--sidebar-bg); backdrop-filter: blur(40px);
            position: fixed; left: 0; top: 0; padding: 40px 20px;
            border-right: 1px solid var(--border-glass); z-index: 2000;
        }

        .brand-admin {
            text-align: center; margin-bottom: 50px;
            border-bottom: 1px solid var(--border-glass); padding-bottom: 30px;
        }

        .nav-link-custom {
            display: flex; align-items: center; gap: 15px; padding: 16px 20px;
            color: rgba(255,255,255,0.4); text-decoration: none; border-radius: 20px;
            margin-bottom: 8px; font-weight: 700; cursor: pointer; transition: var(--transition);
        }
        .nav-link-custom:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-link-custom.active { background: var(--neon-blue); color: #000; box-shadow: 0 0 30px rgba(0, 217, 255, 0.3); }

        /* --- CONTENU PRINCIPAL --- */
        .main-engine { margin-left: var(--sidebar-width); padding: 50px; min-height: 100vh; }

        .glass-panel {
            background: var(--card-glass); border: 1px solid var(--border-glass);
            border-radius: 40px; padding: 40px; margin-bottom: 40px;
            backdrop-filter: blur(10px);
        }

        /* STATS CARDS */
        .stat-card {
            background: rgba(255,255,255,0.01); border: 1px solid var(--border-glass);
            border-radius: 30px; padding: 30px; text-align: center; transition: 0.3s;
        }
        .stat-card:hover { transform: translateY(-5px); border-color: var(--neon-blue); }
        .stat-icon { font-size: 2rem; color: var(--neon-blue); margin-bottom: 15px; display: block; }
        .stat-value { font-size: 2.2rem; font-weight: 900; line-height: 1; }
        .stat-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; opacity: 0.5; margin-top: 10px; display: block; }

        /* TABLES PREMIUM */
        .table-titan { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
        .table-titan td { background: rgba(255,255,255,0.03); padding: 18px 25px; border: none; font-size: 0.9rem; border-radius: 18px; vertical-align: middle; }
        .table-titan tr { transition: 0.3s; }
        .table-titan tr:hover td { background: rgba(255,255,255,0.06); }

        /* FORMULAIRES ADMIN */
        .admin-form-label { font-size: 0.75rem; font-weight: 800; color: var(--neon-blue); text-transform: uppercase; margin-bottom: 10px; display: block; }
        .admin-input-field {
            background: rgba(0, 0, 0, 0.5); border: 1px solid var(--border-glass);
            border-radius: 20px; padding: 16px 22px; color: white; width: 100%; margin-bottom: 25px;
            transition: 0.3s; font-weight: 600;
        }
        .admin-input-field:focus { border-color: var(--neon-blue); box-shadow: 0 0 20px rgba(0, 217, 255, 0.15); }

        .btn-titan-update {
            background: var(--neon-blue); color: #000; border: none; 
            padding: 22px; border-radius: 25px; font-weight: 900; width: 100%; 
            text-transform: uppercase; cursor: pointer; letter-spacing: 1px;
            box-shadow: 0 10px 30px rgba(0, 217, 255, 0.2); transition: 0.3s;
        }
        .btn-titan-update:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(0, 217, 255, 0.4); }

        /* SECTIONS */
        .panel-hidden { display: none; }
        .panel-visible { display: block; animation: fadeInUp 0.6s cubic-bezier(0.23, 1, 0.32, 1); }

        /* BADGES */
        .badge-rdc { padding: 8px 15px; border-radius: 50px; font-weight: 800; font-size: 0.65rem; text-transform: uppercase; }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

        /* MONITORING DOT */
        .dot-pulse {
            width: 10px; height: 10px; background: var(--neon-green);
            border-radius: 50%; display: inline-block; margin-right: 10px;
            box-shadow: 0 0 10px var(--neon-green); animation: pulse-green 2s infinite;
        }
        @keyframes pulse-green { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.5); opacity: 0.5; } 100% { transform: scale(1); opacity: 1; } }
    </style>
</head>
<body>

    <aside class="sidebar-master">
        <div class="brand-admin">
            <h3 class="fw-900 mb-1 text-white">CASH LINK</h3>
            <div class="d-flex align-items-center justify-content-center">
                <span class="dot-pulse"></span>
                <small class="fw-bold text-success" style="font-size: 0.65rem;">MONITORING ACTIF</small>
            </div>
        </div>

        <nav class="nav-menu">
            <div class="nav-link-custom active" onclick="switchPanel('dashboard', this)">
                <i class="bi bi-speedometer2 fs-5"></i> Vue d'ensemble
            </div>
            <div class="nav-link-custom" onclick="switchPanel('deposits', this)">
                <i class="bi bi-shield-lock fs-5"></i> Dépôts (TID) 
                <% if(stats.enAttente > 0) { %>
                    <span class="badge bg-danger ms-auto rounded-circle"><%= stats.enAttente %></span>
                <% } %>
            </div>
            <div class="nav-link-custom" onclick="switchPanel('withdrawals', this)">
                <i class="bi bi-bank fs-5"></i> Retraits 
            </div>
            <div class="nav-link-custom" onclick="switchPanel('design', this)">
                <i class="bi bi-brush fs-5"></i> Design Dashboard
            </div>
            <div class="nav-link-custom" onclick="switchPanel('legal', this)">
                <i class="bi bi-file-earmark-medical fs-5"></i> Contenu Légal
            </div>
            <div class="nav-link-custom" onclick="switchPanel('users', this)">
                <i class="bi bi-people fs-5"></i> Investisseurs
            </div>
        </nav>

        <div style="position: absolute; bottom: 40px; width: 80%;">
            <a href="/logout" class="nav-link-custom text-danger bg-transparent"><i class="bi bi-power"></i> QUITTER LE TERMINAL</a>
        </div>
    </aside>

    <main class="main-engine">

        <section id="dashboard" class="panel-hidden panel-visible">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <h2 class="fw-900 m-0">PERFORMANCES DU RÉSEAU</h2>
                <span class="badge-rdc bg-primary">RDC SERVER CLOUD v5.0</span>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="stat-card">
                        <i class="bi bi-people-fill stat-icon"></i>
                        <div class="stat-value"><%= stats.totalUsers %></div>
                        <span class="stat-label">Total Investisseurs</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <i class="bi bi-hourglass-split stat-icon text-warning"></i>
                        <div class="stat-value text-warning"><%= stats.enAttente %></div>
                        <span class="stat-label">Paiements en Attente</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <i class="bi bi-cash-coin stat-icon text-success"></i>
                        <div class="stat-value text-success"><%= stats.soldeTotalUsers.toLocaleString() %> <small style="font-size: 1rem;">FC</small></div>
                        <span class="stat-label">Capital Global Réseau</span>
                    </div>
                </div>
            </div>

            <div class="glass-panel">
                <h5 class="fw-900 mb-4 text-info text-uppercase">Logs de Sécurité en Temps Réel</h5>
                <div id="log-monitor" class="bg-black p-4 rounded-4" style="height: 200px; overflow-y: auto; font-family: monospace; font-size: 0.8rem; border: 1px solid var(--border-glass);">
                    <div class="text-success">[SYSTEM] Moteur de minage stabilisé...</div>
                    <div class="text-info">[AUTH] Admin connecté depuis l'adresse IP 197.xxx.xxx.xxx</div>
                    <div class="text-warning">[SYNC] Synchronisation avec Vodacom M-Pesa OK.</div>
                    <div class="text-white opacity-50">[INFO] Vérification des cycles de 24h terminée.</div>
                    <div class="text-danger">[ALERT] Tentative de retrait bloquée pour l'utilisateur Anash (Délai non atteint).</div>
                </div>
            </div>
        </section>

        <section id="deposits" class="panel-hidden">
            <h2 class="fw-900 mb-5 text-uppercase">Validation des ID de Transaction (TID)</h2>
            <div class="glass-panel">
                <% if(transactions.length === 0) { %>
                    <div class="text-center py-5 opacity-50">Aucun dépôt en attente pour le moment.</div>
                <% } else { %>
                <div class="table-responsive">
                    <table class="table-titan">
                        <thead><tr class="text-muted" style="font-size: 0.7rem; text-transform: uppercase;"><th>Utilisateur</th><th>Pack</th><th>ID Transaction (TID)</th><th>Montant</th><th>Action</th></tr></thead>
                        <tbody>
                            <% transactions.forEach(tx => { %>
                            <tr>
                                <td class="fw-bold text-white"><%= tx.username %></td>
                                <td><span class="badge bg-primary rounded-pill"><%= tx.type %></span></td>
                                <td><code class="text-info fs-6"><%= tx.reference %></code></td>
                                <td class="fw-bold"><%= tx.montant.toLocaleString() %> FC</td>
                                <td>
                                    <form action="/admin/approve-tx" method="POST" class="d-inline">
                                        <input type="hidden" name="txId" value="<%= tx.id %>">
                                        <button class="btn btn-success btn-sm rounded-pill px-4 fw-bold">APPROUVER</button>
                                    </form>
                                    <button class="btn btn-link text-danger btn-sm text-decoration-none ms-2">Rejeter</button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } %>
            </div>
        </section>

        <section id="withdrawals" class="panel-hidden">
            <h2 class="fw-900 mb-5 text-uppercase">Demandes de Retraits (Profits)</h2>
            <div class="glass-panel">
                <div class="table-responsive">
                    <table class="table-titan">
                        <thead><tr class="text-muted" style="font-size: 0.7rem; text-transform: uppercase;"><th>Client</th><th>Téléphone</th><th>Montant</th><th>Status</th><th>Action</th></tr></thead>
                        <tbody>
                            <% retraits.forEach(r => { %>
                            <tr>
                                <td class="fw-bold text-white"><%= r.username %></td>
                                <td class="fw-bold text-info">+243 <%= r.phone %></td>
                                <td class="fw-bold text-warning"><%= r.montant.toLocaleString() %> FC</td>
                                <td><span class="badge bg-dark border border-warning text-warning"><%= r.certified ? 'CERTIFIÉ (24h)' : 'STANDARD (3j)' %></span></td>
                                <td>
                                    <form action="/admin/confirm-pay" method="POST">
                                        <input type="hidden" name="reqId" value="<%= r.id %>">
                                        <button class="btn btn-warning btn-sm rounded-pill px-4 fw-900 text-dark">MARQUER PAYÉ</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="design" class="panel-hidden">
            <h2 class="fw-900 mb-5 text-uppercase">Pilotage du Dashboard</h2>
            <form action="/admin/update-content" method="POST">
                <div class="glass-panel">
                    <div class="row">
                        <div class="col-md-6 border-end border-secondary border-opacity-25 pe-md-5">
                            <h5 class="text-info fw-bold mb-4">NUMÉROS DE RÉCEPTION (RDC)</h5>
                            <label class="admin-form-label">Numéro M-PESA</label>
                            <input type="text" name="admin_voda" class="admin-input-field" value="<%= site.admin_voda %>">
                            
                            <label class="admin-form-label">Numéro AIRTEL MONEY</label>
                            <input type="text" name="admin_airtel" class="admin-input-field" value="<%= site.admin_airtel %>">
                            
                            <label class="admin-form-label">Numéro ORANGE MONEY</label>
                            <input type="text" name="admin_orange" class="admin-input-field" value="<%= site.admin_orange %>">
                        </div>
                        <div class="col-md-6 ps-md-5">
                            <h5 class="text-warning fw-bold mb-4">TEXTES MARKETING</h5>
                            <label class="admin-form-label">Titre Marketing (H1)</label>
                            <input type="text" name="titre_principal" class="admin-input-field" value="<%= site.titre_principal %>">
                            
                            <label class="admin-form-label">Phrase d'Espoir (Slogan)</label>
                            <textarea name="description" class="admin-input-field" rows="4"><%= site.description %></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn-titan-update">💾 Enregistrer la nouvelle configuration</button>
                </div>
            </form>
        </section>

        <section id="legal" class="panel-hidden">
            <h2 class="fw-900 mb-5 text-uppercase">Gestion des Règles & Infos</h2>
            <form action="/admin/update-content" method="POST">
                <div class="glass-panel">
                    <label class="admin-form-label">À Propos de CASH LINK (Philosophie)</label>
                    <textarea name="about_text" class="admin-input-field" rows="6"><%= site.about_text %></textarea>

                    <label class="admin-form-label">Règles de Conformité (Sauts de ligne autorisés)</label>
                    <textarea name="rules_text" class="admin-input-field" rows="10"><%= site.rules_text %></textarea>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <label class="admin-form-label">Adresse Physique (Kinshasa)</label>
                            <input type="text" name="contact_address" class="admin-input-field" value="<%= site.contact_address %>">
                        </div>
                        <div class="col-md-6">
                            <label class="admin-form-label">Téléphone de Support (+243...)</label>
                            <input type="text" name="contact_phone" class="admin-input-field" value="<%= site.contact_phone %>">
                        </div>
                    </div>
                    <button type="submit" class="btn-titan-update">💾 Mettre à jour les pages légales</button>
                </div>
            </form>
        </section>

        <section id="users" class="panel-hidden">
            <h2 class="fw-900 mb-5 text-uppercase">Journal des Investisseurs Actifs</h2>
            <div class="glass-panel">
                <div class="table-responsive">
                    <table class="table-titan">
                        <thead><tr class="text-muted" style="font-size: 0.7rem; text-transform: uppercase;"><th>Utilisateur</th><th>Machine Active</th><th>Status</th><th>Capital</th><th>Action</th></tr></thead>
                        <tbody>
                            <% users.forEach(u => { %>
                            <tr>
                                <td class="fw-bold text-white"><%= u.username %></td>
                                <td><span class="badge bg-dark"><%= u.pack %></span></td>
                                <td>
                                    <% if(u.certified) { %>
                                        <span class="text-success small fw-bold"><i class="bi bi-patch-check-fill me-1"></i> CERTIFIÉ</span>
                                    <% } else { %>
                                        <span class="text-muted small fw-bold">STANDARD</span>
                                    <% } %>
                                </td>
                                <td class="fw-bold text-info"><%= u.solde.toLocaleString() %> FC</td>
                                <td>
                                    <button class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-outline-danger btn-sm rounded-circle ms-2"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        /**
         * Système de navigation par Panel
         */
        function switchPanel(panelId, btn) {
            // Cacher tous les panels
            document.querySelectorAll('.panel-hidden').forEach(p => p.classList.remove('panel-visible'));
            
            // Afficher le panel cible
            const target = document.getElementById(panelId);
            target.classList.add('panel-visible');

            // Gérer le style des liens du menu
            document.querySelectorAll('.nav-link-custom').forEach(l => l.classList.remove('active'));
            btn.classList.add('active');

            // Log de navigation
            console.log("[ADMIN] Accès à la section : " + panelId);
        }

        /**
         * Système de son pour les alertes TID
         */
        let checkTID = <%= stats.enAttente %>;
        if(checkTID > 0) {
            document.getElementById('notif-sound').play().catch(e => console.log("Audio bloqué par le navigateur"));
        }

        /**
         * Auto-scroll du Moniteur de logs
         */
        const logMonitor = document.getElementById('log-monitor');
        logMonitor.scrollTop = logMonitor.scrollHeight;

        /**
         * Système d'auto-actualisation des logs (Simulation)
         */
        setInterval(() => {
            const logs = [
                "Vérification du flux de minage...",
                "Utilisateur en ligne : " + Math.floor(Math.random()*100),
                "Sauvegarde de la base de données terminée.",
                "Ping serveur : 12ms",
                "Validation SSL OK."
            ];
            const logEntry = document.createElement('div');
            logEntry.className = "text-white opacity-25";
            logEntry.innerText = "[SYSTEM] " + logs[Math.floor(Math.random()*logs.length)];
            logMonitor.appendChild(logEntry);
            logMonitor.scrollTop = logMonitor.scrollHeight;
        }, 10000);
    </script>
</body>
</html>
