    <script>
        function openTab(tabId, btn) {
            document.querySelectorAll('.section-panel').forEach(function(s){ s.classList.remove('active'); });
            var el = document.getElementById(tabId);
            if (el) el.classList.add('active');
            document.querySelectorAll('.nav-item-custom').forEach(function(n){ n.classList.remove('active'); });
            document.querySelectorAll('.mob-nav-item').forEach(function(n){ n.classList.remove('mob-active'); });
            if (btn) {
                if (btn.classList.contains('mob-nav-item')) btn.classList.add('mob-active');
                else btn.classList.add('active');
            }
            var menu = document.getElementById('mob-menu');
            if (menu && menu.style.display === 'block') closeMobileMenu();
        }

        // Universal nav binding — works on all devices/browsers
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-tab]').forEach(function(el) {
                el.addEventListener('click', function() {
                    var tab = this.getAttribute('data-tab');
                    var isMob = this.getAttribute('data-mobile');
                    openTab(tab, this);
                    if (isMob) closeMobileMenu();
                });
            });
            // hamburger
            var hbg = document.getElementById('mob-hamburger');
            if (hbg) hbg.addEventListener('click', toggleMobileMenu);
        });
        function toggleMobileMenu() {
            const menu = document.getElementById('mob-menu');
            const icon = document.querySelector('#mob-hamburger i');
            const isOpen = menu.style.display === 'block';
            menu.style.display = isOpen ? 'none' : 'block';
            icon.className = isOpen ? 'bi bi-list fs-5' : 'bi bi-x-lg fs-5';
        }
        function closeMobileMenu() {
            const menu = document.getElementById('mob-menu');
            if (menu) menu.style.display = 'none';
            const icon = document.querySelector('#mob-hamburger i');
            if (icon) icon.className = 'bi bi-list fs-5';
        }
                function previewImg() { document.getElementById('preview').src = document.getElementById('cover_input').value; }
        let deletedCount = 0;
        function deleteUser(id) {
            if(confirm('⚠️ Supprimer cet utilisateur définitivement ?\nSes retraits, transactions et annulations seront aussi effacés.')) {
                fetch('/admin/delete-user/' + id, { method: 'DELETE' })
                    .then(r => r.json())
                    .then(d => {
                        if(d.ok) {
                            const row = document.getElementById('row-' + id);
                            if(row) { row.style.transition='opacity 0.4s'; row.style.opacity='0'; setTimeout(()=>row.remove(),400); }
                            deletedCount++;
                            // Mettre à jour les compteurs visibles
                            document.querySelectorAll('.stat-val').forEach(el => {
                                const label = el.previousElementSibling;
                                if(label && label.textContent.includes('Membres') || label && label.textContent.includes('Inscrits')) {
                                    const cur = parseInt(el.textContent.replace(/[^0-9]/g,'')) || 0;
                                    if(cur > 0) el.textContent = (cur - 1).toLocaleString();
                                }
                            });
                            // Badge membres dans onglet clients
                            const membBadge = document.querySelector('#clients .badge.bg-info');
                            if(membBadge) { const n = parseInt(membBadge.textContent)||0; membBadge.textContent = Math.max(0,n-1)+' membres inscrits'; }
                        } else { alert('Erreur: ' + d.error); }
                    })
                    .catch(() => alert('Erreur réseau.'));
            }
        }
    
        /* ════ NOTIFICATIONS TEMPS RÉEL ════ */
        let _prevCounts = { tid: -1, retraits: -1, annulations: -1 };
        let _adminToast = null;

        function showAdminToast(msg, color) {
            let t = document.getElementById('admin-notif-toast');
            if (!t) {
                t = document.createElement('div');
                t.id = 'admin-notif-toast';
                t.style.cssText = 'position:fixed;bottom:28px;right:28px;z-index:99999;background:#0f1629;border:2px solid '+color+';border-radius:18px;padding:14px 22px;color:#fff;font-weight:900;font-size:0.9rem;box-shadow:0 20px 60px rgba(0,0,0,0.8);display:flex;align-items:center;gap:12px;max-width:320px;transition:opacity 0.4s;';
                document.body.appendChild(t);
            }
            t.style.borderColor = color;
            t.innerHTML = '<span style="font-size:1.4rem;">🔔</span><span>' + msg + '</span>';
            t.style.opacity = '1';
            clearTimeout(_adminToast);
            _adminToast = setTimeout(() => { t.style.opacity = '0'; }, 5000);
        }

        function updateAdminBadges(data) {
            // TID badge in sidebar
            document.querySelectorAll('.nav-item-custom').forEach(nav => {
                if (nav.textContent.includes('Validations TID')) {
                    let b = nav.querySelector('.badge');
                    if (data.tid > 0) {
                        if (!b) { b = document.createElement('span'); b.className = 'badge bg-danger ms-auto'; nav.appendChild(b); }
                        b.textContent = data.tid;
                    } else if (b) b.remove();
                }
                if (nav.textContent.includes('Retraits')) {
                    let b = nav.querySelector('.badge');
                    if (data.retraits > 0) {
                        if (!b) { b = document.createElement('span'); b.className = 'badge bg-warning text-dark ms-auto'; nav.appendChild(b); }
                        b.textContent = data.retraits;
                    } else if (b) b.remove();
                }
            });
            // Mobile badges
            document.querySelectorAll('.mob-nav-item').forEach(nav => {
                if (nav.textContent.includes('Validations TID')) {
                    let b = nav.querySelector('.badge');
                    if (data.tid > 0) {
                        if (!b) { b = document.createElement('span'); b.className = 'badge bg-danger ms-1'; nav.appendChild(b); }
                        b.textContent = data.tid;
                    } else if (b) b.remove();
                }
            });
            // Toast on new items
            if (_prevCounts.tid >= 0) {
                if (data.tid > _prevCounts.tid) showAdminToast('Nouveau paiement TID à valider !', '#3b82f6');
                else if (data.retraits > _prevCounts.retraits) showAdminToast('Nouvelle demande de retrait !', '#f59e0b');
                else if (data.annulations > _prevCounts.annulations) showAdminToast("Nouvelle demande d'annulation !", '#ef4444');
                else if ((data.proofs||0) > (_prevCounts.proofs||0)) showAdminToast("📸 Nouvelle preuve de paiement reçue !", '#25d366');
            }
            _prevCounts = { tid: data.tid, retraits: data.retraits, annulations: data.annulations, proofs: data.proofs||0 };
            // Badge preuves in sidebar
            document.querySelectorAll('.nav-item-custom').forEach(nav => {
                if (nav.dataset.tab === 'preuves') {
                    let b = nav.querySelector('.badge');
                    if ((data.proofs||0) > 0) {
                        if (!b) { b = document.createElement('span'); b.className = 'badge bg-success ms-auto'; nav.appendChild(b); }
                        b.textContent = data.proofs;
                    } else if (b) b.remove();
                }
            });
        }

        function pollAdminNotifs() {
            fetch('/api/admin-notifications')
                .then(r => r.json())
                .then(data => updateAdminBadges(data))
                .catch(() => {});
        }
        pollAdminNotifs();
        setInterval(pollAdminNotifs, 12000);


        /* ════ VOIR CAHIER UTILISATEUR ════ */
        function voirCahier(userId, username) {
            var m = document.getElementById('cahierModal');
            if (!m) {
                m = document.createElement('div');
                m.id = 'cahierModal';
                m.style.cssText = 'display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,0.8);overflow-y:auto;padding:20px;';
                // Build modal header
                var header = document.createElement('div');
                header.style.cssText = 'max-width:700px;margin:auto;background:#0f1629;border:1px solid rgba(0,217,255,0.2);border-radius:24px;overflow:hidden;';
                header.innerHTML = [
                    '<div style="background:linear-gradient(135deg,#0033cc,#00d9ff);padding:20px 24px;display:flex;justify-content:space-between;align-items:center;">',
                    '<div>',
                    '<div style="color:rgba(255,255,255,0.7);font-size:0.7rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;">ACTIVITE DU MEMBRE</div>',
                    '<div id="cahierTitle" style="color:#fff;font-weight:900;font-size:1.2rem;"></div>',
                    '</div>',
                    '<button id="cahierCloseBtn" style="background:rgba(255,255,255,0.15);border:none;color:#fff;width:34px;height:34px;border-radius:50%;font-size:1rem;cursor:pointer;">&#x2715;</button>',
                    '</div>',
                    '<div id="cahierBody" style="padding:24px;"></div>'
                ].join('');
                m.appendChild(header);
                document.body.appendChild(m);
                m.addEventListener('click', function(e){ if(e.target===m) m.style.display='none'; });
            }
            var closeBtn = document.getElementById('cahierCloseBtn');
            if (closeBtn) closeBtn.onclick = function(){ document.getElementById('cahierModal').style.display='none'; };
            m.style.display = 'block';
            document.getElementById('cahierTitle').textContent = username;
            document.getElementById('cahierBody').innerHTML = '<div style="text-align:center;padding:30px;color:#64748b;">Chargement...</div>';

            fetch('/admin/user-activity/' + userId)
                .then(function(r){ return r.json(); })
                .then(function(data) {
                    if (data.error) { document.getElementById('cahierBody').innerHTML = '<div style="color:#ef4444;padding:20px;">Erreur: '+data.error+'</div>'; return; }
                    var u = data.user || {};
                    var out = '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px;">';
                    out += '<div style="background:rgba(0,217,255,0.08);border:1px solid rgba(0,217,255,0.2);border-radius:14px;padding:14px;text-align:center;"><div style="color:#64748b;font-size:0.65rem;font-weight:900;letter-spacing:1px;text-transform:uppercase;">SOLDE</div><div style="color:#00d9ff;font-weight:900;font-size:1.2rem;">'+(u.solde||0).toLocaleString()+' FC</div></div>';
                    out += '<div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:14px;padding:14px;text-align:center;"><div style="color:#64748b;font-size:0.65rem;font-weight:900;letter-spacing:1px;text-transform:uppercase;">PACK</div><div style="color:#10b981;font-weight:900;font-size:1.2rem;">'+(u.pack||'Aucun')+'</div></div>';
                    out += '<div style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.2);border-radius:14px;padding:14px;text-align:center;"><div style="color:#64748b;font-size:0.65rem;font-weight:900;letter-spacing:1px;text-transform:uppercase;">BONUS</div><div style="color:#f59e0b;font-weight:900;font-size:1.2rem;">'+(u.bonus||0).toLocaleString()+' FC</div></div>';
                    out += '</div>';
                    var txs = data.transactions || [];
                    out += '<div style="font-weight:900;font-size:0.75rem;color:#94a3b8;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;">Transactions ('+txs.length+')</div>';
                    if (txs.length === 0) { out += '<div style="color:#475569;font-size:0.85rem;padding:10px;text-align:center;">Aucune transaction</div>'; }
                    else { txs.slice(0,10).forEach(function(t){
                        var c = t.statut==='VALIDE'?'#10b981':t.statut==='EN_ATTENTE'?'#f59e0b':'#ef4444';
                        out += '<div style="background:#1e293b;border-radius:10px;padding:10px 14px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;"><div><div style="color:#fff;font-weight:700;font-size:0.85rem;">'+t.type+'</div><div style="color:#64748b;font-size:0.72rem;">'+(t.reference||'')+'</div></div><div style="text-align:right;"><div style="color:#00d9ff;font-weight:900;">'+(t.montant||0).toLocaleString()+' FC</div><div style="color:'+c+';font-size:0.7rem;font-weight:800;">'+t.statut+'</div></div></div>';
                    }); }
                    var rets = data.retraits || [];
                    out += '<div style="font-weight:900;font-size:0.75rem;color:#94a3b8;letter-spacing:1px;text-transform:uppercase;margin:12px 0 8px;">Retraits ('+rets.length+')</div>';
                    if (rets.length === 0) { out += '<div style="color:#475569;font-size:0.85rem;padding:10px;text-align:center;">Aucun retrait</div>'; }
                    else { rets.slice(0,5).forEach(function(r){
                        var c = r.statut==='Paye'?'#10b981':r.statut==='En attente'?'#f59e0b':'#ef4444';
                        out += '<div style="background:#1e293b;border-radius:10px;padding:10px 14px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;"><div style="color:#fff;font-weight:700;font-size:0.85rem;">Retrait</div><div style="text-align:right;"><div style="color:#f59e0b;font-weight:900;">'+(r.montant||0).toLocaleString()+' FC</div><div style="color:'+c+';font-size:0.7rem;font-weight:800;">'+r.statut+'</div></div></div>';
                    }); }
                    document.getElementById('cahierBody').innerHTML = out;
                })
                .catch(function(){ document.getElementById('cahierBody').innerHTML = '<div style="color:#ef4444;padding:20px;">Erreur reseau.</div>'; });
        }


</script>
</body>
</html
        <!-- PREUVES DE PAIEMENT -->
        <div id="preuves" class="section-panel">
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:24px;">
                <div>
                    <h4 style="font-weight:900;color:#fff;margin:0;">📸 Preuves de Paiement</h4>
                    <div style="color:#64748b;font-size:0.8rem;margin-top:4px;">Clients ayant envoyé leur preuve via WhatsApp</div>
                </div>
                <span class="badge bg-success fw-800 px-3 py-2" style="border-radius:20px;font-size:0.8rem;"><%= proofs ? proofs.length : 0 %> en attente</span>
            </div>
            <% if(proofs && proofs.length > 0) { %>
            <div style="display:flex;flex-direction:column;gap:10px;">
            <% proofs.forEach(function(p) { %>
                <div style="background:#1e293b;border:2px solid rgba(37,211,102,0.4);border-radius:16px;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                    <div>
                        <div style="font-weight:900;color:#fff;font-size:0.95rem;"><%= p.username %></div>
                        <div style="color:#94a3b8;font-size:0.78rem;margin-top:2px;">📱 <%= p.phone %> &nbsp;|&nbsp; 📦 Pack <strong style="color:#25d366;"><%= p.pack %></strong> &nbsp;|&nbsp; 💰 <%= p.prix %> FC</div>
                        <div style="color:#64748b;font-size:0.72rem;margin-top:4px;"><i class="bi bi-clock me-1"></i><%= p.date %></div>
                    </div>
                    <form method="POST" action="/admin/mark-proof-done" style="margin:0;">
                        <input type="hidden" name="proofId" value="<%= p._id %>">
                        <button type="submit" style="background:linear-gradient(135deg,#059669,#10b981);color:#fff;border:none;padding:8px 18px;border-radius:12px;font-weight:900;font-size:0.75rem;cursor:pointer;letter-spacing:0.5px;">
                            <i class="bi bi-check2-circle me-1"></i>TRAITÉ
                        </button>
                    </form>
                </div>
            <% }) %>
            </div>
            <% } else { %>
            <div style="text-align:center;padding:48px 20px;color:#64748b;">
                <i class="bi bi-image" style="font-size:3rem;display:block;margin-bottom:12px;opacity:0.4;"></i>
                <div style="font-weight:700;">Aucune preuve de paiement en attente</div>
            </div>
            <% } %>
        </div>

