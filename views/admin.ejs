<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ELITE SYSTEM COMMAND | CASHLINK MASTER</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --bg-master: #000c24;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
            --neon-blue: #00d9ff;
            --neon-purple: #bc13fe;
            --emerald: #10b981;
            --rose: #f43f5e;
            --gold: #ffb400;
            --sidebar-width: 290px;
        }

        body {
            background-color: var(--bg-master);
            background-image: radial-gradient(circle at 50% -20%, #001a4d, transparent);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff; margin: 0; overflow-x: hidden;
        }

        /* --- SIDEBAR --- */
        .admin-sidebar {
            width: var(--sidebar-width); height: 100vh;
            background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(30px);
            position: fixed; left: 0; top: 0; padding: 40px 20px;
            border-right: 1px solid var(--border-glass); z-index: 1000;
            display: flex; flex-direction: column;
        }

        .nav-item-custom {
            display: flex; align-items: center; gap: 15px; padding: 15px 22px;
            color: rgba(255,255,255,0.4); text-decoration: none; border-radius: 20px;
            margin-bottom: 10px; font-weight: 700; cursor: pointer; transition: 0.3s;
        }

        .nav-item-custom:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-item-custom.active { background: var(--neon-blue); color: #000; box-shadow: 0 0 25px rgba(0, 217, 255, 0.3); }

        /* --- MAIN CONTENT --- */
        .admin-main-content { margin-left: var(--sidebar-width); padding: 50px; }

        .glass-card {
            background: var(--card-glass); border: 1px solid var(--border-glass);
            border-radius: 40px; padding: 40px; margin-bottom: 40px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
        }

        .stat-val { font-size: 2.2rem; font-weight: 800; color: var(--neon-blue); letter-spacing: -1px; }
        .stat-label { font-size: 0.75rem; text-transform: uppercase; font-weight: 800; opacity: 0.5; letter-spacing: 1px; }

        /* --- TABLES --- */
        .premium-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; }
        .premium-table thead th { padding: 0 20px 10px; font-size: 0.7rem; text-transform: uppercase; color: var(--neon-blue); border: none; }
        .premium-table td { background: rgba(255,255,255,0.02); padding: 20px; border: none; font-size: 0.95rem; font-weight: 600; vertical-align: middle; transition: 0.3s; }
        .premium-table tr td:first-child { border-radius: 20px 0 0 20px; border-left: 4px solid transparent; }
        .premium-table tr:hover td { background: rgba(255,255,255,0.05); }
        .premium-table tr:hover td:first-child { border-left-color: var(--neon-blue); }
        .premium-table tr td:last-child { border-radius: 0 20px 20px 0; }

        .admin-label { font-size: 0.7rem; font-weight: 800; color: var(--neon-blue); text-transform: uppercase; margin-bottom: 8px; display: block; }
        .admin-input {
            background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border-glass);
            border-radius: 18px; padding: 15px 20px; color: white; width: 100%; margin-bottom: 20px;
            font-weight: 600; transition: 0.3s;
        }
        .btn-update { background: var(--neon-blue); color: #000; border: none; padding: 18px; border-radius: 20px; font-weight: 800; width: 100%; text-transform: uppercase; cursor: pointer; }

        .section-panel { display: none; animation: fadeInUp 0.5s ease-out; }
        .section-panel.active { display: block; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

        .badge-vip { background: rgba(255, 180, 0, 0.15); color: var(--gold); border: 1px solid var(--gold); padding: 5px 12px; border-radius: 10px; font-size: 0.7rem; }
        .badge-std { background: rgba(255, 255, 255, 0.05); color: #fff; padding: 5px 12px; border-radius: 10px; font-size: 0.7rem; }

        .btn-action { width: 40px; height: 40px; border-radius: 12px; border: none; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
        .btn-del { background: rgba(244, 63, 94, 0.1); color: var(--rose); }
        .cover-preview { width: 100%; height: 180px; border-radius: 20px; object-fit: cover; border: 2px dashed var(--border-glass); margin-bottom: 15px; }
    </style>
</head>
<body>

    <div class="admin-sidebar">
        <div class="text-center mb-5">
            <div class="p-3 mb-3 animate__animated animate__pulse animate__infinite" style="background: var(--neon-blue); border-radius: 22px; display: inline-block; box-shadow: 0 0 20px rgba(0, 217, 255, 0.5);">
                <i class="bi bi-shield-lock-fill text-dark fs-3"></i>
            </div>
            <h5 class="fw-900">ELITE COMMAND</h5>
            <span class="badge bg-danger rounded-pill" style="font-size: 0.6rem;">MASTER 2026</span>
        </div>

        <div class="nav-menu">
            <div class="nav-item-custom active" onclick="openTab('stats', this)"><i class="bi bi-cpu"></i> Performances CA</div>
            <div class="nav-item-custom" onclick="openTab('validations', this)"><i class="bi bi-shield-check"></i> Validations TID <% if(stats.enAttente > 0){ %><span class="badge bg-danger ms-auto"><%= stats.enAttente %></span><% } %></div>
            <div class="nav-item-custom" onclick="openTab('clients', this)"><i class="bi bi-people"></i> Gestion Membres</div>
            <div class="nav-item-custom" onclick="openTab('interface', this)"><i class="bi bi-palette"></i> Design & Pubs</div>
            <div class="nav-item-custom" onclick="openTab('packs', this)"><i class="bi bi-box-seam"></i> Config Machines</div>
            <div class="nav-item-custom" onclick="openTab('messages', this)"><i class="bi bi-chat-dots"></i> Messages Clients</div>
            <div class="nav-item-custom" onclick="openTab('retraits', this)"><i class="bi bi-cash-coin"></i> Retraits <% if(retraits && retraits.length > 0){ %><span class="badge bg-warning text-dark ms-auto"><%= retraits.length %></span><% } %></div>
            <div class="nav-item-custom" onclick="openTab('logs', this)"><i class="bi bi-journal-text"></i> Journal Activité</div>
            <div class="nav-item-custom" onclick="openTab('annulations', this)"><i class="bi bi-x-octagon"></i> Annulations</div>
            <div class="nav-item-custom" onclick="openTab('security', this)"><i class="bi bi-lock"></i> Accès & Sécurité</div>
        </div>

        <div style="margin-top: auto;">
            <a href="/logout" class="nav-item-custom text-danger"><i class="bi bi-power"></i> SHUTDOWN ADMIN</a>
        </div>
    </div>

    <div class="admin-main-content">

        <div id="stats" class="section-panel active">
            <h3 class="fw-800 mb-5 text-uppercase">Rapport de Croissance</h3>
            <div class="row g-4 mb-5">
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">CA Journalier</span><div class="stat-val text-success"><%= (stats.packsToday || 0).toLocaleString() %></div></div></div>
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">Inscrits (24h)</span><div class="stat-val text-primary"><%= stats.usersToday || 0 %></div></div></div>
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">En Attente</span><div class="stat-val text-warning"><%= stats.enAttente || 0 %></div></div></div>
                <div class="col-md-3"><div class="glass-card text-center"><span class="stat-label">Dette Membres</span><div class="stat-val text-danger" style="font-size: 1.3rem;"><%= (stats.soldeTotalUsers || 0).toLocaleString() %> FC</div></div></div>
            </div>
            
            <div class="glass-card">
                <h5 class="fw-800 mb-4 text-info">Analyse Périodique</h5>
                <div class="row text-center g-4">
                    <div class="col-md-4 border-end border-secondary">
                        <span class="stat-label">Mensuel</span>
                        <div class="h2 fw-900 mt-2 text-white"><%= (stats.packsMonth || 0).toLocaleString() %> FC</div>
                    </div>
                    <div class="col-md-4 border-end border-secondary">
                        <span class="stat-label">Annuel</span>
                        <div class="h2 fw-900 mt-2 text-white"><%= (stats.packsYear || 0).toLocaleString() %> FC</div>
                    </div>
                    <div class="col-md-4">
                        <span class="stat-label">Chiffre d'Affaire Total</span>
                        <div class="h2 fw-900 mt-2" style="color: var(--neon-blue); text-shadow: 0 0 15px rgba(0, 217, 255, 0.4);"><%= (stats.totalGagne || 0).toLocaleString() %> FC</div>
                    </div>
                </div>
            </div>
        </div>

        <div id="validations" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-info mb-4">Transactions en attente</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead>
                            <tr><th>Client</th><th>Opération</th><th>Référence / TID</th><th>Montant</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            <% (typeof transactions !== 'undefined' ? transactions : []).filter(t => t.statut === "EN_ATTENTE").forEach(tx => { %>
                            <tr>
                                <td><b><%= tx.utilisateur %></b><br><small class="opacity-50"><%= tx.phone %></small></td>
                                <td><span class="badge bg-info text-dark"><%= tx.type %></span></td>
                                <td><code class="text-white fs-6"><%= tx.reference || 'N/A' %></code></td>
                                <td class="text-info fw-900"><%= (tx.montant || 0).toLocaleString() %> FC</td>
                                <td>
                                    <form action="/valider-depot" method="POST">
                                        <input type="hidden" name="txId" value="<%= tx._id %>">
                                        <button class="btn btn-success rounded-pill px-4 fw-bold">APPROUVER</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="clients" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 mb-4">Investisseurs</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead>
                            <tr><th>Nom</th><th>Téléphone</th><th>Pack</th><th>Statut</th><th>Gains</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            <% (typeof users !== 'undefined' ? users : []).forEach(u => { %>
                            <tr id="row-<%= u._id %>">
                                <td><i class="bi bi-person-circle me-2 text-info"></i> <%= u.username %></td>
                                <td><%= u.phone %></td>
                                <td><span class="badge bg-dark px-3 py-2"><%= u.pack || 'Aucun' %></span></td>
                                <td><% if(u.certified){ %><span class="badge-vip">CERTIFIÉ VIP</span><% } else { %><span class="badge-std">STANDARD</span><% } %></td>
                                <td class="text-success fw-bold"><%= (u.bonus || 0).toLocaleString() %> FC</td>
                                <td><button class="btn-action btn-del" onclick="deleteUser('<%= u._id %>')"><i class="bi bi-trash"></i></button></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="interface" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-info mb-4">Design & Pubs</h4>
                <form action="/admin/update-content" method="POST">
                    <div class="row">
                        <div class="col-md-7">
                            <label class="admin-label">URL Photo de Couverture</label>
                            <input type="text" name="cover_url" class="admin-input" value="<%= (typeof content !== 'undefined' ? content.cover_url : '') %>" id="cover_input" onchange="previewImg()">
                            <img src="<%= (typeof content !== 'undefined' ? content.cover_url : '') %>" id="preview" class="cover-preview" alt="Preview">
                            <label class="admin-label">Nom de la Marque</label>
                            <input type="text" name="brand_name" class="admin-input" value="<%= (typeof content !== 'undefined' ? content.brand_name : 'CASHLINK') %>">
                        </div>
                        <div class="col-md-5">
                            <label class="admin-label">Grand Titre</label>
                            <input type="text" name="main_title" class="admin-input" value="<%= (typeof content !== 'undefined' ? content.main_title : '') %>">
                            <label class="admin-label">Prix Certification VIP (FC)</label>
                            <input type="number" name="cert_price" class="admin-input" value="<%= (typeof content !== 'undefined' ? content.cert_price : 0) %>">
                        </div>
                    </div>
                    <button type="submit" class="btn-update mt-4">SAUVEGARDER L'INTERFACE</button>
                </form>
            </div>
        </div>

        <div id="packs" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 mb-4 text-info">Config Machines</h4>
                <form action="/admin/update-packs-config" method="POST">
                    <div class="row g-4">
                        <% ['BRONZE', 'SILVER', 'GOLD', 'DIAMOND'].forEach(p => { %>
                        <div class="col-md-6">
                            <div class="p-4 border border-secondary rounded-4" style="background: rgba(0,0,0,0.2);">
                                <h6 class="fw-900 text-uppercase mb-3">Pack <%= p.charAt(0)+p.slice(1).toLowerCase() %></h6>
                                <div class="row">
                                    <div class="col-6"><label class="admin-label">Achat (FC)</label><input type="number" name="price_<%= p %>" class="admin-input" value="<%= (typeof content !== 'undefined' ? content['price_'+p] : 0) %>"></div>
                                    <div class="col-6"><label class="admin-label">Gain / 24h (FC)</label><input type="number" name="daily_<%= p %>" class="admin-input" value="<%= (typeof content !== 'undefined' ? content['daily_'+p] : 0) %>"></div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                    <button type="submit" class="btn-update mt-5">METTRE À JOUR LES PACKS</button>
                </form>
            </div>
        </div>

        <div id="messages" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-info mb-4"><i class="bi bi-chat-quote-fill me-3"></i>Messages &amp; Infos Personnalisées</h4>
                <form action="/admin/update-content" method="POST">
                <div class="row g-4">
                    <div class="col-12">
                        <div class="p-3 mb-2 rounded-3" style="background:rgba(6,182,212,0.1);border:1px dashed #06b6d4;">
                            <div class="fw-900 text-info mb-3" style="font-size:0.8rem;letter-spacing:1px;"><i class="bi bi-card-heading me-2"></i>TEXTES DE LA PAGE D'ACCUEIL</div>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="fw-800 text-warning mb-2" style="font-size:0.72rem;">NOM DU SITE (ex: CASHLINK)</label>
                                    <input type="text" name="brand_name" class="form-control bg-dark text-white border-secondary" style="border-radius:10px;" value="<%= content.brand_name || 'CASHLINK' %>">
                                </div>
                                <div class="col-md-4">
                                    <label class="fw-800 text-warning mb-2" style="font-size:0.72rem;">TITRE HÉRO (ex: MINAGE INDUSTRIEL)</label>
                                    <input type="text" name="hero_title" class="form-control bg-dark text-white border-secondary" style="border-radius:10px;" value="<%= content.hero_title || 'MINAGE INDUSTRIEL' %>">
                                </div>
                                <div class="col-md-4">
                                    <label class="fw-800 text-warning mb-2" style="font-size:0.72rem;">SLOGAN / TAGLINE</label>
                                    <input type="text" name="tagline" class="form-control bg-dark text-white border-secondary" style="border-radius:10px;" value="<%= content.tagline || '' %>">
                                </div>
                                <div class="col-12">
                                    <label class="fw-800 text-warning mb-2" style="font-size:0.72rem;">SOUS-TITRE HÉRO (description sous le titre)</label>
                                    <textarea name="hero_subtitle" class="form-control bg-dark text-white border-secondary" rows="3" style="border-radius:10px;"><%= content.hero_subtitle || 'Le protocole CASHLINK v28.0 déploie une puissance de calcul décentralisée pour chaque citoyen congolais.' %></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="fw-800 text-info mb-2" style="font-size:0.75rem;">MESSAGE D'ACCUEIL (affiché sur le site)</label>
                        <textarea name="welcome_msg" class="form-control bg-dark text-white border-secondary" rows="4" style="border-radius:12px;" placeholder="Ex: Bienvenue sur CashLink..."><%= content.welcome_msg || '' %></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-800 text-info mb-2" style="font-size:0.75rem;">MESSAGE D'ALERTE (barre d'info en rouge)</label>
                        <textarea name="alert_msg" class="form-control bg-dark text-white border-secondary" rows="4" style="border-radius:12px;" placeholder="Ex: Maintenance prévue le..."><%= content.alert_msg || '' %></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-800 text-info mb-2" style="font-size:0.75rem;">NUMÉRO WHATSAPP SUPPORT</label>
                        <input type="text" name="contact_phone" class="form-control bg-dark text-white border-secondary" style="border-radius:12px;" value="<%= content.contact_phone || '' %>">
                    </div>
                    <div class="col-md-6">
                        <label class="fw-800 text-info mb-2" style="font-size:0.75rem;">ADRESSE / LOCALISATION</label>
                        <input type="text" name="contact_address" class="form-control bg-dark text-white border-secondary" style="border-radius:12px;" value="<%= content.contact_address || '' %>">
                    </div>
                    <div class="col-12">
                        <label class="fw-800 text-info mb-2" style="font-size:0.75rem;">TEXTE DE PRÉSENTATION (À PROPOS)</label>
                        <textarea name="about_text" class="form-control bg-dark text-white border-secondary" rows="5" style="border-radius:12px;"><%= content.about_text || '' %></textarea>
                    </div>
                    <div class="col-12">
                        <label class="fw-800 text-info mb-2" style="font-size:0.75rem;">RÈGLES DE RETRAIT (texte complet)</label>
                        <textarea name="rules_text" class="form-control bg-dark text-white border-secondary" rows="5" style="border-radius:12px;"><%= content.rules_text || '' %></textarea>
                    </div>
                    <div class="col-md-4">
                        <label class="fw-800 text-info mb-2" style="font-size:0.75rem;">PRIX CERTIFICATION (FC)</label>
                        <input type="number" name="cert_price" class="form-control bg-dark text-white border-secondary" style="border-radius:12px;" value="<%= content.cert_price || 30000 %>">
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-info fw-900 px-5 py-3 rounded-pill"><i class="bi bi-save me-2"></i>ENREGISTRER LES MODIFICATIONS</button>
                    </div>
                </div>
                </form>
            </div>
        </div>

        <div id="retraits" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-warning mb-4">Demandes de Retrait en attente</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead>
                            <tr><th>Membre</th><th>Téléphone</th><th>Montant</th><th>Date</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            <% (typeof retraits !== 'undefined' ? retraits : []).forEach(ret => { %>
                            <tr>
                                <td><b><%= ret.username %></b></td>
                                <td><%= ret.phone %></td>
                                <td class="text-warning fw-900"><%= (ret.montant || 0).toLocaleString() %> FC</td>
                                <td class="small opacity-50"><%= ret.date %></td>
                                <td>
                                    <form action="/admin/approve-retrait" method="POST">
                                        <input type="hidden" name="retId" value="<%= ret._id %>">
                                        <button class="btn btn-warning rounded-pill px-3 fw-bold text-dark btn-sm">APPROUVER</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                            <% if(!retraits || retraits.length === 0) { %>
                            <tr><td colspan="5" class="text-center py-4 opacity-50">Aucune demande en attente</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="security" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-info mb-4">Accès &amp; Sécurité</h4>
                <div class="row">
                    <div class="col-md-6">
                        <div class="p-4" style="background:rgba(255,255,255,0.03);border-radius:20px;border:1px solid rgba(255,255,255,0.08);">
                            <h6 class="fw-800 text-warning mb-3">Accès Administrateur</h6>
                            <p class="small opacity-50">Mot de passe admin défini via variable d'environnement <code>ADMIN_PASS</code>.</p>
                            <p class="small opacity-50 mb-0">Chemin de connexion : <code>/admin-login</code></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-4" style="background:rgba(255,255,255,0.03);border-radius:20px;border:1px solid rgba(255,255,255,0.08);">
                            <h6 class="fw-800 text-info mb-3">Base de données</h6>
                            <p class="small opacity-50">Stockage dans <code>/tmp/cashlink-data</code>. Les données sont effacées à chaque redémarrage du serveur.</p>
                            <a href="/admin-logout" class="btn btn-sm btn-outline-danger mt-2">Déconnexion Admin</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="annulations" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 text-danger mb-4"><i class="bi bi-x-octagon-fill me-3"></i>Demandes d'Annulation d'Abonnement</h4>
                <% if(!annulations || annulations.length === 0) { %>
                    <div class="text-center text-muted py-5"><i class="bi bi-check-circle-fill text-success fs-1"></i><br>Aucune demande d'annulation en attente</div>
                <% } else { %>
                <div class="table-responsive">
                    <table class="premium-table">
                        <thead><tr>
                            <th>CLIENT</th><th>TÉLÉPHONE</th><th>PACK</th><th>INVESTISSEMENT</th><th>REMBOURSEMENT (50%)</th><th>DATE</th><th>ACTION</th>
                        </tr></thead>
                        <tbody>
                        <% annulations.forEach(a => { %>
                        <tr>
                            <td class="fw-900"><%= a.username %></td>
                            <td><%= a.phone %></td>
                            <td><span style="font-weight:900;color:#ef4444;"><%= a.pack %></span></td>
                            <td class="fw-900"><%= (a.prixPack||0).toLocaleString() %> FC</td>
                            <td class="fw-900 text-warning"><%= (a.remboursement||0).toLocaleString() %> FC</td>
                            <td style="font-size:0.8rem;"><%= a.date %></td>
                            <td>
                                <form action="/admin/process-annulation" method="POST" style="display:inline;">
                                    <input type="hidden" name="annId" value="<%= a._id %>">
                                    <button type="submit" class="btn btn-danger btn-sm fw-900" onclick="return confirm('Confirmer le remboursement de '+<%= a.remboursement %>+' FC et annuler le pack ?')">
                                        <i class="bi bi-check-lg me-1"></i>REMBOURSER & ANNULER
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } %>
            </div>
        </div>

        <div id="logs" class="section-panel">
            <div class="glass-card">
                <h4 class="fw-900 mb-4">Journal d'Activité</h4>
                <div class="table-responsive">
                    <table class="premium-table">
                        <tbody>
                            <% (typeof logs !== 'undefined' ? logs : []).forEach(log => { %>
                            <tr><td class="small opacity-50"><%= log.date %></td><td class="text-white small fw-bold"><%= log.text %></td></tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <script>
        function openTab(tabId, btn) {
            document.querySelectorAll('.section-panel').forEach(s => s.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            document.querySelectorAll('.nav-item-custom').forEach(n => n.classList.remove('active'));
            btn.classList.add('active');
        }
        function previewImg() { document.getElementById('preview').src = document.getElementById('cover_input').value; }
        function deleteUser(id) {
            if(confirm('Supprimer cet utilisateur définitivement ?')) {
                fetch('/admin/delete-user/' + id, { method: 'DELETE' })
                    .then(r => r.json())
                    .then(d => {
                        if(d.ok) { const row = document.getElementById('row-' + id); if(row) row.remove(); }
                        else { alert('Erreur: ' + d.error); }
                    })
                    .catch(() => alert('Erreur réseau.'));
            }
        }
    </script>
</body>
</html>
