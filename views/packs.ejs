<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Programmes d'Investissement | CASHLINK ELITE</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #060912;
            --card: #111827;
            --emerald: #10b981;
            --accent: #3b82f6;
            --text-dim: #94a3b8;
            --grad-bronze: linear-gradient(135deg, #78350f, #a87932);
            --grad-silver: linear-gradient(135deg, #334155, #94a3b8);
            --grad-gold: linear-gradient(135deg, #92400e, #fbbf24);
            --grad-diamond: linear-gradient(135deg, #1e3a8a, #3b82f6);
        }

        body { 
            background-color: var(--bg); 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            color: white; 
            padding: 40px 20px;
        }

        .section-title {
            font-weight: 800;
            letter-spacing: 2px;
            color: var(--text-dim);
            margin-bottom: 30px;
            text-align: center;
        }

        .packs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .pack-card {
            background: var(--card);
            border-radius: 25px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.05);
            transition: 0.4s;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .pack-card:hover { transform: translateY(-10px); border-color: var(--emerald); }

        .pack-header {
            padding: 20px;
            text-align: center;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .pack-body { padding: 30px; text-align: center; flex-grow: 1; }

        .pack-price { font-size: 2.5rem; font-weight: 900; margin-bottom: 5px; }

        .daily-badge {
            background: rgba(16, 185, 129, 0.1);
            color: var(--emerald);
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: 800;
            font-size: 0.85rem;
            display: inline-block;
            margin-bottom: 20px;
        }

        .btn-buy-now {
            background: transparent;
            border: 2px solid var(--emerald);
            color: var(--emerald);
            padding: 12px;
            border-radius: 15px;
            font-weight: 800;
            width: 100%;
            margin-bottom: 20px;
            transition: 0.3s;
            text-transform: uppercase;
            font-size: 0.75rem;
        }

        .btn-buy-now:hover { background: var(--emerald); color: white; }

        .pack-features {
            list-style: none;
            padding: 0;
            margin: 20px 0;
            font-size: 0.85rem;
            color: var(--text-dim);
            text-align: left;
            border-top: 1px solid rgba(255,255,255,0.05);
            padding-top: 20px;
        }

        .pack-features li { margin-bottom: 10px; display: flex; align-items: center; gap: 10px; }
        .pack-features i { color: var(--emerald); }

        .btn-action {
            width: 100%;
            padding: 15px;
            border-radius: 18px;
            border: none;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.8rem;
            transition: 0.3s;
        }

        .btn-lock { background: #334155; color: #94a3b8; cursor: not-allowed; }
        .btn-ready { background: var(--emerald); color: white; box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3); }
        .btn-active { background: var(--accent); color: white; cursor: default; }

    </style>
</head>
<body>

    <div class="container">
        <div class="text-center mb-5">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm mb-3">
                <i class="bi bi-arrow-left"></i> Retour au Dashboard
            </a>
            <h2 class="section-title">NOS SOLUTIONS DE MINAGE</h2>
        </div>

        <div class="packs-grid">
            <% 
            // Liste des packs définie ici si non envoyée par le serveur
            const packsList = [
                { id: 'BRONZE', price: 50000, daily: 4000, grad: 'var(--grad-bronze)' },
                { id: 'SILVER', price: 150000, daily: 13500, grad: 'var(--grad-silver)' },
                { id: 'GOLD', price: 500000, daily: 50000, grad: 'var(--grad-gold)' },
                { id: 'DIAMOND', price: 1000000, daily: 120000, grad: 'var(--grad-diamond)' }
            ];

            displayPacks.forEach(p => { 
            %>
            <div class="pack-card">
                <div class="pack-header" style="background: <%= p.grad %>;">
                    <%= p.id %> MINER
                </div>
                
                <div class="pack-body">
                    <div class="pack-price">
                        <%= p.price.toLocaleString() %> <small style="font-size: 1rem; opacity: 0.5;">FC</small>
                    </div>
                    <div class="daily-badge">+ <%= p.daily.toLocaleString() %> FC / JOUR</div>

                    <form action="/souscrire-pack" method="POST">
                        <input type="hidden" name="packName" value="<%= p.id %>">
                        <input type="hidden" name="prix" value="<%= p.price %>">
                        <button type="submit" class="btn-buy-now">
                            <i class="bi bi-cart-plus me-1"></i> Acheter ce pack
                        </button>
                    </form>

                    <ul class="pack-features">
                        <li><i class="bi bi-check2-circle"></i> Durée : <b>30 Jours</b></li>
                        <li><i class="bi bi-check2-circle"></i> Profit Total : <b><%= (p.daily * 30).toLocaleString() %> FC</b></li>
                        <li><i class="bi bi-check2-circle"></i> Retraits : <b>Instantanés</b></li>
                        <li><i class="bi bi-check2-circle"></i> Bonus Dépôt : <b>+5% inclus</b></li>
                    </ul>

                    <% if (user.pack === p.id) { %>
                        <button class="btn-action btn-active">
                            <i class="bi bi-patch-check-fill me-2"></i> PACK ACTIF
                        </button>
                    <% } else if (user.solde >= p.price) { %>
                        <form action="/activer-investissement" method="POST">
                            <input type="hidden" name="packName" value="<%= p.id %>">
                            <input type="hidden" name="prix" value="<%= p.price %>">
                            <button type="submit" class="btn-action btn-ready">
                                <i class="bi bi-lightning-fill me-1"></i> ACTIVER MAINTENANT
                            </button>
                        </form>
                    <% } else { %>
                        <button class="btn-action btn-lock">
                            <i class="bi bi-slash-circle me-1"></i> SOLDE INSUFFISANT
                        </button>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
    </div>

</body>
</html>