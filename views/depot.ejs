<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CashLink - Effectuer un dépôt</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; }
        .depot-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }
        .btn-send {
            background-color: #27ae60;
            border: none;
            padding: 15px;
            font-weight: bold;
            border-radius: 12px;
            transition: 0.3s;
        }
        .btn-send:hover {
            background-color: #1e8449;
            transform: translateY(-2px);
        }
        .input-amount {
            font-size: 2rem;
            font-weight: bold;
            text-align: center;
            border-radius: 15px;
            border: 2px solid #eee;
            padding: 20px;
        }
        .input-amount:focus {
            border-color: #27ae60;
            box-shadow: none;
        }
    </style>
</head>
<body>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            
            <a href="/dashboard" class="text-decoration-none text-muted mb-4 d-inline-block">
                <i class="bi bi-arrow-left"></i> Retour au Dashboard
            </a>

            <div class="card depot-card p-4">
                <div class="card-body text-center">
                    <div class="mb-4">
                        <div class="bg-success-subtle d-inline-block p-3 rounded-circle mb-3">
                            <i class="bi bi-wallet2 fs-1 text-success"></i>
                        </div>
                        <h3 class="fw-bold">Nouveau Dépôt</h3>
                        <p class="text-muted">Entrez le montant que vous souhaitez ajouter à votre compte.</p>
                    </div>

                    <form action="/process-depot" method="POST">
                        <div class="mb-4">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-0 fs-3 fw-bold">$</span>
                                <input type="number" 
                                       name="amount" 
                                       class="form-control input-amount" 
                                       placeholder="0.00" 
                                       step="0.01" 
                                       min="1" 
                                       required 
                                       autofocus>
                            </div>
                            <div class="form-text mt-3">
                                <i class="bi bi-info-circle"></i> Votre demande sera examinée par l'administrateur pour validation.
                            </div>
                        </div>

                        <button type="submit" class="btn btn-send btn-primary w-100 shadow-sm">
                            <i class="bi bi-send-fill me-2"></i> ENVOYER LA DEMANDE
                        </button>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <small class="text-muted">Système sécurisé par CashLink Protocol</small>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>