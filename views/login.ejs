<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CASHLINK ELITE | Accès Membres</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --bleu-bic: #003399;
            --neon-blue: #00d9ff;
            --dark-deep: #001133;
        }

        body {
            background-color: var(--bleu-bic);
            background-image: radial-gradient(at 0% 0%, #0044cc 0, transparent 50%), 
                              radial-gradient(at 100% 100%, var(--dark-deep) 0, transparent 50%);
            background-attachment: fixed;
            font-family: 'Plus Jakarta Sans', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
            letter-spacing: -0.4px;
        }

        .auth-container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
            perspective: 1000px;
        }

        .auth-card {
            background: #ffffff;
            border-radius: 40px;
            padding: 50px 40px;
            box-shadow: 0 30px 70px rgba(0,0,0,0.5);
            border: 1px solid rgba(255,255,255,0.2);
            position: relative;
        }

        .brand-logo {
            font-weight: 900;
            color: var(--bleu-bic);
            font-size: 2.2rem;
            text-align: center;
            letter-spacing: -2.5px;
            margin-bottom: 5px;
            display: block;
            text-decoration: none;
        }

        .brand-subtitle {
            text-align: center;
            color: #64748b;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 20px; /* Réduit pour laisser place à l'alerte */
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- ALERTE CUSTOM --- */
        .alert-custom {
            border-radius: 15px;
            font-size: 0.85rem;
            font-weight: 700;
            border: none;
            margin-bottom: 25px;
        }

        /* --- TABS --- */
        .nav-pills {
            background: #f1f5f9;
            padding: 6px;
            border-radius: 20px;
            margin-bottom: 30px;
        }

        .nav-pills .nav-link {
            border-radius: 15px;
            font-weight: 800;
            font-size: 0.85rem;
            color: #64748b;
            padding: 12px;
            transition: 0.3s;
        }

        .nav-pills .nav-link.active {
            background-color: var(--bleu-bic);
            color: #ffffff;
            box-shadow: 0 10px 20px rgba(0,51,153,0.2);
        }

        .form-label {
            font-weight: 700;
            color: #1e293b;
            font-size: 0.8rem;
            margin-left: 10px;
            margin-bottom: 8px;
        }

        .input-group-text {
            background: #f8fafc;
            border: 2px solid #f1f5f9;
            border-right: none;
            border-radius: 15px 0 0 15px;
            color: #94a3b8;
        }

        .form-control {
            background: #f8fafc;
            border: 2px solid #f1f5f9;
            border-left: none;
            border-radius: 0 15px 15px 0;
            padding: 14px;
            font-weight: 600;
            color: #0f172a;
            font-size: 0.95rem;
            transition: 0.3s;
        }

        .form-control:focus {
            background: #ffffff;
            border-color: var(--neon-blue);
            box-shadow: none;
            outline: none;
        }

        .btn-auth {
            background: var(--bleu-bic);
            color: white;
            border: none;
            border-radius: 18px;
            padding: 16px;
            font-weight: 800;
            font-size: 1rem;
            width: 100%;
            margin-top: 10px;
            transition: 0.4s;
            box-shadow: 0 10px 25px rgba(0,51,153,0.3);
        }

        .btn-auth:hover {
            transform: translateY(-3px);
            background: var(--dark-deep);
            color: white;
        }

        .footer-note {
            text-align: center;
            margin-top: 30px;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="auth-container animate__animated animate__zoomIn">
        <div class="auth-card">
            <a href="/" class="brand-logo">CASHLINK</a>
            <div class="brand-subtitle">Elite Mining System</div>

            <% if(typeof msg !== 'undefined' && msg) { %>
                <div class="alert alert-info alert-custom animate__animated animate__shakeX text-center">
                    <i class="bi bi-exclamation-circle-fill me-2"></i> <%= msg %>
                </div>
            <% } %>

            <ul class="nav nav-pills nav-justified mb-4" id="authTab" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="login-tab" data-bs-toggle="pill" data-bs-target="#login" type="button">CONNEXION</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="register-tab" data-bs-toggle="pill" data-bs-target="#register" type="button">INSCRIPTION</button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="login">
                    <form action="/login" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Numéro de téléphone</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                <input type="text" name="phone" class="form-control" placeholder="Ex: 0812345678" required>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Mot de passe</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-auth">ACCÉDER AU DASHBOARD</button>
                    </form>
                </div>

                <div class="tab-pane fade" id="register">
                    <form action="/register" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Nom complet</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" name="username" class="form-control" placeholder="Votre nom" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Téléphone (Définitif)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-phone-vibrate"></i></span>
                                <input type="text" name="phone" class="form-control" maxlength="10" placeholder="08..." required>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Créer un mot de passe</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                                <input type="password" name="password" class="form-control" placeholder="Min. 6 caractères" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-auth">CRÉER MON COMPTE ELITE</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="footer-note">
            &copy; 2026 Cashlink Elite. Tous droits réservés.<br>
            Système de minage cloud sécurisé.
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>